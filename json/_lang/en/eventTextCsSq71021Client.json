{
  "342337": {
    "「お集まりの　皆さまぁ～っ！　記念すべき\n　第１３回　アストルティア・ナイト\n　コンテストの　参加者を　紹介しちゃうよ～っ！": ""
  },
  "342338": {
    "「前大会で　好成績をおさめ \n　見事　出場権を獲得した　３名に加えて……": ""
  },
  "342339": {
    "「総勢４８人による　激闘の予選を\n　見事勝ち抜いた　精鋭　５名！ \n　あわせて　８名のイケメンによる　戦いだぁっ！": ""
  },
  "342340": {
    "「まずは　まずは　前大会の覇者の　入場だっ！\n　勝者の晴れ舞台に　ふさわしく……\n　まぶしい衣装で　登場の　このお方っ！": ""
  },
  "342341": {
    "「夫婦そろって　クイーンとナイトに輝くという\n　前代未聞の　偉業を成しとげた　頼れる男！\n　至高の時渡りの使い手　パドレ！": ""
  },
  "342342": {
    "「俺はついに　念願の　アストルティア・ナイトに\n　なることができた。すべては　皆のおかげだ。\n　この喜びを　生涯　忘れることはないだろう。": ""
  },
  "342343": {
    "「しかも……まさか　マローネと　夫婦そろって\n　クイーンとナイトに　なれるとは……\n　これ以上の幸せはない。本当に……ありがとう。": ""
  },
  "342344": {
    "「だが……俺は　頂点を極めたからといって\n　ここで　満足するつもりはない！\n　今年も　王座を　死守してみせよう！": ""
  },
  "342345": {
    "「続いては　準ナイトの　おでましだぁ～っ！！\n　初登場ながら　いきなり２位の　超新星！": ""
  },
  "342346": {
    "「まっすぐな瞳は　新たな主神へと　進化の途中！\n　がんばる彼に　ご褒美あげたい　餌付けしたい！\n　未知なる大地のオオカミ少年～！　ラキ！": ""
  },
  "342347": {
    "「……前回　ここに来て　わかった。\n　みんなを　笑顔にする\n　アストルティア・ナイトは　すごい。": ""
  },
  "342348": {
    "「ラキは　アストルティア・ナイトに　なりたい。\n　そうすれば　もっと　みんなのことを……\n　この世界を　幸せにできる気がするから……！": ""
  },
  "342349": {
    "「さあ　お待ちかね！　今年も　アイツの登場だ！\n　初回コンテスト出場から　４回も　ナイトに輝き\n　それ以外でも　必ず３位以上の　異次元の強さ！": ""
  },
  "342350": {
    "「最近　ツッコミとしての切れ味も一流と評判！\n　皆の心に殿堂入りの　国民的ヒーロー！\n　神出鬼没の　孤高なる剣士～！　ヒューザ！": ""
  },
  "342351": {
    "「……ここんとこ　圧の強いヤツらと\n　行動していたせいか　おかしなところばっか\n　目立っちまって　いけねえぜ。": ""
  },
  "342352": {
    "「だが　強敵と戦うことこそ　オレの本領だ。\n　もう一度　ナイトの座を取りもどして\n　格の違いを　見せつけてやるぜ！": ""
  },
  "342353": {
    "「一番　アストルティア・ナイトに相応しいのが\n　誰なのか……あんたらも　わかってるんだろ？\n　本気で行くから　ついてこいよ？": ""
  },
  "342354": {
    "「ここからは　総勢４８人による　激しい予選を\n　見事勝ち抜いた　精鋭５名を　ご紹介だあ～っ！\n　まずは　５年ぶりの出場を勝ちとった　この方！": ""
  },
  "342355": {
    "「アストルティアへの　激重な愛を語らせたら最後\n　彼のマシンガントークを　止めるすべはない！\n　帰ってきた　優美なる魔王～！　アスバル！": ""
  },
  "342356": {
    "「ああ！　これって　夢じゃないんだよね？\n　また　ここに戻れて　本当に　うれしいよ！\n　正真正銘の　ナイトコンテストだ……！": ""
  },
  "342357": {
    "「みんな　僕にチャンスをくれて　ありがとう！\n　出られたからには　僕の有能なる臣下と共に\n　全力で　このお祭りを　楽しませてもらうよ！": ""
  },
  "342358": {
    "「というわけで　リソル！　せっかく一緒なんだし\n　コンテストで僕たちが　いい成績を収められたら\n　ペアルックをキメて　お祝いしようじゃないか！": ""
  },
  "342359": {
    "「はあ！？　ペアルックとか　バカじゃないの？\n　絶対に　お断りなんだけど！": ""
  },
  "342360": {
    "「いよっ！　この毒舌を　待っていました！\n　お次は　熱狂的ファンを抱える　このお方っ！\n　一度ハマると　抜け出せない魅力は　まさに沼！": ""
  },
  "342361": {
    "「今年は　ついに　ご主人様と　そろって登場！\n　いつもと違った　レアな彼が　見れるかも！？\n　気まぐれバンビーノ！　リソル！ ": ""
  },
  "342362": {
    "「今年こそ　絶対に　サボろうと　思ったのに\n　一番やっかいなヒトと　一緒になっちゃったよ。\n　マジで　ついてないんだけど……。": ""
  },
  "342363": {
    "「まあ　でも？　このヒトが暴走しても\n　先輩が　何とかしてくれるんだよね？\n　頼りにしてるよ？　せーんぱい♪": ""
  },
  "342364": {
    "「う～ん　残念だなあ。 \n　君と　カワイイ衣装で　ペアルックにしたら\n　絶対に楽しいと　思うんだけどなぁ。 ": ""
  },
  "342365": {
    "「あのさぁ……。\n　いい加減　もう　黙っててくれない？": ""
  },
  "342366": {
    "「自由奔放すぎる主に　振り回される大変さ……。\n　痛いほど　わかりますよ。": ""
  },
  "342367": {
    "「さっすが　大人の余裕といえば　このお方！\n　お次に登場するのは　魔界随一の　シゴデキ男！\n　雌伏の時を経て　リベンジを見せてくれるのか？": ""
  },
  "342368": {
    "「冷静沈着　頭脳明晰！　だが　主への忠誠心は\n　ジャリムバハ砂漠の熱砂よりも　熱い！\n　隻眼の苦労人～っ　ナジーン！": ""
  },
  "342369": {
    "「ようやく　役者がそろって　我々の見せ場と\n　思っていたら……今年は　隣国ゼクレスの\n　ライバルたちが　騒がしいようですね。": ""
  },
  "342370": {
    "「ですが　ナイトの座に　ふさわしいのは……\n　我ら　ファラザード陣営であることを\n　証明してみせましょう。": ""
  },
  "342371": {
    "「そうでしょう？　ユシュカ。\n　我が主……ファラザードの王よ！": ""
  },
  "342372": {
    "「ああ！　その通りだ！　ナジーンッ！": ""
  },
  "342373": {
    "「待ってました～！　主役は　遅れてやってくる！ \n　満を持して　ファラザードの双璧が完成だ！": ""
  },
  "342374": {
    "「有能なる片腕と　チカラを合わせ\n　ついに　アストルティア・ナイトに輝くか！？\n　魔界の風雲児～ッ！　ユシュカ！": ""
  },
  "342375": {
    "「魔界で一番　ナイトにふさわしいのは　誰か……\n　副官殿に　助けられるばかりじゃなく\n　そろそろ　王としての　威厳を示さなきゃな。": ""
  },
  "342376": {
    "「さあ　俺の手を取れ。\n　誰も見たことのない景色を　見せてやるよ。": ""
  },
  "342377": {
    "「いよいよ　最後に登場するのは　\n　ミステリアスな魅力で　常に上位の　このお方！\n　よぉーっく　その目に　焼きつけろぉ～っ！！": ""
  },
  "342378": {
    "「冷たいゴーグルの奥に秘めた　熱きココロ！\n　一途に追うのは　唯一無二の　果てなき幻影！\n　博識なる探究者～！　ラウル！　": ""
  },
  "342379": {
    "「どれほど求めても……月に　手は届かない。\n　あの娘のために　どんな宝も　手に入れると\n　約束……したのに……。": ""
  },
  "342380": {
    "「ふたりで　一緒に…………約束よ。": ""
  },
  "342381": {
    "「いつだって……\n　俺に　チカラをくれるのは　キミなんだな。": ""
  },
  "342382": {
    "「俺は　もう一度　ナイトの座を手に入れる！\n　いつか胸を張って　キミと再会できるように……\n　そして　応援してくれる　皆のために！": ""
  },
  "342383": {
    "「以上っ！　８名のイケメンが\n　ナイトの座をかけ　コンテストを争っちゃうよ！": ""
  },
  "342384": {
    "「栄光の座に　かがやくのは　誰か……\n　それを決めるのは！\n　こ・こ・に・い・る　キミなんだよ～ん！！": ""
  },
  "342385": {
    "「さ～て　どう？　どう？　<pc>。 \n　ちょーイケメンが　大集合だけど\n　正直　誰が　好みなのかなぁ～？": ""
  },
  "342386": {
    "「アストルティア・ナイトに　ふさわしいと思う \n　イケメンを選んだら\n　キミの　清き１票を　投票すべし！": ""
  },
  "342387": {
    "「投票は　私の　カワイイ妹っ！\n　集計係モカの所で　受け付けてるからね！": ""
  },
  "342388": {
    "「ナイトに　投票し終わったら\n　話すことがあるから　メリルの所に　来るべし！\n　外で待ってるから　約束だよ～っ！！": ""
  },
  "342389": {
    "「じゃじゃーん！　記念すべき \n　第１３回　アストルティア・ナイト\n　コンテストの　結果発表を　始めちゃうよーん！": ""
  },
  "342390": {
    "「さあさあ！　ホワイトショコラ城の\n　ナイトの座は　誰の手に！？\n　耳の穴かっぽじって　よく聞けぇ～っ！": ""
  },
  "342391": {
    "「いっくよ～！\n　みんなっ　ステージに　注目するべ～しっ！！": ""
  }
}
