{
  "4459": {
    "「おお\u3000これはこれは\u3000英雄フォステイル様！\n\u3000よいところへ\u3000いらっしゃいました。": ""
  },
  "4460": {
    "「どうか\u3000急ぎ\u3000玉座の間へ向かい\n\u3000王に\u3000お会いください！": ""
  },
  "4461": {
    "「……まさか\u3000プーポッパン王の身に\n\u3000何か\u3000あったのか？": ""
  },
  "4462": {
    "「いえ。ご病状は\u3000安定しておりますが\n\u3000王は……とうとう\u3000あの儀式をおこなうと\n\u3000おっしゃっているのです。": ""
  },
  "4463": {
    "「フォステイル様\u3000お願いです。\n\u3000王を\u3000止めてください！\n\u3000儀式をおこなえば\u3000王の命は……。": ""
  },
  "4464": {
    "「わかった。ありがとう。": ""
  },
  "4465": {
    "「……ん？\u3000なんだ\u3000お前は。": ""
  },
  "4466": {
    "「あやしいヤツめ。\n\u3000何用があって\u3000メギストリス城へ来た？": ""
  },
  "4467": {
    "「……ほほう。キーエンブレムを求めて\n\u3000この国へ\u3000やってきたのだな。": ""
  },
  "4468": {
    "「それならば\u3000一人前の証を持っているはずだ。\n\u3000どれ\u3000あらためさせてもらうぞ。": ""
  },
  "4469": {
    "「ふむふむ……ふむ。 \n\u3000これは\u3000まごうことなき一人前の証！": ""
  },
  "4470": {
    "「よーし\u3000問題なし。 \n\u3000通っていいぞ！": ""
  },
  "4471": {
    "「プーポッパン王！\n\u3000どうか\u3000お考えなおしください！": ""
  },
  "4472": {
    "「いかに\u3000魔瘴を\u3000しりぞけたとしても\n\u3000王を失えば\u3000我が国は\u3000おしまいです！！": ""
  },
  "4473": {
    "「ゴホッ\u3000ゴホッ！": ""
  },
  "4474": {
    "「イッドよ……。\n\u3000魔瘴に触れた\u3000この身は\n\u3000もう\u3000長くはもたぬ……。": ""
  },
  "4475": {
    "「ならば\u3000最期ぐらい\n\u3000好きにさせてくれても\u3000よいだろう。": ""
  },
  "4476": {
    "「私も\u3000王に\u3000お仕えする前は\n\u3000レンダーシアの地で\n\u3000魔瘴の脅威を\u3000研究しておりました。": ""
  },
  "4477": {
    "「このまま\u3000何もせずにいれば\n\u3000プクランド大陸各地に現れた\u3000魔瘴が\n\u3000大陸を\u3000滅亡に導くことは\u3000承知しております。": ""
  },
  "4478": {
    "「ですが……。": ""
  },
  "4479": {
    "「なにも\u3000王が\u3000儀式をおこなわずとも\n\u3000王家の血を受け継ぐ者は\n\u3000もうひとり\u3000いるではありませんか……！": ""
  },
  "4480": {
    "「……王子は\u3000この国の未来を背負う者。": ""
  },
  "4481": {
    "「わしは魔瘴に侵され\u3000死を待つだけの身だ。\n\u3000どちらが\u3000儀式に\u3000ふさわしいかは明白だろう。": ""
  },
  "4482": {
    "「し……しかし。": ""
  },
  "4483": {
    "「くどいぞ\u3000イッド！": ""
  },
  "4484": {
    "「誰が\u3000なんと言おうとも\n\u3000わしは\u3000王家の儀式をおこない\n\u3000魔瘴から\u3000この国を守る！！": ""
  },
  "4485": {
    "「……この命ひとつで\u3000プクランド大陸に住む\n\u3000すべての民を救えるのなら\u3000安いものよ。": ""
  },
  "4486": {
    "「いいえ\u3000その必要は\u3000ありません！": ""
  },
  "4487": {
    "「……誰かと思えば\n\u3000インチキ予言者の\u3000フォステイルどのか。": ""
  },
  "4488": {
    "「今\u3000私と王は\u3000大切な話をしているのです。\n\u3000席を外してくださいませんか。": ""
  },
  "4489": {
    "「まあよい\u3000イッド。": ""
  },
  "4490": {
    "「……フォステイル。ひさしぶりだな。": ""
  },
  "4491": {
    "「さあて\u3000今度は\u3000どんな不幸な未来を\n\u3000わしに予言してくれるのだ？": ""
  },
  "4492": {
    "「………………。": ""
  },
  "4493": {
    "「運命とは\u3000あらかじめ\u3000定められたもの。\n\u3000ぼくの意志が\u3000選んでいるのではありません。": ""
  },
  "4494": {
    "「では\u3000わしが魔瘴に侵され\u3000死にかけているのも\n\u3000このプクランド大陸が\u3000滅びようとしているのも\n\u3000すべて\u3000定められたことだというのか……。": ""
  },
  "4495": {
    "「ゴホッ\u3000ゴホッ！": ""
  },
  "4496": {
    "「……そのお身体では\u3000もとより\n\u3000儀式の塔へ向かうのは\u3000無理でしょう。": ""
  },
  "4497": {
    "「ふん。わしの身体のことが\n\u3000お前などに\u3000わかってたまるか！": ""
  },
  "4498": {
    "「……王よ。塔へは\u3000行かぬことです。\n\u3000ぼくの予知では\u3000儀式の塔へ向かえば\n\u3000取り返しの\u3000つかないことになる。": ""
  },
  "4499": {
    "「魔瘴の脅威から\u3000国を守りたいなら\n\u3000亡くなられた\u3000アルウェ王妃のノートを\n\u3000探すより他にないのです。": ""
  },
  "4500": {
    "「アルウェ王妃のノート……？": ""
  },
  "4501": {
    "「いかなる願いをも\u3000かなえるという\n\u3000伝説のノートが……\n\u3000まさか\u3000実在するというのかっ！？": ""
  },
  "4502": {
    "「アルウェ王妃のノートは\n\u3000この国のどこかに\u3000眠っているはずです。": ""
  },
  "4503": {
    "「そのノートさえあれば \n\u3000王自ら\u3000命を捧げずとも\n\u3000この国は\u3000魔瘴から守られます！": ""
  },
  "4504": {
    "「……我が君\u3000プーポッパン王。": ""
  },
  "4505": {
    "「インチキ予言者を\u3000信じるわけではありませんが \n\u3000ためしに\u3000アルウェ王妃のノートを\n\u3000探してみては\u3000いかがでしょうか？": ""
  },
  "4506": {
    "「貴様まで\u3000そんな\u3000くだらんものを\n\u3000信じるというのかっ！？\u3000イッドよ！": ""
  },
  "4507": {
    "「い\u3000いえっ。\n\u3000めっそうも\u3000ございません……！": ""
  },
  "4508": {
    "「予知も\u3000ノートも\u3000でたらめだ！\n\u3000アルウェのノートなど\u3000あるはずがない！": ""
  },
  "4509": {
    "「ですが\u3000王よ！": ""
  },
  "4510": {
    "「出ていけ！！": ""
  },
  "4511": {
    "「フォステイル！\u3000\n\u3000二度と\u3000わしの前へ\u3000姿を現すな！！": ""
  },
  "4512": {
    "「ん……？": ""
  },
  "4513": {
    "「旅人か？\n\u3000どうした。わしに\u3000何用だ。": ""
  },
  "4514": {
    "「……ほほう。キーエンブレムを求めて\n\u3000はるばる\u3000この都へ参ったか。\n\u3000それは\u3000ご苦労。": ""
  },
  "4515": {
    "「ならば\u3000ちょうどよい。\n\u3000そなたに\u3000頼みたいことがあるのだ。": ""
  },
  "4516": {
    "「入れ！": ""
  },
  "4517": {
    "「こ\u3000この者たちは……？": ""
  },
  "4518": {
    "「近頃\u3000キラキラ大風車塔の儀式の間に\n\u3000恐ろしい魔物が\u3000棲みついたという報告は\n\u3000わしも\u3000受けておる。": ""
  },
  "4519": {
    "「そこで\u3000我が国に集う精鋭たちに\n\u3000魔物を討伐してもらおうと\u3000思ってな。\n\u3000そうすれば\u3000安心して儀式もできる。": ""
  },
  "4520": {
    "「……ううむ。\n\u3000王が\u3000そこまで\u3000お考えとは……。": ""
  },
  "4521": {
    "「わかりました。\n\u3000では\u3000私の部下たちも\u3000討伐隊として\n\u3000儀式の塔へ\u3000同行させましょう。": ""
  },
  "4522": {
    "「討伐隊の兵たちが\n\u3000無事\u3000塔に潜む魔物を倒したならば\n\u3000もはや\u3000儀式を止め立ては\u3000いたしません。": ""
  },
  "4523": {
    "「すべては\u3000王の御心のままに。": ""
  },
  "4524": {
    "「……というわけだ\u3000旅人よ。\n\u3000そなたも\u3000一人前の証を持つほどのウデ前。\n\u3000魔物退治を\u3000恐れたりはすまい。": ""
  },
  "4525": {
    "「魔物を討伐してきた\u3000あかつきには\n\u3000キーエンブレムを\u3000ほうびに\u3000くれてやる。\n\u3000どうだ？\u3000行ってくれるか？<yesno><close>": ""
  },
  "4526": {
    "「どうした\u3000怖じ気づいたのか？": ""
  },
  "4527": {
    "「だが\u3000討伐隊に加わり\u3000塔の魔物を倒さんかぎり\n\u3000そなたに\u3000キーエンブレムは\u3000やれんぞ。\n\u3000どうだ。やってくれるな？<yesno><close>": ""
  },
  "4528": {
    "「そうか！\u3000やってくれるか。": ""
  },
  "4529": {
    "「これで\u3000討伐隊は\u3000そろった！\n\u3000皆\u3000一人前の証を持つ\u3000勇敢なる者たちだ。\n\u3000これなら魔物も\u3000ひとひねりだろう。": ""
  },
  "4530": {
    "「討伐隊に\u3000申しつける！": ""
  },
  "4531": {
    "「風車の丘にある\u3000キラキラ大風車塔へと向かい\n\u3000儀式の間に潜んでいる魔物を\u3000討伐するのだ！": ""
  },
  "4532": {
    "「では……頼んだぞ！": ""
  },
  "4533": {
    "「……ここが\u3000儀式の塔。\n\u3000キラキラ大風車塔か……。": ""
  },
  "4534": {
    "「おお\u3000お前も討伐隊の者だな。": ""
  },
  "4535": {
    "「王の\u3000ご命令は\u3000この塔を登り\n\u3000儀式の間に潜んでいる\u3000恐ろしい魔物を\n\u3000討伐することだ。みんな\u3000準備はいいか？": ""
  },
  "4536": {
    "「どうした\u3000どうした\u3000ちっこいの！\n\u3000魔物に会う前から\u3000怖じ気づいたか？": ""
  },
  "4537": {
    "「魔物なんか\u3000怖くねーや！\n\u3000ただ……": ""
  },
  "4538": {
    "「オレたちが\u3000魔物を倒したら\n\u3000王様は\u3000この儀式の塔で\n\u3000……王家に伝わる儀式を\u3000やるんだろ？": ""
  },
  "4539": {
    "「古来より伝えられし\u3000プクリポの\n\u3000王家の儀式は\u3000我が王都カミハルムイにも\n\u3000伝えられています。": ""
  },
  "4540": {
    "「王家の者が\u3000儀式の塔で\u3000命を捧げれば\n\u3000その祈りは天へと届き\u3000大陸は\n\u3000聖なるチカラに\u3000守られるだろうと……。": ""
  },
  "4541": {
    "「てことは……平和と引き換えに\u3000王様は\n\u3000死んじまうってことだ！\u3000そんなことになったら\n\u3000あのボンクラ王子に\u3000次の王が\u3000務まるのか？": ""
  },
  "4542": {
    "「おい！\u3000フポット！ \n\u3000ちょっと\u3000クチが過ぎるぞ。": ""
  },
  "4543": {
    "「王家の者が\u3000命を捧げればいいなら\n\u3000儀式をおこなうのは\u3000王子だって\u3000いいはずだ。\n\u3000お前だって\u3000そう思うだろ？<yesno><close>": ""
  },
  "4544": {
    "「なんだよ！\u3000いい子ぶりやがって！！\n\u3000イッド様だって\u3000王様よりも\n\u3000役立たずの王子がいいって\u3000言ってたぜ！": ""
  },
  "4545": {
    "「そうだよ。イッド様だって\u3000そう言ってた。\n\u3000王様は\u3000この国にとって\u3000かけがえのない方。\n\u3000だけど\u3000あの王子は……。": ""
  },
  "4546": {
    "「だから\u3000ちっこいのは \n\u3000アタマが足りんというのだ。": ""
  },
  "4547": {
    "「なんだとー！？": ""
  },
  "4548": {
    "「プーポッパン王は\u3000オトナで\u3000身体も大きい。\n\u3000だが\u3000ラグアス王子は\u3000まだ子供。": ""
  },
  "4549": {
    "「同じ\u3000命を捧げられるなら\n\u3000神だって\u3000小さい魂よりも\n\u3000大きいほうが\u3000いいはずだ！": ""
  },
  "4550": {
    "「……それは\u3000ともかく。\n\u3000プーポッパン王の身体は\u3000魔瘴に侵され\n\u3000いつまで\u3000もつか\u3000わからない。": ""
  },
  "4551": {
    "「なのに\u3000ひとり息子のラグアス王子が\n\u3000儀式のために\u3000死んでしまったら\n\u3000王家の血が\u3000途絶えるじゃないか。": ""
  },
  "4552": {
    "「……そりゃ\u3000オレだって\u3000わかってるよ。\n\u3000わかってるけど……。": ""
  },
  "4553": {
    "「……お前の気持ちは\u3000俺だって\u3000よくわかる。\n\u3000だが\u3000他でもない\u3000王ご自身が\n\u3000自ら儀式をおこなうと\u3000お望みなんだ。": ""
  },
  "4554": {
    "「さあ！\u3000行こう！": ""
  },
  "4555": {
    "「王が\u3000無事に儀式をおこなえるように\n\u3000塔に潜んでいる魔物を\u3000倒すぞ！！": ""
  },
  "4556": {
    "「……ここ……なのか……？": ""
  },
  "4557": {
    "「おい。どうなってるんだ？\n\u3000魔物なんか\u3000いないじゃないか。": ""
  },
  "4558": {
    "「……奇妙ですね。\n\u3000この部屋には\u3000魔物の気配が\u3000まるでない。": ""
  },
  "4559": {
    "「塔の構造から考えても\u3000この部屋が\n\u3000儀式の間に\u3000まちがいないのですが……。": ""
  },
  "4560": {
    "「………………。": ""
  },
  "4561": {
    "「仕方ない。一度\u3000城へ戻って\n\u3000儀式の間に\u3000魔物なんて\u3000いなかったと\n\u3000プーポッパン王に\u3000ご報告しよう！": ""
  },
  "4562": {
    "「……それは困るなあ。": ""
  },
  "4563": {
    "「魔物は\u3000いるんですよ。\n\u3000この儀式の間に……。なあ？": ""
  },
  "4564": {
    "「そうとも。この儀式の間には\n\u3000恐ろしい魔物が\u3000いるんだ。": ""
  },
  "4565": {
    "「へへへ……。そして\u3000あんたたちは\n\u3000魔物に\u3000やられて……": ""
  },
  "4566": {
    "「全滅しちまうんだよ！！": ""
  },
  "4567": {
    "「なっ……": ""
  },
  "4568": {
    "「お前たちは\u3000イッド様直属の……\n\u3000いったい\u3000なんのつもりだ！？": ""
  },
  "4569": {
    "「なんのつもりって……。\n\u3000わかってんだろ？\u3000なあ。": ""
  },
  "4570": {
    "「くっくっく……おろか者どもめ。\n\u3000この儀式の間には\u3000もとより\n\u3000魔物など\u3000おらぬのよ！": ""
  },
  "4571": {
    "「塔に\u3000魔物が出るというウワサを流し\n\u3000討伐隊を\u3000おびきよせたのも……": ""
  },
  "4572": {
    "「おい……。": ""
  },
  "4573": {
    "「まだ\u3000生き残りがいたか……。\n\u3000いいだろう。冥土のみやげだ。": ""
  },
  "4574": {
    "「我らが真の姿を\u3000その目に焼きつけ\n\u3000息絶えるがよいわっ！！": ""
  },
  "4575": {
    "「はっはっは！\u3000おろか者め！": ""
  },
  "4576": {
    "「あのまま\u3000逃げかえれば \n\u3000命ばかりは\u3000助かったものを。": ""
  },
  "4577": {
    "「みすみす\u3000儀式の間を汚すための \n\u3000いけにえになりに\u3000戻ってくるとはな。": ""
  },
  "4578": {
    "「まあ\u3000よいではないか。 \n\u3000いけにえの数が\u3000増えれば増えるほど\n\u3000我々にとって\u3000好都合よ。": ""
  },
  "4579": {
    "「おうよ！\u3000せっかく戻ってきたのだ。 \n\u3000ぞんぶんに\u3000痛めつけた後……": ""
  },
  "4580": {
    "「貴様の命\u3000奪ってやろうっ！！！ ": ""
  },
  "4581": {
    "「くっくっく……。\n\u3000我らを倒すとは\u3000見事……。": ""
  },
  "4582": {
    "「だが……すでに\u3000儀式の間は\n\u3000おろかなる討伐隊の血で\u3000汚れた後よ。": ""
  },
  "4583": {
    "「すべては\u3000我らが主\n\u3000イッド様の\u3000計画…通り……。": ""
  },
  "4584": {
    "「うっ……ぐふっ！！ ": ""
  },
  "4585": {
    "「ククク……。王に\u3000報告するがいい。\n\u3000魔物など\u3000いなかった……。\n\u3000すべては\u3000側近イッドの企みだ……と。": ""
  },
  "4586": {
    "「だが\u3000流れ者の旅人ふぜいと \n\u3000イッド様の言葉……\n\u3000はたして\u3000王は\u3000どちらを信じるかな……？": ""
  },
  "4587": {
    "「はっはっは……！ \n\u3000あーっはっはっはっは……！！": ""
  },
  "4588": {
    "「……貴様\u3000なぜ生きて……！？": ""
  },
  "4589": {
    "「い\u3000いや……失礼した。\n\u3000たしか\u3000討伐隊に加わっていた者だな。\n\u3000他の連中とは\u3000一緒ではないのか？": ""
  },
  "4590": {
    "「……イッド。なんの騒ぎだ。": ""
  },
  "4591": {
    "「王！\u3000お休みになられておりませんと \n\u3000お身体に\u3000障りますぞ！": ""
  },
  "4592": {
    "「わしに残された時間は\u3000わずかだ。\n\u3000この命\u3000尽きるまで\n\u3000国のために\u3000はたらきたいのよ。": ""
  },
  "4593": {
    "「おお……なんという\u3000気高き精神！\n\u3000さすが\u3000我が主君と心に決めし\u3000お方よ！": ""
  },
  "4594": {
    "「もうよい\u3000やめんか。\n\u3000それより……": ""
  },
  "4595": {
    "「そなたは\u3000討伐隊に加わった者だな。\n\u3000どうした。無事\u3000魔物は討伐できたのか？": ""
  },
  "4596": {
    "「……なんだと？": ""
  },
  "4597": {
    "「儀式の間には\u3000魔物は\u3000おらず……\n\u3000代わりに\u3000イッドの部下たちが\n\u3000討伐隊を皆殺しにした……だと？": ""
  },
  "4598": {
    "「な\u3000な\u3000なんたる……": ""
  },
  "4599": {
    "「なんたる\u3000デタラメを！！": ""
  },
  "4600": {
    "「王！\u3000かような痴れ者の言葉に\n\u3000耳を貸しては\u3000なりませぬ！": ""
  },
  "4601": {
    "「……なんと\u3000見下げ果てた\u3000ひきょう者よ。": ""
  },
  "4602": {
    "「おっ\u3000王よ！？": ""
  },
  "4603": {
    "「……いい面がまえをしておるからと\n\u3000討伐隊に入れたが\u3000どうやら\n\u3000わしの目が\u3000くもっておったようだな。": ""
  },
  "4604": {
    "「この\u3000ひきょう者めが！！": ""
  },
  "4605": {
    "「魔物から\u3000逃げかえってきただけなら\n\u3000許してやろうとも\u3000思ったが\n\u3000イッドに\u3000罪をなすりつけるとは！": ""
  },
  "4606": {
    "「魔物が\u3000いなかっただの \n\u3000我が腹心イッドが\u3000討伐隊を殺させただの\n\u3000バカも\u3000休み休み言うがよい！！": ""
  },
  "4607": {
    "「ゲホッ\u3000ゴホゴホッ！！": ""
  },
  "4608": {
    "「よいのです\u3000王よ……。\n\u3000しょせんは\u3000おくびょう者の浅はかなウソ。\n\u3000お気になさることはございません。": ""
  },
  "4609": {
    "「それよりも\u3000そう興奮なさると \n\u3000お身体に\u3000障りますぞ。": ""
  },
  "4610": {
    "「う…む。すまんな\u3000イッド……。": ""
  },
  "4611": {
    "「イッドに免じ\u3000貴様の罪は\u3000不問としてやる。\n\u3000だが……その顔は\u3000二度と見たくないわ。": ""
  },
  "4612": {
    "「旅人よ\u3000早々に\u3000立ち去るがいい！\n\u3000ふたたび\u3000我が前へ\u3000姿を現したなら\n\u3000次こそ\u3000容赦せんぞ！！": ""
  },
  "4613": {
    "「……というわけだ\u3000旅の方。\n\u3000お引き取り願えませんかな。": ""
  },
  "4614": {
    "「あの者が\u3000戻ってきたということは \n\u3000討伐隊の者たちも\u3000そろそろ\n\u3000任務を終えた頃かも\u3000しれませんな。": ""
  },
  "4615": {
    "「うむ。わしも\u3000儀式の塔へ\n\u3000旅立つ準備をせねばならんな……。": ""
  },
  "4616": {
    "「……待ってくれ！": ""
  },
  "4617": {
    "「君はウソなどついていないと\u3000ぼくにはわかる。\n\u3000……君のチカラを\u3000貸してほしい。": ""
  },
  "4618": {
    "「突然\u3000すまない。\n\u3000ぼくは\u3000フォステイル。\n\u3000君の名前は……\u3000ぼくが当ててみせよう。": ""
  },
  "4619": {
    "「君は\u3000アグラニの町から来た \n\u3000<pc>……だね。": ""
  },
  "4620": {
    "「だが\u3000君が\u3000本当に生まれた場所は\n\u3000アグラニの町とは\u3000ちがうようだ……。": ""
  },
  "4621": {
    "「ぼくは……ずっと昔から予知していた。": ""
  },
  "4622": {
    "「いずれ\u3000大いなる災いに見舞われる時\n\u3000<pc>という旅人が現れ\n\u3000この国を\u3000救うだろうと……。": ""
  },
  "4623": {
    "「<pc>\u3000君も知っている通り\n\u3000今\u3000プクランド大陸は\n\u3000魔瘴によって\u3000滅びようとしている。": ""
  },
  "4624": {
    "「プーポッパン王は\u3000王家に伝わる儀式を\n\u3000おこなおうとしているが\u3000儀式の間は\n\u3000すでに\u3000汚された。そうだね？": ""
  },
  "4625": {
    "「結局\u3000すべては予知した通りか。\n\u3000……そうとも。ぼくには\u3000未来が見える。 \n\u3000王の儀式では\u3000国は救えない。 ": ""
  },
  "4626": {
    "「それどころか\u3000このまま\u3000儀式をやれば\n\u3000プクランド大陸は\u3000さらなる災いに見舞われ\n\u3000滅びてしまうだろう……。": ""
  },
  "4627": {
    "「だが……ひとつだけ\u3000国を救う方法が\n\u3000残されている。": ""
  },
