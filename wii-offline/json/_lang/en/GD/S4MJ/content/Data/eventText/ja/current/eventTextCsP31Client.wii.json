  },
  "4800": {
    "「……お父さん！": ""
  },
  "4801": {
    "「お父さん！\u3000お父さん！！\n\u3000しっかりしてください！": ""
  },
  "4802": {
    "「ラグアス……か……。\n\u3000しばらく見んうちに…大きくなったな……。": ""
  },
  "4803": {
    "「謀られたよ……イッドの企みに\n\u3000まんまと\u3000してやられた……。": ""
  },
  "4804": {
    "「……旅人よ。 \n\u3000お前は\u3000真実を語っておったのだな……。": ""
  },
  "4805": {
    "「あの時……わしが\u3000お前を信じておれば。\n\u3000……いや\u3000フォステイルの言葉を信じておれば\n\u3000このようなことには……。": ""
  },
  "4806": {
    "「ゲホッ！\u3000ゲホッ！！": ""
  },
  "4807": {
    "「……大丈夫です\u3000お父さん。": ""
  },
  "4808": {
    "「お母さんが持っていた\n\u3000あの\u3000願いのかなうノートが\n\u3000見つかったんです！": ""
  },
  "4809": {
    "「今\u3000ノートに願いを書きます。\n\u3000お父さんの命は\u3000助かるはずです！": ""
  },
  "4810": {
    "「だめだ\u3000ラグアス……。": ""
  },
  "4811": {
    "「すべては\u3000わしの\u3000おろかさと\n\u3000人を信じぬ\u3000かたくなな心が招いたこと。": ""
  },
  "4812": {
    "「……尽きた命を\u3000呼びもどすなど\n\u3000天の理に反することを\u3000してはならん……。": ""
  },
  "4813": {
    "「それよりも……わしの\u3000おろかさにより\n\u3000滅びようとしている\u3000この大陸を……。": ""
  },
  "4814": {
    "「どうか……魔瘴から\u3000我が国を……\n\u3000プクランド大陸を…救ってくれ……。": ""
  },
  "4815": {
