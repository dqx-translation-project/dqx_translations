{
  "16478": {
    "「あっ\u3000<pc>！\n\u3000もうレベル４０以上の\u3000パラディンに\n\u3000なっているのだ！\u3000すごいのだ～！": ""
  },
  "16479": {
    "「そろそろ来ると思っていたぞ\u3000ズーボー！": ""
  },
  "16480": {
    "「今\u3000<pc>に\u3000ジェニャどのに関する\n\u3000任務を\u3000依頼したところだ。\n\u3000ズーボーも\u3000同じ任務に\u3000当たってくれ。": ""
  },
  "16481": {
    "「ジェニャに関する任務？\n\u3000もちろん\u3000やるのだ。まかせてほしいのだ！": ""
  },
  "16482": {
    "「ウェナ諸島にある\u3000地底湖の洞くつへ\n\u3000ジェニャどのを\u3000連れていってもらいたい。": ""
  },
  "16483": {
    "「ジェニャどのは\u3000２階の\u3000マグナスさまの部屋で\n\u3000出発の準備をしているところだ。\n\u3000お迎えにあがってくれ。": ""
  },
  "16484": {
    "「わかりましたなのだ！": ""
  },
  "16485": {
    "「じゃあ\u3000オイラは\u3000先に\n\u3000マグナスさまの部屋で\u3000待っているのだ。\n\u3000<pc>も\u3000後で来るのだ！": ""
  },
  "16486": {
    "「あっ\u3000<pc>はん！\n\u3000これで\u3000みんな\u3000そろったんやろ？\n\u3000ほな\u3000出かけられるな！": ""
  },
  "16487": {
    "「ウェナ諸島には\u3000はじめて行くねん！\n\u3000あったかくて\u3000ええ所なんやろうなあ。\n\u3000めっちゃ\u3000楽しみや！": ""
  },
  "16488": {
    "「そうかそうか。\n\u3000ジェニャは\u3000思いっきり\u3000楽しむといいのだ！\n\u3000オイラたちが守るから\u3000心配ないのだ。": ""
  },
  "16489": {
    "「本当に\u3000くれぐれも\u3000お願いしますね。\n\u3000ジェニャさまには\u3000かすり傷ひとつ\u3000つけるなと\n\u3000私も\u3000強く言われているんですっ。": ""
  },
  "16490": {
    "「そのために\u3000この部屋にいた\u3000マリーちゃんを\n\u3000よそに\u3000あずけたくらいなんですから。": ""
  },
  "16491": {
    "「マリーちゃん？\n\u3000それって\u3000誰なん？": ""
  },
  "16492": {
    "「マグナスさまの\u3000愛犬ですわっ。\n\u3000やんちゃが過ぎるので\u3000万一のことを考えて\n\u3000別の所へ\u3000あずけたのです。": ""
  },
  "16493": {
    "「へえ～\u3000この部屋に\u3000ワンコがおったんか。\n\u3000ええなあ……。あたし\u3000ワンコ好きやのにな。\n\u3000みんな\u3000大げさに\u3000気にしすぎやわ……。": ""
  },
  "16494": {
    "「ほな\u3000出かけようか？\n\u3000はよう\u3000ウェナ諸島に\u3000行きたいわあ！": ""
  },
  "16495": {
    "「じゃあ\u3000オイラが\u3000ジェニャを連れていくから\n\u3000地底湖の洞くつで\u3000落ち合おうなのだ！\n\u3000レーナム緑野側の入り口で\u3000待ってるのだ！": ""
  },
  "16496": {
    "「ジュレットの町の名物\u3000とこなつココナッツ\n\u3000めっちゃ\u3000おいしかったな～！\n\u3000おごってくれて\u3000ありがとうな。": ""
  },
  "16497": {
    "「あんなに\u3000食べたそうな顔で\u3000見られては\n\u3000ごちそうしないわけには\u3000いかないのだ。": ""
  },
  "16498": {
    "「海も\u3000景色も\u3000めちゃくちゃキレイやし……\n\u3000ほんま\u3000こういうとこ来ると\n\u3000イヤなこと全部\u3000忘れられるわ～！": ""
  },
  "16499": {
    "「ジェニャ……\u3000聞いてもいいのだ？\n\u3000ちょっと\u3000気になるウワサを\u3000耳にしたのだ。": ""
  },
  "16500": {
    "「ジェニャは\u3000以前\u3000ランガーオ村に住んでて\n\u3000……その頃は\u3000村でも\n\u3000有名な\u3000守銭奴少女だったって。": ""
  },
  "16501": {
    "「もし\u3000何か理由があって\n\u3000お金がいるのなら\u3000言ってほしいのだ。\n\u3000オイラに\u3000できることなら\u3000助けてあげるのだ。": ""
  },
  "16502": {
    "「……もう！\u3000なに言うてんの。\n\u3000あたしは\u3000貯金が\u3000趣味やっただけや。\n\u3000ズーボーはんは\u3000ほんま\u3000心配症やな～。": ""
  },
  "16503": {
    "「あたしのことは\u3000なんも\u3000心配いらんよ。\n\u3000貯金も\u3000もう\u3000やめたし……\n\u3000助けてほしいことなんて\u3000なんもあらへん！": ""
  },
  "16504": {
    "「そうか……。\n\u3000ジェニャが\u3000そう言うなら\u3000いいのだ……。": ""
  },
  "16505": {
    "「あっ\u3000<pc>！\n\u3000いつの間に\u3000来ていたのだ？": ""
  },
  "16506": {
    "「ジェニャは\u3000この洞くつの奥に\n\u3000用事があるらしいのだ。\n\u3000強い魔物たちが\u3000たくさんいる場所なのだ。": ""
  },
  "16507": {
    "「うん。あたしと\u3000ズーボーはんだけじゃ\n\u3000ちょっと\u3000危ないような場所やねん。\n\u3000奥のな……\u3000清澄の冷泉って所に行きたいんや。": ""
  },
  "16508": {
    "「だから\u3000<pc>には\u3000魔物を倒しながら\n\u3000先に\u3000清澄の冷泉へ\u3000行ってもらいたいのだ。\n\u3000場所は\u3000地図を見れば\u3000わかるはずなのだ。": ""
  },
  "16509": {
    "「オイラは\u3000ジェニャを守りながら\n\u3000魔物たちに出会わないように\u3000隠れて\n\u3000ついてゆくのだ。では\u3000頼んだのだ！": ""
  },
  "16510": {
    "「うん……\u3000ここや！\n\u3000ここに\u3000まちがいあらへん。": ""
  },
  "16511": {
    "「さすが\u3000<pc>なのだ！\n\u3000後をついてきたら\u3000楽に\u3000来られたのだ！": ""
  },
  "16512": {
    "「ほな\u3000さっさと終わらせるから\n\u3000ちょっと\u3000待っててな～。": ""
  },
  "16513": {
    "「ジェニャ！？\n\u3000危ないのだ！\u3000戻ってくるのだ！": ""
  },
  "16514": {
    "「平気やって！\u3000大丈夫や～！": ""
  },
  "16515": {
    "「ジェニャ……？": ""
  },
  "16516": {
    "「……………………。": ""
  },
  "16517": {
    "「我……\u3000いにしえの約束を果たせし\u3000乙女……。": ""
  },
  "16518": {
    "「太古より\u3000満たされし水よ。\n\u3000わが身を清めたまえ。我\u3000オーグリード大陸に\n\u3000安息を\u3000もたらす\u3000……………と\u3000ならん。": ""
  },
  "16519": {
    "「ジェニャ……。": ""
  },
  "16520": {
    "「えへへ……\u3000お待たせ～。\n\u3000ほな\u3000終わったし\u3000帰ろうか？": ""
  },
  "16521": {
    "「ジェニャ……\u3000今\u3000何をしたのだ？\n\u3000なんか\u3000儀式みたいだったのだ。": ""
  },
  "16522": {
    "「えへへ………\u3000ヒミツ\u3000ヒミツ！\n\u3000女の子の\u3000ヒミツや～！": ""
  },
  "16523": {
    "「帰ろ\u3000帰ろ！": ""
  },
  "16524": {
    "「待つのだ\u3000ジェニャ！": ""
  },
  "16525": {
    "「それじゃあ\u3000<pc>。\n\u3000ガートラント城で\u3000会おうなのだ！": ""
  },
  "16526": {
    "「わんっ\u3000わんっ！": ""
  },
  "16527": {
    "「くぬぅぅうう！\n\u3000王宮パラディンの中でも\u3000超エリートなボクが\n\u3000なぜ\u3000こんな役目を……！！": ""
  },
  "16528": {
    "「待てぇぇえええい！！": ""
  },
  "16529": {
    "「わあっ\u3000ワンコや……！\n\u3000もしかして\u3000この子が\u3000マリーちゃん！？": ""
  },
  "16530": {
    "「そうなのだ！\n\u3000いつも元気いっぱいな\u3000マリーちゃんなのだ。": ""
  },
  "16531": {
    "「あれ？\u3000マリーちゃん\u3000おなかが大きいのだ。\n\u3000これは……\u3000もしかして！？": ""
  },
  "16532": {
    "「もうすぐ\u3000赤ちゃんが\u3000生まれるのだ！": ""
  },
  "16533": {
    "「うわあ～\u3000赤ちゃんか～！\n\u3000ええなあ。きっと\u3000かわええやろうなあ！": ""
  },
  "16534": {
    "「赤ちゃんは\u3000みんな\u3000かわいいのだ！\n\u3000マリーちゃんの赤ちゃんが生まれたら\n\u3000ジェニャも\u3000一緒に遊んであげるのだ！": ""
  },
  "16535": {
    "「そっかあ\u3000楽しみやなあ。": ""
  },
  "16536": {
    "「……せやけど\u3000あたし\n\u3000その頃は\u3000もう\u3000おらへんねん。": ""
  },
  "16537": {
    "「そうか……。\n\u3000ジェニャは\u3000ずっと\u3000ガートラントに\n\u3000いるわけではないのだな。": ""
  },
  "16538": {
    "「じゃあ\u3000せめて\u3000ここにいる間\n\u3000マリーちゃんと\u3000一緒にいられるように\n\u3000ピチョンに\u3000頼んであげるのだ。": ""
  },
  "16539": {
    "「ほんま！？\u3000めっちゃ\u3000うれしい！\n\u3000ありがとうな\u3000ズーボーはん！": ""
  },
  "16540": {
    "「じゃあ\u3000オイラは\u3000ジェニャを\n\u3000部屋に送っていくから\u3000<pc>は\n\u3000先に\u3000団長の所へ行っててほしいのだ。": ""
  },
  "16541": {
    "「あのマリーを\u3000あそこまで\u3000手なずけるとは\n\u3000さすが\u3000いなか者……。\n\u3000高貴な生まれのボクには\u3000できない芸当だよ。": ""
  },
  "16542": {
    "「ジェニャを\u3000マグナスさまの部屋まで送り\n\u3000ただいま\u3000帰還いたしましたなのだ。": ""
  },
  "16543": {
    "「<pc>\u3000朗報なのだ！\n\u3000ジェニャとマリーちゃんは\n\u3000同じ部屋で\u3000暮らせるようになったのだ。": ""
  },
  "16544": {
    "「ご苦労だった\u3000<pc>\u3000ズーボー。\n\u3000ずいぶん\u3000ジェニャどのに\n\u3000親身になっているようだが……。": ""
  },
  "16545": {
    "「ジェニャどのとは\u3000任務として\n\u3000一緒に\u3000いるのだということを\u3000忘れるな。\n\u3000極端な肩入れは\u3000やめておけよ。": ""
  },
  "16546": {
    "「さあ\u3000今回の報酬だ！\u3000受け取れ！": ""
  },
  "16547": {
    "「では\u3000また\u3000しばらくしたら\u3000任務を頼みたい。\n\u3000そうだな。レベル４５以上のパラディンなら\n\u3000今後も\u3000問題なく\u3000まかせられるだろう。": ""
  },
  "16548": {
    "「わかりましたなのだ。\n\u3000じゃあ\u3000<pc>。オイラは\u3000行くのだ。\n\u3000また\u3000会おうなのだ！": ""
  }
}