{
  "19811": {
    "「それは…………。": ""
  },
  "19812": {
    "「フィーヤというのが\u3000死の言葉を使う\n\u3000少女の名前だからです\u3000バルチャさん。": ""
  },
  "19813": {
    "「……ルベカ！？\n\u3000なぜ\u3000そのことを\u3000知っている！": ""
  },
  "19814": {
    "「やっぱり\u3000そうなんだ……。\n\u3000フィーヤ孤児院というのは\n\u3000あの子の名前から\u3000取った名前なんですね。": ""
  },
  "19815": {
    "「…………。": ""
  },
  "19816": {
    "「ダーリアさんが\u3000海で\u3000おぼれた原因を調べて\n\u3000いろいろなことが\u3000わかったんです。": ""
  },
  "19817": {
    "「死の言葉を使う女の子が\u3000この村にいたこと。\n\u3000その子が\u3000ダーリアさんを\u3000海に沈めたこと。": ""
  },
  "19818": {
    "「私のアタマの中に\u3000聞こえる言葉が\n\u3000その死の言葉と\u3000同じだということ……。": ""
  },
  "19819": {
    "「フィーヤの声が\u3000聞こえるだと？\n\u3000そんな\u3000バカな……。": ""
  },
  "19820": {
    "「フィーヤが\u3000閉じ込められてたっていう\n\u3000洞くつへ行ったら\u3000また\u3000声が聞こえました。": ""
  },
  "19821": {
    "「……来てくれたのね。\n\u3000私の名前は\u3000フィーヤ……って。": ""
  },
  "19822": {
    "「名前を\u3000教えてくれたってことは\n\u3000私に\u3000何か\u3000伝えようとしてるんです。\n\u3000だから\u3000知っていることを\u3000教えてください！": ""
  },
  "19823": {
    "「……そうか。\n\u3000もはや\u3000わしが隠しても\u3000ムダのようだな……。": ""
  },
  "19824": {
    "「おまえたちが知った\u3000少女の事件は\n\u3000すべて\u3000本当にあったことなのだ。\n\u3000この村に埋もれた\u3000負の歴史だ。": ""
  },
  "19825": {
    "「わしが知っていることを\u3000教えよう。\n\u3000フィーヤの最期をな……。": ""
  },
  "19826": {
    "「フィーヤは……。\n\u3000この村の者たちに\u3000殺されたのだ。": ""
  },
  "19827": {
    "「…………そんな。どうして？": ""
  },
  "19828": {
    "「……死の言葉を使うと\u3000恐れられ\n\u3000心を閉ざしてしまったフィーヤだが\n\u3000それを\u3000かばおうとする者もいたのだ。": ""
  },
  "19829": {
    "「それが\u3000レグと\u3000その恋人ダーリアだった。\n\u3000ふたりのおかげで\u3000フィーヤは\n\u3000この村で\u3000生活できていたと\u3000言ってもいい。": ""
  },
  "19830": {
    "「フィーヤも\u3000そのふたりにだけは\n\u3000心を開いていた……はずだった。": ""
  },
  "19831": {
    "「だが\u3000フィーヤは\u3000その恩を忘れて\n\u3000ダーリアに\u3000死の言葉を使ったのだ。": ""
  },
  "19832": {
    "「しかも\u3000死の言葉が効かないと悟ると\n\u3000次には\u3000自ら海に引きずり込んで\n\u3000ダーリアを殺したのだ……。": ""
  },
  "19833": {
    "「村の者は\u3000怒りに我を忘れた。\n\u3000ひとり\u3000またひとりと\u3000武器を手に取り\n\u3000フィーヤに\u3000襲いかかった。": ""
  },
  "19834": {
    "「そんな\u3000ひどい……。": ""
  },
  "19835": {
    "「それで\u3000フィーヤは死んだ……。\n\u3000その後は\u3000どうなったんですか……？": ""
  },
  "19836": {
    "「ちょうど\u3000そのとき\u3000ダーリアの結婚式のために\n\u3000祈りの宿から\u3000ひとりの神官が村に来ていてな。": ""
  },
  "19837": {
    "「事情を聞いた\u3000祈りの宿の神官は\n\u3000フィーヤの遺体を\u3000引き取りたいと申しでた。": ""
  },
  "19838": {
    "「異を唱える者は\u3000誰ひとり\u3000いなかった。 \n\u3000我に返った村の者たちは\u3000皆\u3000自分の\n\u3000しでかしたことに\u3000恐れおののいていたからな。": ""
  },
  "19839": {
    "「フィーヤの遺体を抱いた神官は\n\u3000この孤児院を訪れ\u3000わしに\u3000言い残した。": ""
  },
  "19840": {
    "「……村の者たちは\u3000この痛ましい出来事を\n\u3000時に流し\u3000忘れ去ろうとするだろう。": ""
  },
  "19841": {
    "「だが\u3000同じ悲劇をくり返しては\u3000ならない。\n\u3000フィーヤの名を\u3000この孤児院に残し\n\u3000村の戒めとするがよい……とな。": ""
  },
  "19842": {
    "「神官の言うとおり\u3000フィーヤの名を残したが\n\u3000この話を\u3000若い者に\u3000伝えることはしなかった。\n\u3000わしも\u3000忘れたかったのだ……。": ""
  },
  "19843": {
    "「わしも\u3000フィーヤを襲った者と同罪だ。\n\u3000これ以上\u3000わしに語れることはない……。": ""
  },
  "19844": {
    "「村の人たちが\u3000フィーヤを殺したなんて……。\n\u3000でも\u3000そんなことがあったんなら\n\u3000村の人ばかりが\u3000悪いわけじゃないけど……。": ""
  },
  "19845": {
    "「フィーヤが\u3000ダーリアさんを殺したのは\n\u3000やっぱり\u3000事実なんだし。": ""
  },
  "19846": {
    "「でも\u3000どうして\u3000自分に優しくしてくれていた\n\u3000ダーリアさんまで……？\n\u3000ますます\u3000理由が\u3000わからなくなっちゃった。": ""
  },
  "19847": {
    "「もしかして！\u3000逆に\u3000仲が良かったから？": ""
  },
  "19848": {
    "「……フィーヤは\u3000レグさんを\n\u3000好きだったんじゃないかな。": ""
  },
  "19849": {
    "「ダーリアさんと結婚したら\n\u3000レグさんを取られちゃうと\u3000思ったんだ。\n\u3000だから\u3000ダーリアさんを……。": ""
  },
  "19850": {
    "「でも……。１０歳の女の子が\u3000本当に\n\u3000そんなことをしたなんて\u3000信じたくない……。": ""
  },
  "19851": {
    "「あのね。私\u3000祈りの宿へ行ってみたいの。\n\u3000もし\u3000お墓とかあるなら\u3000見てみたいし\n\u3000何か\u3000フィーヤのことも\u3000わかるかも。": ""
  },
  "19852": {
    "「お父さんが\u3000心配してるみたいだから\n\u3000私\u3000ちょっと適当に\u3000なだめてくるね。\n\u3000先に\u3000祈りの宿へ向かっててほしいな。": ""
  },
  "19853": {
    "「<pc>\u3000遅くなって\u3000ごめんね。\n\u3000ここは\u3000私に\u3000まかせて。": ""
  },
  "19854": {
    "「リリーエ様。フィーヤという名に\n\u3000心当たりは\u3000ありませんか？": ""
  },
  "19855": {
    "「おお\u3000セトリー村長の\u3000お嬢さん。\n\u3000ありますとも\u3000ありますとも。\n\u3000バルチャ老が建てた\u3000孤児院の名前ですな。": ""
  },
  "19856": {
    "「いえ\u3000そうじゃなくて……。\n\u3000フィーヤという女の子の\u3000お墓が\n\u3000ここに\u3000あったりはしませんか？": ""
  },
  "19857": {
    "「そのような名の墓は\u3000ここには\u3000ありません。\n\u3000いったい\u3000なんのお話ですかな？": ""
  },
  "19858": {
    "「ダーリアさんが\u3000亡くなった事件のころ\n\u3000レーンの村で\u3000フィーヤっていう女の子が\n\u3000かわいそうな亡くなり方をしたんです……。": ""
  },
  "19859": {
    "「それは\u3000慰霊碑の逸話の時代の\u3000お話ですな。\n\u3000私が\u3000ここに来る前のことですので\n\u3000申し訳ありませんが\u3000わかりかねます。": ""
  },
  "19860": {
    "「なにせ\u3000慰霊碑の逸話も\u3000当時の神官が残した\n\u3000日記を読んで\u3000知ったことですし……。": ""
  },
  "19861": {
    "「その日記に\u3000フィーヤって女の子のことが\n\u3000書かれていませんでしたか！？": ""
  },
  "19862": {
    "「……いいえ。記憶にありませんな。": ""
  },
  "19863": {
    "「おお！\u3000そういえば\u3000もう１冊\n\u3000カギのかけられた日記が\u3000ありましたな。\n\u3000しばし\u3000お待ちください。": ""
  },
  "19864": {
    "「ルベカお嬢さんの\u3000お役に立つのなら\n\u3000この日記は\u3000差し上げましょう。": ""
  },
  "19865": {
    "「ありがとうございます\u3000リリーエ様。": ""
  },
  "19866": {
    "「この間\u3000ジュレリア地下廃坑を通って\n\u3000巡礼に行ったとき\u3000魔物に襲われて\n\u3000持っていたカギ束を\u3000盗られましてな……。": ""
  },
  "19867": {
    "「この建物のカギは\u3000新しいものに変えましたが \n\u3000日記のカギは\u3000読む者もおらぬだろうと\n\u3000そのままに\u3000しておりました。": ""
  },
  "19868": {
    "「なので\u3000日記のカギは\u3000ないのです。\n\u3000<%sEV_QUE_NAME0>という魔物が\n\u3000カギ束を\u3000持ったままなのではないかと……。": ""
  },
  "19869": {
    "「この日記が\u3000当時の神官のものなら\n\u3000フィーヤのことも\u3000書いてあるはずよね。\n\u3000カギが\u3000かかってるなんて\u3000怪しいし！": ""
  },
  "19870": {
    "「うかつに\u3000カギを壊して\u3000日記の中身が\n\u3000ダメになっちゃったら\u3000元も子もないわ。\n\u3000ここは\u3000<pc>の出番ね。": ""
  },
  "19871": {
    "「ジュレリア地下廃坑の\u3000<%sEV_QUE_NAME0>が\n\u3000今も\u3000神官のカギ束を\u3000持ち歩いてるかも。\n\u3000そこに行って\u3000取り返してきてほしいの。": ""
  },
  "19872": {
    "「私は\u3000レーンの村で\u3000待ってるから。\n\u3000<pc>\u3000頼んだわよ！": ""
  },
  "19873": {
    "「私の推理によれば\u3000この日記には\n\u3000フィーヤのことが\u3000書かれているはずよ。\n\u3000だから\u3000カギが\u3000かけられたんだ。": ""
  },
  "19874": {
    "「やった！\u3000開いたよ。": ""
  },
  "19875": {
    "「この真実\u3000いただきます！": ""
  },
  "19876": {
    "「じゃあ\u3000さっそく\u3000読んでみよう。\n\u3000ちょっと\u3000量がありそうだけど\n\u3000ガマンして\u3000聞いててね。": ""
  },
  "19877": {
    "……今日\u3000私は\u3000ひとりの少女を\n祈りの宿へと\u3000運んだ。": ""
  },
  "19878": {
    "レーンの村の者によれば\nこのフィーヤという少女は\u3000死の言葉によって\n多くの者を\u3000死に至らしめたという。": ""
  },
  "19879": {
    "だが\u3000いかなる理由があろうと\nこんな年端のいかない少女が\u3000村の者の手により\n殺められるなど\u3000あってはならない。": ""
  },
  "19880": {
    "私は\u3000まだ息のあった少女を\n死んだと\u3000いつわり\u3000連れてきたのだ。\n私の回復呪文で\u3000今なら\u3000まだ助けられる。": ""
  },
  "19881": {
    "「フィーヤは\u3000生きてた……？": ""
  },
  "19882": {
    "少女の負ったキズは\u3000快方へ向かっている。\nだが\u3000その心は\u3000かたくなに閉じたままで\nどうやら\u3000言葉も失っているようだ。": ""
  },
  "19883": {
    "調べたところ\u3000薬を飲まされたせいと\u3000わかった。\n死の言葉におびえた\u3000村の者のしわざなのだろう。": ""
  },
  "19884": {
    "この少女が\u3000人を殺したことは\u3000事実なのか？\n私の目には\u3000この少女の心は\u3000無垢で\n汚れなき清水のように\u3000映っている。\u3000": ""
  },
  "19885": {
    "人々に\u3000さげすまれ\u3000憎まれたまま\nたった\u3000ひとりで\u3000生きつづけることが\nこの少女の運命であるはずがない。\u3000": ""
  },
  "19886": {
    "フィーヤは\u3000言葉を失っていたが\n死の言葉の持つチカラは\u3000いまだに\n彼女の中に潜んでいることが\u3000わかった。": ""
  },
  "19887": {
    "私は\u3000ひとつの仮説を立てた。死の言葉の持つ\nチカラそのものが\u3000この少女を操るようにして\n悪事を果たしていたとは\u3000考えられないか？": ""
  },
  "19888": {
    "このチカラを消すことができれば\nフィーヤは\u3000普通の少女として\n生きていくことが\u3000できるかもしれない。": ""
  },
  "19889": {
    "私は\u3000あらんかぎりの方法を試したが\nいずれも\u3000失敗に終わった。\nだが\u3000決して\u3000あきらめたりはしない。": ""
  },
  "19890": {
    "……あらゆる書物をあさって\u3000調べたが\n死の言葉を消す方法は\u3000見つからない。\n時間だけが\u3000無情に過ぎていく。": ""
  },
  "19891": {
    "私は\u3000ウェナ諸島で\u3000もっとも多く\n海の神のチカラが宿ると言われる\n清廉の大滝に\u3000最後の望みを託すことにした。": ""
  },
  "19892": {
    "海の神のチカラを借り\u3000命をかけて\n祈りを捧げれば\u3000可能性はある。": ""
  },
  "19893": {
    "……フィーヤを連れて\u3000清廉の大滝へ。": ""
  },
  "19894": {
    "祈りの儀式は\u3000失敗に終わり\n私の心は\u3000絶望の淵に沈んだ。": ""
  },
  "19895": {
    "だが\u3000なによりも愚かだったのは\n私は\u3000自分の感じた絶望を\nフィーヤにまで\u3000悟らせてしまったことだ。": ""
  },
  "19896": {
    "清廉の大滝を離れ\u3000ブーナー熱帯雨林を\n歩いていた\u3000そのとき。\n不意にフィーヤが\u3000あらぬ方へと走りだした。": ""
  },
  "19897": {
    "後を追った私が\u3000見たものは……。\nドルロイの滝へ身を投じた\u3000フィーヤの姿だった。": ""
  },
  "19898": {
    "フィーヤの姿は\u3000激しい流れに飲み込まれた。\n必死に探したが\u3000見つけられなかった。\nもはや\u3000生きているはずなどない。": ""
  },
  "19899": {
    "私が\u3000殺したも同然だ。\nおのれのチカラを過信し\u3000フィーヤに\nあまりにも深い絶望を\u3000与えてしまった。": ""
  },
  "19900": {
    "私は\u3000フィーヤを救えなかった。\n笑顔を取り戻すことが\u3000できなかった。\n私に\u3000神官を務める資格など\u3000なかったのだ。": ""
  },
  "19901": {
    "「……ここで\u3000日記は終わってる。\n\u3000これって\u3000きっと\u3000村の人たちも\n\u3000知らないことなんだよね。": ""
  },
  "19902": {
    "「祈りの宿の神官は\u3000フィーヤを信じて\n\u3000いろいろと\u3000助けようとしていたんだ……。\n\u3000でも\u3000フィーヤは\u3000滝に身を投げて……。": ""
  },
  "19903": {
    "「フィーヤは\u3000いったい\u3000どんな子なの？\n\u3000悪い子なのか\u3000それとも\u3000いい子なのか\n\u3000もう\u3000ぜんぜん\u3000わからなくなってきちゃった。": ""
  },
  "19904": {
    "「う～ん\u3000うう～ん……。": ""
  },
  "19905": {
    "「ダメだ。熱が出てきたよ……。": ""
  },
  "19906": {
    "「ふうう。フィーヤの足取りも\u3000つかめたし\n\u3000いったん\u3000この辺で\u3000やめておくかな。": ""
  },
  "19907": {
    "「助手をしてくれて\u3000ありがとう。\n\u3000いつもどおり\u3000お礼を用意してあるよ。": ""
  },
  "19908": {
    "「あれ？\u3000なんか\u3000足もとが……。": ""
  },
  "19909": {
    "<center>ルベカが\u3000死ぬ\n命の輝きが\u3000闇に呑まれる": ""
  },
  "19910": {
    "「今の声……。<pc>にも\n\u3000聞こえたんだね……。": ""
  },
  "19911": {
    "「フィーヤは\u3000ずっと\u3000私の名前を\n\u3000呼んでいたんだ……。": ""
  },
  "19912": {
    "「なんで\u3000私に\u3000死の言葉を使うの？\n\u3000フィーヤは\u3000やっぱり\u3000悪い子なの！？\u3000": ""
  },
  "19913": {
    "「わ…私も\u3000死んじゃうんだ！！": ""
  },
  "19914": {
    "「なんで\u3000こんなことに\u3000なっちゃったの……。\n\u3000フィーヤのことを\u3000調べたりしたから？": ""
  },
  "19915": {
    "「怖い……。怖いよ……。死ぬの\u3000やだもん。": ""
  },
  "19916": {
    "「……<pc>\u3000ごめんなさい。\n\u3000今日は\u3000帰って……。": ""
  },
  "29443": {
    "「フィーヤが？\u3000そんな……。": ""
  }
