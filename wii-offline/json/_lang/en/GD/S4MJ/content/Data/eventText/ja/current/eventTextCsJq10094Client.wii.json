{
  "20842": {
    "……どこからか\u3000ひそひそと\n話す声が\u3000聞こえてくる。": ""
  },
  "20843": {
    "「すごいよ\u3000ノーラン兄ちゃん……！\n\u3000取り引き場所を\u3000突きとめるなんて！": ""
  },
  "20844": {
    "「ノーラン兄ちゃんが\u3000来てくれれば\n\u3000魔法戦士団は\u3000今よりも\n\u3000もっと\u3000強力な組織になれるのにな……。": ""
  },
  "20845": {
    "「魔法戦士の話は\u3000もういい。\n\u3000オレが守りたいのは\u3000この国なんだ。": ""
  },
  "20846": {
    "「オレは\u3000巡視の任務に戻る。\n\u3000そっちも\u3000がんばるんだな\u3000ユナティ。": ""
  },
  "20847": {
    "「ノーラン兄ちゃん……。": ""
  },
  "20848": {
    "「<pc>\u3000何をしている？\n\u3000調達任務が\u3000終わったのならば\n\u3000すぐに\u3000魔法戦士団のサロンへ来い。": ""
  },
  "20849": {
    "<center>アーベルクの号令によって\n魔法戦士たちが\u3000サロンに集められた。\nそして\u3000いよいよ\u3000出撃の時間が訪れた。": ""
  },
  "20850": {
    "「我がヴェリナード王立魔法戦士団の\n\u3000華麗なる\u3000魔法戦士たちよ！": ""
  },
  "20851": {
    "「ウェナ諸島の魔物が\u3000幾多の国で暴れるという\n\u3000これまでにない\u3000事態が起こった！": ""
  },
  "20852": {
    "「だが\u3000我ら魔法戦士団が\n\u3000女王の御心を持ちて\u3000救いの手を差しのべ\n\u3000その被害は\u3000最小限に抑えられたのである！": ""
  },
  "20853": {
    "「そして今！\u3000その主犯たる人物\n\u3000魔物商人ザルギスの存在が\u3000明らかとなった！": ""
  },
  "20854": {
    "「ザルギスは\u3000強力な魔物を\n\u3000大量に\u3000売りさばこうとしている！\n\u3000この暴挙を\u3000決して\u3000許してはならない！！": ""
  },
  "20855": {
    "「女王ディオーレも\u3000心を痛めておられる。\n\u3000我らが女王のためにも\u3000早く\n\u3000なんとかしてくれないと\u3000困るのだよ～！": ""
  },
  "20856": {
    "「我ら魔法戦士団は\u3000制圧任務に出撃する！\n\u3000取り引きを未然に防ぎ\u3000ザルギスを捕縛せよ！！": ""
  },
  "20857": {
    "「目標は\u3000オーグリード大陸！\n\u3000ギルザッド地方で確認された\n\u3000トガス岩道と呼ばれる\u3000洞くつである。": ""
  },
  "20858": {
    "「規律に生き\u3000規律に殉ずる覚悟はあるか！\n\u3000魔法戦士の諸君！\u3000剣をかかげよ！！": ""
  },
  "20859": {
    "「魔法戦士団\u3000出撃せよ！！": ""
  },
  "20860": {
    "<center>こうして\u3000魔法戦士たちは\u3000出撃していった。": ""
  },
  "20861": {
    "「来たか\u3000<cs_pchero>。\n\u3000ノーランの情報は\u3000正しかった。\n\u3000魔物商人ザルギスを\u3000発見したのだ。": ""
  },
  "20862": {
    "「キヒヒヒ……。そろったか\u3000魔法戦士団。\n\u3000待ってたんだぜえ。": ""
  },
  "20863": {
    "「……待っていたとは\u3000どういうことだ。\n\u3000取り引きは\u3000どうしたのだ？": ""
  },
  "20864": {
    "「取り引き？\u3000ほおー。ノーランのヤツは\n\u3000ずいぶん\u3000あんたらに\u3000信頼されてんだなあ。\n\u3000話をつけといて\u3000正解だったぜ。": ""
  },
  "20865": {
    "「貴様……。ノーランに\u3000何を吹き込んだ！": ""
  },
  "20866": {
    "「ん？\u3000前に会ったよな？\u3000そんときに\n\u3000魔法戦士団って\u3000むかつくよなーって\n\u3000言ってやったら\u3000乗ってきやがったのさ。": ""
  },
  "20867": {
    "「それで魔法戦士団に\u3000ひと泡吹かせてやろうって\n\u3000話になったわけよ。ウソの取り引き情報で\n\u3000魔法戦士団を\u3000誘いだし……キーヒヒヒ！": ""
  },
  "20868": {
    "「……てなわけで\u3000引っかかった\u3000あんたらぁ\n\u3000ここで\u3000ひとり残らず\u3000死ぬってえ寸法だあ！": ""
  },
  "20869": {
    "「世界に名の知れた\u3000魔法戦士団を倒したとなりゃ\n\u3000うちの商品は\u3000売れまくり\u3000まちがいなしよ！\n\u3000キヒャヒャヒャヒャ！！": ""
  },
  "20870": {
    "「くっ\u3000なんという数だ。\n\u3000<cs_pchero>は\u3000大物を引きつけろ！\n\u3000我々は\u3000雑魚を全滅させる！": ""
  },
  "20871": {
    "「改良型のナンバー７を\u3000なめるなよ。\n\u3000それに\u3000最新作ナンバー１２のパワーもなあ。\n\u3000キヒヒ……。その身をもって\u3000知るこった！": ""
  },
  "20872": {
    "「<cs_pchero>！\u3000戦いは続いているぞ。\n\u3000貴公は\u3000大物を引きつけてくれ！": ""
  },
  "20873": {
    "「なんでぇ。あんた\u3000まだ\u3000生きてたんかい。\n\u3000獲物には\u3000しっかり\u3000トドメを刺せと\n\u3000調教したんだがなあ。": ""
  },
  "20874": {
    "「ギシャァァァァ！！": ""
  },
  "20875": {
    "「くっ……。これで\u3000すべて倒したか……？": ""
  },
  "20876": {
    "「うーん……。ナンバー１２は\n\u3000バランスが\u3000イマイチだったか。\n\u3000あんな若手の魔法戦士に\u3000負けるようじゃなあ。": ""
  },
  "20877": {
    "「さて\u3000倉庫の掃除をしなきゃな。 \n\u3000汚ねーゴミが\u3000転がってやがる。": ""
  },
  "20878": {
    "<center>魔法戦士たちは\u3000その後も\n死力を尽くして戦った。": ""
  },
  "20879": {
    "<center>だが\u3000いくら倒しても\u3000魔物は次々と現れた。\n多くの魔法戦士が倒れ\nそして\u3000ようやく\u3000戦いは終わった……。": ""
  },
  "20880": {
    "「ぬぬうっ？\u3000なんてこった。 \n\u3000まさか\u3000品切れまで\u3000いっちまうなんてよ。": ""
  },
  "20883": {
    "「<cs_pchero>。任務は失敗だ……。\n\u3000すみやかに\u3000撤退したまえ。": ""
  },
  "20884": {
    "「ノーランは\u3000いたのか？": ""
  },
  "20885": {
    "「……どこにも\u3000おらんかった。": ""
  },
  "20886": {
    "「城の者に聞いたが\u3000ノーランは\n\u3000魔法戦士団が\u3000帰ってくるのを見て\n\u3000青い顔で\u3000外に飛びだしていったそうだ……。": ""
  },
  "20887": {
    "「やはりな。魔物商人ザルギスと結託し\n\u3000我ら魔法戦士団を\u3000おとしいれたこと。\n\u3000もはや\u3000疑いようがない。": ""
  },
  "20888": {
    "「ノーランは\u3000国家反逆人として\u3000指名手配する。\n\u3000かばいだてするなら\u3000そちらも同罪だ。": ""
  },
  "20889": {
    "「衛士団を\u3000みくびるな！\n\u3000ノーランを捕らえるのなら\u3000協力はする。\n\u3000本人から\u3000真実を聞かなければ\u3000納得できん！": ""
  },
  "20890": {
    "「<pc>。今回の任務は\u3000失敗だ……。\n\u3000ゆえに\u3000貴公への報酬も\u3000用意されない。": ""
  },
  "20891": {
    "「だが……。貴公のチカラは\n\u3000これから\u3000さらに必要となるだろう……。": ""
  },
  "20892": {
    "「私から\u3000貴公に\u3000技を託す……。\n\u3000我が魔法戦士団に伝わる\u3000必殺の技だ。": ""
  },
  "20893": {
    "「……この技があれば\n\u3000いざというときに\u3000ＭＰを回復できる。\n\u3000どれほど\u3000回復できるかは……神頼みだがな。": ""
  },
  "20894": {
    "「私が\u3000個人的に\u3000報酬を用意した。\n\u3000受け取ってくれ……。": ""
  },
  "20895": {
    "「ノーランが\u3000なぜ\u3000こんなことをしたか\n\u3000わからないが……。": ""
  },
  "20896": {
    "「我々\u3000魔法戦士団は……ザルギスだけではなく\n\u3000指名手配されたノーランも\u3000追うことになる。": ""
  },
  "20897": {
    "「ふたりの足取りを追うには\u3000時間が必要だ……。\n\u3000貴公は\u3000レベル５０以上の魔法戦士を目指せ。\n\u3000今回のような失敗は……もう許されない。": ""
  },
  "28345": {
    "「しゃあねえ。この辺で\u3000店じまいだ。\n\u3000だいぶ\u3000魔法戦士団を痛めつけてやったし\n\u3000しばらく\u3000商売も\u3000しやすくなるだろ。": ""
  },
  "28346": {
    "「ま……待て……。うっ。": ""
  },
  "28347": {
    "「……おのれ\u3000ノーラン。\n\u3000どういうつもりなのだ……。": ""
  }
}