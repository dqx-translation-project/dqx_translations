{
  "1171": {
    "「おっと\u3000ごめんよ。": ""
  },
  "1172": {
    "「おおっ\u3000賢者マリーンさまじゃ！": ""
  },
  "1173": {
    "「ジャマだよっ！": ""
  },
  "1174": {
    "「ほら\u3000このサイフ。\n\u3000あんたのだろ？": ""
  },
  "1175": {
    "「あっはっはっは！\n\u3000もしかして\u3000気づいてないのかい？": ""
  },
  "1176": {
    "「さっきの男は\u3000スリさ！\n\u3000あんた\u3000スリにあったんだよ！": ""
  },
  "1177": {
    "「見たところ\u3000一人前の証を持ってるようだが……\n\u3000ずいぶん\u3000マヌケな一人前も\u3000いたもんだね。": ""
  },
  "1180": {
    "「あっはっはっはっは！": ""
  },
  "1182": {
    "「よく来てくれた\u3000アロルド！\n\u3000急な呼びだしにも\u3000かかわらず\n\u3000こうして\u3000来てくれたこと\u3000感謝するぞ。": ""
  },
  "1183": {
    "「すでに\u3000聞き及んでいるかもしれぬが\u3000今\n\u3000我が国は\u3000やっかいな問題を\u3000抱えているのだ。": ""
  },
  "1184": {
    "「はい\u3000グロスナー王。\n\u3000ウワサは\u3000道中\u3000耳にいたしました。\n\u3000なんでも\u3000強い者たちが\u3000いなくなるとか？": ""
  },
  "1185": {
    "「さよう。このひと月ほどの間に\n\u3000次々と\u3000強い者たちが\u3000姿を消しておるのじゃ。\n\u3000しかも\u3000まったく突然にな……。": ""
  },
  "1186": {
    "「……おや？\u3000客人かい？": ""
  },
  "1187": {
    "「おお\u3000マリーンどの！\n\u3000ゼラリム姫の\u3000病状は……？": ""
  },
  "1188": {
    "「大丈夫だよ。\n\u3000ちゃんと\u3000快方に向かってる。": ""
  },
  "1189": {
    "「紹介しよう\u3000アロルド。\n\u3000こちらが\u3000あの\u3000いやしの術で名高い\n\u3000賢者マリーンどのだ。": ""
  },
  "1190": {
    "「マリーンどの。\n\u3000アロルドと\u3000その婚約者のマイユさんだ。": ""
  },
  "1191": {
    "「アロルドは\u3000わしの命の恩人でな。\n\u3000強いだけでなく\u3000知恵も勇気もある\n\u3000わしが\u3000いちばん頼りにしている男なのだ。": ""
  },
  "1192": {
    "「……へえ。しかも\u3000男前だね。\n\u3000婚約者が\u3000一緒じゃなかったら\n\u3000あたしが\u3000お近づきになりたいくらいだ。": ""
  },
  "1193": {
    "「……アロルドよ。無理を承知で\u3000頼みたい。\n\u3000行方不明者を\u3000探しだすため\n\u3000そなたのチカラを\u3000貸してくれぬか？": ""
  },
  "1194": {
    "「もちろんです\u3000グロスナー王。\n\u3000そのために\u3000来たのです。": ""
  },
  "1195": {
    "「感謝するぞ。\n\u3000状況は\u3000参謀のマグナスから聞いてくれ。": ""
  },
  "1196": {
    "「アロルドさんが\u3000この国を去って\n\u3000しばらくしてからのことです。": ""
  },
  "1197": {
    "「我が国の勇猛な兵士や\u3000パラディンの精鋭\n\u3000そして\u3000他国より訪れた猛者たちが\n\u3000姿を消すように\u3000なったのです。": ""
  },
  "1198": {
    "「最初に姿を消したのは\u3000グレン城へ\n\u3000我が国からの友好の品を届けた\n\u3000パラディンの輸送団なのですが……。": ""
  },
  "1199": {
    "「その探索に\u3000向かった者たちまでもが\n\u3000次々に姿を消すといった\u3000ありさまでして……。": ""
  },
  "1200": {
    "「なるほど……。": ""
  },
  "1201": {
    "「わからないことばかりですが\n\u3000とにかく\u3000情報を集めるところから\n\u3000やってみましょう。": ""
  },
  "1202": {
    "「お願いします。": ""
  },
  "1203": {
    "「じゃあ\u3000あたしは\u3000いつもの見回りに行くよ。\n\u3000弱い者を助けてやるのが\n\u3000あたしの\u3000生きがいだからね！": ""
  },
  "1204": {
    "「おや\u3000あんたは……。": ""
  },
  "1205": {
    "「今の話\u3000聞いてたのかい？\n\u3000でも\u3000サイフを抜き取られて気づかないような\n\u3000おマヌケさんに\u3000解決できる問題じゃないよ。": ""
  },
  "1206": {
    "「１００万ゴールド\u3000賭けたって\u3000いいね！\n\u3000あっはっはっは！": ""
  },
  "1221": {
    "「おおおっ\u3000すごいな！\n\u3000さすが\u3000ピュージュさんだ！": ""
  },
  "1222": {
    "「あはは\u3000あはは♪": ""
  },
  "1223": {
    "「それじゃ\u3000最後のお楽しみ～！\n\u3000よ～く\u3000見ててね～。": ""
  },
  "1224": {
    "「あ～らよっと。": ""
  },
  "1225": {
    "「あれま\u3000あれま～。": ""
  },
  "1226": {
    "「ふしぎ～\u3000ふしぎ～。\n\u3000お人形ちゃんが\u3000消えちゃった～。": ""
  },
  "1227": {
    "「どうしましょ～\u3000どうしましょ～。\n\u3000どこへ行ったの\u3000お人形ちゃん。\n\u3000ボクの大事な\u3000お人形ちゃん。": ""
  },
  "1228": {
    "「あはは\u3000あはは♪\n\u3000こわくな～い\u3000こわくないよ～。": ""
  },
  "1229": {
    "「さあ\u3000ぼうや。\n\u3000その手を\u3000そっと開いて\u3000見てごらん。": ""
  },
  "1230": {
    "「オオーーーーー！": ""
  },
  "1231": {
    "「お人形ちゃんは\u3000キミが大好きなのさ。\n\u3000キミと\u3000仲良くなりた～いって。": ""
  },
  "1232": {
    "「あはは\u3000あはは♪\n\u3000お友達に\u3000なってあげてね～。\n\u3000約束だよ～。": ""
  },
  "1233": {
    "「さ～て\u3000それじゃ\u3000ボクは帰るね～。": ""
  },
  "1234": {
    "「皆さ～ん。\n\u3000こ～んな\u3000大変な時だけど\n\u3000笑いを忘れちゃ\u3000ダメだよ～。": ""
  },
  "1235": {
    "「あはは\u3000バイバ～イ♪": ""
  },
  "1236": {
    "「ああ\u3000<pc>さん！\n\u3000来てくれたんですね！\n\u3000入れ違いに\u3000ならなくてよかった。": ""
  },
  "1237": {
    "「アロルドが……\u3000アロルドが\n\u3000いなくなってしまったんです！": ""
  },
  "1240": {
    "「黒いモヤが\u3000アロルドを包んで……。\n\u3000私……\u3000何もできなかった……。": ""
  },
  "1242": {
    "「私は\u3000グロスナー王に\n\u3000このことを\u3000報告しにいかなくては。": ""
  },
  "1247": {
    "「なんということだ！\n\u3000アロルドまでが\u3000姿を消したとは……。": ""
  },
  "1250": {
    "「も…申し訳ありません\u3000グロスナー王！\n\u3000私たちは……\u3000グレン城へ\n\u3000大変な品を\u3000届けてしまったようなのです……。": ""
  },
  "1253": {
    "「ヤツは\u3000グレン城に\u3000ニセの贈り物が\n\u3000届けられたのを\u3000見届けてから\n\u3000私たちを\u3000捕らえました……。": ""
  },
  "1254": {
    "「あの女……。\n\u3000白いヴェールで\u3000顔を隠した\u3000あの女……！\n\u3000正体は\u3000おそらく\u3000魔物です……！": ""
  },
  "1255": {
    "「私が囚われていた場所には……\n\u3000まだ仲間たちが\u3000閉じ込められています！\n\u3000グロスナー王よ！\u3000どうか\u3000お助けください！": ""
  },
  "1263": {
    "「いいえっ！\u3000けっこうっ！！\n\u3000通りすがりの賢者の助けなど\n\u3000我が剣の前では\u3000なんの役にも立ちませんっ！": ""
  },
  "1272": {
    "「まったく……！\n\u3000あたしの目を盗んで\u3000１匹\u3000外に逃がすなんて\n\u3000ずいぶん\u3000なめたマネしてくれるわねえ。": ""
  },
  "1273": {
    "「それとも……\u3000あたしに\u3000お仕置きされたくて\n\u3000イケナイことしちゃったのかしら？": ""
  },
  "1274": {
    "「うう……。": ""
  },
  "1275": {
    "「も…もう\u3000許してくれ………。": ""
  },
  "1276": {
    "「くっくっく……。\n\u3000どこかに\u3000あたしを楽しませてくれるような\n\u3000ステキな相手は\u3000いないものかしらねえ？": ""
  },
  "1277": {
    "「この魔瘴石のチカラを……": ""
  },
  "1278": {
    "「存分に\u3000ふるえるような！": ""
  },
  "1279": {
    "「あ～ら\u3000めずらしい。\n\u3000こんな所に\u3000お客さま？": ""
  },
  "1280": {
    "「ようこそ\u3000あたしの店に<heart>\n\u3000あたしの名前は\u3000妖魔ジュリアンテ。": ""
  },
  "1282": {
    "「あなたは\u3000どうかしら……？\n\u3000このジュリアンテさまを\u3000満たせる相手か\n\u3000たっぷり\u3000試して\u3000あ・げ・る<heart>": ""
  },
  "1284": {
    "「あ～ら\u3000いらっしゃい。\n\u3000ようこそ\u3000あたしの店に<heart>\n\u3000きっと\u3000また来てくれると\u3000思ってたわよ。": ""
  },
  "1285": {
    "「さあ\u3000今度は\u3000もっと\n\u3000楽しませて\u3000ちょ・う・だ・い<heart>": ""
  },
  "1286": {
    "「う…\u3000うそでしょ………。": ""
  },
  "1287": {
    "「魔瘴石のチカラを……\u3000使った\u3000あたしが……？": ""
  },
  "1288": {
    "「あぁ……\u3000見つけた……。\n\u3000お前が……\u3000あの………！": ""
  },
  "1289": {
    "「うぅっ……。": ""
  },
  "1290": {
    "「たあーーーーーっ！！": ""
  },
  "1291": {
    "「ふむっ！\u3000今のが\u3000白いヴェールの女の正体か！\n\u3000なかなか\u3000手強い相手であった！": ""
  },
  "1292": {
    "「よし！\u3000グロスナー王に\u3000報告だ！": ""
  },
  "1293": {
    "「<cs_pchero>くんは\n\u3000囚われていた人々の\u3000解放を頼む！": ""
  },
  "1294": {
    "「<cs_pchero>さん！\n\u3000白いヴェールの女を\u3000倒したんですね！": ""
  },
  "1295": {
    "「ありがとうございます。\n\u3000これで\u3000アロルドも……。": ""
  },
  "1296": {
    "「た\u3000助けか……。": ""
  },
  "1297": {
    "「……えっ！？": ""
  },
  "1298": {
    "「……他の人たち？\n\u3000あの女に\u3000捕らえられたのは\u3000オレたち\n\u3000パラディンの\u3000輸送団だけだが……。": ""
  },
  "1299": {
    "「そんな……。": ""
  },
  "1300": {
    "「それじゃあ\u3000アロルドは\u3000どこにいるの……？": ""
  },
  "1303": {
    "「果たして\u3000白いヴェールの女は\n\u3000魔物の正体を現しっ！\u3000この世のものとも思えぬ\n\u3000連続攻撃で\u3000襲いかかってきましたがっ！！": ""
  },
  "1304": {
    "「フッフッフ……。それを\u3000いくどとなく\n\u3000かわして\u3000ついに決めた\u3000トドメの\u3000ひと太刀！\n\u3000グロスナー王にも\u3000見せたかったですなあ！": ""
  },
  "1305": {
    "「そうかそうか！\n\u3000よくやったぞ\u3000スピンドル兵士長！": ""
  },
  "1306": {
    "「して……\u3000囚われていた者たちは\u3000どこに？": ""
  },
  "1307": {
    "「え\u3000ええと……\n\u3000解放は\u3000他の者に\u3000まかせまして……。": ""
  },
  "1308": {
    "「ややっ\u3000戻ったのか\u3000<pc>くん。\n\u3000さあ\u3000グロスナー王に報告を！": ""
  },
  "1309": {
    "「…………ん～？\n\u3000どうも\u3000怪しいねえ。": ""
  },
  "1310": {
    "「スピンドル兵士長……。\n\u3000あんた\u3000本当に\u3000白いヴェールの女を\n\u3000倒したのかい？": ""
  },
  "1311": {
    "「なっ\u3000何を根拠に\u3000そんなことを！\n\u3000そこまで言うのなら\u3000お見せしましょう！\n\u3000この私が\u3000白いヴェールの女を倒した証を！！": ""
  },
  "1312": {
    "「ま\u3000まさか……\n\u3000なぜ\u3000魔瘴石のネックレスが\u3000そこに……？": ""
  },
  "1313": {
    "「えっ？\u3000えっ？\u3000えっ？": ""
  },
  "1314": {
    "「マリーンどの！\u3000これは\u3000どういうことか！": ""
  },
  "1315": {
    "「グレンへの贈り物に\u3000まぎれ込まされた\n\u3000あのネックレスは\u3000そなたが\u3000グレンから回収し\n\u3000封印したはずではなかったのか！？": ""
  },
  "1316": {
    "「……………………。": ""
  },
  "1317": {
    "「……封印？\u3000冗談じゃないね。": ""
  },
  "1318": {
    "「この魔瘴石はねえ\u3000あたしたちのチカラを\n\u3000サイコーに高めてくれる\u3000秘宝なんだ。\n\u3000封印なんて\u3000してたまるかい！": ""
  },
  "1319": {
    "「貴様……\u3000いったい……！？": ""
  },
  "1320": {
    "「あたしは\u3000呪術師マリーン！\n\u3000白いヴェールの女……\u3000ジュリアンテは\n\u3000あたしの\u3000かわいい妹さ！": ""
  },
  "1322": {
    "「あたしは\u3000いくさなんて\u3000どうでもいいのさ！": ""
  },
  "1323": {
    "「あたしたちは\u3000ずっと\u3000探してたんだ。\n\u3000この世界の\u3000どこかにいるという\n\u3000生き返しを受けた者ってヤツをね。": ""
  },
  "1324": {
    "「魔瘴石を使った\u3000ジュリアンテを倒すとは\n\u3000とんでもないチカラじゃないか。\n\u3000ねえ\u3000スピンドル兵士長？": ""
  },
  "1325": {
    "「それほどのチカラを持つ者……\n\u3000あんたこそ\u3000生き返しを受けた者に違いない！\n\u3000今まで\u3000見くびってて\u3000すまなかったねえ！": ""
  },
  "1326": {
    "「わわっ……！": ""
  },
  "1327": {
    "「スピンドル兵士長\u3000い・た・だ・き<heart>": ""
  },
  "1328": {
    "「とうとう\u3000手に入れたよ！\n\u3000これでもう\u3000こんな国に\u3000用はない。": ""
  },
  "1329": {
    "「スピンドルに\u3000何をした！": ""
  },
  "1330": {
    "「くっくっくっ……\u3000老いてもなお\u3000その気迫！\n\u3000たいしたもんだねえ。": ""
  },
  "1331": {
    "「グロスナー！\n\u3000ついでに\u3000あんたも\u3000いただくよっ！": ""
  },
  "1332": {
    "「あの\u3000黒いモヤは……\n\u3000アロルドが消えた時と同じ！": ""
  },
  "1333": {
    "「グロスナー王\u3000い・た・だ・き<heart>": ""
  },
  "1334": {
    "「おや\u3000マイユちゃん。": ""
  },
  "1335": {
    "「その声……。\n\u3000あなただったのね\u3000マリーン！\n\u3000アロルドを\u3000さらったのは！！": ""
  },
  "1336": {
    "「この場で\u3000たたきのめされたくなかったら\n\u3000すぐに\u3000アロルドを返しなさい！": ""
  },
  "1337": {
    "「あっはっはっは！\n\u3000恋する乙女は\u3000威勢が\u3000いいねえ！\n\u3000あたしゃ\u3000そういうの\u3000大好きだよ。": ""
  },
  "1338": {
    "「いいだろう。\n\u3000アロルドに\u3000会わせてやるよ。\n\u3000古代オルセコ闘技場まで\u3000来るんだねっ！": ""
  },
  "1339": {
    "「<pc>さんも\u3000お願いします！\n\u3000一緒に\u3000古代オルセコ闘技場に\u3000来てください！\n\u3000マリーンを倒すために\u3000チカラを貸して！！": ""
  },
  "1342": {
    "「マリーンさま……\u3000バンザイ……。": ""
  },
  "1343": {
    "「この世界は……\u3000うるわしき\n\u3000マリーンさまのもの………。": ""
  },
  "1344": {
    "「あっはっはっは！\u3000いいねえ！": ""
  },
  "1345": {
    "「かたっぱしから集めてきただけあって\n\u3000結構な数に\u3000なったじゃないか。\n\u3000まさに\u3000マリーン軍団と呼ぶに\u3000ふさわしいね！": ""
  },
  "1346": {
    "「特に\u3000アロルドと\u3000ランガーオ村の\n\u3000武闘大会チャンピオン\u3000ジーガンフ。\n\u3000このふたりの強さは\u3000バツグンだね！": ""
  },
  "1347": {
    "「それに\u3000ひきかえ……\n\u3000いまいましいのは\u3000スピンドルのヤツだ。": ""
  },
  "1348": {
    "「あの弱さは\u3000どういうことだい！\n\u3000やっぱり\u3000あんなヤツが\n\u3000生き返しを受けた者のはずが\u3000なかったんだ！": ""
  },
  "1349": {
    "「スピンドルのくせに\u3000あたしを\u3000だましたねっ！": ""
  },
  "1350": {
    "「まあいい……。\n\u3000これだけ\u3000多くの猛者がいるんだ。\n\u3000生き返しを受けた者に\u3000こだわる必要はないさ！": ""
  },
  "1351": {
    "「どんな者が\u3000立ちはだかろうと\n\u3000すべて\u3000ぶっ潰し！\n\u3000あたしが\u3000世界の帝王になってみせるよ！！": ""
  },
  "1352": {
    "「ん……？": ""
  },
  "1353": {
    "「ちぃっ！\n\u3000本当に使えないヤツだね\u3000スピンドルはっ！": ""
  },
  "1354": {
    "「よし！\u3000みんな\u3000戻れっ！\n\u3000休憩にするよっ！！": ""
  },
  "1356": {
    "「おや\u3000あんた……？": ""
  },
  "1357": {
    "「こんな所まで\u3000たどり着くなんて\n\u3000おマヌケさんのわりには\u3000やるじゃないか！": ""
  },
  "1358": {
    "「そういえば\u3000あんたは\n\u3000ジュリアンテが倒された時にも\n\u3000あの場にいたんだったね…………。": ""
  },
  "1359": {
    "「まさか…………\n\u3000ジュリアンテを倒したのは…………": ""
  },
  "1360": {
    "「出てきな\u3000アロルド！\u3000ジーガンフっ！\n\u3000<cs_pchero>を\u3000捕らえるんだっ！": ""
  },
  "1361": {
    "「はい……\u3000マリーンさま………。": ""
  },
  "1362": {
    "「待ちなさいっ！": ""
  },
  "1363": {
    "「はんっ！\u3000今度は誰だいっ！？": ""
  },
  "1364": {
    "「来たわよ\u3000マリーン！\n\u3000罪のない人々を\u3000あやつり人形に変えるなんて\n\u3000許さないっ！": ""
  },
  "1365": {
    "「ふたりとも\u3000目を覚まして！": ""
  },
  "1367": {
    "「<cs_pchero>さん！\n\u3000あのふたりは\u3000私が止めます！": ""
  },
  "1368": {
