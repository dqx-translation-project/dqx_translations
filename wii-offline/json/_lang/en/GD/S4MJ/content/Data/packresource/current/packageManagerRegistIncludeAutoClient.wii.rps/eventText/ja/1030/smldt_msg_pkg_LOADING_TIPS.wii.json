{
  "27461": {
    "<communication>を押すと\nチャットや\u3000ログを\u3000いつでも見られる\nコミュニケーションウィンドウが開きます。": ""
  },
  "27462": {
    "<soft_key>を押すと\nキーボードがなくても\u3000文字が入力できる\nソフトウェアキーボードが使えます。": ""
  },
  "27463": {
    "装備品は\u3000一度装備すると\u3000所有者が確定し\n他のプレイヤーに渡したり\n旅人バザーへの出品が\u3000できなくなります。": ""
  },
  "27464": {
    "バトル中の\u3000他のプレイヤーに\n話しかけて\u3000「おうえん」をすると\n応援された人は\u3000テンションが上がります！": ""
  },
  "27465": {
    "バトル中\u3000敵から逃げたいときは\nとにかく\u3000モンスターから離れて\n白いラインの外まで\u3000走りましょう！": ""
  },
  "27466": {
    "他のプレイヤーと\u3000仲間になると\n一緒に冒険ができます。話しかけて\n「なかまにさそう」で\u3000誘ってみましょう。": ""
  },
  "27467": {
    "<cancel>長押しで\u3000チャットのときに\nよく使うセリフを\u3000コマンドから選べます。": ""
  },
  "27468": {
    "他のプレイヤーと仲間になった時は\nストーリーリーダーのお話が進みます。\n同じ進み具合の人も\u3000一緒に進みます。": ""
  },
  "27469": {
    "他のプレイヤーと\u3000アイテム交換を\nしたいときは\u3000先に相手に断ってから\n「とりひき」を\u3000選びましょう。": ""
  },
  "27470": {
    "職業のレベルは\u3000職業別に持っています。\nなので\u3000転職しても\u3000また元の職業に戻れば\nレベルも\u3000元のレベルに戻ります。": ""
  },
  "27471": {
    "レベルアップで覚えた呪文は\nその職業の時だけ\u3000使えます。\n転職をすると\u3000使えなくなりますよ。": ""
  },
  "27472": {
    "レベルアップの時に\u3000手に入れた\nスキルポイントは\u3000「さくせん」コマンドの\n「スキルふりわけ」から振り分けられます。": ""
  },
  "27473": {
    "スキルで覚えた特技には\u3000どの職業でも\n使える特技と\u3000その職業のときだけ使える\n特別な\u3000（専）特技があります。": ""
  },
  "27474": {
    "武器スキルで覚えた特技は\n転職をしても\u3000同じ武器が使える職業なら\nその特技を\u3000引き継いで使えます。": ""
  },
  "27475": {
    "「さくせん」コマンド「いろいろ設定」から\nボリュームや\u3000視点の調整など\n様々な設定を行えます。": ""
  },
  "27476": {
    "「さくせん」コマンド「いろいろ設定」の\n「アタマ装備表示設定」では\n守備力を変えずに装備を非表示にできます。": ""
  },
  "27477": {
    "「さくせん」コマンド「いろいろ設定」の\n「フリーコメント設定」は他プレイヤーから\n見られるコメントの\u3000編集ができます。": ""
  },
  "27478": {
    "「さくせん」コマンド「いろいろ設定」の\n「いまどんな？設定」を使えば\u3000他の人に\n今どんな状態かを\u3000伝えられます。": ""
  },
  "27479": {
    "「さくせん」コマンド「いろいろ設定」の\n「よく使うセリフ設定」で\u3000よく使うセリフ\nコメントや\u3000しぐさを\u3000変更できます。": ""
  },
  "27480": {
    "チャットの送信相手を\u3000変更するには\nキーボードのCtrl＋カーソルキーか\nTabキーを\u3000押してください。": ""
  },
  "27481": {
    "「きようさ」が上がると\nかいしんのいちげきの確率や\n敵の不意をつく確率が\u3000アップします！": ""
  },
  "27482": {
    "「すばやさ」が上がると\u3000バトルコマンドの\n間隔が短くなり\u3000身をかわす確率もアップ！\n足の速さは\u3000変わりません。": ""
  },
  "27483": {
    "「おしゃれさ」が上がると\n敵が自分に見とれて\n動けなくなる確率が\u3000アップします！": ""
  },
  "27484": {
    "「こうげき魔力」が上がると\n攻撃呪文の効果や\u3000敵を弱体させる呪文の\n成功確率が\u3000アップします！": ""
  },
  "27485": {
    "「かいふく魔力」が上がると\n回復呪文の効果や仲間を生き返らせる呪文の\n成功確率が\u3000アップします！": ""
  },
  "27486": {
    "「おもさ」が上がると\nバトル中に\u3000敵に押されづらくなります！\n足の速さやコマンド間隔は\u3000変わりません。": ""
  },
  "27487": {
    "選んでしまった呪文でも\u3000発動前なら\n<cancel>で\u3000キャンセルできます。\nまちがえた時に\u3000使ってみましょう。": ""
  },
  "27488": {
    "両手杖やスティックで敵を攻撃すると\nダメージに応じて\u3000ＭＰを吸収します。\nＭＰが減ってきたら\u3000攻撃に転じましょう。": ""
  },
  "27489": {
    "フィールドに置いてある青い宝箱は\nいつも同じ場所にあるとは限りません。\n見つけたら\u3000ラッキーです！": ""
  },
  "27490": {
    "世界を\u3000隅々まで歩いてみましょう。\nキラキラ光る場所や\u3000宝箱から\u3000\n色々なアイテムを\u3000ゲットできますよ！": ""
  },
  "27491": {
    "町の酒場で\u3000「自分をとうろく」して\nゲームを中断すると\u3000誰かに\u3000やとわれて\n経験値やゴールドを\u3000稼いでくれるかも？": ""
  },
  "27492": {
    "町の酒場では\u3000サポート仲間という\nＡＩで一緒に戦ってくれる\n頼もしい仲間を\u3000紹介してもらえます。": ""
  },
  "27493": {
    "サポート仲間は\u3000「さくせん」コマンドの\n「サポートなかま」からバトルに参加しない\n待機中状態に\u3000変更できます。": ""
  },
  "27494": {
    "自分が\u3000誰かのサポート仲間となっても\n持ち物を勝手に使われたり\n装備品を盗られることは\u3000絶対ありません！": ""
  },
  "27495": {
    "自分の部屋のベッドで眠ると\nＨＰとＭＰが\u3000完全に回復します。\n疲れた時は\u3000無理せず\u3000休みましょう。": ""
  },
  "27496": {
    "町の宿屋に泊まると\nＨＰとＭＰが\u3000完全に回復します。\n疲れた時は\u3000無理せず\u3000休みましょう。": ""
  },
  "27497": {
    "教会で\u3000お祈りすることで\u3000冒険の書に\n旅の記録（セーブ）ができます。\n無理せず\u3000こまめに\u3000お祈りしましょう。": ""
  },
  "27498": {
    "教会では\u3000全滅時の復活場所の設定や\nルーラストーンの記憶\u3000呪いをとく\n毒のちりょうなど\u3000様々なことができます。": ""
  },
  "27499": {
    "オンラインの世界では\n冒険の書への記録は\u3000自動的に行われます。\n教会での記録は\u3000必要ありません。": ""
  },
  "27500": {
    "オンラインの世界では「さくせん」コマンド\n「冒険を中断する」から\u3000中断ができます。\n敵がいる場所では\u3000少し時間がかかります。": ""
  },
  "27501": {
    "預かり所では\u3000アイテムやゴールドを\n無料で\u3000預かってもらえます。\n旅立つ前は\u3000立ち寄るのを忘れずに！": ""
  },
  "27502": {
    "人が多くて\u3000話したい人と\u3000なかなか\n話せない時は\u3000「はなす」コマンドを使えば\nリストから\u3000話す相手を選べて便利です。": ""
  },
  "27503": {
    "町の中では\u3000本棚も忘れずにチェックを！\n思いもよらない\u3000大切な情報を\nゲットできることが\u3000ありますよ。": ""
  },
  "27504": {
    "職人になって\u3000武器や防具を生産すると\nそれらを\u3000誰かに装備してもらうことで\n職人としての評判が\u3000アップします。": ""
  },
  "27505": {
    "装備品の名前についている\n「＋１」や「＋２」は\u3000その装備品に\n付けられた\u3000錬金効果の数です。": ""
  },
  "27506": {
    "旅人バザーでは\u3000自分が売りたいアイテムを\n出品したり\u3000他のプレイヤーが出品した\nアイテムを\u3000買うことができます！": ""
  },
  "27507": {
    "旅のコンシェルジュは\u3000冒険者たちの\n強い味方。お得情報が\u3000盛りだくさんなので\n宿屋にいる案内係に\u3000話しかけてください。": ""
  },
  "27508": {
    "チームに入ると\u3000同じチームのメンバーと\n専用のチャットルームを持てます。\nオリジナルエンブレムも\u3000作れますよ！": ""
  },
  "27509": {
    "郵便局では\u3000手紙や荷物を送ったり\n受け取ったりすることが\u3000できます。\n便せん屋さんも\u3000ありますよ。": ""
  },
  "27510": {
    "ストーリーを進めるヒントがほしいときは\n名前がピンク色のキャラと\u3000話しましょう。\n大切な情報を\u3000教えてくれますよ。": ""
  },
  "27511": {
    "やることを忘れてしまったときは\n「せんれき」の「これまでのおはなし」を。\nこれまでのストーリーが\u3000わかります。": ""
  },
  "27512": {
    "新しい町に着いたら\u3000まず最初に\n復活場所や\u3000ルーラストーンの飛び先を\nその町にするべきか\u3000検討しましょう。": ""
  },
  "27513": {
    "一度クリアした\u3000クエストでも\nクエストリストでリプレイ可能状態にすれば\nもう一度\u3000受けることができます。": ""
  },
  "27514": {
    "クエストの進み具合を確認するときは\n「せんれき」コマンド「クエストリスト」。\n次に何をするのかも\u3000ばっちりわかります。": ""
  },
  "27515": {
    "名前の色が\u3000紫色のキャラは\nあなたに\u3000何かを\u3000頼みたがっている人。\n話しかけて\u3000頼みを聞いてみましょう。": ""
  },
  "27516": {
    "「武器鍛冶職人」になると\n剣やオノ\u3000ヤリ\u3000ハンマーなどの\n金属製の武器を\u3000作ることができます。": ""
  },
  "27517": {
    "「防具鍛冶職人」になると\n盾や\u3000よろいなど\n金属製の防具を\u3000作ることができます。": ""
  },
  "27518": {
    "「道具鍛冶職人」になると\nさまざまな職人たちが使う\n職人道具を\u3000作ることができます。": ""
  },
  "27519": {
    "「木工職人」になると\u3000弓や杖\nスティックなどの\u3000木製のアイテムが作れ\nいずれは\u3000家具も作れるようになれます。": ""
  },
  "27520": {
    "「さいほう職人」になると\n服や\u3000ぼうし\u3000クツなどの\n布製の防具を\u3000作ることができます。": ""
  },
  "27521": {
    "「ランプ錬金職人」になると\n魔法系の\u3000錬金効果をつけて\n装備品を強化することができます。": ""
  },
  "27522": {
    "「ツボ錬金職人」になると\n物理系の\u3000錬金効果をつけて\n装備品を強化することができます。": ""
  },
  "27523": {
    "名声値は\u3000サポート仲間としてやとわれたり\nクエストクリアしたり\u3000長く倒されていない\nモンスターを倒した時にも\u3000上がります。": ""
  },
  "27524": {
    "名声レベルは\u3000名声値がたまってから\n宿屋に泊まると\u3000レベルアップします。\n名声値がたまったら\u3000宿屋に行きましょう。": ""
  },
  "27525": {
    "手に入れた武器や防具は\n持ってるだけでは\u3000なんにもなりません。\n「そうび」コマンドで\u3000身につけましょう。": ""
  },
  "27526": {
    "町の外で\u3000柵を見つけたら\nその向こうに\u3000強敵がいるかもしれません。\n進む時には\u3000注意しましょう！": ""
  },
  "27527": {
    "<autorun>を押すと\u3000オートラン。\n自動的に\u3000まっすぐ走り続けます。\n敵に当たらないように\u3000注意しましょう。": ""
  },
  "27528": {
    "<jump>で\u3000その場でジャンプ！\n走りながらも使えるので\n気分が向いたら\u3000ジャンプジャンプ！": ""
  },
  "27529": {
    "仲間のキャラに話しかけて\n「ついていく」を選ぶと\u3000そのキャラに\n自動で\u3000ついていくようになります。": ""
  },
  "27530": {
    "チャットは\u3000移動中でもできるので\nオートランや\u3000ついていくを使いながら\n移動中も\u3000チャットを楽しんでみましょう。": ""
  },
  "27531": {
    "「せんれき」の「討伐モンスターリスト」\nモンスターが表示されてる時\u3000<convenience>で\nいろいろな動きを\u3000見せてくれますよ。": ""
  },
  "27532": {
    "無理に強い敵と戦うよりも\nじつは\u3000楽に勝てる相手と\u3000たくさん\n戦った方が\u3000レベルアップの近道かも？": ""
  },
  "27533": {
    "防具は\u3000同じシリーズをそろえると\n特別なセット効果がつきますよ。\n「つよさ」で\u3000確認してみましょう。": ""
  },
  "27534": {
    "冒険者なら\u3000深追いしすぎない勇気も必要。\n敵が強いなと感じたら\u3000ひとつ前の\nエリアに戻って\u3000レベル上げしましょう。": ""
  },
  "27535": {
    "全滅し復活場所に戻る際\u3000ＬＶ１０以上だと\nゴールドをすこし失います。お金がなければ\n失わないので\u3000預かり所を活用しましょう。": ""
  },
  "27536": {
    "時々ドラキーがメッセージを運んできます。\n返事が必要な時は\u3000<menu>のメニューから\n「へんじをする」を\u3000選んでください。": ""
  },
  "27537": {
    "同じ場所にいても\u3000サーバーが違うと\n会うことができません。友達と会うときは\n同じサーバーに\u3000集まりましょう。": ""
  },
  "27538": {
    "バトルのコマンドを選んでいる間も\n次のコマンドまでの\u3000時間は進んでいます。\nあんまり\u3000あわてなくても\u3000大丈夫です。": ""
  },
  "27539": {
    "他の人がパーティ（仲間）を組んでいるかは\n話しかけた時の\u3000ピンの数でわかります。\n青はプレイヤー。水色はサポート仲間です。": ""
  },
  "27540": {
    "頭上の名前に\u3000緑色のアイコンがある人は\n一緒に戦う仲間を探している人です。自分も\n仲間がほしい時は\u3000声をかけてみましょう。": ""
  },
  "27541": {
    "一緒に冒険をする仲間がほしい時は\n「さくせん」コマンド「いろいろ設定」の\n「いまどんな？設定」を\u3000仲間募集中に！": ""
  },
  "27542": {
    "他のプレイヤーと仲間になると\n誘われた方が\u3000連れていたサポート仲間は\n自動的に\u3000待機中状態になります。": ""
  },
  "27543": {
    "サポート仲間がいると「さくせん」コマンド\n「サポートなかま」から作戦を選べます。\n強敵と戦う時は\u3000いろいろ試しましょう。": ""
  },
  "27544": {
    "<map>で\u3000地図が見られます。\n地図メニューを開けば\u3000キャラの居場所や\n施設の場所もわかって\u3000便利です！": ""
  },
  "27545": {
    "バトル勝利後\u3000モンスターが落とした宝箱は\n仲間全員が\u3000同じものを入手できます！\n遠慮せずに\u3000いただいてください！": ""
  },
  "27546": {
    "ゲームと連動した\u3000プレイヤー専用サイト\n『目覚めし冒険者の広場』ご利用ください！\nGO! ⇒ http://hiroba.dqx.jp": ""
  },
  "27547": {
    "手に入れた\u3000ちいさなメダルの所持数は\n「つよさ」から\u3000「ぜんいん」に\nカーソルを合わせると\u3000見られます。": ""
  },
  "27548": {
    "仲間がいるときには\u3000仲間の持っている\nルーラストーンも\u3000使うことができます！\nただし行ったことがない所には行けません。": ""
  },
  "27549": {
    "バトル中に\u3000怒ったモンスターは\n怒った相手を\u3000集中して攻撃します。\n狙われている仲間を\u3000守りましょう！": ""
  },
  "27550": {
    "<camera_reset>で\n画面の視点の位置が\u3000すぐに\nキャラの後ろに移動します。": ""
  },
  "27551": {
    "チャットでの言葉づかいには\u3000ご注意を。\n乱暴な言葉で\u3000相手の人を\u3000キズつけたり\nいやな気持ちに\u3000させてしまわないように。": ""
  },
  "27552": {
    "フレンドに誘ったり\u3000取り引きを\nもちかけるときは\u3000相手に話しかけて\n先に\u3000ＯＫを\u3000もらってからにしましょう。": ""
  },
  "27553": {
    "「さくせん」コマンド「いろいろ設定」の\n「ログイン非通知設定」で\u3000フレンドに\n自分のログイン状況を知られなくできます。": ""
  },
  "27554": {
    "【便利な機能】": ""
  },
  "27555": {
    "【冒険者の知識】": ""
  },
  "27556": {
    "【バトルの知識】": ""
  },
  "27557": {
    "【成長に関する知識】": ""
  },
  "27558": {
    "【パラメータの知識】": ""
  },
  "27559": {
    "【施設の紹介】": ""
  },
  "27560": {
    "【冒険者の基礎知識】": ""
  },
  "27561": {
    "【職人の紹介】": ""
  },
  "27562": {
    "【便利な機能？】": ""
  },
  "27563": {
    "【オンラインのマナー】": ""
  },
  "27662": {
    "そうびコマンドの操作中\n<jump>で\u3000キャラを拡大できます。\n大きく見たい時に\u3000使ってみましょう。": ""
  },
  "27663": {
    "アクセサリーは\u3000他のプレイヤーに渡したり\n旅人バザーへの出品は\u3000できません！\nがんばって\u3000自力で手に入れましょう。": ""
  },
  "27697": {
    "ソフトウェアキーボードは\n同じ方向を\u3000押し続けると\u3000各行の\n先頭文字の所で\u3000一瞬\u3000止まります。": ""
  },
  "27857": {
    "本名や住所や\u3000電話番号などの個人情報は\nたとえ\u3000相手が知っている人でも\u3000絶対に\nゲーム内で\u3000教えないようにしましょう。": ""
  },
  "28200": {
    "<shasinki>で\u3000写真が撮れます！\n撮った写真は\u3000せんれきの思い出アルバムか\nプレイヤー専用サイトで\u3000見られます。": ""
  },
  "28201": {
    "お金かせぎの近道は\u3000手に入れたアイテムを\nどんどん\u3000お店に売ること！\n旅人バザーなら\u3000お店より高く売れるかも！": ""
  }
}