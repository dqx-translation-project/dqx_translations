{
  "16094": {
    "「……む？\n\u3000そこにいるのは\u3000<pc>ではないか。": ""
  },
  "16095": {
    "「……ふむ。ここは\u3000ひとつ\n\u3000<pc>に\u3000頼むとしよう。\n\u3000それでよいな\u3000スピンドル？": ""
  },
  "16096": {
    "「陛下の思し召しのままに……。\n\u3000それでは\u3000私は\u3000負傷兵たちの様子を\n\u3000見てくるとしましょう。": ""
  },
  "16097": {
    "「よく来てくれた\u3000<pc>。\n\u3000じつは\u3000ちょっとした問題が起こっていてな。\n\u3000お前さんに\u3000頼みたいことがあるのだ。": ""
  },
  "16098": {
    "「マグナスよ。\n\u3000くわしい説明を\u3000してやってくれ。": ""
  },
  "16099": {
    "「<pc>さんは\u3000ガズバランの牙のことを\n\u3000ご存知でしたな。先日の魔物狩りの際に\n\u3000王を狙った\u3000不届きな秘密結社のことです。": ""
  },
  "16100": {
    "「私は\u3000あれから\u3000連中のアジトを調べだし\n\u3000一網打尽に\u3000捕らえるべく\u3000その洞くつに\n\u3000精鋭部隊の一団を\u3000送り込んだのです。": ""
  },
  "16101": {
    "「しかし\u3000兵士たちが\u3000踏み込んでも\n\u3000洞くつ内に\u3000ヤツらの姿はなく\n\u3000代わりに\u3000多数の魔物に\u3000襲われたのです。": ""
  },
  "16102": {
    "「こちらの不意打ちのはずが\u3000ガズバランの牙は\n\u3000知っていたかのように\u3000ワナを張っていました。\n\u3000完全に\u3000してやられたのです。": ""
  },
  "16103": {
    "「思いがけない襲撃に\u3000兵士たちは\u3000総崩れ。\n\u3000ほとんどの兵士は\u3000なんとか\u3000脱出しましたが\n\u3000今も\u3000２名の兵士が\u3000取り残されています。": ""
  },
  "16104": {
    "「すぐにも\u3000彼らの救出に向かいたいのですが\n\u3000我が軍が受けたダメージも\u3000深刻でして\n\u3000助けにいこうにも……という状況なのです。": ""
  },
  "16105": {
    "「そこでだ\u3000<pc>よ。\n\u3000お前さんに\u3000この２名の兵士の救出を\n\u3000頼みたいというわけじゃ。": ""
  },
  "16106": {
    "「ガズバランの牙のアジトは\u3000グレン領西の\n\u3000南西にある\u3000グレゴールの洞くつじゃ。\n\u3000どうか\u3000引き受けてはくれまいか？": ""
  },
  "16107": {
    "「さすがは\u3000<pc>じゃ。\n\u3000お前さんなら\u3000引き受けてくれると\n\u3000信じていたぞ！": ""
  },
  "16108": {
    "「取り残された兵士たちは\u3000今も\n\u3000暗い洞くつで\u3000助けを待っているはず。\n\u3000一刻も早く\u3000救出してやってくれ。": ""
  },
  "16109": {
    "「さすがは\u3000<pc>。\n\u3000……と言いたいところだが\u3000どうやら\n\u3000お前さん\u3000予定が\u3000いっぱいのようじゃな。": ""
  },
  "16110": {
    "「２名の兵士の命が\u3000かかっておるのじゃ！\n\u3000できるだけ早く\u3000頼まれごとを片付けて\n\u3000また\u3000ここに来てくれよ！": ""
  },
  "16111": {
    "「<pc>ともあろう者の言葉とは\n\u3000とても\u3000思えんな。": ""
  },
  "16112": {
    "「おくびょう風に吹かれるとは……\n\u3000呪術師マリーンを倒した\u3000あの勇敢な若者は\n\u3000どこへ\u3000行ってしまったのじゃろうか？": ""
  },
  "16113": {
    "「た……助けが\u3000来たのか？": ""
  },
  "16114": {
    "「あ…あなたは……！？\n\u3000この間の……\u3000マリーン事件を解決した\n\u3000ガートラントの英雄\u3000<pc>さん！": ""
  },
  "16115": {
    "「さすがは……グロスナー王。\n\u3000最高の助っ人を……送ってくれたワケだ。": ""
  },
  "16116": {
    "「……<pc>さん。\n\u3000よかったら\u3000どくけしそうと\u3000まんげつそうを\n\u3000ゆずっていただけないだろうか？": ""
  },
  "16117": {
    "「私は\u3000毒に冒されて\u3000これ以上\u3000歩けないし\n\u3000ジブラは\u3000身体がマヒして……動けないのです。": ""
  },
  "16118": {
    "兵士たちに\u3000どくけしそうと\u3000\nまんげつそうを\u3000渡しますか？<yesno><close>": ""
  },
  "16119": {
    "「助けにきてもらって……悪いが\n\u3000オレたち\u3000このままじゃ動くことも\n\u3000ままならないんだ……。": ""
  },
  "16120": {
    "「もし\u3000持ってないなら\u3000両方そろえてから\n\u3000もう１回\u3000ここまで\u3000来てくれよ。": ""
  },
  "16121": {
    "<pc>は\u3000兵士たちに\nどくけしそうと\u3000まんげつそうを\u3000渡した！": ""
  },
  "16122": {
    "「おお……\u3000ありがてえ！": ""
  },
  "16123": {
    "「毒さえ……抜けてくれれば……。": ""
  },
  "16124": {
    "デオルドは\u3000どくけしそうを使い\nジブラは\u3000まんげつそうを使って\u3000回復した！": ""
  },
  "16125": {
    "「ああ。すっかり\u3000回復したぜ！\n\u3000これなら\u3000あとは\u3000自力で脱出できそうだ。": ""
  },
  "16126": {
    "「ありがとうございます\u3000<pc>さん。\n\u3000私たちは\u3000もう\u3000大丈夫です！": ""
  },
  "16127": {
    "「ガートラント城までは\u3000ふたりで戻れますので\n\u3000<pc>さんも\u3000お気をつけて。\n\u3000それでは\u3000お先に失礼しますね！": ""
  },
  "16128": {
    "<pc>は\u3000どくけしそうしか\n持っていなかった。": ""
  },
  "16129": {
    "「そう……か。相棒とは\u3000ここまで\n\u3000はげまし合いながら\u3000やってきたんだ……。\n\u3000一方だけが\u3000助かるつもりはねえ。": ""
  },
  "16130": {
    "「悪いが\u3000両方そろえてから\n\u3000もう１回\u3000ここまで\u3000来てくれよ。": ""
  },
  "16131": {
    "<pc>は\u3000どくけしそうも\nまんげつそうも\u3000持っていなかった。": ""
  },
  "16132": {
    "「助けにきてもらって……悪いが\n\u3000オレたち\u3000このままじゃ動くことも\n\u3000ままならないんだよ……。": ""
  },
  "16133": {
    "「どくけしそうと\u3000まんげつそうを\n\u3000両方そろえてから\n\u3000もう１回\u3000ここまで\u3000来てくれ。": ""
  },
  "16134": {
    "「よお……あんたか。\n\u3000生きてるうちに\u3000また会えて\u3000うれしいぜ。": ""
  },
  "16135": {
    "「……<pc>さん。どくけしそうと\n\u3000まんげつそうは……\u3000手に入りましたか？": ""
  },
  "16136": {
    "「おお\u3000帰ったか\u3000<pc>！\n\u3000今\u3000ちょうど\u3000ジブラと\u3000デオルドから\n\u3000報告を受けていたところだ。": ""
  },
  "16137": {
    "「我々が\u3000こうして無事\u3000帰ってこれたのは\n\u3000すべて\u3000<pc>さんのおかげです。": ""
  },
  "16138": {
    "「無事の帰還\u3000なによりであった。\n\u3000下がってよいぞ\u3000ジブラ。デオルド。": ""
  },
  "16139": {
    "「ハッ！！": ""
  },
  "16140": {
    "「ふたりには\u3000充分な休養を\u3000とらせましょう。": ""
  },
  "16141": {
    "「よくやってくれた\u3000<pc>。\n\u3000お前のおかげで\u3000貴重な兵士たちの命が\n\u3000失われずに\u3000すんだのだ。": ""
  },
  "16142": {
    "「ガートラントの王として\u3000礼を言おう。\n\u3000それと\u3000ほうびもな……。\n\u3000さあ\u3000これを\u3000受け取ってくれ！": ""
  },
  "16143": {
    "「兵士たちが\u3000助かったのは\u3000めでたいが……\n\u3000これで\u3000問題が\u3000片付いたわけではない。\n\u3000今後の対策を\u3000考えねばならんの。": ""
  },
  "16144": {
    "「ガズバランの牙……ですな。\n\u3000ヤツら\u3000どうやって\u3000こちらの作戦を\n\u3000知り得たのか……？": ""
  },
  "16145": {
    "「今回のことで\u3000ガズバランの牙という組織が\n\u3000油断ならぬ相手であることが\u3000よくわかった。\n\u3000……だが\u3000ヤツらは\u3000ひとつのミスを犯した。": ""
  },
  "16146": {
    "「それは\u3000このガートラント国王\u3000グロスナーを\n\u3000本気にさせたことだ！": ""
  },
  "16147": {
    "「……わしは\u3000決して\u3000ヤツらを許さぬ。\n\u3000これは\u3000わしと\u3000ガズバランの牙との戦争だ！": ""
  },
  "44975": {
    "<pc>は\u3000まんげつそうしか\n持っていなかった。": ""
  }
}