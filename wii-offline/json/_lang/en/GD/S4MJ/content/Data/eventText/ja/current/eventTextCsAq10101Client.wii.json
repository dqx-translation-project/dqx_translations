{
  "15459": {
    "「そ\u3000村王……！\u3000お戻りか！？": ""
  },
  "15460": {
    "「いや\u3000<pc>だったか……。\n\u3000おどろかせて\u3000すまなかった。\n\u3000だが\u3000いいところに来てくれたな。": ""
  },
  "15461": {
    "「じつは\u3000村王クリフゲーンさまが\n\u3000帰りの遅い村人を探しに\n\u3000雪山に行ったまま\u3000戻ってこないのだ。": ""
  },
  "15462": {
    "「ちがったか……。お前は\u3000旅の者だな。\n\u3000ふむ。<pc>というのか。": ""
  },
  "15463": {
    "「じつは\u3000このランガーオ村の村王である\n\u3000クリフゲーンさまが\u3000帰りの遅い村人を探しに\n\u3000雪山に行ったまま\u3000戻ってこないのだ。": ""
  },
  "15464": {
    "「村王は\u3000お父さんを\u3000探しにいったの！": ""
  },
  "15465": {
    "「お父さんが帰ってこないのって\u3000私が言ったら\n\u3000すぐに連れ戻してくるから\u3000お前は\n\u3000心配しないで待ってろ\u3000ガハハって……。": ""
  },
  "15466": {
    "「村の者が\u3000雪山から戻らないときに\n\u3000村王が捜索に行くのは\u3000よくあることだが\n\u3000これほど帰りが遅いのは\u3000はじめてなのだ。": ""
  },
  "15467": {
    "「考えたくはないが……\u3000村王の身に\n\u3000何か\u3000あったのかもしれん。すまないが\n\u3000村王を探しに\u3000雪山に行ってくれないか！？": ""
  },
  "15468": {
    "「おおっ\u3000本当か！\u3000恩に着るぞ！": ""
  },
  "15469": {
    "「お父さんは\u3000今日は\n\u3000ラギ雪原の方に行くって\u3000言ってました。\n\u3000町で売れる素材を\u3000採るんだって……。": ""
  },
  "15470": {
    "「村王にも\u3000そう伝えたから\n\u3000そっちの方に行けば\n\u3000きっと\u3000ふたりに\u3000会えるはずです！": ""
  },
  "15471": {
    "「ラギ雪原は\u3000ランガーオ山地の東端から\n\u3000北へ抜けた所にある\u3000厳しい雪原だ。\n\u3000そこへ行くなら\u3000これを持っていってくれ。": ""
  },
  "15472": {
    "<pc>は\nヌーク草（だいじなもの）を\u3000手に入れた！<me_60>": ""
  },
  "15473": {
    "「それは\u3000雪山で体力をうばわれぬよう\n\u3000身体を\u3000あたためるための\u3000薬草の一種だ。": ""
  },
  "15474": {
    "「もしも\u3000村王や\u3000フウミの父親が\n\u3000寒さで弱っていたら\u3000それを食べさせてくれ。\n\u3000よろしく頼んだぞ。": ""
  },
  "15475": {
    "「<pc>さん！\u3000お父さんと\n\u3000村王のことを\u3000よろしくお願いします！": ""
  },
  "15476": {
    "「おおっ\u3000恩に着るぞ……と言いたいところだが\n\u3000どうやら\u3000今は\u3000頼まれごとが\n\u3000いっぱいのようだな……。": ""
  },
  "15477": {
    "「無理強いはできんが\u3000こちらも急を要する。\n\u3000できるなら\u3000手を空けてきて\n\u3000私の頼みを\u3000聞いてほしいところだ。": ""
  },
  "15478": {
    "「そ\u3000そうか……。\n\u3000こうなったら\u3000村王が\u3000無事に戻られることを\n\u3000天に祈るよりほかにないな……。": ""
  },
  "15479": {
    "「おお\u3000<pc>よ……。\n\u3000また来てくれたのだな。": ""
  },
  "15480": {
    "「もう一度\u3000頼もう。\n\u3000村王が\u3000帰りの遅い村人を探しに\n\u3000雪山に行ったまま\u3000戻ってこないのだ。": ""
  },
  "15481": {
    "「村の者が\u3000雪山から戻らないときに\n\u3000村王が捜索に行くのは\u3000よくあることだが\n\u3000これほど帰りが遅いのは\u3000はじめてなのだ。": ""
  },
  "15482": {
    "「考えたくはないが……\u3000村王の身に\n\u3000何か\u3000あったのかもしれん。すまないが\n\u3000村王を探しに\u3000雪山に行ってくれないか！？": ""
  },
  "15483": {
    "「おお\u3000<pc>！\n\u3000村王と\u3000フウミの父親は\u3000見つかったのか！？": ""
  },
  "15484": {
    "「そうか。まだか……。\n\u3000いや\u3000急かして\u3000すまない。": ""
  },
  "15485": {
    "「村王と\u3000フウミの父親は\n\u3000ラギ雪原の方に\u3000向かったと思われる。\n\u3000そちらを\u3000重点的に探してみてくれ。": ""
  },
  "15486": {
    "「頼りは\u3000お前だけなのだ。\n\u3000よろしく頼むぞ。": ""
  },
  "15487": {
    "「<pc>さん！\u3000お父さんと\n\u3000村王のことを\u3000よろしくお願いします！": ""
  },
  "15488": {
    "「お…お前は……。": ""
  },
  "15489": {
    "「<pc>……？\u3000まさか\u3000わしは\n\u3000幻覚を\u3000見ているんじゃないだろうな……。": ""
  },
  "15490": {
    "「わしを\u3000助けにきたのか……。": ""
  },
  "15491": {
    "「……目を覚ませ\u3000クーガ。\n\u3000どうやら\u3000神さまは\u3000まだ\n\u3000わしらを\u3000死なせてくれんらしいぞ。": ""
  },
  "15492": {
    "「いかんな……。寒さで\u3000意識を\n\u3000失ってしまっている。何か\u3000身体を\n\u3000あたためる物が\u3000あればよいのだが……。": ""
  },
  "15493": {
    "村王クリフゲーンに\nヌーク草を\u3000渡しますか？<yesno><close>": ""
  },
  "15494": {
    "「お前は\u3000村から来たのだろう？\n\u3000だったら\u3000ランガーオ村の者から\n\u3000何か\u3000あずかっては\u3000いないか？": ""
  },
  "15495": {
    "<pc>は\u3000村王クリフゲーンに\nヌーク草を\u3000渡した。": ""
  },
  "15496": {
    "「おお\u3000ヌーク草を持ってきてくれたか！\n\u3000よし！\u3000これさえあれば！": ""
  },
  "15497": {
    "「さあ\u3000クーガ。\n\u3000これを\u3000食べるんだ。": ""
  },
  "15498": {
    "「……………………。": ""
  },
  "15499": {
    "「うっはあああああ～～～～っ！！": ""
  },
  "15500": {
    "「さすが\u3000効果絶大だな。\n\u3000よし\u3000わしも\u3000ひとクチいただこう。": ""
  },
  "15501": {
    "「いやあ\u3000ありがとうございました。\n\u3000おかげで\u3000血が沸き立つくらい\n\u3000全身ポカポカです。これなら\u3000村まで帰れます！": ""
  },
  "15502": {
    "「村王も\u3000ありがとうございました。\n\u3000もし\u3000村王が岩陰に運んでくれなかったら\n\u3000今頃\u3000凍え死んでいたかもしれません……。": ""
  },
  "15503": {
    "「ガハハ！\u3000わしに\u3000礼はいらん！\n\u3000わしも\u3000寒さに体力をうばわれて\n\u3000ここまで運ぶのが\u3000精一杯だったのだ。": ""
  },
  "15504": {
    "「ヌーク草も持たずに\u3000雪山に来るとは\n\u3000わしも\u3000うかつだったわ。\n\u3000いや\u3000それより……": ""
  },
  "15505": {
    "「この\u3000わしが\u3000雪山で動けなくなる日が\n\u3000来るとはな……。": ""
  },
  "15506": {
    "「いやいや。そんなこと言ってる場合ではない。\n\u3000ヌーク草の\u3000効果が切れる前に\n\u3000わしらも\u3000村に戻るとしよう！": ""
  },
  "15507": {
    "「ガハハ！\u3000<pc>よ！\n\u3000お前には\u3000礼をせねばな！\n\u3000村に戻ったら\u3000わしの家まで来てくれ！": ""
  },
  "15508": {
    "「おっ\u3000<pc>\u3000戻ったか！\n\u3000ガハハ！\u3000待っていたぞ！": ""
  },
  "15509": {
    "「お前が\u3000村に来てくれて\u3000助かった！\n\u3000もし\u3000お前が\u3000いなかったらと思うと\n\u3000ぞっとするぞ！\u3000ガハハハ！": ""
  },
  "15510": {
    "「<pc>さん\u3000ありがとうございました。\n\u3000おかげで\u3000お父さんも\u3000村王も\n\u3000無事に\u3000帰ってきてくれました。": ""
  },
  "15511": {
    "「採取の帰りに\u3000急に吹雪が強くなりまして……。\n\u3000雪山には\u3000慣れているつもりだったのですが\n\u3000まったく\u3000面目ありません。": ""
  },
  "15512": {
    "「まあ\u3000みんな無事で\u3000なによりだ！\n\u3000そうだ\u3000ギュラン。忘れないうちに\n\u3000あれを\u3000<pc>に\u3000渡してくれ。": ""
  },
  "15513": {
    "「これは\u3000私と村王からの\u3000心ばかりの\u3000お礼だ。\n\u3000受け取ってくれ。": ""
  },
  "15514": {
    "「では\u3000私たちは\u3000これで。": ""
  },
  "15515": {
    "「<pc>さん！\n\u3000今度\u3000うちにも\u3000遊びにきてくださいね！": ""
  },
  "15516": {
    "「今\u3000この村の\u3000若くて強い連中は\n\u3000みんな\u3000修行の旅に出ている。その間くらいは\n\u3000しっかり\u3000村を守ろうと思ったのだが……": ""
  },
  "15517": {
    "「……わしも\u3000トシをとったということか。\n\u3000どうやら\u3000もう\u3000若い頃と\n\u3000同じようには\u3000いかんようだ……。": ""
  },
  "15518": {
    "「そういえば\u3000村王。\n\u3000村王が\u3000村を離れられている間に\n\u3000こんな手紙が\u3000届いておりましたぞ。": ""
  },
  "15519": {
    "「おお。わしにか？\n\u3000わしに手紙など\u3000めずらしいな。": ""
  },
  "15520": {
    "「そうか。あいつが\u3000来るか……。": ""
  },
  "15521": {
    "「きっと……\u3000強くなったのだろうな。": ""
  }
}