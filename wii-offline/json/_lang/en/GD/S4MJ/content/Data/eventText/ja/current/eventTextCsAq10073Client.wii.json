{
  "18991": {
    "「では\u3000これより２次予選を始める。\n\u3000参加するのは\u3000海で漂流してる時でも\n\u3000ボケまくる\u3000愛すべきバカの３組じゃ！": ""
  },
  "18992": {
    "「このうち\u3000面白かった２組が\n\u3000決勝戦に進出とする！\n\u3000２次予選の\u3000お題は……。": ""
  },
  "18993": {
    "「この黄金の像から\u3000イメージして\n\u3000何か\u3000面白いことをする！\u3000じゃ！": ""
  },
  "18994": {
    "「ウオオオオーーーッ！！\n\u3000２次予選も\u3000ハンパじゃねえ難しさだ！": ""
  },
  "18995": {
    "「これは\u3000お笑い界に伝説が生まれるな！": ""
  },
  "18996": {
    "「エントリーナンバー２！\n\u3000オレは\u3000テンション芸だけで飯を食っていく！\n\u3000プクレットの爆走芸人！\u3000フップ～～！": ""
  },
  "18997": {
    "「あーっ！\u3000ボクの大事な黄金像が倒れてる！": ""
  },
  "18998": {
    "「大事な黄金像を\u3000こんな風に扱うなんて！\n\u3000くっそー！\u3000お前！": ""
  },
  "18999": {
    "「お前\u3000しまいにゃ……。": ""
  },
  "19000": {
    "「おーこんぞう！": ""
  },
  "19001": {
    "会場は\u3000なごやかな笑いに包まれた。": ""
  },
  "19002": {
    "「エントリーナンバー３！\n\u3000オレたちの\u3000しゃべりは\u3000デンジャーゾーン！": ""
  },
  "19003": {
    "「お笑い界の下克上コンビ！\n\u3000ハパント・ヘント兄弟～～！": ""
  },
  "19004": {
    "「こないだなー。うちの学校に\n\u3000新任の先生\u3000来たんだよ。": ""
  },
  "19005": {
    "「へー。どんな先生？": ""
  },
  "19006": {
    "「それがなー。ずっと\u3000手ぇあげてて\n\u3000しかも\u3000全然\u3000話さへんねん。": ""
  },
  "19007": {
    "「うんうん。": ""
  },
  "19008": {
    "「しかもな\u3000なんか見た目キンピカやねん。": ""
  },
  "19009": {
    "「えー。ほんまなんー？": ""
  },
  "19010": {
    "「あ\u3000ちょうど先生来たから\u3000紹介したるわー。\n\u3000せんせー！\u3000ほら\u3000こちらが新しい先生や。": ""
  },
  "19011": {
    "「……って\u3000お前。\n\u3000新しい先生って…………": ""
  },
  "19012": {
    "「女の先生かい！": ""
  },
  "19013": {
    "「ツッコむとこ\u3000そこかい！": ""
  },
  "19014": {
    "会場は\u3000爆笑の渦に包まれた！": ""
  },
  "19015": {
    "「うん。ヒマつぶしには\u3000ちょうどいいね。": ""
  },
  "19016": {
    "「エントリーナンバー４！\n\u3000いぶし銀の輝き\u3000今ここに！\n\u3000孤高のお笑い職人！\u3000ホッププ～～！": ""
  },
  "19017": {
    "「ホッププ。７５歳。独身。\n\u3000尊敬する人は\u3000しびれくらげ先生。": ""
  },
  "19018": {
    "「黄金の女神像で\u3000謎かけします。": ""
  },
  "19019": {
    "「オホン……。黄金の女神像と\u3000かけまして。": ""
  },
  "19020": {
    "「仕事をしない二代目と解きます。": ""
  },
  "19021": {
    "「ふむ。そのココロは？": ""
  },
  "19022": {
    "「どちらも\u3000ドウシヨウもありません。": ""
  },
  "19023": {
    "「ふむ！\u3000どうしようもないと\n\u3000黄金だけに銅使用もないを\u3000かけたんじゃな！\n\u3000まさに\u3000名人芸じゃ！": ""
  },
  "19024": {
    "会場に\u3000感嘆の声が巻き起こった！": ""
  },
  "19025": {
    "「さて！\u3000これより\u3000２次予選は審査に入る。\n\u3000結果が出るまで\u3000しばし\u3000お待ちくだされ。": ""
  },
  "19026": {
    "「<pc>よ。お前の意見も\n\u3000後で\u3000わしに聞かせてくれ。": ""
  },
  "19027": {
    "「みなさん\u3000お待たせいたしました。\n\u3000では\u3000これより\u3000２次予選を通過した組を\n\u3000発表します……。えー\u3000コホン……。": ""
  },
  "19028": {
    "「１……２……１・２・３！": ""
  },
  "19029": {
    "「フウッ！！": ""
  },
  "19030": {
    "「ジャラジャラジャラジャラ……………。": ""
  },
  "19031": {
    "「ジャジャーーーン！！": ""
  },
  "19032": {
    "「ハパント・ヘント兄弟！\u3000ホッププ！\n\u3000以上２組が\u3000決勝戦に進出！": ""
  },
  "19034": {
    "「……そして\u3000残念ながら\n\u3000２次予選の脱落者は\u3000フップ\u3000お前じゃ。\n\u3000敗れはしたが\u3000非常に惜しかったぞ。": ""
  },
  "19035": {
    "「最後に\u3000何か言いたいことはあるか？": ""
  },
  "19036": {
    "「ボクを\u3000２次予選で落とすなんて！\n\u3000くっそー！\u3000お前！": ""
  },
  "19037": {
    "「お前\u3000しまいにゃ……。": ""
  },
  "19038": {
    "「おーこんぞう！": ""
  },
  "19039": {
    "「では\u3000これにて２次予選は終了じゃ！\n\u3000みんな\u3000次回は決勝戦で……。": ""
  },
  "19040": {
    "「と言いたいところじゃが\u3000次回は\n\u3000恒例\u3000審査員による\u3000エキシビションを行う！\n\u3000もちろん\u3000主役は\u3000<pc>～！": ""
  },
  "19041": {
    "「いったい\u3000どんな面白いことをやるのか！？\n\u3000もう\u3000抱腹絶倒は\u3000まちがいなし！\n\u3000みんな！\u3000エキシビションで\u3000また会おうね！": ""
  },
  "29418": {
    "「オオオオオーーーーーーー！！": ""
  }
}