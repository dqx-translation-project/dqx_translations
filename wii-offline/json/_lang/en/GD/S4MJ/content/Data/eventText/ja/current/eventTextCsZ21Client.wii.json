{
  "10469": {
    "「……ん～？": ""
  },
  "10470": {
    "「な～んだい\u3000アンタ。\n\u3000人んちに\u3000勝手に上がり込んできてさ～。\n\u3000押し売りなら\u3000帰っとくれよ。": ""
  },
  "10471": {
    "「じゃまするぞい。": ""
  },
  "10472": {
    "「破邪舟使いの末裔\u3000フルッカじゃな？\n\u3000わしは\u3000賢者ホーローじゃ。\n\u3000そなたに\u3000頼みがあってきた。": ""
  },
  "10473": {
    "「え？\u3000フルッカは\u3000あたしだけど。\n\u3000今どき\u3000破邪舟使いって……。": ""
  },
  "10474": {
    "「単刀直入に言おう。冥王の心臓に行くため\n\u3000おぬしのチカラが必要じゃ。\n\u3000わしらのために\u3000破邪舟の術を使ってくれんか？": ""
  },
  "10475": {
    "「はぁ？\u3000冥王の心臓？\u3000なによそれ。\n\u3000それに破邪舟の術なんて\u3000あたしゃ使えないよ。": ""
  },
  "10476": {
    "「なに？\u3000おぬしは\u3000使えないのか。\n\u3000ならば\u3000誰が使える？\n\u3000破邪舟の術は\u3000一子相伝の術だと聞いたが……。": ""
  },
  "10477": {
    "「今は\u3000誰も使えないわよ～。\n\u3000あたし\u3000ひとりっ子だし\n\u3000そもそも\u3000父ちゃんが\u3000使えなかったしね～。": ""
  },
  "10478": {
    "「つまり\u3000そんな術\u3000どこにもないってワケ。\n\u3000破邪舟使いの一族なんて肩書きも\n\u3000大昔ならともかく\u3000今は使わないわよ～。": ""
  },
  "10479": {
    "「な\u3000なんということじゃ……。": ""
  },
  "10480": {
    "「破邪舟の術は\u3000歴史の中から\n\u3000消えてしまったというのか……。\n\u3000う～む\u3000万事休すじゃな。": ""
  },
  "10481": {
    "「……いや\u3000待てよ。": ""
  },
  "10482": {
    "「おお\u3000そうか！\u3000そういうことか！\n\u3000わしの連れ合いは\u3000このことまで\n\u3000ちゃんと\u3000見抜いておったわ！": ""
  },
  "10483": {
    "「のう\u3000<pc>よ。\n\u3000先ほど\u3000わしが教えた予言を\u3000覚えておるか？": ""
  },
  "10484": {
    "「輝ける破邪舟は\u3000時の海を渡り\n\u3000救世主\u3000大いなる闇を\u3000越える……。": ""
  },
  "10485": {
    "「この\u3000時の海を渡り……という一節は\n\u3000現代に失われた破邪舟を\u3000過去にさかのぼり\n\u3000復活させることを\u3000意味してたんじゃ……。": ""
  },
  "10486": {
    "「いかにも\u3000信じられんといった顔じゃな。\n\u3000だがな\u3000<pc>。\n\u3000おぬしがいれば\u3000それも可能であろう。": ""
  },
  "10487": {
    "「かつて\u3000自分の<kyodai_rel3>に\u3000時渡りの術を使った\n\u3000おぬしならばな……。": ""
  },
  "10488": {
    "「だが\u3000そのチカラを\u3000使うために\n\u3000おぬしは\u3000人間の姿を取り戻す必要がある。\n\u3000その身体の持ち主は\u3000別の種族の者だからな。": ""
  },
  "10489": {
    "「案ずるでない。おぬしの真の姿は\n\u3000故郷\u3000エテーネの村に\u3000今も存在しておる。": ""
  },
  "10490": {
    "「これから\u3000わしの呪文で\u3000おぬしの魂を\n\u3000エテーネの村まで\u3000送りとどけてやるから\n\u3000おぬしは\u3000人間の姿を取り戻すのじゃ。": ""
  },
  "10491": {
    "「よいか\u3000<pc>。\n\u3000わしは\u3000ここで待っておる。\n\u3000準備ができたら\u3000ふたたび\u3000ここへ来てくれ。": ""
  },
  "10492": {
    "「え～。なに\u3000勝手に決めてんのよ～？\n\u3000ここ\u3000私の家なんですけど～。": ""
  },
  "10493": {
    "「ふふ。おまえの\u3000ものぐさな根性も\n\u3000<pc>が\u3000過去を変えたついでに\n\u3000変わればよいのう。": ""
  },
  "10494": {
    "「ネルゲルの手に落ちた\u3000エテーネの村では\n\u3000何が起こるか\u3000わからんからのう。\n\u3000くれぐれも\u3000気をつけるのじゃぞ！": ""
  },
  "10495": {
    "「あれが\u3000ネルゲルの居城……\n\u3000冥王の心臓じゃ。": ""
  },
  "10496": {
    "「あの中に\u3000おぬしら\u3000エテーネの民を滅ぼし\n\u3000レンダーシアを封印した\u3000悪の権化\n\u3000にっくき\u3000ネルゲルがおる。": ""
  },
  "10497": {
    "「今から\u3000わしが\u3000冥王の心臓に行けるよう\n\u3000光の橋を\u3000かけてやろう。\n\u3000それを渡り\u3000ネルゲルを倒してくるのじゃ……！": ""
  },
  "10498": {
    "「では\u3000ゆくぞ。": ""
  },
  "10499": {
    "「かああああぁぁぁぁぁぁ！！！": ""
  },
  "10500": {
    "「なんという\u3000邪悪なチカラじゃ……。": ""
  },
  "10501": {
    "「たとえ\u3000橋が\u3000かかったとしても\n\u3000あれでは\u3000おぬしが呑み込まれてしまうな。": ""
  },
  "10502": {
    "「さて\u3000どうしたものか……。": ""
  },
  "10503": {
    "「……そう言えば\u3000わしの連れ合いが\n\u3000昔\u3000気になることを\u3000言っておったな……。": ""
  },
  "10504": {
    "「わしの連れ合いは\u3000予知のチカラを持つ女でな。\n\u3000なんでも\u3000ピシャリと言い当てた。\n\u3000やつが\u3000ある日\u3000突然言ったんじゃ……。": ""
  },
  "10505": {
    "「輝ける破邪舟は\u3000時の海を渡り\n\u3000救世主\u3000大いなる闇を\u3000越える……\n\u3000とな。": ""
  },
  "10506": {
    "「破邪舟とは\u3000その名の通り\u3000邪悪をしりぞけ\n\u3000天空を駆ける\u3000魔法の舟だという話じゃ。": ""
  },
  "10507": {
    "「連れ合いが言うには\u3000その破邪舟を\n\u3000創りだすことができる\u3000魔法使いの末裔が\n\u3000グレン城に\u3000身を寄せているらしい。": ""
  },
  "10508": {
    "「その者の手を借りれば\u3000冥王の心臓まで\n\u3000たどりつけるかもしれんな……。": ""
  },
  "10509": {
    "「<pc>よ。\n\u3000ここは\u3000あやつの予言を信じ\n\u3000その魔法使いに\u3000会ってみようではないか。": ""
  },
  "10510": {
    "「わしも\u3000グレン城に向かうとしよう。\n\u3000破邪舟の魔法使いは\u3000城下町のどこかで\n\u3000くらしているはずじゃ。": ""
  },
  "10511": {
    "「それでは\u3000<pc>よ。\n\u3000また\u3000むこうで落ち合おうぞ！\n\u3000": ""
  },
  "10512": {
    "「エテーネの村に\u3000行く準備は\n\u3000できたかな？<yesno><close>": ""
  },
  "10513": {
    "「そうか。\n\u3000これから先\u3000何が起きるか\u3000わからんから\n\u3000怖気づくのも\u3000無理はあるまいな。": ""
  },
  "10514": {
    "「よし。それでは\u3000これから\n\u3000おぬしの故郷である\u3000エテーネの村まで\n\u3000おぬしの魂を\u3000飛ばしてやろう。": ""
  },
  "10515": {
    "「冥王ネルゲルに\u3000こちらの動きを\n\u3000読まれる恐れがあるため\u3000さけていたが\n\u3000もう\u3000そんなことは言っておれん。": ""
  },
  "10516": {
    "「よいか\u3000<pc>。もう一度\u3000言うぞ。\n\u3000おぬしの人間としての姿は\u3000これから行く\n\u3000エテーネの村にある。": ""
  },
  "10517": {
    "「今こそ\u3000その真の姿を\u3000取り戻すときじゃ。\n\u3000時を超え\u3000破邪舟を復活させるという\n\u3000おぬしにしか\u3000できぬ使命を果たすためにな！": ""
  },
  "10518": {
    "「……生まれ育った村の\u3000惨状を見るのは\n\u3000つらいことかもしれんが……。": ""
  },
  "10519": {
    "「頼んだぞ\u3000<pc>……！\n\u3000世界の命運は\u3000おぬしに\u3000かかっておる……！！": ""
  },
  "10520": {
    "「かああああああぁぁぁぁぁぁぁっ！！！": ""
  },
  "10521": {
    "「よくぞ……よくぞ\u3000戻ってきたのう。": ""
  },
  "10522": {
    "「死して後も\u3000わしは\u3000こうして\n\u3000ずっと\u3000お前を待っておったのじゃ。\n\u3000おかえり\u3000<pc>や。\u3000": ""
  },
  "10523": {
    "「わしが\u3000まだ幼い頃\u3000ひとりの若い錬金術師が \n\u3000この村を訪れ\u3000死にかけていた\u3000わしと\n\u3000この村を\u3000不思議な技で救ってくれたのじゃ。": ""
  },
  "10524": {
    "「……そう。お前の<kyodai_rel3>のことじゃ。\n\u3000わしは\u3000<kyodai>が\u3000生まれた時から\n\u3000あやつこそ\u3000あの錬金術師だと気づいておった。": ""
  },
  "10525": {
    "「そして\u3000あれを過去に送った\u3000時渡りの術者が\n\u3000<pc_rel2>である\u3000お前だということにもな……。": ""
  },
  "10526": {
    "「……さあ\u3000ついてくるがよい。\n\u3000お前が\u3000帰ってきた目的は\u3000わかっておる。\n\u3000すべては\u3000今日のためにあったのじゃからな。": ""
  },
  "10527": {
    "「この通り\u3000魂の抜けた\u3000お前の身体を\n\u3000カメさまが\u3000守っていてくださったのじゃ。": ""
  },
  "10528": {
    "「この身体に触れれば\u3000お前の魂は\n\u3000自然と\u3000元に戻るはず。\n\u3000さあ\u3000触れてみるが\u3000よいぞ。": ""
  },
  "10529": {
    "「……おおっ\u3000戻った！\n\u3000戻ったぞ\u3000<pc>っ！": ""
  },
  "10530": {
    "「こうなると\u3000わかってはいたが……\n\u3000やはり\u3000この目で見るまでは\u3000不安じゃったよ。": ""
  },
  "10531": {
    "「さあ\u3000あとは\u3000カメさまに目覚めていただき\n\u3000おチカラを\u3000お借りすれば……。": ""
  },
  "10532": {
    "<center>\u3000人の姿を\u3000取り戻したか。\n\u3000いまわしき\u3000エテーネの生き残りよ。": ""
  },
  "10533": {
    "<center>\u3000だが\u3000この地は\u3000すでに我の支配下。\n\u3000ここで起こることは\u3000すべて\n\u3000冥王ネルゲルの知るところ……。": ""
  },
  "10534": {
    "<center>\u3000我が\u3000闇の炎輪は\u3000\n\u3000その内にあるものを\u3000焼き尽くす。\n\u3000貴様に\u3000逃れる術はないと知れ。": ""
  },
  "10535": {
    "「……こういうことか。\n\u3000やはり\u3000お告げは\u3000正しかったようじゃ。": ""
  },
  "10536": {
    "「覚えておるか\u3000<pc>？\n\u3000あの日\u3000わしに頼まれて\n\u3000お前が採ってきた\u3000テンスの花じゃよ。": ""
  },
  "10537": {
    "「今こそ\u3000これを使うべきときが\u3000来たのじゃ！": ""
  },
  "10538": {
    "「……<pc>。\n\u3000これからも\u3000お前の行く先には\n\u3000多くの苦難が\u3000待ち受けておるじゃろう。": ""
  },
  "10539": {
    "「それを知りながら\u3000もはや\n\u3000なんの手助けもしてやれない\n\u3000わしのことを\u3000許しておくれよ。": ""
  },
  "10540": {
    "「だが\u3000お前なら……\n\u3000カメさまの申し子である\u3000<pc>なら\n\u3000きっと\u3000乗り越えてくれると信じておるぞ！": ""
  },
  "10541": {
    "「……お別れじゃ\u3000<pc>。\n\u3000わしのことは\u3000気にせずに\u3000ゆけ！\n\u3000そして\u3000必ずや\u3000冥王ネルゲルを倒すのじゃ！\u3000": ""
  },
  "10542": {
    "「はじめまして。\n\u3000エテーネの村の\u3000<pc>。": ""
  },
  "10543": {
    "「名乗るまでもないとは思いますが\n\u3000私は\u3000ツスクルの村の\n\u3000<pc>といいます。": ""
  },
  "10544": {
    "「そう。先刻まで\u3000あなたの魂が\n\u3000入り込んでいた\u3000エルフの若者の姿……\n\u3000その元の持ち主が\u3000私です。": ""
  },
  "10545": {
    "「おそらく\u3000同じ名前であるがゆえに\n\u3000あなたの魂と私の姿が\u3000引かれ合い\n\u3000あなたは\u3000私の姿に入り込んだのでしょうね。": ""
  },
  "10546": {
    "「いえ。気に病む必要はありません。\n\u3000あなたの魂が\u3000入り込んだとき\n\u3000私は\u3000すでに死んでいたのですから。": ""
  },
  "10547": {
    "「あなたさえよければ\u3000今後も\u3000私の姿を\n\u3000お使いください。": ""
  },
  "10548": {
    "「ええ。私の姿は\u3000人間に戻った\n\u3000あなたの中に\u3000今も\u3000存在しています。": ""
  },
  "10549": {
    "「今のあなたは\u3000教会へ行くことで\n\u3000人間の姿と\u3000エルフの姿とを\u3000\n\u3000自由に変えることが\u3000できるはずです。": ""
  },
  "10550": {
    "「これはきっと\u3000冥王ネルゲルを倒すという\n\u3000使命を果たすため\u3000神が\u3000あなたに\n\u3000授けてくださった\u3000能力なのでしょう。": ""
  },
  "10551": {
    "<center>\u3000聞こえますか？\n\u3000エテーネの民\u3000<pc>よ。": ""
  },
  "10552": {
    "「……この声の主が\u3000あなたを\n\u3000ここに\u3000運んでくれたのでしょうね。\n\u3000おそらくは\u3000伝説の天馬が……。": ""
  },
  "10553": {
    "<center>\u3000今の\u3000私のチカラでは\n\u3000あなたを\u3000この光の神殿の結界の中に\n\u3000逃がすのが\u3000精一杯でした。": ""
  },
  "10554": {
    "<center>\u3000冥王ネルゲルの持つ\u3000闇のチカラは\u3000今や\n\u3000この世界の光のチカラを\u3000圧倒しています。": ""
  },
  "10555": {
    "<center>\u3000このままでは\u3000レンダーシアはおろか\n\u3000世界のすべてが\u3000いずれ\u3000闇の封印に\n\u3000堕とされてしまうことでしょう。": ""
  },
  "10556": {
    "<center>\u3000そして\u3000それを防ぐことができるのは\n\u3000エテーネの民の姿を\u3000取り戻した\n\u3000<pc>……あなただけなのです。": ""
  },
  "10557": {
    "<center>\u3000あなたは\u3000いにしえのエテーネの民の血を\n\u3000もっとも強く\u3000受け継ぐ者。\n\u3000そのチカラは\u3000歴史の因果すら変えうるのです。": ""
  },
  "10558": {
    "<center>\u3000ネルゲルも\u3000それを恐れるが故に\n\u3000エテーネの村と\u3000エテーネの民を\n\u3000滅ぼさんとしたのでしょう。": ""
  },
  "10559": {
    "<center>\u3000そして\u3000私は\u3000わずかな希望をつなぐべく\n\u3000あなたの魂を\u3000生き返しの儀によって\u3000逃がし\n\u3000ネルゲルの目から\u3000かくしたのです。": ""
  },
  "10560": {
    "<center>\u3000今こそ\u3000希望の芽の息吹くとき。": ""
  },
  "10561": {
    "<center>\u3000あなた方が\u3000大地の箱舟と呼ぶ\u3000乗り物。\n\u3000あれこそは\u3000かつて\u3000天の箱舟と呼ばれた\n\u3000神秘なる存在の\u3000生まれ変わりし姿。": ""
  },
  "10562": {
    "<center>\u3000私に近しい存在である\u3000かの箱舟が\n\u3000時渡りのチカラを持つ\u3000あなたを\n\u3000あるべき時代へと\u3000導いてくれるでしょう。": ""
  },
  "10563": {
    "<center>\u3000そして\u3000もうひとつ……。": ""
  },
  "10564": {
    "<center>\u3000今\u3000かけた魔法によって\u3000あなたは\n\u3000人間の姿\u3000エルフの姿\u3000どちらであっても\n\u3000他者から\u3000同じに見えるようになりました。": ""
  },
  "10565": {
    "<center>\u3000これで\u3000あなたのことを知る人々が\n\u3000あなたが\u3000姿を変えることによって\n\u3000混乱することは\u3000なくなるでしょう。": ""
  },
  "10566": {
    "<center>\u3000過去への旅の準備は\u3000ととのいました。\n\u3000さあ\u3000そろそろ\u3000お戻りなさい。\n\u3000エテーネの民\u3000<pc>よ。": ""
  },
  "10567": {
    "「……どうやら\u3000あなたのなすべきことが\n\u3000ハッキリしたようですね。": ""
  },
  "10568": {
    "「今後の戦い。できれば\u3000人間の姿だけでなく\n\u3000エルフの姿も\u3000使ってやってください。": ""
  },
  "10569": {
    "「そして\u3000その姿を使って\u3000\n\u3000生前\u3000私が\u3000果たせなかった夢を……。": ""
  },
  "10570": {
    "「……いえ。\n\u3000今\u3000言うべきことでは\u3000ありませんでしたね。\n\u3000どうか\u3000忘れてください。": ""
  },
  "10571": {
    "「それでは\u3000お気をつけて。\n\u3000必ず\u3000冥王ネルゲルを倒して\n\u3000レンダーシアを\u3000解放してください。": ""
  },
  "10572": {
    "「はじめまして……でよいのかしら？\n\u3000エテーネの村の\u3000<pc>。": ""
  },
  "10573": {
    "「すでに\u3000ご承知のこととは思いますが\n\u3000私は\u3000ツスクルの村の\n\u3000<pc>と申します。": ""
  },
  "10574": {
    "「そう。先刻まで\u3000あなたの魂が\n\u3000入り込んでいた\u3000エルフの娘の姿……\n\u3000その元の持ち主が\u3000私なのです。": ""
  },
  "10575": {
    "「それにしても\u3000不思議なものですわね。\n\u3000たまたま\u3000同じ名前の方の魂が\u3000\n\u3000私の姿に\u3000入ってしまうなんて……。": ""
  },
  "10576": {
    "「いえ。そのことは\u3000気にしていませんわ。\n\u3000あなたの魂が\u3000入り込んだとき\n\u3000私の命は\u3000すでに\u3000絶えてましたもの。": ""
  },
  "10577": {
    "「そういうわけですから\u3000あなたさえよければ\n\u3000今後も\u3000私の姿をお使いください。": ""
  },
  "10578": {
    "「ええ。私の姿は\u3000人間に戻った\n\u3000あなたの中に\u3000今も\u3000存在しています。": ""
  },
  "10579": {
    "「これからは\u3000教会へ行くことで\n\u3000人間の姿と\u3000エルフの姿とを\u3000\n\u3000自由に変えることが\u3000できるはずですわ。": ""
  },
  "10580": {
    "「これはきっと\u3000冥王ネルゲルを倒すという\n\u3000使命を果たすため\u3000神が\u3000あなたに\n\u3000授けてくださった能力なのでしょう。": ""
  },
  "10581": {
    "<center>\u3000聞こえますか？\n\u3000エテーネの民\u3000<pc>よ。": ""
  },
  "10582": {
