{
  "4865": {
    "「うん？\u3000ドゥラ院長に\u3000何か用か？\n\u3000だが\u3000院長は……": ""
  },
  "4866": {
    "「ドゥラ院長！\n\u3000もう\u3000お出かけですか？": ""
  },
  "4867": {
    "「では\u3000行ってくる。": ""
  },
  "4869": {
    "「あれで\u3000ラミザ王子と同じ\u3000１６歳とは。\n\u3000まったく\u3000たいした若者だ……。": ""
  },
  "4871": {
    "「待っておったぞ\u3000ドゥラ。\n\u3000今にも失われそうな\u3000太陽の石のかがやきを\n\u3000取り戻すことができるとは\u3000本当なのか？": ""
  },
  "4872": {
    "「はい\u3000ウラード国王。\n\u3000まずは\u3000こちらを\u3000ご覧ください。": ""
  },
  "4873": {
    "「それは……\u3000まさか\u3000太陽の石か！？": ""
  },
  "4874": {
    "「さようでございます。": ""
  },
  "4875": {
    "「どうやって\u3000太陽の石を\u3000手に入れたのじゃ！？\n\u3000数十年も前に\u3000掘りつくされ\n\u3000枯渇したと言われる\u3000幻の石なのじゃぞ！": ""
  },
  "4876": {
    "「創りだしたのでございます\u3000国王。": ""
  },
  "4877": {
    "「創った……じゃと！？\n\u3000そんなこと\u3000できるはずが……。": ""
  },
  "4878": {
    "「では\u3000今から\u3000実際に\n\u3000太陽の石を\u3000創ってみせましょう。": ""
  },
  "4879": {
    "「その黒い石は……！？": ""
  },
  "4880": {
    "「はい。悪しき瘴気の塊\u3000魔瘴石でございます。\n\u3000ですが\u3000この魔法布の上に置き\n\u3000直接\u3000触れねば\u3000なんの心配もございません。": ""
  },
  "4881": {
    "「う……うむ。": ""
  },
  "4882": {
    "「では\u3000始めます。": ""
  },
  "4883": {
    "「ま\u3000まさか……！\n\u3000魔瘴石を\u3000太陽の石に変えたというのか！？": ""
  },
  "4884": {
    "「魔瘴石と\u3000太陽の石……。\n\u3000陰と陽のちがいは\u3000ありますが\n\u3000どちらも\u3000強いチカラを秘めた石。": ""
  },
  "4885": {
    "「私は\u3000長い研究の末\u3000たどりついたのです！\n\u3000魔瘴石は\u3000チカラの向きを変えると\n\u3000太陽の石に\u3000生まれ変わるという事実に！！": ""
  },
  "4886": {
    "「すばらしい……！": ""
  },
  "4887": {
    "「よくやった\u3000ドゥラよ。\n\u3000そなたの情熱が\u3000ついに\u3000実を結んだのじゃな！": ""
  },
  "4888": {
    "「おほめにあずかり\u3000光栄でございます。\n\u3000しかし\u3000まだ\u3000安心はできません。": ""
  },
  "4889": {
    "「この国を支える\u3000頭上の太陽の石が\n\u3000太古のかがやきを\u3000取り戻すためには\n\u3000多くの魔瘴石が\u3000必要なのです！": ""
  },
  "4890": {
    "「なるほど。\n\u3000では\u3000さっそく\u3000魔瘴石を集めさせよう！": ""
  },
  "4891": {
    "「聞いた通りだ\u3000皆の者！\n\u3000これより\u3000魔瘴石を集めてきた者には\n\u3000その量に応じて\u3000ほうびを与える！": ""
  },
  "4892": {
    "「魔瘴石は\u3000この国の東にある\n\u3000カルサドラ火山で\u3000多く採れます。\n\u3000現地にいる\u3000研究員の指示に従ってください。": ""
  },
  "4893": {
    "「ドルワームを救うのは……\u3000この私だ！": ""
  },
  "4894": {
    "「魔瘴石ってヤツを\u3000大量に集めてきたら\n\u3000それだけ\u3000注目を浴びるってワケね。\n\u3000これは\u3000使えるかも……。": ""
  },
  "4895": {
    "「あら\u3000あなたは\u3000たしか……。\n\u3000あたしの元下僕の\u3000<pc>じゃないッ！？": ""
  },
  "4896": {
    "「くくく……\u3000いいところで\u3000会ったわね！\n\u3000タイミングのよさに免じて\n\u3000もう一度\u3000あたしの下僕にしてあげるわッ！": ""
  },
  "4897": {
    "「あら\u3000あなた……。\n\u3000なかなか\u3000いい目をしてるじゃないッ！？\n\u3000名前は……\u3000そう\u3000<pc>っていうの。": ""
  },
  "4898": {
    "「ふふん\u3000気に入ったわ！\n\u3000ちょうど\u3000人手のほしいところだったし\n\u3000あなた\u3000このルナナさまの下僕になりなさいッ！": ""
  },
  "4899": {
    "「それでは\u3000さっそく\u3000命令するわ！\n\u3000今すぐ\u3000東のカルサドラ火山へ行き\n\u3000大量の魔瘴石を\u3000ゲットしてくるのよッ！！": ""
  },
  "4900": {
    "「そなた\u3000旅の者じゃな。": ""
  },
  "4901": {
    "「我が国では\u3000魔瘴石を集めてきた者に\n\u3000ほうびを\u3000与えることにした。": ""
  },
  "4902": {
    "「ウデに\u3000自信があるのなら\n\u3000この国の東にある\u3000カルサドラ火山へ向かい\n\u3000魔瘴石を\u3000手に入れてくるがよい。": ""
  },
  "4903": {
    "「ラミザ王子！": ""
  },
  "4904": {
    "「チリ……。": ""
  },
  "4905": {
    "「ドゥラくん\u3000すごかったよねえ。\n\u3000父上も\u3000あんなに\u3000よろこんでさ……。": ""
  },
  "4906": {
    "「ど\u3000どうして\u3000ボクは\u3000ダメなのかな。\n\u3000ボクは\u3000捨てられた兄弟の分まで\n\u3000がんばらないと\u3000いけないのに……。": ""
  },
  "4907": {
    "「ラミザ王子……。": ""
  },
  "4908": {
    "「いやあ～\u3000たんまり\u3000掘ったなあ！": ""
  },
  "4909": {
    "「これだけありゃ\u3000いったい\n\u3000どれくらい\u3000ほうびが\u3000もらえるのか……。\n\u3000ダハハハハッ\u3000笑いが止まらねえ！！": ""
  },
  "4910": {
    "「あなたも\u3000魔瘴石を\n\u3000掘りにいらっしゃったんですか？": ""
  },
  "4911": {
    "「あら\u3000<pc>！\n\u3000ちゃんと\u3000待ってるなんて\u3000エライじゃないの。": ""
  },
  "4912": {
    "「ふ～ん……\u3000ここね？\n\u3000魔瘴石が採れるっていう\u3000洞くつは。": ""
  },
  "4913": {
    "「……は\u3000はい。\n\u3000でも\u3000ずいぶん\u3000掘られてしまった後ですし\n\u3000かなり奥まで行かないと\u3000採れないかと。": ""
  },
  "4914": {
    "「ふふん\u3000上等よッ！\n\u3000誰も見たことがないくらい\u3000デカイ魔瘴石を\n\u3000掘りだしてみせるわ！": ""
  },
  "4916": {
    "「わ\u3000わかりました。それでは\u3000皆さん\n\u3000この布を\u3000お受け取りください。": ""
  },
  "4919": {
    "「やるじゃない\u3000<cs_pchero>ッ！": ""
  },
  "4920": {
    "「あたしたちが\u3000来る前に\n\u3000掃除しておくなんて\u3000下僕のカガミ……\n\u3000まさに\u3000エリート下僕ねッ！": ""
  },
  "4921": {
    "「ふっふっふ……。\n\u3000この辺りは\u3000まだ誰も\u3000掘ってないみたいだし\n\u3000デカイ魔瘴石が\u3000期待できそうね。": ""
  },
  "4922": {
    "「へいっ！": ""
  },
  "4923": {
    "「くくく……\u3000感じるわ。\n\u3000魔瘴石の気配を\u3000ヒシヒシとねッ！": ""
  },
  "4924": {
    "「出るわ！\u3000デカイ魔瘴石が\u3000出るわよッ！！": ""
  },
  "4925": {
    "「ルナナさま！\n\u3000なんか\u3000変なものが……。": ""
  },
  "4926": {
    "「ん？": ""
  },
  "4927": {
    "「何よ\u3000これ？\u3000おふだ？\n\u3000ずいぶん\u3000古くさい封印ね……。\n\u3000しかも\u3000解けかけちゃってるじゃないの。": ""
  },
  "4928": {
    "「わかったわッ！": ""
  },
  "4929": {
    "「見て！\u3000巨大な魔瘴石よッ！\n\u3000私の思った通り\u3000このおふだで\n\u3000こいつを封じていたんだわッ！！": ""
  },
  "4930": {
    "「ふ\u3000封印を\u3000解いちまったりして\n\u3000いいんですかい\u3000ルナナさま！？": ""
  },
  "4931": {
    "「ふんッ\u3000何を\u3000怖じ気づいてるのよ！\n\u3000そのために\u3000魔法布が\u3000あるんでしょッ！？\n\u3000さっさと\u3000掘りだしてちょうだいッ！！": ""
  },
  "4932": {
    "「へ……へいっ！": ""
  },
  "4933": {
    "「バカの相手は\u3000疲れるわ……。\n\u3000採掘のウデ前が\u3000なかったら\n\u3000とっくに\u3000クビにしているところよ。": ""
  },
  "4934": {
    "「こ\u3000これは……！": ""
  },
  "4935": {
    "「想像以上ですぜっ！": ""
  },
  "4936": {
    "「いや～ん！\n\u3000やればできるじゃないの\u3000あなたたち～！": ""
  },
  "4937": {
    "「さあ\u3000それを持って\n\u3000ドルワームに戻るわよッ！": ""
  },
  "4938": {
    "「ああ……\u3000<cs_pchero>にも\n\u3000魔物を掃除してくれた\u3000ごほうびを\n\u3000あげないといけないわね。": ""
  },
  "4939": {
    "<cs_pchero>は\u3000ルナナから\n小さな魔瘴石のかけらを\u3000受け取った！": ""
  },
  "4940": {
    "「じゃあ\u3000さよならッ！": ""
  },
  "4941": {
    "どこからか\u3000もの悲しい音楽が\n聞こえてくる……。": ""
  },
  "4942": {
    "「ラララ\u3000遠い昔の物語～♪\n\u3000王家に生まれた\u3000双子の子～。\n\u3000王位を争い\u3000国を滅ぼす～。": ""
  },
  "4943": {
    "「時は流れて\u3000歴史はめぐり～♪\n\u3000またも\u3000生まれた\u3000災いの双子～。\n\u3000３つの星を手にした\u3000運命の子～。": ""
  },
  "4944": {
    "「そうはいえども\u3000かわいい\u3000我が子～♪\n\u3000誰が\u3000この子を手放せようか～。\n\u3000誰が\u3000この子を責められようか～。": ""
  },
  "4945": {
    "「国を選ぶか\u3000我が子を選ぶか～♪\n\u3000ふたつにひとつ\u3000ふたつにひとつ～。\n\u3000星降りの夜に\u3000ルラルルル～♪": ""
  },
  "4946": {
    "「むむむっ！\u3000あなた\u3000魔瘴石をお持ちですねっ？\n\u3000魔法布と一緒に\u3000回収させていただきますっ！": ""
  },
  "4947": {
    "<pc>は\u3000ツィベルに\n魔瘴石の包みを\u3000渡した！": ""
  },
  "4948": {
    "「おおっと\u3000これはっ！！\n\u3000なんと\u3000まれに見る\u3000ささやかさっ……。": ""
  },
  "4949": {
    "「すみません。\n\u3000そういうことなので\u3000お礼も\u3000ささやかでっ。": ""
  },
  "4950": {
    "<pc>は\u3000５０ゴールドを\u3000受け取った！<se_nots System 7>": ""
  },
  "4951": {
    "「さっきまでは\u3000すごーい行列だったんですが\n\u3000さすがに\u3000そろそろ\u3000終わりかなっ。": ""
  },
  "4952": {
    "「んんんっ！？": ""
  },
  "4953": {
    "「ジャマよッ！！": ""
  },
  "4954": {
    "「あら\u3000<pc>\u3000ずいぶん早い到着ね！\n\u3000うふふ……\u3000荷物が増えないように\n\u3000気を使ってあげた\u3000あたしに\u3000感謝なさいッ！": ""
  },
  "4955": {
    "「はわわわわわわわっ……。": ""
  },
  "4956": {
    "「ねえ\u3000あなた！\n\u3000王立研究院の人でしょッ！？\n\u3000さっさと\u3000魔瘴石を\u3000引き取ってよッ！": ""
  },
  "4957": {
    "「は\u3000はいぃっ！\n\u3000少々\u3000お待ちをっ！！": ""
  },
  "4958": {
    "「あーもう\u3000グズばっかりねッ！": ""
  },
  "4959": {
    "「こっちは\u3000この魔瘴石のせいで\n\u3000ノロノロとしか歩けなくて\u3000疲れてるのにッ！！": ""
  },
  "4960": {
    "「なんて\u3000見事な魔瘴石だ……！": ""
  },
  "4961": {
    "「すばらしい！！\n\u3000これだけの魔瘴石が\u3000あれば\n\u3000ドルワームは\u3000永遠に安泰だ！": ""
  },
  "4962": {
    "「さあ\u3000この魔瘴石を\u3000玉座の間へ！\n\u3000さっそく\u3000太陽の石に\u3000変えるとしよう。": ""
  },
  "4963": {
    "「本当に\u3000ありがとう。\n\u3000あなた方のおかげで\u3000私の夢が\u3000かなう。": ""
  },
  "4964": {
    "「さあ\u3000私と\u3000一緒に来てください！\n\u3000皆さんに\u3000キーエンブレムが贈られるよう\n\u3000私から\u3000国王に進言しましょう。": ""
  },
  "4965": {
    "「キーエンブレムですって……？": ""
  },
  "4966": {
    "「ふふふ……\u3000当然よねッ！\n\u3000あたしは\u3000この国の英雄なんだから<heart>": ""
  },
  "4969": {
    "「この巨大な魔瘴石は\u3000こちらにいらっしゃる\n\u3000ルナナさんと\u3000その仲間たちによって\n\u3000掘りだされたものです。": ""
  },
  "4970": {
    "「これを\u3000太陽の石に変えて\u3000補充すれば\n\u3000ドルワームの太陽は\u3000永遠に\n\u3000かがやきを\u3000失うことはないでしょう。": ""
  },
  "4971": {
    "「そう！\u3000私の研究の成果で\n\u3000ドルワームは\u3000救われるのです！！": ""
  },
  "4972": {
    "「様子が\u3000おかしいわ！": ""
  },
  "4973": {
    "「くっ……！": ""
  },
  "4974": {
    "「我ハ\u3000天魔クァバルナ……。": ""
  },
  "4975": {
    "「ドゥラよ\u3000礼を言おウ。\n\u3000今\u3000ふたタビ\u3000地上に出ることができたノハ\n\u3000すべて\u3000お前ノ\u3000おかげダ……。": ""
  },
  "4976": {
    "「……なんの話だ？": ""
  },
  "4977": {
    "「わからぬノカ？": ""
  },
  "4978": {
    "「思いダセ……。\n\u3000太陽の石ヲ作るために\u3000魔瘴石ノ利用を\n\u3000思いつイタ\u3000アノ日のことヲ……。": ""
  },
  "4979": {
    "「ククク……。\n\u3000お前に\u3000魔瘴石を使うよう助言したのハ\n\u3000神の声などでは\u3000ナイ。": ""
  },
  "4980": {
    "「ま\u3000まさか\u3000あれは……\n\u3000あのときの声は……\u3000お前が！？": ""
  },
  "4981": {
    "「……さよウ。\n\u3000魔瘴石ヲ集めさせルタメ\u3000我ハ\n\u3000お前ヲ\u3000利用させてモらったノだ。": ""
  },
  "4982": {
    "「魔瘴石と成りはテタ\u3000我ノ魂ヲ\n\u3000封印から\u3000解きはなってもらうためにナ！！": ""
  },
  "4983": {
    "「ふ\u3000封印って\u3000まさか……\n\u3000あのとき\u3000ルナナさまが解いちゃった……？": ""
  },
  "4984": {
    "「うるさいッ！\u3000この\u3000アブラねんどッ！！": ""
  },
  "4985": {
    "「魂ガ\u3000よみがえった\u3000今\n\u3000あとハ\u3000肉体ヲ取り戻セバ\u3000我ハ自由ダ！！": ""
  },
  "4986": {
    "「な\u3000なによッ！": ""
  },
  "4987": {
    "「あんなヤツが\u3000埋まってるなんて\n\u3000聞いてないもの！\n\u3000あたしが\u3000悪いんじゃないわよッ！！": ""
  },
  "4988": {
    "「ふんッ！": ""
  },
  "4989": {
    "「なんということじゃ……。\n\u3000かつて\u3000この国を滅ぼそうとした\u3000伝説の魔物\n\u3000天魔クァバルナが\u3000復活してしまうとは……。": ""
  },
  "4990": {
    "「はい……。\n\u3000どうやら\u3000そのようです。": ""
  },
  "4991": {
    "「お前ほどの者が\u3000功をあせり\n\u3000魔物に\u3000つけこまれるとは……。": ""
  },
  "4992": {
    "「富\u3000名声\u3000知識……。\n\u3000それらを求めすぎた\u3000ドワーフたちの末路を\n\u3000知らぬわけでは\u3000あるまいに。": ""
  },
  "4993": {
    "「私は……\u3000どうしても\u3000この国を救いたかった！\n\u3000救わなくては\u3000ならなかったんだ！": ""
  },
  "4994": {
    "「ウラード国王っ！\n\u3000あなたは\u3000この３つのホクロに\n\u3000見覚えがあるはずだ！": ""
  },
  "4995": {
    "「私は\u3000国のために\u3000あなたに捨てられた\n\u3000３つの星をつかむ子です！": ""
  },
  "4996": {
    "「無能な兄\u3000ラミザに代わって\u3000ドルワームを救い\n\u3000私を捨てたのは\u3000まちがいだったと\n\u3000あなたに\u3000謝罪させたかったのです！": ""
  },
  "4997": {
    "「ドゥラくんが……\u3000ボクの弟………。": ""
  },
  "4998": {
    "「おろかな……。": ""
  },
  "4999": {
    "「その話は\u3000あとだ。\n\u3000今は\u3000あの魔物……天魔クァバルナを\n\u3000なんとかせねば！": ""
  },
  "5000": {
    "「ヤツが\u3000向かった先に\n\u3000心当たりのある者は\u3000いるか！？": ""
  },
  "5001": {
    "「……おそらく\u3000この大陸の西の果て\n\u3000ボロヌスの穴かと。": ""
  },
  "5002": {
    "「古文書によると\u3000天魔クァバルナは\n\u3000肉体と魂に分けられ\u3000ボロヌスの穴の泉に\n\u3000その肉体が\u3000封印されたとあるのです。": ""
  },
  "5003": {
    "「よし！\u3000ラミザよ。\n\u3000騎士団を率いて\u3000ボロヌスの穴へ向かうのじゃ！\n\u3000ドゥラ\u3000お前も\u3000一緒に行くように！": ""
  },
  "5004": {
    "「はいっ！": ""
  },
  "5005": {
    "「は\u3000はいっ……。": ""
  },
  "5006": {
    "「まさか\u3000クァバルナの魂が\n\u3000カルサドラ火山に\u3000封じられていたとは……。\n\u3000なぜ\u3000私は\u3000気づかなかった！": ""
  },
  "5007": {
    "「私の責任だ……。\n\u3000この命に代えても\u3000クァバルナを討つ！": ""
  },
  "5008": {
    "「ドゥラめ……。なんという\n\u3000おろかなことをしてくれたのじゃ。\n\u3000よりにもよって\u3000あの天魔クァバルナを……。": ""
  },
  "5009": {
    "「しかし\u3000それもすべて\n\u3000愛しい我が子を\u3000捨ててしまった\n\u3000わしの過ちが\u3000原因なのだな……。": ""
  },
  "5013": {
    "「我ノ\u3000身体……\u3000我ノ\u3000美しい……。": ""
  },
  "5014": {
    "「よくモ……\u3000よくも\u3000このような……！！": ""
  },
  "5015": {
    "「クゥェェエエアアアッ！！！": ""
  },
  "5016": {
    "「長かっタ……。\n\u3000我ノ……\u3000我の\u3000いとしイ身体……。": ""
  },
  "5017": {
    "「もう二度ト\u3000封印などされるモノカ！！": ""
  },
  "5018": {
    "「生きとし生ける者ハ\u3000すべて\u3000我が糧……！\n\u3000まずは\u3000お前から\u3000喰らってやロウ！！": ""
  },
  "5019": {
    "「まだ\u3000我ニ\u3000挑もうとするカ？\n\u3000はかなく\u3000弱き者よ。": ""
  },
  "5020": {
    "「おもしろイ……。\n\u3000次は\u3000魂まで\u3000喰らってやロウ！！": ""
  },
  "5021": {
    "「な\u3000ぜダ……。": ""
  },
  "5022": {
    "「我ハ\u3000かつて\u3000世界最強ト\u3000謳われた……\n\u3000そノ誇りに……\u3000かけテ……": ""
  },
  "5023": {
    "「このまマ\u3000倒れるわけニハ\u3000ゆかぬうぅぅ！！": ""
  },
  "5024": {
    "「あぶないっ！": ""
  },
  "5025": {
    "「クククク……！\n\u3000ドゥラ……。まだ\u3000絶望は…終わらヌ……。\n\u3000我が呪イ\u3000絶えヌ…限…り……。": ""
  },
  "5026": {
    "「……あなたが\u3000クァバルナを？": ""
  },
  "5027": {
    "「ありがとうございました。\n\u3000私たちが\u3000遅れてしまったせいで\n\u3000危険な目に\u3000あわせてしまいましたね……。": ""
  },
  "5028": {
    "「ぜい\u3000ぜい……\u3000ドゥラくん\u3000速いよ。\n\u3000ク\u3000クァバルナは\u3000どこ？": ""
  },
  "5029": {
    "「お前のようなヤツが\n\u3000私の兄だなんて\u3000うんざりだ！": ""
  },
  "5030": {
    "「討伐のための騎士を選ぶのに\u3000時間をかけて。\n\u3000そのために\u3000なんの関係もない旅の者が\n\u3000クァバルナと\u3000戦ってしまったんだぞ！": ""
  },
  "5031": {
    "「ご\u3000ごめん。\n\u3000あやまるから\u3000怒らないで。\n\u3000ボクは\u3000兄弟仲良くしたいんだよ！": ""
  },
  "5032": {
    "「そ\u3000それに\u3000戦う人は\u3000ちゃんと選ばないと。\n\u3000ケガしたら悲しむ家族が\u3000みんないるから。": ""
  },
  "5033": {
    "「やはり\u3000お前のような甘いヤツに\n\u3000ドルワームを\u3000まかせるわけにはいかない！": ""
  },
  "5034": {
    "「よくぞ帰った\u3000ラミザ\u3000ドゥラ！\n\u3000見事\u3000クァバルナを倒してきたのだな？": ""
  },
  "5035": {
    "「いえ……。": ""
  },
  "5036": {
    "「天魔クァバルナを倒したのは\u3000あの者です。\n\u3000私たちが\u3000到着したときには\n\u3000すでに\u3000すべてが\u3000終わっていました。": ""
  },
  "5037": {
    "「なんと！\u3000それは\u3000まことか？": ""
  },
  "5038": {
    "「クァバルナを倒したという旅人よ。\n\u3000こちらへ\u3000参られよ。": ""
  },
  "5039": {
    "「そなた\u3000名は\u3000なんと申す？": ""
  },
  "5040": {
    "「……そうか\u3000<pc>というのか。\n\u3000<pc>よ。我が家臣の不始末で\n\u3000そなたには\u3000迷惑をかけたようだ。": ""
  },
  "5041": {
    "「そなたのはたらきと\u3000勇気をたたえ……": ""
  },
  "5042": {
    "「た\u3000太陽の石がっ！！\n\u3000いったい\u3000何が起こったのじゃ！？": ""
  },
  "5043": {
    "「こ\u3000これは……。": ""
  },
  "5044": {
    "「恐れながら\u3000国王様。\n\u3000一部\u3000太陽の石になりきれなかった魔瘴石があり\n\u3000それが\u3000悪さをしているのでしょう。": ""
  },
  "5045": {
    "「では\u3000どうすれば……？": ""
  },
  "5046": {
    "「この暴走を\u3000止めるのです。\n\u3000太陽の石のチカラを\u3000制御できるのは\n\u3000ドルワーム王家の血を\u3000引く者のみ！": ""
  },
  "5047": {
    "「私が\u3000止めてみせましょう！\n\u3000それが\u3000私が\u3000この国の王子であるという\n\u3000何よりの証になる！": ""
  },
  "5048": {
    "「ムダじゃ！\u3000お前は\u3000王家の者ではない！": ""
  },
  "5049": {
    "「なぜ\u3000認めないっ！？": ""
  },
  "5050": {
    "「国のために\u3000子を捨てたのでしょう！？\n\u3000正しいことをしたと思っているのなら\n\u3000認められるはずです！！": ""
  },
  "5051": {
    "「だが\u3000子を捨てた罪は\u3000決して消えない！\n\u3000私の恨みも\u3000消えることはない……！！": ""
  },
  "5052": {
    "「見ろっ！！\n\u3000私が\u3000捨てられた王子だ！！！": ""
  },
  "5053": {
    "「止まれ！\u3000太陽の石よ！！\n\u3000暴走をやめろ！！！": ""
  },
  "5054": {
    "「……なぜだっ！\u3000なぜ\u3000止まらない！？": ""
  },
  "5055": {
    "「わしが\u3000かつて\u3000捨てた子は……": ""
  },
  "5056": {
    "「女の子なのじゃよ。": ""
  },
  "5057": {
    "「女……。": ""
  },
  "5058": {
    "「国王様っ！\u3000チカラをお貸しください！\n\u3000早く\u3000太陽の石を抑えないと\n\u3000お城が\u3000ふき飛んでしまいます！！": ""
  },
  "5059": {
    "「うむっ！": ""
  },
  "5060": {
    "「止まらぬぞ……！\n\u3000わしのチカラだけでは\u3000足りぬのか！？": ""
  },
  "5061": {
    "「ラミザ王子も\u3000チカラを貸してください！": ""
  },
  "5062": {
    "「うう……\u3000うううっ………。": ""
  },
  "5063": {
    "「ラミザ王子！？": ""
  },
  "5064": {
    "「ううっ。ドゥラくん\u3000かわいそう……。\n\u3000ここまで\u3000一生懸命……\n\u3000がんばって\u3000きたのに……\u3000ううっ……。": ""
  },
  "5065": {
    "「ボクより……\u3000王子らしいのに……\n\u3000王子じゃないなんて………。": ""
  },
  "5066": {
    "「王子\u3000お願いです！\n\u3000チカラを貸してください！": ""
  },
  "5067": {
    "「ボクには\u3000ムリだよ………。": ""
  },
  "5068": {
    "「ラミザ王子っ！！": ""
  },
  "5069": {
    "「……チリ！？": ""
  },
  "5070": {
    "「ま\u3000まさか\u3000キミが！？": ""
  },
  "5071": {
    "「お願いします\u3000ラミザ王子！\n\u3000あなたのチカラが\u3000必要なんです！！": ""
  },
  "5072": {
    "「どうしよう\u3000これでも治まらないなんて。\n\u3000このままじゃ\u3000城ごと\u3000私たちは……！": ""
  },
  "5073": {
    "「…………………。": ""
  },
  "5074": {
    "「くっ……\u3000うあああああああ！！！": ""
  },
  "5075": {
    "「い\u3000今のは\u3000ボクの……\u3000あれ？": ""
  },
  "5076": {
    "「ラミザ王子\u3000すごいです！": ""
  },
  "5077": {
    "「チリ……\u3000と言ったか。\n\u3000わしに\u3000顔を見せておくれ。": ""
  },
  "5078": {
    "「そうか……\u3000お前だったのか。": ""
  },
  "5079": {
    "「すまなかった……。\n\u3000あのとき\u3000わしは\u3000お前を手放す以外に\n\u3000国を守る方法はないと\u3000信じておったのじゃ。": ""
  },
  "5080": {
    "「だが\u3000結果的に\u3000多くの者をキズつけ\n\u3000この国に\u3000新たな悲劇を生んでしまった。\n\u3000わしの選択は\u3000まちがっていたのじゃな。": ""
  },
  "5081": {
    "「チリよ。この王宮で\u3000一緒に暮らさぬか？\n\u3000亡き王妃も\u3000お前を手放したことを\n\u3000ずっと\u3000気に病んでおった。": ""
  },
  "5083": {
    "「ありがとうございます\u3000国王様。": ""
  },
  "5084": {
    "「ですが……\u3000王宮の生活は\n\u3000きっと\u3000私には\u3000あいません。": ""
  },
  "5085": {
    "「私の父は\u3000ガタラに住む\u3000養父だけ。\n\u3000変わり者だけど\u3000愛情込めて育ててくれました。\n\u3000私は\u3000彼のように\u3000自由に生きたいのです。": ""
  },
  "5086": {
    "「ドゥラくん\u3000どこへ行くの？": ""
  },
  "5087": {
    "「ウラード国王\u3000暴言の数々を\u3000お許しください。\n\u3000私は\u3000もう二度と\u3000ドルワームの土を\n\u3000踏みません。": ""
  },
  "5088": {
    "「待ってください\u3000ドゥラ院長！\n\u3000院長の代わりになるような研究者は\n\u3000どこにも\u3000いません。": ""
  },
  "5089": {
    "「院長なら\u3000クァバルナの入れ知恵なんてなくても\n\u3000いつか\u3000太陽の石を\u3000創りだせたはずです！\n\u3000私は\u3000そう信じてます！": ""
  },
  "5090": {
    "「………………。": ""
  },
  "5091": {
    "「ありがとう……\u3000チリ。": ""
  },
  "5092": {
    "「ドゥラよ。そなたには\u3000これからも\n\u3000王立研究院の長であることを\u3000命ずる。\n\u3000ドルワームのため\u3000チカラを貸してほしい。": ""
  },
  "5093": {
    "「は……はいっ！": ""
  },
  "5094": {
    "「そして\u3000もちろん\u3000忘れてはならぬ。\n\u3000見事\u3000天魔クァバルナを葬ってくれた\n\u3000ドルワームの英雄\u3000<pc>の活躍を。": ""
  },
  "5095": {
    "「そなたには\u3000ほうびとして\n\u3000金のキーエンブレムを与えよう！": ""
  },
  "5096": {
    "<pc>は\n金のキーエンブレム（だいじなもの）を\n受け取った！<me 72>": ""
  },
  "5097": {
    "「また\u3000今後は\u3000水晶宮の中にある\n\u3000ドルワーム鉄道駅の利用を\u3000許可しよう。\n\u3000そなたの旅に\u3000大いに役立てるがよい！": ""
  },
  "5098": {
    "「そなたたちの未来に\u3000明るい太陽の光が\n\u3000降りそそがんことを！": ""
  },
  "5099": {
    "「ああ。私の研究成果を見てもらい\n\u3000ウラード国王にも\u3000早く\n\u3000安心していただきたいからね。": ""
  },
  "5100": {
    "「いってらっしゃいませ！": ""
  },
  "5101": {
    "<pc>は\n魔法布（だいじなもの）を\u3000受け取った！<me 60>": ""
  },
  "5102": {
    "「それは\u3000王立研究院で開発された\u3000魔法布です。\n\u3000魔瘴石に\u3000直接\u3000触れるのは危険ですから\n\u3000必ず\u3000その布ごしに\u3000持ってください。": ""
  },
  "5103": {
    "「ふふん。さあ\u3000奥へ行くわよ\u3000<pc>！\n\u3000このルナナさまの\u3000神がかった運のよさを\n\u3000見せつけてあげるわッ！！": ""
  },
  "5104": {
    "「おおお～っ\u3000さすが\u3000ドゥラ様！": ""
  },
  "5105": {
    "「うおおっ\u3000でけえ！！！": ""
  },
  "5106": {
    "「国王様……。\n\u3000その件は\u3000国を想うため\u3000仕方のなかったこと。\n\u3000どうか\u3000ご自分を責めないでください。": ""
  },
  "5108": {
    "「そなたは\u3000たしか\u3000王立研究院の者だったな。\n\u3000名は\u3000チリと申したか。": ""
  },
  "28441": {
    "「それに\u3000ラミザ王子が\u3000きっと\n\u3000天魔クァバルナを\u3000討ってくださると\n\u3000私は\u3000信じております。": ""
  },
  "28442": {
    "「……礼を言わねばな。そなたの申す通りじゃ。\n\u3000今は\u3000ラミザを信じ\u3000待つことにしよう。": ""
  },
  "28443": {
    "「む？": ""
  },
  "28444": {
    "「そなたは\u3000旅の者か。\n\u3000こんなときに\u3000ドルワームを訪れるとは\n\u3000ついておらんかったな。": ""
  },
  "28445": {
    "「……ほう。なかなか\u3000ウデの立ちそうな旅人だ。\n\u3000どうじゃ？\u3000そなたさえよければ\n\u3000天魔クァバルナを討つ\u3000手助けをしてくれぬか？": ""
  },
  "28446": {
    "「ラミザを\u3000信頼していないわけではないが\n\u3000ひとりでも\u3000味方が増えたほうが\n\u3000きっと\u3000あやつも\u3000心強いじゃろう。": ""
  },
  "28447": {
    "「天魔クァバルナは\u3000この大陸の西の果て\n\u3000ボロヌスの穴に\u3000向かったそうじゃ。\n\u3000活躍次第では\u3000ほうびをとらせようぞ。": ""
  },
  "28448": {
    "「ドゥラよ\u3000クァバルナの言ったことは\u3000本当か？\n\u3000あろうことか\u3000ヤツの知恵を借り\n\u3000太陽の石を\u3000創ってしまったというのか？": ""
  },
  "28449": {
    "「さあ\u3000ムチェ\u3000ブチャ！\n\u3000あなたたちの出番よ。\n\u3000さっさと\u3000掘ってちょうだいッ！！": ""
  },
  "28450": {
    "「ハイ！\u3000これが\u3000ごほうびよッ<heart>": ""
  },
  "28451": {
    "<cs_pchero>は\u3000小さな魔瘴石のかけらを\n持っていた魔法布で\u3000包んだ。": ""
  },
  "28452": {
    "「アグラニでは\u3000散々な目にあったけど\n\u3000このドルワームで活躍をして\u3000今度こそ\n\u3000私の名を\u3000世界中に\u3000とどろかせるのよッ！": ""
  },
  "28453": {
    "「私の夢は\u3000世界一の名声を\u3000手に入れること！\n\u3000このドルワームで\u3000活躍をして\n\u3000私の名を\u3000世界中に\u3000とどろかせるのよッ！": ""
  },
  "28454": {
    "「命令に背いたら\u3000痛い目を見るからね。\n\u3000頼んだわよ\u3000<pc>！": ""
  },
  "32286": {
    "「ドルワームに\u3000平和を\u3000もたらしてくれた\n\u3000すべての者たちに\u3000感謝する。": ""
  },
  "37699": {
    "<cs_pchero>は\n魔瘴石の包み（だいじなもの）を\u3000手に入れた！<me 60>": ""
  }
