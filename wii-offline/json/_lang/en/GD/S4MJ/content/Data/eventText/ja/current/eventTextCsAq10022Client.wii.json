{
  "17355": {
    "「来てくれたか\u3000<pc>……。\n\u3000キミのことを待っていた！": ""
  },
  "17356": {
    "「リジン！！\u3000戦士たちを呼べ！\n\u3000これより軍議を行う！\n\u3000ただちに\u3000作戦会議室に\u3000集うのだ！！": ""
  },
  "17357": {
    "「承知！": ""
  },
  "17358": {
    "「<pc>！\u3000まずは\u3000朗報だ。\n\u3000ヴァルハラの戦士たちの\u3000はたらきにより\n\u3000三賢人の\u3000ひとりの居場所が\u3000明らかとなった！": ""
  },
  "17359": {
    "「三賢人とは\u3000来たるべき最終戦争の際\n\u3000我ら\u3000ヴァルハラの戦士と共に\u3000立つといわれる\n\u3000英知の結晶に\u3000ございます。": ""
  },
  "17360": {
    "「彼らは\u3000それぞれ\u3000チカラと\u3000愛\u3000そして光を\n\u3000つかさどる賢人。こたび\u3000居場所が判明したのは\n\u3000チカラの賢人トールでございます。": ""
  },
  "17361": {
    "「……で\u3000その\u3000チカラの賢人トールは\n\u3000巨人族が\u3000この世の楽園と呼ぶ\n\u3000娯楽の島とやらにいることが\u3000わかったんでさ。": ""
  },
  "17362": {
    "「ひとつ問題なのは\u3000その娯楽の島が\n\u3000途方もなく\u3000遠方の地だってことでして。\n\u3000誰が\u3000娯楽の島へ行くべきか……。": ""
  },
  "17363": {
    "「賢人トールの\u3000捜索にあたる人員は\n\u3000もう\u3000決めてある。\n\u3000ボクと\u3000<pc>が行こう！": ""
  },
  "17364": {
    "「シグルド様\u3000お考え直しを！！\n\u3000あなたは\u3000我らヴァルハラの戦士を率いるお方。\n\u3000御身に\u3000もしものことが\u3000あっては……！": ""
  },
  "17365": {
    "「リジンよ。まだ\u3000それを言うか。": ""
  },
  "17366": {
    "「ボクは\u3000皆を導く指導者として\n\u3000巨人族の世界を\u3000深く知っておく必要がある！\n\u3000お前は\u3000それを止めようというのか？": ""
  },
  "17367": {
    "「……めっそうも\u3000ございません。\n\u3000では\u3000せめて\u3000お気をつけて\n\u3000いってくださいませ。": ""
  },
  "17368": {
    "「さて\u3000巨人族の戦士\u3000<pc>よ！\n\u3000キミの役目は\u3000先ほど話したとおりだ。": ""
  },
  "17369": {
    "「キミには\u3000このボクと\u3000ともに\n\u3000娯楽の島に\u3000行ってもらいたい！\n\u3000チカラの賢人トールの\u3000捜索に\u3000あたろう！": ""
  },
  "17370": {
    "「心強い返事だ。巨人族である\n\u3000キミと一緒なら\u3000チカラの賢人トールも\n\u3000必ずや\u3000見つけだすことができるだろう！": ""
  },
  "17371": {
    "「それでは\u3000すぐに\u3000出発しよう！\n\u3000ボクは\u3000キミの\u3000かばんの中に入らせてもらう。": ""
  },
  "17372": {
    "「皆！\u3000留守を\u3000頼んだぞ！！": ""
  },
  "17373": {
    "<pc>は\n戦士シグルド（だいじなもの）を\u3000手に入れた！<me 60>": ""
  },
  "17374": {
    "「むっ！？\u3000待て\u3000<pc>！\n\u3000どうやら\u3000キミは\u3000他にも\n\u3000多数の使命を\u3000抱えているようだな。": ""
  },
  "17375": {
    "「まずは\u3000その使命を\u3000まっとうしてくれ。\n\u3000それが戦士たる者の\u3000つとめであろう。": ""
  },
  "17376": {
    "「そうか……。\n\u3000ならば\u3000無理強いすることはできないな。\n\u3000キミにも\u3000事情というものが\u3000あるのだろう。": ""
  },
  "17377": {
    "「よくぞ\u3000戻ってきてくれた！": ""
  },
  "17378": {
    "「巨人族の戦士\u3000<pc>よ。\n\u3000以前\u3000話したとおり\u3000チカラの賢人トールの\n\u3000居場所が\u3000明らかになったのだ。": ""
  },
  "17379": {
    "「キミには\u3000このボクと\u3000ともに\n\u3000娯楽の島に\u3000行ってもらいたい！\n\u3000チカラの賢人トールの\u3000捜索に\u3000あたろう！": ""
  },
  "17380": {
    "かばんの中から\u3000シグルドの声が聞こえる。": ""
  },
  "17381": {
    "「すばらしい……！\n\u3000ボクの想像を\u3000はるかに超えている！": ""
  },
  "17382": {
    "「この島が\u3000巨人族の\u3000娯楽の島！\n\u3000<pc>！\u3000ボクは\u3000こんなに\n\u3000美しい景色を\u3000見たことがない！": ""
  },
  "17383": {
    "「……むっ！？\u3000あ…あれは……！": ""
  },
  "17384": {
    "「なんと\u3000幸運なんだ！\n\u3000こんなに早く\u3000見つかるとは！": ""
  },
  "17385": {
    "「<pc>！\u3000あの\u3000ご婦人を追ってくれ！\n\u3000離れていても感じる\u3000チカラの波動……。\n\u3000あのオレンジ色の者こそが\u3000賢人トールだ！": ""
  },
  "17386": {
    "「皆\u3000待たせたな！\n\u3000ボクだ！\u3000今\u3000帰ったぞ！！": ""
  },
  "17387": {
    "「おお……！\n\u3000この方が\u3000チカラの賢人トール様！\n\u3000なんという神々しき\u3000お姿……！": ""
  },
  "17388": {
    "「英知の結晶よ！\u3000我が声に\u3000応えたまえ！": ""
  },
  "17389": {
    "「天命のもとに\u3000その英知を\u3000捧げよ！\n\u3000賢人トール！\u3000その瞳に\u3000光を！": ""
  },
  "17390": {
    "「ううぅ……\u3000ぐ…むう……。": ""
  },
  "17391": {
    "「賢人トール！！\n\u3000ようやく\u3000あなたに\u3000お会いできた！": ""
  },
  "17392": {
    "「ふうむ……\u3000賢人トール……？\n\u3000ひさかたぶりに\u3000我が名を呼ばれたわい。\n\u3000ずいぶん長く\u3000眠っておったようじゃ……。": ""
  },
  "17393": {
    "「賢人トールよ\u3000あなたのチカラを借りたい！\n\u3000天命の戦乙女が\u3000連れ去られたために\n\u3000世界の均衡が\u3000崩れ始めているのだ！": ""
  },
  "17394": {
    "「な\u3000なんじゃと！？\u3000天命の戦乙女が！？": ""
  },
  "17395": {
    "「こうしては\u3000おれん。すぐに\u3000我が占術で\n\u3000残りの三賢人の居場所を\u3000明らかにせねば……。\n\u3000ひとまず\u3000ワシに\u3000まかせてくれい。": ""
  },
  "17396": {
    "「<pc>。キミのおかげで\n\u3000天命の戦乙女の奪還に向けて\u3000大きな一歩を\n\u3000踏みだせた。わずかだが\u3000これは礼だ。": ""
  },
  "17397": {
    "「……そういえば\u3000キミには\u3000天命の戦乙女の話を\n\u3000ほとんど\u3000したことがなかったな。": ""
  },
  "17398": {
    "「ボクは\u3000あの方に出会った日を\u3000忘れはしない。\n\u3000あの日……\u3000敵の夜襲に倒れた\u3000ボクの前に\n\u3000昇るはずのない\u3000太陽が現れたのだ。": ""
  },
  "17399": {
    "<center>勇猛なる戦士\u3000シグルドよ。\n目を\u3000覚ましなさい……。": ""
  },
  "17400": {
    "<center>……戦いに散った\u3000あなたの魂は\u3000尊きもの。\nこれからは\u3000ヴァルハラの戦士として\n新たな人生を\u3000歩むのです……。": ""
  },
  "17401": {
    "「そうして\u3000ボクは……\n\u3000美しく気高い\u3000天命の戦乙女に仕える\n\u3000ヴァルハラの戦士に\u3000生まれ変わった。": ""
  },
  "17402": {
    "「ボクの命は\u3000天命の戦乙女のもの。\n\u3000決して\u3000あの方を失うわけには\u3000いかないのだ。": ""
  },
  "17403": {
    "「ありがとう\u3000<pc>。\n\u3000キミのおかげで\u3000チカラの賢人トールを\n\u3000見つけだすことができた。": ""
  },
  "17404": {
    "「これで\u3000天命の戦乙女の奪還に向けて\n\u3000ボクたちは\u3000大きな一歩を\u3000踏みだせたのだ。": ""
  },
  "17405": {
    "「今は\u3000賢人トールが\u3000占術を使って\n\u3000残りの三賢人の居場所を\u3000探してくれている。\n\u3000彼にまかせ\u3000休息を取っていてくれ。": ""
  }
}