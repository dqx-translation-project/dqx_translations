{
  "71057": {
    "「さすがは\u3000<cs_pchero>さま。\n\u3000この場から\u3000邪悪な気を感じましたが\n\u3000すでに\u3000退治していただけたようですね。": ""
  },
  "71058": {
    "「……世告げの姫として目覚めた時\n\u3000私は\u3000ひとりで\u3000ここに立っていました。": ""
  },
  "71059": {
    "「あの時\u3000ここで\u3000何が起きたのでしょう……。": ""
  },
  "71060": {
    "「おや？\u3000この魔物は……。": ""
  },
  "71061": {
    "「ああっ……！？\u3000こ\u3000これは……？": ""
  },
  "71062": {
    "「故郷を滅ぼされ\u3000悲しいか？": ""
  },
  "71063": {
    "「死の恐怖から\u3000逃げ惑うだけの生活にも\n\u3000疲れただろう。今すぐ\u3000楽にしてやる……。": ""
  },
  "71064": {
    "「コ…コゼット……。コゼット……。": ""
  },
  "71065": {
    "「……コゼット。\n\u3000あ…あなたを守れ…なくて\u3000ごめ…ん…なさい。\n\u3000私も…すぐ\u3000いく…からね……。": ""
  },
  "71066": {
    "「あと少し…で\n\u3000あの…場所に\u3000たどり着け…たのに……。": ""
  },
  "71067": {
    "「あ…と少しで……。": ""
  },
  "71068": {
    "「うう……っ。\n\u3000ひっく\u3000ひっく……。": ""
  },
  "71069": {
    "「あなたは……？\n\u3000な…ぜ\u3000こんな所…に\u3000いる…の？": ""
  },
  "71070": {
    "「ボ……ボク……。": ""
  },
  "71071": {
    "「ボク……帰らなくちゃいけなくて……。\n\u3000だけど\u3000追いだされてしまったから\n\u3000ひとりじゃ\u3000帰れなくて……。": ""
  },
  "71072": {
    "「……………………。": ""
  },
  "71073": {
    "「おねえちゃん\u3000ボクといっしょに\n\u3000帰ってくれないかな。おねえちゃんと\n\u3000いっしょなら\u3000ボク\u3000きっと帰れるから。": ""
  },
  "71074": {
    "「そしたら\u3000ボク……\u3000おねえちゃんの頼み\n\u3000どんなことでも\u3000きいてあげるから！": ""
  },
  "71075": {
    "「私の…願い……？": ""
  },
  "71076": {
    "「無理よ……。かなうはずが…ない……。": ""
  },
  "71077": {
    "「クックック……。見つけたぞ。\n\u3000まさか\u3000こんな所に隠れていたとはな。": ""
  },
  "71078": {
    "「だが\u3000もう\u3000逃げられん。\n\u3000すぐに\u3000妹の後を追わせてやろう。": ""
  },
  "71079": {
    "「私は\u3000死ん…でもいい……。\n\u3000でも…もし\u3000かなう…の…なら……\n\u3000コ\u3000コゼットを……。": ""
  },
  "71080": {
    "「大丈夫だよ。\n\u3000おねえちゃんの願い\u3000ちゃんと\u3000わかるよ。\n\u3000じゃあ……すこし待ってて。": ""
  },
  "71081": {
    "「な\u3000なんだ\u3000この光は！？": ""
  },
  "71082": {
    "「グワアアアアアアーーーーーーッ！！": ""
  },
  "71083": {
    "「うっ……うぅ……。": ""
  },
  "71084": {
    "「コゼットが\u3000生き返った……？": ""
  },
  "71085": {
    "「これで\u3000ボクといっしょに帰ってくれるよね？": ""
  },
  "71086": {
    "「あなたは\u3000いったい……\u3000何者なの……？": ""
  },
  "71087": {
    "「ボクはね………………": ""
  },
  "71088": {
    "「……思いだしました。": ""
  },
  "71089": {
    "「私を\u3000世告げの姫として動かしていた者……。\n\u3000彼の者の思惑も\u3000すべて……。": ""
  },
  "71090": {
    "「先ほど\u3000<cs_pchero>さまが倒された魔物は\n\u3000コゼットの命を奪った\u3000追っ手に対する\n\u3000私の恐怖が\u3000具現化したものなのでしょう。": ""
  },
  "71091": {
    "「<cs_pchero>さま……。\n\u3000ここまで来られたのも\u3000あなたのおかげです。\n\u3000どうか\u3000こちらを受け取ってください。": ""
  },
  "71092": {
    "「<cs_pchero>さま。\n\u3000のちほど\u3000落陽の草原にいる\n\u3000コゼットのもとへ\u3000お越しください。": ""
  },
  "71095": {
    "「コゼット……。\n\u3000あの子が\u3000呪縛から解かれる日は\n\u3000いつ\u3000訪れるのでしょうか……。": ""
  }
}