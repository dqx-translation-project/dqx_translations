{
  "75711": {
    "「お姉ちゃん\u3000いないみたい……。": ""
  },
  "75712": {
    "「でも\u3000さっきの光を見たら\n\u3000お姉ちゃんも\u3000ここに\u3000来る約束なの。\n\u3000だから\u3000ちょっと\u3000待ってみよう！": ""
  },
  "75713": {
    "<pc>と\u3000コゼットは\nロディアが\u3000現れるのを待った。": ""
  },
  "75714": {
    "しかし\u3000いくら待っても\nロディアは\u3000現れなかった……。": ""
  },
  "75715": {
    "「おねえちゃん\u3000来ないよ……。\n\u3000てことは\u3000<pc>さんの言ったとおり\n\u3000本当に\u3000おねえちゃんは\u3000もう……？": ""
  },
  "75716": {
    "「あなたたちは……誰？": ""
  },
  "75717": {
    "「我々は\u3000ある王国の者。\n\u3000そなたたちこそ\u3000ここで\u3000何をしている？": ""
  },
  "75718": {
    "「ここは\u3000おねえちゃんとの約束の場所なの。\n\u3000おねえちゃんが来るのを\u3000待ってただけ。": ""
  },
  "75719": {
    "「約束の場所と\u3000申したか？\n\u3000もしや\u3000そなたの名は……。": ""
  },
  "75720": {
    "「えっ？\u3000私の名前は\u3000コゼットだけど……。": ""
  },
  "75721": {
    "「お帰りを\u3000お待ちしておりました。": ""
  },
  "75722": {
    "「我らが主\u3000コゼット姫……。": ""
  },
  "75723": {
    "「なっ\u3000なにそれ！？\n\u3000姫って\u3000ど……どういうこと？": ""
  },
  "75724": {
    "「無理もございません……。ロディア姫とともに\n\u3000滅亡の危機に陥った王国を脱したとき\n\u3000あなたは\u3000まだ\u3000あまりに幼くあられた。": ""
  },
  "75725": {
    "「あなたは\u3000ロディア姫とともに\n\u3000我らが祖国……エクゼリア王国の\n\u3000未来を担う\u3000お方なのです。": ""
  },
  "75726": {
    "「……エクゼリア王国？\u3000おねえちゃんの言ってた\n\u3000私たちの滅ぼされた故郷が\u3000そうなの……？": ""
  },
  "75727": {
    "「我らが王国は\u3000悪しき者の手により\n\u3000一度は\u3000滅びかけましたが\n\u3000今\u3000再興の時を迎えようとしております。": ""
  },
  "75728": {
    "「故に\u3000我々\u3000王国の民は\u3000亡き王の跡を継ぐ\n\u3000姫のご帰還を\u3000お待ちしているのです。": ""
  },
  "75729": {
    "「……おねえちゃんは\u3000そんなこと\n\u3000ひとことも\u3000言ってなかった。": ""
  },
  "75730": {
    "「おふたりには\u3000追っ手が\u3000かかっておりました。\n\u3000おそらくは\u3000追跡の目を逃れるために\n\u3000素性を\u3000隠しておられたのでしょう。": ""
  },
  "75731": {
    "「ときに\u3000コゼット姫。この者は……？\n\u3000そして\u3000ロディア姫は\u3000いずこに？": ""
  },
  "75732": {
    "「この人は\u3000<pc>さん。\n\u3000おねえちゃんの\u3000知り合いなんだ。": ""
  },
  "75733": {
    "「<pc>さんが\u3000おねえちゃんは\n\u3000もう\u3000帰ってこないって言ってるんだけど\n\u3000私\u3000それを確かめたくて\u3000ここに……。": ""
  },
  "75734": {
    "「では\u3000ロディア姫は\u3000行方不明であると？": ""
  },
  "75735": {
    "「……もしや\u3000コゼット姫。\n\u3000ロディア姫より\u3000何か\n\u3000預かっているものは\u3000ありませんか？": ""
  },
  "75736": {
    "「預かったもの……？": ""
  },
  "75737": {
    "「預かったかどうか\u3000わからないけど\n\u3000これを持っててって\u3000渡されたものがあるよ！": ""
  },
  "75738": {
    "「その指輪は\u3000まさしく\n\u3000王位継承者の証たる\u3000エクゼリア王家の指輪。": ""
  },
  "75739": {
    "「それを\u3000渡していたということは\n\u3000ロディア姫は\u3000コゼット姫に\u3000王位継承を\n\u3000託される\u3000おつもりだったのでは……。": ""
  },
  "75740": {
    "「そ\u3000それって\n\u3000私に\u3000女王様になれってこと？": ""
  },
  "75741": {
    "「そっ……そんなのムリだよ。\n\u3000私が\u3000女王様なんて\u3000なれっこないよ！": ""
  },
  "75742": {
    "「私\u3000おねえちゃんを探してくる！\n\u3000それで\u3000ふたりで戻ってくるから！\n\u3000ねっ。いいでしょ！？": ""
  },
  "75743": {
    "「追っ手の件もありますゆえ\u3000承服しかねます。\n\u3000どうか\u3000我らと共に来てくださいますよう……。": ""
  },
  "75744": {
    "「だいじょうぶだよ！\n\u3000<pc>さんに\u3000守ってもらうから。\n\u3000ダメって言っても\u3000絶対\u3000行くもん！！": ""
  },
  "75745": {
    "「……姫のお言葉とあらば\u3000仕方ありません。\n\u3000我々は\u3000お帰りをお待ちいたします。\n\u3000必ず\u3000無事に\u3000お戻りください。": ""
  },
  "75746": {
    "「……結局\u3000おねえちゃんは\n\u3000来てくれなかったね……。\n\u3000おねえちゃんは\u3000本当に\u3000もう……。": ""
  },
  "75747": {
    "「……私\u3000ちょっと\u3000疲れちゃったよ。\n\u3000いったん\u3000ガケっぷち村に戻ろ？": ""
  },
  "75748": {
    "「……なんなの\u3000ここ？\n\u3000こんな変な場所\u3000はじめて来たよ……。": ""
  },
  "75749": {
    "「<pc>さんがいるから\u3000平気だよね？\n\u3000私\u3000こっそり\u3000後をついていくから\n\u3000おねえちゃんのいる所まで\u3000連れてって！": ""
  },
  "75750": {
    "「<pc>さん……。\n\u3000ここに\u3000災厄の王とかいうのが\u3000いたの？\n\u3000もう\u3000なんにもいない……よね？": ""
  },
  "75751": {
    "「ロディアおねえちゃーーーんっ！！": ""
  },
  "75752": {
    "「………………。": ""
  },
  "75753": {
    "「……ねえ\u3000おねえちゃん。\n\u3000この王家の指輪は\u3000おねえちゃんのだよ。\n\u3000私\u3000届けに来たんだ……。": ""
  },
  "75754": {
    "「私が女王様なんて\u3000絶対にムリだし……。\n\u3000おねえちゃん\u3000この指輪を着けて\n\u3000いつか\u3000戻ってきてね。": ""
  },
  "75755": {
    "「……おねえちゃん？": ""
  },
  "75756": {
    "「…………ここは\u3000どこ？": ""
  },
  "75757": {
    "「あっ…………。": ""
  },
  "75758": {
    "「うん！\u3000聞こえる！\u3000聞こえるよ！": ""
  },
  "75759": {
    "「えっ……そんな…………。\n\u3000ううん。でも……。": ""
  },
  "75760": {
    "「うん……うん……。\n\u3000わかったよ……。": ""
  },
  "75761": {
    "「……大丈夫。私\u3000がんばってみるよ。\n\u3000だから\u3000心配しないで……。\n\u3000ロディアお……ねえちゃ……ん……。": ""
  },
  "75762": {
    "「ありがとう\u3000<pc>さん。\n\u3000あなたのおかげで\u3000私\n\u3000おねえちゃんと\u3000話すことができたよ。": ""
  },
  "75763": {
    "「私\u3000急いで\u3000あの兵士さんたちの所に\n\u3000行かなきゃ！\u3000ギルザッド地方の\n\u3000約束の場所へ\u3000もう一度\u3000連れてって！": ""
  },
  "75764": {
    "「……それじゃ\u3000私は行くよ。\n\u3000ロディアおねえちゃん\u3000元気でね！": ""
  },
  "75765": {
    "「ありがとう\u3000<pc>さん。\n\u3000何度も\u3000ごめんなさい。": ""
  },
  "75766": {
    "「お待ちしておりました\u3000コゼット姫。": ""
  },
  "75767": {
    "「おねえちゃんは\u3000生きてるよ！\n\u3000私\u3000おねえちゃんと\u3000話したもん！": ""
  },
  "75768": {
    "「でもね。とても大切な役目があるから\n\u3000すぐには\u3000帰れないんだって……。": ""
  },
  "75769": {
    "「私\u3000おねえちゃんに\u3000頼まれたの。\n\u3000あなたにも\u3000やってほしいことがある。\n\u3000あなたにしか\u3000できないこと……って。": ""
  },
  "75770": {
    "「それはね。役目を終えた\u3000おねえちゃんが\n\u3000安心して帰ってこれる場所を\u3000作ること。\n\u3000エクゼリア王国の再興を\u3000果たすことなの！": ""
  },
  "75771": {
    "「だから\u3000私\u3000女王様になるよ！": ""
  },
  "75772": {
    "「ご決断なされましたか。\n\u3000エクゼリアの民も\u3000新たな女王の誕生を\n\u3000心より\u3000歓迎することでしょう！": ""
  },
  "75773": {
    "「ですが\u3000エクゼリア王国へと至る道の\n\u3000安全を確保するため\u3000今しばらく\n\u3000時間を\u3000いただきたいのです。": ""
  },
  "75774": {
    "「だったら\u3000私は\u3000あの場所に戻るよ。\n\u3000あそこなら\u3000おねえちゃんが帰ってきた時に\n\u3000すぐに\u3000わかるから。": ""
  },
  "75775": {
    "「姫の\u3000おおせのままに。\n\u3000我々は\u3000道中の安全が\u3000確保できしだい\n\u3000お迎えに\u3000あがることにいたします。": ""
  },
  "75776": {
    "「<pc>さんが\u3000いなかったら\n\u3000私\u3000これから\u3000どうすればいいのか\n\u3000きっと\u3000わからなかったよ。": ""
  },
  "75777": {
    "「でも\u3000<pc>さんのおかげで\n\u3000私にも\u3000やらなきゃいけない\n\u3000大切なことがあるって\u3000わかったんだ。": ""
  },
  "75778": {
    "「本当に\u3000ありがとう！！\n\u3000これ……。お礼だから\u3000受け取って！": ""
  },
  "75779": {
    "「それじゃあ\u3000私は\n\u3000ガケっぷち村に\u3000戻るね。\n\u3000本当に\u3000ありがとう\u3000<pc>さん！": ""
  },
  "78825": {
    "「ロディア姫は\u3000ご一緒でないようですが\n\u3000やはり……。": ""
  }
}