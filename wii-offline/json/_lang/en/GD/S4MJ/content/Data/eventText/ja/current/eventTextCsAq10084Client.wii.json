{
  "19441": {
    "「ぜえぜえ……。ぜえぜえ……。": ""
  },
  "19442": {
    "「ぜえぜえ……。あ…あなた。\n\u3000よく\u3000見つけてくれ…ましたね……。\n\u3000ぶ…部下に\u3000してあげても…いいくらいですわ。": ""
  },
  "19443": {
    "「さあ…神父さま。一刻を\u3000争いますわ！\n\u3000オルフェアの町で\u3000生き残るためにも\n\u3000おはらいで\u3000呪いを解いてあげてください！": ""
  },
  "19444": {
    "「ちょ…ちょっと\u3000待ちたまえ。\n\u3000ひさしぶりに走ったから\u3000呼吸が……。": ""
  },
  "19445": {
    "「すぅーーー。はぁーーー。\n\u3000すぅーーー。はぁーーー。": ""
  },
  "19446": {
    "「ふぅ。少しは\u3000落ち着きました。\n\u3000困っている方を\u3000見過ごせません。\n\u3000さっそく\u3000呪いを解きましょう。": ""
  },
  "19447": {
    "「おお\u3000神よ！\u3000わが主よ！\n\u3000この者の身体より\n\u3000呪いを\u3000はらいたまえ！": ""
  },
  "19448": {
    "「おお！\u3000動く！\u3000身体が動くぞ！": ""
  },
  "19449": {
    "「ありがとうございます！\u3000旅の方！\n\u3000ありがとうございます！\u3000神父さま！": ""
  },
  "19450": {
    "「私\u3000カメラマンの\u3000メロポネスといいます！\n\u3000この\u3000ご恩は\u3000一生忘れません！": ""
  },
  "19451": {
    "「いえ……。当然のことをしたまで……": ""
  },
  "19452": {
    "「や…やりました！\u3000呪いを解いたわ！\n\u3000このウワサを広めれば\u3000神父さまは安泰ね！\n\u3000町から\u3000追いだされずに済むわ！": ""
  },
  "19453": {
    "「あなた！\u3000お礼をするから\n\u3000後で\u3000教会に来てくださいね！": ""
  },
  "19454": {
    "「さあ！\u3000行きましょう\u3000神父さま！": ""
  },
  "19455": {
    "「こんな近くで\u3000叫ばなくても……。": ""
  }
}