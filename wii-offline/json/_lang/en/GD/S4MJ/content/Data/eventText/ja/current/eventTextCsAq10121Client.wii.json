{
  "16059": {
    "「先に\u3000着いていたか。<pc>。": ""
  },
  "16060": {
    "「では\u3000今回の魔物狩りは\n\u3000このメンバーで\u3000行うこととしよう。": ""
  },
  "16061": {
    "「グロスナー王\u3000直々の\u3000お召しにより\n\u3000ガートラントの華\u3000このスピンドルも\n\u3000緊急参戦いたしますぞ！": ""
  },
  "16062": {
    "「自分は\u3000いつ\u3000いかなるときも\n\u3000グロスナー王のそばにあって\n\u3000護衛の任を\u3000果たすのみであります。": ""
  },
  "16063": {
    "「私\u3000荒っぽいのは\u3000苦手だと言ってるのに\n\u3000無理矢理\u3000参加させられてしまいました……。": ""
  },
  "16064": {
    "「ボヤくな\u3000ボヤくな。\n\u3000城に\u3000閉じこもってばかりいないで\n\u3000たまには\u3000身体を動かすのも\u3000いいものだぞ。": ""
  },
  "16065": {
    "「さて\u3000今回の獲物だが……\n\u3000このザマ峠の\u3000博愛の碑辺りに\u3000出現する\n\u3000<%sEV_QUE_NAME0>にしようと思う。": ""
  },
  "16066": {
    "「だが\u3000普通に倒すだけでは\u3000つまらんからな。\n\u3000ひとつ\u3000競争することにしようか。\n\u3000優勝者には\u3000わしから\u3000ほうびを取らせよう。": ""
  },
  "16067": {
    "「<%sEV_QUE_NAME0>が\u3000よく落とす\n\u3000地竜のツノ。これを\u3000いちばん早く\n\u3000持ってきた者を\u3000優勝としようぞ！": ""
  },
  "16068": {
    "「それなら\u3000審判は\u3000私が\u3000引き受けましょう。\n\u3000地竜のツノを\u3000手に入れた方は\u3000\n\u3000私のところまで\u3000持ってきてください。": ""
  },
  "16069": {
    "「では\u3000今から\u3000狩りの開始じゃ！\n\u3000皆\u3000ケガなどせぬよう\u3000気をつけて\n\u3000ハンティングするのじゃぞ！": ""
  },
  "16070": {
    "「き\u3000貴様たちっ\u3000何者だっ！？": ""
  },
  "16071": {
    "「今のは\u3000グロスナー王の声っ！？": ""
  },
  "16072": {
    "「大丈夫か\u3000リッグ？": ""
  },
  "16073": {
    "「ぐうう……。": ""
  },
  "16074": {
    "「……貴様ら。わしを\u3000ガートラント国王\n\u3000グロスナーと知っての\u3000ろうぜきかっ！？": ""
  },
  "16075": {
    "「もちろん\u3000よーく\u3000ご存知さ。\n\u3000オーガという種族全体を\u3000堕落させる\n\u3000罪深き\u3000ガートラント王家のグロスナー王。": ""
  },
  "16076": {
    "「我らは\u3000ガズバランの牙！\n\u3000オーガの未来を憂う\u3000秘密結社よ。": ""
  },
  "16077": {
    "「ガズバランの……だと？": ""
  },
  "16078": {
    "「その生涯を\u3000ひたすら修行に費やす\n\u3000オーガ本来の生き方を\u3000取り戻すため\n\u3000ジャマ者の陛下には\u3000ご退場願いましょう。": ""
  },
  "16079": {
    "「グロスナー王\u3000ご無事ですかーっ！！": ""
  },
  "16080": {
    "<center>待て……。": ""
  },
  "16081": {
    "<center>あの後ろにいる\u3000旅人。\nヤツには\u3000お前たちでは勝てぬ。\n今は\u3000退け……。": ""
  },
  "16082": {
    "「上からの命令だ。退くぞ！": ""
  },
  "16083": {
    "グロスナー王を救った\u3000<pc>たちは\nケガを負った\u3000兵士リッグを運んで\nザマ烽火台まで\u3000戻った。": ""
  },
  "16084": {
    "参謀マグナスや\u3000スピンドル兵士長も合流し\n魔物狩りは\u3000終了となった。": ""
  },
  "16085": {
    "「ガズバランの牙……\n\u3000そのような\u3000危険な秘密結社が\n\u3000ガートラント王家を狙っていたとは……。": ""
  },
  "16086": {
    "「その場にいれば\u3000このスピンドルが\n\u3000けちらしてやりましたものを……\n\u3000無念であります。": ""
  },
  "16087": {
    "「ともかく\u3000大事なくて\u3000よかった。\n\u3000リッグのケガも\u3000たいしたことがなくて\n\u3000ひと安心じゃ。": ""
  },
  "16088": {
    "「ところで\u3000魔物狩り競争は\u3000どうなった？\n\u3000わしは\u3000ウヤムヤにするつもりは\u3000ないぞ。": ""
  },
  "16089": {
    "「それでしたら\u3000１位は\u3000グロスナー王。\n\u3000２位は\u3000<pc>さんです。\n\u3000他の方は\u3000地竜のツノを持っていませんな。": ""
  },
  "16090": {
    "「……フム。そうか\u3000わしの優勝か！\n\u3000しかし\u3000わしが\u3000賞品をもらっても\u3000仕方ない。\n\u3000優勝の名誉だけを\u3000いただくとしよう。": ""
  },
  "16091": {
    "「というわけで\u3000優勝賞品は\u3000２位である\n\u3000<pc>に\u3000贈るとしよう。\n\u3000さあ\u3000ありがたく\u3000受け取るがよいぞ。": ""
  },
  "16092": {
    "「今回の魔物狩りは\u3000これで終了とする。\n\u3000思いがけぬトラブルも\u3000起こったが\n\u3000ひさしぶりで\u3000なかなか\u3000楽しめたぞ。": ""
  },
  "16093": {
    "「では\u3000わしらは\u3000城に戻るとしよう！\n\u3000<pc>\u3000ジャンガ\u3000ご苦労であった。": ""
  }
}