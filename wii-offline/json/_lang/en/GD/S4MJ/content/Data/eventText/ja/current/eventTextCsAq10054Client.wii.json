{
  "20131": {
    "「ミャー。<pc>さま。\n\u3000ソーミャお嬢さんが\u3000わざわざ\n\u3000旦那のために\u3000来てくれたんでヤンスよ。": ""
  },
  "20132": {
    "「オレのことを\u3000マンマーさまに\u3000\n\u3000とりなしてくれるそうなのニャ。": ""
  },
  "20133": {
    "「うん。私の両親のこと\u3000調べてくれたもん。\n\u3000ちゃんと\u3000約束は守らなきゃ。": ""
  },
  "20134": {
    "「あれから\u3000オレは\u3000自分のチカラで\n\u3000マンマーさまのために\u3000できることはないかと\n\u3000考えていたところなのニャが……": ""
  },
  "20135": {
    "「せっかく来てくれた\u3000ソーミャの気持ちを\n\u3000ムダにしちゃ\u3000いけないよニャ？\n\u3000だから\u3000お願いしちゃおうと思うのニャ。": ""
  },
  "20136": {
    "「だが\u3000ひとつ\u3000問題があってニャー。\n\u3000オレが\u3000ソーミャを連れていくと\n\u3000誰かに見られたときに\u3000誤解されそうなのニャ。": ""
  },
  "20137": {
    "「普通に\u3000人さらいに見えるでヤンしょね。\n\u3000あるいは……食べ……": ""
  },
  "20138": {
    "「<pc>が\u3000ソーミャを\n\u3000巨猫の巣まで\u3000連れてきてくれないかニャあ？": ""
  },
  "20139": {
    "「ありがたニャ。<pc>なら\n\u3000やってくれると思ってたのニャ。": ""
  },
  "20140": {
    "「ソーミャは\u3000<pc>に\u3000まかして\n\u3000オレとミャルジも\u3000出発するのニャー。": ""
  },
  "20141": {
    "「ミャハッ。行くでヤンス！": ""
  },
  "20142": {
    "「私は\u3000<pc>さんの後ろに隠れて\n\u3000ついていくから\u3000巨猫の巣へ向かってね。": ""
  },
  "20143": {
    "「ちょっと\u3000待つのニャ。\n\u3000<pc>は\u3000他の頼まれごとで\n\u3000いっぱいのようなのニャ。": ""
  },
  "20144": {
    "「先に終わらせてくるといいニャ。\n\u3000オレたちは\u3000狩りでもして\u3000待つのニャ。": ""
  },
  "20145": {
    "「じゃあ\u3000私は\u3000いったん\n\u3000ジュレットの町へ\u3000帰るね。": ""
  },
  "20146": {
    "「ダメかニャー。オレが\u3000ソーミャを\n\u3000連れていくのは\u3000マズいのニャよ……。": ""
  },
  "20147": {
    "「気が変わったら\u3000また来てほしいニャ。\n\u3000それまでオレたちは\u3000狩りでもしてるニャ。": ""
  },
  "20148": {
    "「じゃあ\u3000私は\u3000いったん\n\u3000ジュレットの町へ帰るね。": ""
  },
  "20149": {
    "「ミャー。<pc>さま。\n\u3000リベリオの旦那の頼みを\u3000聞きにきて\n\u3000くれたんでヤンスね？": ""
  },
  "20150": {
    "「ソーミャが\u3000オレのことを\n\u3000とりなしてくれると\u3000言ってくれたのニャ。": ""
  },
  "20151": {
    "「今から\u3000マンマーさまの所へ\u3000行くニャ。\n\u3000<pc>は\u3000巨猫の巣まで\n\u3000ソーミャを\u3000連れてきてくれないかニャあ？": ""
  },
  "20152": {
    "「ミャハッ。<pc>さま。\n\u3000リベリオの旦那が\u3000ちょっと途中で\n\u3000へたばりまして\u3000戻ってきヤンした。": ""
  },
  "20153": {
    "「すこし\u3000休んだら\u3000アッシらも向かいますんで\n\u3000<pc>さまも\u3000ソーミャお嬢さんを連れて\n\u3000巨猫の巣へ\u3000向かってほしいでヤンス。<open_irai>": ""
  },
  "20154": {
    "<close_irai>「よろしく\u3000お願いするでヤンス！！": ""
  },
  "20155": {
    "「今度こそ\u3000マンマーさまに\n\u3000ゆるしてもらうのニャー。": ""
  },
  "20156": {
    "「ミャッ？\u3000リベリオの旦那ぁ。\n\u3000置いてかないでほしいでヤンス～！": ""
  },
  "20157": {
    "「わらわは\u3000この子を守らねばならぬ……。": ""
  },
  "20158": {
    "「……みゃうう～。": ""
  },
  "20159": {
    "「……ジュニアちゃんの声？": ""
  },
  "20160": {
    "「おおっ\u3000ソーミャではないか。\n\u3000元気そうで\u3000なによりだ。": ""
  },
  "20161": {
    "「マンマーさんも\u3000お元気そうですね。": ""
  },
  "20162": {
    "「ささっ\u3000近うよれ。苦しゅうないぞ。\n\u3000ジュニアのカオを\u3000見てやっておくれ。": ""
  },
  "20163": {
    "「ジュニアは\u3000健やかに育っておる。\n\u3000すべて\u3000そなたの\u3000おかげであるぞ。": ""
  },
  "20164": {
    "「んみゃ～～。みゃ～みゃ～。": ""
  },
  "20165": {
    "「ホホホ。そなたの名を呼んだぞ？\n\u3000ジュニアも\u3000礼を言っているようだ。": ""
  },
  "20166": {
    "「本当は\u3000もっと\u3000大きくなってから\n\u3000ひとりで会いにこようと思ってたけど\n\u3000会えて\u3000うれしいよ\u3000ジュニアちゃん。": ""
  },
  "20167": {
    "「ニャー！\u3000遅れたのニャー！！": ""
  },
  "20168": {
    "「リベリオの旦那は\u3000走るのが遅いでヤンスよ。\n\u3000ダイエットしたほうが\u3000いいでヤンス！": ""
  },
  "20169": {
    "「マンマーさま！\n\u3000先日は\u3000たいへん失礼しましたニャ。": ""
  },
  "20170": {
    "「私\u3000リベリオは\u3000気づいたのですニャ。\n\u3000これからは\u3000人に頼らず\n\u3000自分のチカラで\u3000がんばりますニャ！": ""
  },
  "20171": {
    "「ですから\u3000どうか\u3000おゆるしを！": ""
  },
  "20172": {
    "「……そなたの言うことなど\n\u3000聞く耳は持たぬと\u3000言ったはずだが？": ""
  },
  "20173": {
    "「私からも\u3000お願いします\u3000マンマーさん。\n\u3000リベリオは\u3000本当は\u3000悪いネコじゃないんです！\n\u3000ゆるしてあげてくださいっ。": ""
  },
  "20174": {
    "「……ソーミャ。ありがとニャー。": ""
  },
  "20175": {
    "「………………。": ""
  },
  "20176": {
    "「リベリオよ。人には頼らぬと言ったな？\n\u3000では\u3000それを確かめさせてもらうぞ。\n\u3000わらわの頼みを\u3000そなたが聞くのだ。": ""
  },
  "20177": {
    "「この猫島を\u3000乗っ取ろうと企む者たちがいる。\n\u3000その首謀者を\u3000そなたが退治してまいれ。\n\u3000そうすれば\u3000ゆるしてやろう。": ""
  },
  "20178": {
    "「乗っ取り……ですかニャ。\n\u3000まさか\u3000その首謀者というのは……。": ""
  },
  "20179": {
    "「そうだ。ヒポポ・サードンだ。": ""
  },
  "20180": {
    "「ヒポポ・サードン……。": ""
  },
  "20181": {
    "「その名を聞くと\u3000この目が\u3000うずくのニャ。\u3000": ""
  },
  "20182": {
    "「昔\u3000猫島を襲ってきた\u3000アイツと戦い……\n\u3000勝つには勝ったが\u3000この傷を負ったのニャ。": ""
  },
  "20183": {
    "「オレが猫島から\u3000いなくなったのを知って\n\u3000また動きはじめたに\u3000ちがいないのニャ……。": ""
  },
  "20184": {
    "「マンマーさま\u3000おまかせを。\n\u3000私ひとりで\u3000アイツのアジトに乗り込んで\n\u3000今度こそ\u3000息の根を止めてきますのニャ！": ""
  },
  "20185": {
    "「ミャッ！！\u3000アッシも\u3000お供するでヤンスよ！": ""
  },
  "20186": {
    "「……来ちゃダメなのニャ！\n\u3000これは\u3000オレひとりで\u3000やることなのニャ！": ""
  },
  "20187": {
    "「ああは言ったが\u3000あやつ\u3000ひとりにやらせるには\n\u3000いささか\u3000不安があるのだ。\n\u3000そなたの手を\u3000貸してやってはくれぬか？": ""
  },
  "20188": {
    "「それが\u3000いいよ。私は\u3000ひとりで町に帰れるから\n\u3000<pc>さん\u3000リベリオを手伝ってあげて。": ""
  },
  "20189": {
    "「それじゃ\u3000マンマーさん。私は\u3000帰ります。": ""
  },
  "20190": {
    "「すまぬな\u3000ソーミャ。\n\u3000ことが済んだら\u3000いつでも\u3000来ておくれ。\n\u3000そなたに会えれば\u3000ジュニアも\u3000よろこぶ。": ""
  },
  "20191": {
    "「みゃ～みゃ～。みゃ～みゃ～。": ""
  },
  "20192": {
    "「ありがとう\u3000マンマーさん。\n\u3000また\u3000会いにくるね\u3000ジュニアちゃん！": ""
  },
  "20193": {
    "「ヒポポ・サードンのアジトは\u3000ジュレー島の北\n\u3000キュララナ海岸の\u3000海のとける洞くつの奥だ。\n\u3000<pc>よ。助太刀をしてやってくれ。": ""
  },
  "20194": {
    "「アッシも\u3000行くでヤンス！\n\u3000旦那を死なせるわけには\u3000いかねえでヤンスよ！\n\u3000海のとける洞くつに\u3000出陣でヤンス～！": ""
  },
  "20195": {
    "「ミャハッ。間に合ったでヤンス！": ""
  },
  "20196": {
    "「キサマら\u3000なんで来たのニャ。\n\u3000オレひとりでやるって\u3000言ったのニャ！": ""
  },
  "20197": {
    "「アッシは\u3000どこにだって\u3000ついてくでヤンス。\n\u3000それが\u3000敵のアジトだろうと\n\u3000地獄の三丁目だろうと\u3000おかまいなしでヤンス！": ""
  },
  "20198": {
    "「さあ\u3000旦那。ヒポポ・サードンを\n\u3000サクッと\u3000やっちまうでヤンス～。": ""
  },
  "20199": {
    "「待つのニャ。こいつは\u3000雑魚ニャ。\n\u3000ヒポポ・サードンの手下らしいのニャ。": ""
  },
  "20200": {
    "「それミャあ\u3000旦那は\u3000ヒポポ・サードンを\n\u3000探しにいってほしいでヤンス。\n\u3000ここは\u3000アッシに\u3000まかせるでヤンスよ。": ""
  },
  "20201": {
    "「さっすが\u3000ミャルジ。\n\u3000スーパー・フォローキャットなのニャ。": ""
  },
  "20202": {
    "「よし。オレは\u3000ヒポポ・サードンを\n\u3000探しにいってくるニャー！！": ""
  },
  "20203": {
    "「ミャッと。ここは\u3000通さないでヤンスよ！": ""
  },
  "20204": {
    "「グァルルルル……。": ""
  },
  "20205": {
    "「ミャギャッ！": ""
  },
  "20206": {
    "「ミャひー\u3000<cs_pchero>さま～。\u3000\n\u3000ここは\u3000一肌\u3000脱いでほしいでヤンスよ～。": ""
  },
  "20207": {
    "「アッシは\u3000うしろで\n\u3000ラブリーに\u3000応援してるでヤンスから～！": ""
  },
  "20208": {
    "「グァルルルルゥ！！": ""
  },
  "20209": {
    "「ミャヒィィッ\u3000<cs_pchero>さま！\n\u3000アッシを\u3000ひとりにするミャんて\n\u3000ひどいでヤンスよ。": ""
  },
  "20210": {
    "「リベリオの旦那も\u3000帰ってこねえでヤンスし\n\u3000ここは\u3000<cs_pchero>さまに\n\u3000一肌\u3000脱いでほしいでヤンス～！！": ""
  },
  "20211": {
    "「アッシは\u3000うしろで\n\u3000ラブリーに\u3000応援してるでヤンスから～！": ""
  },
  "20212": {
    "「グァルルルルゥ！！": ""
  },
  "20213": {
    "「さっすが\u3000<cs_pchero>さまでヤンス。\n\u3000その強さに\u3000アッシは\u3000メロメロでヤンスよ！": ""
  },
  "20214": {
    "「ニャー！\u3000このオレに恐れをなしたか\n\u3000ヒポポ・サードォォォォン！！": ""
  },
  "20215": {
    "「ミャッハー\u3000リベリオの旦那～。\n\u3000手下の雑魚は\u3000やっつけといたでヤンスよ。\n\u3000サードンは\u3000見つからなかったでヤンスか？": ""
  },
  "20216": {
    "「どこにも\u3000いなかったのニャ。\n\u3000アイツは\u3000オレが怖くて\n\u3000どこかに隠れてるに\u3000ちがいないのニャ。": ""
  },
  "20217": {
    "「ククク……おろかな……。\n\u3000サ……サードンさまが\u3000ブタネコごときに\n\u3000おびえたり\u3000するものかよ……。": ""
  },
  "20218": {
    "「ブタネコって言うの\u3000ヤメろニャ！": ""
  },
  "20219": {
    "「そうニャ。コイツに聞けば\u3000いいのニャ。": ""
  },
  "20220": {
    "「キリキリと\u3000吐くのニャ。\n\u3000ヒポポ・サードンは\u3000どこに行ったのニャ！？": ""
  },
  "20221": {
    "「……教えてやろう。サードンさまは\n\u3000新たな手下を\u3000集めに向かったのだ……。": ""
  },
  "20222": {
    "「猫島への\u3000一斉攻撃の準備さ。\n\u3000今ごろ\u3000多くの手下を従えている頃よ。\n\u3000クククク……時すでに遅い……。": ""
  },
  "20223": {
    "「なんということニャ……。\n\u3000オレは\u3000サードンに出し抜かれたのニャ！": ""
  },
  "20224": {
    "「こうなったら\u3000迎え撃つのニャ！\n\u3000猫島で\u3000アイツが来るのを待つのニャー！": ""
  },
  "20225": {
    "「……また\u3000置いていかれたでヤンス。": ""
  },
  "20226": {
    "「アッシも\u3000追いかけるでヤンスね。\n\u3000<cs_pchero>さまの\u3000シゴトは\n\u3000いったん\u3000ここで終わりってことで。": ""
  },
  "20227": {
    "「じつは\u3000マンマーさまから\u3000預かった\n\u3000お礼の品が\u3000あるんでヤンスよ。\n\u3000受け取ってほしいでヤンス。\u3000": ""
  },
  "20228": {
    "「それじゃ\u3000ごめんなすってでヤンス。": ""
  },
  "20229": {
    "「ミャハー\u3000<pc>さま。\n\u3000猫島へ\u3000行ったんでヤンスが\n\u3000マンマーさまに\u3000追いだされちまいヤンした。": ""
  },
  "20230": {
    "「オレが\u3000マンマーさまのお部屋に\n\u3000サードンを\u3000おびきよせたいとか\n\u3000余計なことを\u3000言っちまったせいニャ……。": ""
  },
  "20231": {
    "「旦那ぁ。気を落としちゃあ\u3000ダメでヤンス。\n\u3000猫島の様子は\u3000アッシが\n\u3000ちょこちょこ\u3000見にいってきヤンスから。": ""
  },
  "20232": {
    "「それミャあ\u3000さっそく\n\u3000猫島に\u3000偵察にいってくるでヤンス～。": ""
  },
  "20233": {
    "「オレは\u3000ハラが減ったから\n\u3000食い物を\u3000手に入れてくるニャ～。": ""
  }
}