{
  "15675": {
    "「おおっ\u3000<pc>か！\n\u3000よく来てくれた！": ""
  },
  "15676": {
    "「ケガを負って\u3000帰って以来\n\u3000ずっと\u3000村王の熱が下がらなかったのだが\n\u3000さきほど\u3000ついに\u3000意識を失ってしまった……。": ""
  },
  "15677": {
    "「こ\u3000このままでは\u3000村王の\u3000命が危ない！\n\u3000急いで\u3000解熱薬を用意せねばならん！": ""
  },
  "15678": {
    "「<pc>よ！\u3000材料となる\n\u3000<%sEV_QUE_NAME4>と\u3000<%sEV_QUE_NAME5>を\n\u3000早急に\u3000持ってきてもらえんか！": ""
  },
  "15679": {
    "「ありがたい！\u3000どちらも\u3000特別なことをせずとも\n\u3000手に入るものだ！\u3000もし見つからないなら\n\u3000旅人バザーを\u3000のぞいたりしてみてくれ！": ""
  },
  "15680": {
    "「私は\u3000村王から\u3000目が離せん！\n\u3000よろしく頼むぞ！！": ""
  },
  "15681": {
    "「やってくれるか……。\n\u3000だが\u3000頼まれごとで\u3000いっぱいではないか！": ""
  },
  "15682": {
    "「手遅れになる前に\u3000頼みを聞ける状態にして\n\u3000また来てくれ！\u3000急ぐのだぞ！\u3000いいな！": ""
  },
  "15683": {
    "「お前だけが\u3000頼りなのだ！\n\u3000そう言わずに\u3000もう一度\u3000考え直してくれ！": ""
  },
  "15684": {
    "「おおっ\u3000<pc>！\n\u3000来てくれたか！": ""
  },
  "15685": {
    "「村王が\u3000熱で\u3000意識を失ってしまった……。\n\u3000このままでは\u3000命が危ない！\n\u3000急いで\u3000解熱薬を用意せねばならん！": ""
  },
  "15686": {
    "「<pc>よ！\u3000材料となる\n\u3000<%sEV_QUE_NAME4>と\u3000<%sEV_QUE_NAME5>を\n\u3000早急に\u3000持ってきてもらえんか！": ""
  },
  "15687": {
    "「<pc>！\u3000戻ったか！": ""
  },
  "15688": {
    "「む……。どうやら\u3000まだ\n\u3000<%sEV_QUE_NAME4>と\u3000<%sEV_QUE_NAME5>は\n\u3000手に入らないようだな……。": ""
  },
  "15689": {
    "「ならば\u3000ここに来ている場合ではない！\n\u3000解熱薬の材料を\u3000急いで\u3000集めてきてくれ！": ""
  },
  "15690": {
    "「どうだ！\n\u3000解熱薬の材料は\u3000手に入ったか！": ""
  },
  "15691": {
    "ギュランに\u3000<%sEV_QUE_NAME4>と\n<%sEV_QUE_NAME5>を\u3000渡しますか？<yesno><close>": ""
  },
  "15692": {
    "「……そうか。まだ\u3000手に入らないか。\n\u3000ならば\u3000ここに来ている場合ではない！\n\u3000解熱薬の材料を\u3000急いで\u3000集めてきてくれ！": ""
  },
  "15693": {
    "<pc>は\u3000ギュランに\n<%sEV_QUE_NAME4>と\n<%sEV_QUE_NAME5>を\u3000渡した！": ""
  },
  "15694": {
    "「おおっ！\u3000ありがたい！\n\u3000さっそく\u3000解熱薬を\u3000調合しよう！\n\u3000これで\u3000村王を\u3000助けられるぞ！": ""
  },
  "15695": {
    "「よく眠っておられる……。\n\u3000どうやら\u3000落ち着いたようだ。": ""
  },
  "15696": {
    "「しばらく\u3000ゆっくり眠れば\n\u3000また元気な村王に\u3000戻られるだろう。\n\u3000ありがとう。<pc>のおかげだ。": ""
  },
  "15697": {
    "「……私は\u3000１０年\u3000お仕えしているが\n\u3000村王の\u3000お気持ちは\u3000まだまだ\n\u3000理解できていない部分が\u3000多いのかもしれんな。": ""
  },
  "15698": {
    "「……だが\u3000心から\u3000人に優しい方であることは\n\u3000知っている。今\u3000多くを語られないことにも\n\u3000相応の理由が\u3000あってのことなのだろう……。": ""
  },
  "15699": {
    "「村王！\u3000村王ーっ！！": ""
  },
  "15700": {
    "「やめんかっ！\u3000村王は\u3000お休み中だ！": ""
  },
  "15701": {
    "「た\u3000大変なんです！！": ""
  },
  "15702": {
    "「何事だ。\n\u3000つまらんことだったら\u3000承知せんぞ。": ""
  },
  "15703": {
    "「む\u3000村の武闘場に\n\u3000見たことのないヤツが\u3000入り込んできて\n\u3000占拠してるんです！": ""
  },
  "15704": {
    "「で\u3000そいつは\u3000自分のことを\n\u3000死神だとか\u3000言ってやがるんです！": ""
  },
  "15705": {
    "「なんだと……？": ""
  },
  "15706": {
    "「それは\u3000確かに\u3000ただごとではないな。\n\u3000村王が\u3000このようなときに\n\u3000村を\u3000襲ってくるとは……。": ""
  },
  "15707": {
    "「<pc>よ！\n\u3000すまないが\u3000武闘場の様子を\n\u3000見にいってくれ！": ""
  },
  "15708": {
    "「味方が増えるのは\u3000ありがたい！\n\u3000一緒に\u3000行きましょう！": ""
  },
  "15709": {
    "「<pc>っ！\n\u3000私は\u3000村王のそばから\u3000離れられん！": ""
  },
  "15710": {
    "「武闘場の様子を\u3000見にいってくれ！\n\u3000頼れるのは\u3000お前だけだ！\u3000頼むぞ！": ""
  },
  "15711": {
    "「……これで\u3000もう終わりか？": ""
  },
  "15712": {
    "「強さこそ至上と唱えた\u3000ランガーオ村とは\n\u3000とても思えぬ\u3000歯ごたえのなさだ。": ""
  },
  "15713": {
    "「どうやら\u3000集まってきたようだな。": ""
  },
  "15714": {
    "「ランガーオ村の\u3000愚民どもに告ぐ！\n\u3000オレは\u3000今から\u3000この村を\u3000滅ぼす！！": ""
  },
  "15715": {
    "「不意打ちのような\u3000ひきょうなマネはしない。\n\u3000戦う意志のあるやつは\n\u3000全員\u3000相手をしてやろう！": ""
  },
  "15716": {
    "「さあ\u3000好きなタイミングで\u3000かかってこい！\n\u3000束になってきても\u3000構わんぞ！！": ""
  },
  "15717": {
    "「やれやれ。どうやら\u3000今\n\u3000この村にいるのは\u3000戦う勇気さえも失った\n\u3000情けないオーガばかりのようだな。": ""
  },
  "15718": {
    "「ならば\u3000こっちも遠慮はせん。\n\u3000端から順番に\u3000殺していってやろう。\n\u3000命乞いしたいやつは\u3000せいぜい叫ぶがいい。": ""
  },
  "15719": {
    "「き\u3000き\u3000貴様ぁ！\n\u3000次は……\u3000次は\u3000オ\u3000オレが相手だ！": ""
  },
  "15720": {
    "「よし。それでこそ\n\u3000ランガーオ村の\u3000勇気あるオーガだ。\n\u3000次に死ぬのは\u3000お前にしてやる。": ""
  },
  "15721": {
    "「……待てっ！": ""
  },
  "15722": {
    "「ギュランよ……。すまんな。\n\u3000ここからは\u3000ひとりで行く。": ""
  },
  "15723": {
    "「村王…………。": ""
  },
  "15724": {
    "「……ガガイよ。\n\u3000今\u3000この村には\u3000お前に勝てるような\n\u3000強いオーガは\u3000ひとりもいない……。": ""
  },
  "15725": {
    "「……だが\u3000わしは\u3000この村の王だ。\n\u3000たとえ\u3000どんなことをしてでも\n\u3000村の者を\u3000守り抜かなくてはならない。": ""
  },
  "15726": {
    "「これが\u3000今の\u3000わしにできる\u3000すべてだ。": ""
  },
  "15727": {
    "「この通りだ。頼む……。\n\u3000この村の者を\u3000殺さないでくれ……。\n\u3000わしの命ならば\u3000いくらでも\u3000くれてやる。": ""
  },
  "15729": {
    "「はっはっは！\n\u3000いい姿だな\u3000クリフゲーン。": ""
  },
  "15730": {
    "「見るがいい\u3000ランガーオ村の者たちよ！\n\u3000これが\u3000貴様らが\u3000村王などと呼び\n\u3000崇める者の\u3000本当の姿だ！": ""
  },
  "15731": {
    "「つい先日のことだ。\n\u3000この男は\u3000オレとの真剣勝負に敗れた。\n\u3000今も\u3000そのキズで\u3000満足に動けないようだ。": ""
  },
  "15732": {
    "「この男は\u3000敗者だ！\n\u3000貴様らは\u3000それを知っても\u3000この男を\n\u3000同じように\u3000村王と呼び続けられるのか！！": ""
  },
  "15733": {
    "「よ\u3000呼び続けられるもん……。": ""
  },
  "15734": {
    "「そうだよっ！\u3000村王は\u3000村王だもん！\n\u3000勝者とか敗者とか\u3000そんなのカンケーないよっ！": ""
  },
  "15737": {
    "「この村に\u3000お前の居場所は\u3000なーいっ！\n\u3000早々に\u3000立ち去れい！": ""
  },
  "15738": {
    "「き…貴様ら……。": ""
  },
  "15739": {
    "「……ガガイよ。今は\u3000ちがうのだ。\n\u3000ランガーオ村は\u3000変わったのだ。": ""
  },
  "15740": {
    "「だ\u3000だまれえええっ！！！": ""
  },
  "15741": {
    "「変わったなど\u3000オレは認めんっ！！\n\u3000貴様ら\u3000皆殺しにしてやるっ！！": ""
  },
  "15742": {
    "「<cs_pchero>っ！\u3000村王を！\n\u3000村王を\u3000お守りしてくれっ！！": ""
  },
  "15743": {
    "「<cs_pchero>っ！\u3000戻ってきてくれたか！": ""
  },
  "15744": {
    "「今度こそ\u3000ガガイを倒し\u3000村王を……\n\u3000いや\u3000この村を\u3000守ってくれっ！！": ""
  },
  "15745": {
    "「何度やっても\u3000同じことだ！\n\u3000この村のやつらは\u3000ひとり残らず\n\u3000殺してやるっ！！": ""
  },
  "15746": {
    "「……バ\u3000バカな。\n\u3000このオレが……敗れた…だと……？": ""
  },
  "15747": {
    "「……これが\u3000神の意志だというのか。\n\u3000親子二代に渡り\u3000同じ場所で\n\u3000同じ屈辱にまみれて\u3000死ねと……。": ""
  },
  "15748": {
    "「オレの……負けだ！\u3000さあ\u3000オレを殺せ！": ""
  },
  "15749": {
    "「お前たちが\u3000父と母にしたのと同じように\n\u3000敗れた弱者を\u3000さげすみながら\n\u3000オレを\u3000殺すがいい！": ""
  },
  "15750": {
    "「お前を\u3000死なすわけにはいかん。": ""
  },
  "15753": {
    "「どっちも\u3000サイコーに\u3000かっけーぜっ！\n\u3000オイラ\u3000チョーあこがれちまうぜーっ！": ""
  },
  "15754": {
    "「見てくれ\u3000ガガイ。\n\u3000このランガーオ村は\u3000変わったのだ。": ""
  },
  "15755": {
    "「死への恐怖に打ち勝ち\u3000勇気を持って\n\u3000戦った両者を\u3000等しく敬え。\n\u3000それが\u3000今の\u3000この村の教えだ。": ""
  },
  "15756": {
    "「お前が\u3000村を出ていってから\n\u3000２０年かけて……\u3000この教えを\n\u3000村の皆に\u3000行きわたらせたのだ。": ""
  },
  "15757": {
    "「ガガイよ。言わば\u3000お前の父親の死が\n\u3000今の\u3000この村の姿を\u3000作ったのだ……。": ""
  },
  "15758": {
    "「バカな…………。": ""
  },
  "15759": {
    "「もう一度言う。ガガイよ。": ""
  },
  "15760": {
    "「お前には\u3000この村で\u3000暮らしてほしい。\n\u3000そして\u3000その強さを\n\u3000この村のために\u3000役立ててほしいのだ。": ""
  },
  "15761": {
    "「それが\u3000かなえば\u3000きっと\n\u3000ガガベスも\u3000報われるだろう……。": ""
  },
  "15762": {
    "「これは\u3000私も\u3000最近\u3000村人から聞いて\n\u3000知ったことだが……。": ""
  },
  "15763": {
    "「この村では\u3000当時\u3000敗者の墓を作ることは\n\u3000禁じられていた。だが\u3000村王は\u3000オキテを破って\n\u3000ガガベス殿の墓を作り\u3000今も供養しているのだ。": ""
  },
  "15764": {
    "「墓を作ったことも\u3000新しい教えを\n\u3000行きわたらせたことも\u3000すべては\u3000いつの日か\n\u3000そなたを\u3000この村に\u3000迎えたいと願ったため。": ""
  },
  "15765": {
    "「ガガイ殿よ……。\n\u3000どうか\u3000村王の気持ちを\u3000察してくれまいか。": ""
  },
  "15766": {
    "「わかった……。もう充分だ。": ""
  },
  "15767": {
    "「だが……オレには\u3000オレの\u3000けじめがある。\n\u3000この村で\u3000暮らすことは\u3000できない……。": ""
  },
  "15768": {
    "「オレは\u3000罪を重ねすぎた……。": ""
  },
  "15769": {
    "「ありがとう\u3000<cs_pchero>よ。\n\u3000まったく\u3000お前には\n\u3000最後まで\u3000世話に\u3000なりっぱなしだったな。": ""
  },
  "15770": {
    "「せめてものことは\u3000させてほしい。\n\u3000後で\u3000わしの所に\u3000来てくれ。": ""
  },
  "50293": {
    "「村王さま……。": ""
  },
  "50294": {
    "「そうだそうだ！\n\u3000オレたちが\u3000村王を尊敬しているのは\n\u3000強いからだけじゃないぞ！": ""
  },
  "50295": {
    "「あたしたちは\u3000村王が\u3000立派な人だから\n\u3000心から\u3000尊敬してるんだよ！": ""
  },
  "50296": {
    "「ガガイーっ！\n\u3000お前は\u3000負けはしたが\u3000すごかったぞー！": ""
  },
  "50297": {
    "「最後まで\u3000あきらめずに戦い続けて\n\u3000<cs_pchero>も\u3000ガガイも\u3000本当に立派だよ！\n\u3000あたし\u3000感動で\u3000泣けてきたよっ！！": ""
  }
}