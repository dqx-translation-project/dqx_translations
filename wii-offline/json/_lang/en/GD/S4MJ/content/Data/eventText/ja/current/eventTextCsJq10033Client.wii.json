{
  "13381": {
    "「ああ\u3000<pc>さん。おひさしぶりです。\n\u3000おたがい\u3000レベル４０以上に\u3000なった頃かと思い\n\u3000連絡を\u3000取ろうとしてたんですよ。": ""
  },
  "13382": {
    "「この間なんて\u3000全然ちがう人に\n\u3000話しかけてしまって\u3000ずいぶん\u3000相手を\n\u3000おどろかせてしまいました。": ""
  },
  "13383": {
    "「あなたと\u3000こうして話すのも\n\u3000もう\u3000けっこうな回数になるのに\n\u3000あんな失敗するなんて\u3000情けない限りです。": ""
  },
  "13384": {
    "「…………。": ""
  },
  "13385": {
    "「……あのぅ\u3000<pc>さん。": ""
  },
  "13386": {
    "「もし……もし\u3000よかったらで\n\u3000いいんですけれど……\n\u3000一度\u3000私と\u3000会ってみませんか？": ""
  },
  "13387": {
    "「おたがい\u3000相手の顔が\u3000わからないので\n\u3000目印となる服装と\u3000待ち合わせ場所を\n\u3000決めておくと\u3000いいと思うんです。": ""
  },
  "13388": {
    "「……そうですね。<%sEV_QUE_NAME4>を装備して\n\u3000プクランド大陸のミュルエルの森\n\u3000フォステイル広場で会うなんて\u3000どうです？": ""
  },
  "13389": {
    "「おお\u3000よかった！\n\u3000断られるんじゃないかと思って\n\u3000ドキドキしちゃいましたよ。": ""
  },
  "13390": {
    "「じつは\u3000以前から\u3000<pc>さんとは\n\u3000直接\u3000会ってみたいと思ってたんです。\n\u3000あなたも\u3000同じ気持ちだったみたいですね。": ""
  },
  "13391": {
    "「おたがいに\u3000<%sEV_QUE_NAME4>を装備して\n\u3000ミュルエルの森のフォステイル広場で\n\u3000待ち合わせですよ。忘れないでくださいね！": ""
  },
  "13392": {
    "「それでは\u3000今日のところは\u3000失礼します。\n\u3000お会いできるの\u3000楽しみにしてますから！": ""
  },
  "13393": {
    "「よかった！……と言いたいところですが\n\u3000あなたは\u3000今\u3000たくさんの頼まれごとを\n\u3000抱えているみたいですね。": ""
  },
  "13394": {
    "「しかたありません。\n\u3000この件は\u3000また今度……ということで。": ""
  },
  "13395": {
    "「……そうですか。残念ですね。\n\u3000もし\u3000気が変わったら\u3000また\n\u3000この鏡に\u3000話しかけてみてください。": ""
  },
  "13397": {
    "「……あ！\u3000もしかして\u3000直接\u3000会いたいって\n\u3000私の願いを\u3000かなえてくださるとか？": ""
  },
  "13398": {
    "「<%sEV_QUE_NAME4>をつけたヤツ……\n\u3000貴様が\u3000リュナンだな？": ""
  },
  "13399": {
    "「……あで？\u3000おかしいど\u3000アニキ。\n\u3000聞いた話だど\u3000リュナンって奴は\u3000もっと……": ""
  },
  "13400": {
    "「うっせー\u3000うっせー！\n\u3000メギドローム様は\u3000<%sEV_QUE_NAME4>を\n\u3000つけたヤツを\u3000連れてこいって言ってただろ？": ""
  },
  "13401": {
    "「だったら\u3000オレら\u3000舎弟は\n\u3000言われたとおりにするだけだろーが！": ""
  },
  "13402": {
    "「……あぐぅ。\n\u3000そ\u3000それも\u3000そうなんだな。": ""
  },
  "13403": {
    "「おい\u3000貴様っ！\u3000メギドローム様の命令だど。\n\u3000一緒に\u3000来てもらうかんな！": ""
  },
  "13404": {
    "「抵抗しても\u3000いいんだぜぇ！\n\u3000ただし\u3000ようしゃなく\u3000たたきのめすケドな！\n\u3000グヒャヒャヒャ……。": ""
  },
  "13405": {
    "「……あのぅ\u3000もしかして\u3000あなたが\n\u3000<cs_pchero>さんですか？<yesno><close>": ""
  },
  "13406": {
    "「ああ\u3000よかった！\n\u3000ウルトラ速達便で\u3000ここに届けるよう\n\u3000言われて\u3000はるばる来たんです。": ""
  },
  "13407": {
    "「こんな魔物の出る\u3000危険な場所で\n\u3000もし\u3000届ける相手が\u3000見つからなかったら\n\u3000どうしようかと思いましたよー。": ""
  },
  "13408": {
    "「うわー\u3000どうしよう！\n\u3000ウルトラ速達便で\u3000ここに届けるよう\n\u3000言われて\u3000来たんですよー。": ""
  },
  "13409": {
    "「もう\u3000特別料金\u3000もらっちゃってるから\n\u3000放りだすわけにも\u3000いかないし……。": ""
  },
  "13410": {
    "「いいや！\u3000もう\u3000あなたに\u3000託しちゃいます。\n\u3000<cs_pchero>って人が\u3000来たら\n\u3000あなたから\u3000渡してあげてください！": ""
  },
  "13411": {
    "「それじゃ\u3000これ\u3000受け取ってくださいね。": ""
  },
  "13412": {
    "<cs_pchero>は\nリュナンの手紙（だいじなもの）を\u3000受け取った！<me 60>": ""
  },
  "13413": {
    "「確かに\u3000渡しましたから！\n\u3000では\u3000私は\u3000これで失礼しますっ！": ""
  },
  "13414": {
    "<cs_pchero>は\u3000リュナンの手紙を読んだ。": ""
  },
  "13415": {
    "親愛なる\u3000<cs_pchero>さんへ\nまず\u3000最初に\u3000謝らせてください。\n今日は\u3000行けなくて\u3000すみませんでした。": ""
  },
  "13416": {
    "ギリギリになって\u3000どうしても行けない理由が\nできてしまい\u3000中止を伝えようにも方法がなく\n間に合わなかったのです。": ""
  },
  "13417": {
    "くわしい事情は\u3000シーバの鏡を通して\n説明したいので\u3000申し訳ないのですが\n戻ってもらえないでしょうか？": ""
  },
  "13418": {
    "どうか\u3000この手紙が\n無事\u3000あなたの元に\u3000届きますように。\n\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000あなたの友人\u3000リュナンより": ""
  },
  "13420": {
    "「待ち合わせに\u3000行けなかったばかりか\n\u3000魔物が\u3000私とあなたを\u3000まちがえて\n\u3000襲いかかるなんて……。": ""
  },
  "13421": {
    "「もう\u3000お気づきのこととは思いますが\n\u3000じつは\u3000私\u3000メギドロームという魔物に\n\u3000ねらわれているんです。": ""
  },
  "13422": {
    "「今回\u3000行けなかったのも\u3000私が\n\u3000フォステイル広場に\u3000行くという予定が\n\u3000ヤツに\u3000バレてしまったからなんですよ。": ""
  },
  "13423": {
    "「……でも\u3000こっちの勝手な都合ですよね。\n\u3000せめてもの\u3000おわびの気持ちです。\n\u3000どうか\u3000これを受け取ってください。": ""
  },
  "13424": {
    "「……今回のことで\u3000こりましたよ。\n\u3000魔物にねらわれている身の上で\n\u3000人と会おうなんて\u3000まちがいでした。": ""
  },
  "13425": {
    "「……いえ。この鏡での会話も\u3000しばらくは\n\u3000ひかえた方が\u3000いいかもしれませんね。": ""
  },
  "13426": {
    "「せめて\u3000メギドロームなど恐れずにすむくらい。\n\u3000具体的には\u3000レベル４５以上の魔法使いに\n\u3000なるまでは……。": ""
  },
  "13427": {
    "「あ\u3000あなたたちは\u3000なんですかっ！？": ""
  },
  "13428": {
    "「な\u3000何をする……うぐっ！！": ""
  },
  "13429": {
    "「…………。": ""
  },
  "13552": {
    "「おう\u3000おう\u3000また来てくれるとは\n\u3000うれしーじゃねえか！": ""
  },
  "13553": {
    "「連れてこいって\u3000命令なのに\n\u3000ブッ倒しちまって\u3000どうすんだって\n\u3000困ってたところだったんだど。": ""
  },
  "13554": {
