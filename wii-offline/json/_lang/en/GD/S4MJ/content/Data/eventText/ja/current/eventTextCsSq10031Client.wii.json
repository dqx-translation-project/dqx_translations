{
  "53222": {
    "「ただいまより\u3000第１回\n\u3000アストルティア・クイーン\u3000コンテストに\n\u3000参加する\u3000うるわしき美女たちを紹介します！": ""
  },
  "53223": {
    "「オーグリード大陸に咲く\u3000一輪の赤いバラ！\n\u3000どんな豪傑も\u3000気安く近づけば返り討ち！\n\u3000パワーと美しさをあわせ持つ\u3000才女……": ""
  },
  "53224": {
    "「オーガニック\u3000ビューティー！\u3000マイユ！": ""
  },
  "53225": {
    "「こんな盛大なイベントに参加できて\u3000光栄だわ。\n\u3000強敵ばかりだけど\u3000これは\u3000真剣勝負……\n\u3000絶対に\u3000クイーンの座を勝ち取ってみせる！": ""
  },
  "53226": {
    "「風の町アズランに\u3000ひっそりと咲く\u3000月見草！\n\u3000その\u3000つぶらな瞳は\u3000見る者をとりこに！\n\u3000カムシカたちの\u3000アイドル……": ""
  },
  "53227": {
    "「夢見る風乗り少女\u3000フウラ！": ""
  },
  "53228": {
    "「お父さまが\u3000勝手に応募しちゃったけど\n\u3000わ…私なんかが\u3000勝てるのかな？\n\u3000みんなに見られて\u3000は…はずかしい……。": ""
  },
  "53229": {
    "「あたしのゼニは\u3000あたしの物！\n\u3000あんたのゼニも\u3000あたしの物！\n\u3000その若さに似合わぬ\u3000守銭奴の中の守銭奴……": ""
  },
  "53230": {
    "「お金大好きガール\u3000ジェニャ！": ""
  },
  "53231": {
    "「こら！\u3000お金のことしか言ってないで！": ""
  },
  "53232": {
    "「てへへっ。あたしを\u3000クイーンにしたってや。\n\u3000クイーンになって\u3000この城を\u3000もらいたいんや。\n\u3000でな\u3000城を貸し出して\u3000使用料を……": ""
  },
  "53233": {
    "「こら！\u3000まだ\u3000言い終わってないで！": ""
  },
  "53234": {
    "「ウェナ諸島に平安をもたらす\u3000美しきディーバ！\n\u3000その歌声に\u3000ウェディたちはメロメロ！\n\u3000まさか\u3000本物のクイーンが来てくれるとは……": ""
  },
  "53235": {
    "「恵みの女王\u3000ディオーレ！": ""
  },
  "53236": {
    "「クイーン\u3000コンテストと聞いては\n\u3000わらわが参加しないワケには\u3000いくまい。\n\u3000本物の女王の威厳を\u3000知るがよいぞ。": ""
  },
  "53237": {
    "「岳都ガタラを駆け抜ける\u3000黒い影！\n\u3000今夜のエモノは\u3000あなたのハート！\n\u3000天知る！\u3000地知る！\u3000人ぞ知る……": ""
  },
  "53238": {
    "「美少女怪盗ポイックリン！\n\u3000華麗に\u3000参上でございますわっ！": ""
  },
  "53239": {
    "「私に盗めぬ物は\u3000なし！\n\u3000クイーンの座も\u3000華麗に盗んでみせますわ！\n\u3000ドワーフのみんな\u3000よろしくねっ！": ""
  },
  "53240": {
    "「すべての男は\u3000私に\u3000ひれ伏す！\n\u3000彼女に打ちのめされた旅人は\u3000数知れず！\n\u3000ただいま\u3000下僕を募集中……": ""
  },
  "53241": {
    "「暴走メガネっ娘\u3000ルナナ！": ""
  },
  "53242": {
    "「ふん……。時間のムダね。\n\u3000こんなコンテストなんか\u3000やるまでもないわ。\n\u3000クイーンになるのは\u3000あたしに決まってるのに。": ""
  },
  "53243": {
    "「そこの\u3000あなた！\n\u3000いいわね？\u3000あたしを選ぶのよ。\n\u3000あたしに\u3000ひざまずけるなんて\u3000光栄でしょ？": ""
  },
  "53244": {
    "「ジュレットの町に舞い降りた\u3000心優しき天使！\n\u3000彼女に頼まれたら\u3000誰も断れない！\n\u3000あなたの妹に\u3000なってもいいですか？": ""
  },
  "53245": {
    "「薄幸の美少女\u3000ソーミャ！": ""
  },
  "53246": {
    "「こ…こんにちは！": ""
  },
  "53247": {
    "「クイーンになれば\u3000お友達が増えるかなって。\n\u3000だから\u3000コンテストに参加してみたの……。\n\u3000私でよければ\u3000応援してください！": ""
  },
  "53248": {
    "「フランクな口調が\u3000チャームポイント！\n\u3000その明るさで\u3000みんなの心を\u3000わしづかみにした\n\u3000あの人が\u3000天国から\u3000まさかの参戦！": ""
  },
  "53249": {
    "「天然☆予知っ娘ママ\u3000アルウェ王妃！": ""
  },
  "53250": {
    "「ちっちっち。ちがいまぁーすっ。": ""
  },
  "53251": {
    "「あたしはぁ\u3000アルウェ王妃ちゃん様でーす。\n\u3000あたしぃ\u3000予知っ娘だから\u3000結果は\n\u3000見えてるけどぉ\u3000教えてあげませ～んっ。": ""
  },
  "53252": {
    "「すべてのスーパースターが\u3000彼女に嫉妬する\n\u3000１００年にひとりの\u3000天才！\n\u3000その踊りは\u3000見る者をノックアウトしてしまう！": ""
  },
  "53253": {
    "「ザ・スーパースター！\u3000プレシアンナ！": ""
  },
  "53254": {
    "「なぜ\u3000あたしが\u3000クイーンに選ばれるのか……\n\u3000それは\u3000あたしが\u3000プレシアンナだから<heart>\n\u3000トップスターに\u3000敗北の二文字はないってやつ？": ""
  },
  "53255": {
    "「あこがれの\u3000いやし系お姉様！\n\u3000ああ！\u3000そのムネに抱かれて\u3000眠りたい……！\n\u3000今大会のダークホース……": ""
  },
  "53256": {
    "「ダイナマイト女賢者\u3000マリーン！": ""
  },
  "53257": {
    "「あっはっはっは！\u3000他の連中は\u3000やせっぽちで\n\u3000全然\u3000女としての魅力が\u3000足りないねえ！": ""
  },
  "53258": {
    "「いいかい！\u3000クイーンに必要なのは\n\u3000すべてを包み込む\u3000包容力と決まってるのさ！\n\u3000この勝負\u3000い・た・だ・き<heart>": ""
  },
  "53259": {
    "「以上\u3000１０名の美女たちが\n\u3000クイーンの座を賭けて\u3000コンテストを争います。": ""
  },
  "53260": {
    "「果たして\u3000栄光の座に\u3000かがやくのは\n\u3000誰なのか！？\n\u3000それを決めるのは\u3000あなたなのですっ！！": ""
  },
  "53261": {
    "「どうですか\u3000<pc>さん。\n\u3000お気に入りの美女は\u3000見つかりましたか？": ""
  },
  "53262": {
    "「クイーンにふさわしいと思う\u3000美女が決まったら\n\u3000その方から\u3000チョコを受け取ってください。\n\u3000ただし\u3000チョコを受け取れるのは\u3000ただひとり！": ""
  },
  "53263": {
    "「あなたが\u3000チョコを受け取った相手に\n\u3000あなたの一票が\u3000投じられるのです。\n\u3000よく\u3000お考えの上\u3000選んでくださいね。": ""
  },
  "53279": {
    "「ただいまより\u3000第１回\n\u3000アストルティア・クイーン\u3000コンテストの\n\u3000結果発表を\u3000おこないます！": ""
  },
  "53280": {
    "「この\u3000ショコラフォンテヌ城の\n\u3000クイーンの座は\u3000いったい\u3000誰の手に！？\n\u3000その結果が\u3000ついに\u3000明らかになるのです！！": ""
  },
  "53281": {
    "「皆さま！\u3000ステージに\u3000ご注目ください！": ""
  },
  "58803": {
    "「選び終わりましたら\u3000お話がありますので\n\u3000私の所に\u3000お立ち寄りください。\n\u3000外にいますので\u3000よろしくお願いしますね。": ""
  }
}