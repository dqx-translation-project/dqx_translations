{
  "13640": {
    "「義賊のヤツらめ……。\n\u3000なぜ\u3000このオレが\u3000あの偽善者どもに\n\u3000引けを\u3000とらなきゃいけないんだ！": ""
  },
  "13641": {
    "「オレが\u3000間違ってるっていうのか！？\n\u3000答えろよ\u3000ギャスモン！": ""
  },
  "13642": {
    "「答エナド\u3000必要ナイ。\n\u3000汝ハ\u3000求メレバ\u3000得ラレルノダ。\n\u3000ソノ欲望コソガ\u3000汝ノ\u3000ちから……。": ""
  },
  "13643": {
    "「へへっ\u3000そうか。それじゃあ\n\u3000今よりも\u3000強い魔物を操るチカラをくれ！\n\u3000旅団を\u3000もっと\u3000でかくしてやるんだ！": ""
  },
  "13644": {
    "「マタ\u3000魔物ヲ\u3000操ルちからカ……。\n\u3000ソロソロ\u3000汝自身\u3000強クナル\n\u3000必要ガ\u3000アルノデハ\u3000ナイカ……？": ""
  },
  "13645": {
    "「ソノ手デ\u3000憎シミヲ\u3000断ツタメニ……。": ""
  },
  "13646": {
    "「ホウラ……。ソノコトヲ告ゲル\n\u3000使者ガ\u3000来タヨウダ……。": ""
  },
  "13647": {
    "「何しにきやがった。\n\u3000オレを\u3000正しい道に進ませようとか\n\u3000ふざけたこと\u3000考えてんじゃねえだろうな。": ""
  },
  "13648": {
    "「チッ！\u3000親父と同じ\u3000偽善者の目……。\n\u3000その目を見てると\u3000むしずが走るぜ！\n\u3000アンタ\u3000親父が何したか\u3000知ってんのかよ！": ""
  },
  "13649": {
    "「ムーチョが\u3000町長の家に盗みに入った日……\n\u3000オレの母さんは\u3000生死の境を\u3000さまよっていた。\n\u3000……何年も続いた\u3000大病の果てにな。": ""
  },
  "13650": {
    "「うちは\u3000貧乏でよ。薬を買う金もなかった……。\n\u3000そんなとき\u3000町長の財宝を持ったムーチョが\n\u3000うちに来たのさ。オレは\u3000小おどりしたね！": ""
  },
  "13651": {
    "「……けどよ！\u3000ムーチョは……\n\u3000親父は\u3000母さんの\u3000まくらもとに立っても\n\u3000何も置いていかずに\u3000去っていったんだ！": ""
  },
  "13652": {
    "「次の日に\u3000母さんは\u3000死んだよ。\n\u3000親父は泣いてたが\u3000今思えば\u3000あのときの涙も\n\u3000うそっぱちだったに\u3000ちがいねえ。": ""
  },
  "13653": {
    "「オレは\u3000ムーチョへの復讐を誓い\u3000家を出た。\n\u3000……そして\u3000ここにいるギャスモンと出会い\n\u3000魔物を操るチカラを\u3000手に入れたのさ！": ""
  },
  "13654": {
    "「盗賊なんて\u3000しょせん悪党……。\n\u3000そのことを\u3000世間に教えてやるために\n\u3000つむじ風の旅団を\u3000結成したんだ！": ""
  },
  "13655": {
    "「でもよ……\u3000もう\u3000つむじ風の旅団なんて\n\u3000まわりくどいことは\u3000やめるぜ。\n\u3000オレは\u3000貴様らを\u3000直接\u3000皆殺しにしてやる！": ""
  },
  "13656": {
    "「ギャスモン！\u3000さあ\u3000オレにチカラをくれ！\n\u3000こいつらを\u3000ひねりつぶすための\n\u3000絶大なチカラを……！！": ""
  },
  "13657": {
    "「スベテハ\u3000欲望ノ\u3000オモムクママニ……。": ""
  },
  "13658": {
    "「おお……\u3000みなぎる\u3000みなぎるぞ！！！\n\u3000黒いチカラが\u3000オレの身体に………ッ！！！": ""
  },
  "13659": {
    "「ウガァァァァァァァァァァァ……！！！": ""
  },
  "13660": {
    "「ブルルルルッ！\n\u3000すべての義賊に\u3000死を……！\n\u3000死を\u3000死をォォォ…………ッ！！！": ""
  },
  "13661": {
    "「ブルルルルッ！！\u3000何度来ても同じこと！\n\u3000貴様ら\u3000義賊は\u3000オレには勝てん！！\n\u3000正しいのは\u3000オレのほうだ！！": ""
  },
  "13662": {
    "「ブルルルルッ！\n\u3000すべての義賊に\u3000死を……！\n\u3000死を\u3000死をォォォ…………ッ！！！": ""
  },
  "13663": {
    "「ブ…ブルルルル……。\n\u3000憎しみに身をまかせ\u3000チカラを得た\n\u3000このオレが\u3000なぜ\u3000義賊なんかに……。": ""
  },
  "13664": {
    "「憎しみが\u3000足りないのか……？\n\u3000義賊を……\u3000親父を\u3000憎む心が……。": ""
  },
  "13665": {
    "「この\u3000バカ息子ーーーーー！！！": ""
  },
  "13666": {
    "「アンタは\u3000母親の思いを\u3000踏みにじる気かい！！\n\u3000妻を救えなかった\u3000親父さんの気持ちを\n\u3000少しでも\u3000考えたことが\u3000あるのかい！？": ""
  },
  "13667": {
    "「アンタの親父さんね\u3000このままじゃいけないって\n\u3000あたいに\u3000真相を話してくれたよ。\n\u3000アンタも\u3000耳の穴かっぽじって\u3000よく聞きな！": ""
  },
  "13668": {
    "「……町長の家に盗みに入った\u3000あの日\n\u3000ワシは\u3000お前の母を\u3000助けられるだけのカネを\n\u3000置いていこうとしたんだ。": ""
  },
  "13669": {
    "「だが\u3000お前の母は……": ""
  },
  "13670": {
    "「私たちの約束を\u3000忘れたのですか……。\n\u3000そう言って\u3000カネを置いていくことを\n\u3000強く\u3000こばんだのだ。": ""
  },
  "13671": {
    "「約束……？\n\u3000約束って\u3000なんだよ……？": ""
  },
  "13672": {
    "「ワシが\u3000ムーチョになると決めたとき\n\u3000妻は\u3000いっさいの盗品を\u3000自分たちのために\n\u3000使わないと\u3000約束してくれ\u3000と言った。": ""
  },
  "13673": {
    "「盗んだものを\u3000少しでも\u3000自分たちのために\n\u3000使ってしまえば\u3000それは義賊ではなく\n\u3000ただのドロボーだ……と\u3000そう告げたのだ。": ""
  },
  "13674": {
    "「そして\u3000私利私欲のために\u3000動くのではなく\n\u3000人のために尽くすことを\u3000固く誓い\n\u3000ワシは\u3000ムーチョになったのだ……。": ""
  },
  "13675": {
    "「ねえ\u3000チャムール。\n\u3000ふたりの心意気……。\n\u3000アンタには\u3000もう\u3000わからないのかい？": ""
  },
  "13676": {
    "「この\u3000オルゴールの音色を聞いても\n\u3000母親の優しさを\u3000思いだせなかったのかい？": ""
  },
  "13677": {
    "「母さん……。": ""
  },
  "13678": {
    "「うっ…\u3000うおおおおぉぉぉ！！": ""
  },
  "13679": {
    "「憎シミノ心ガ\u3000消エタ……。\n\u3000コノ器ハ\u3000使エヌ。欲望ガ足リヌ……。": ""
  },
  "13680": {
    "「チャムール！！": ""
  },
  "13681": {
    "「すまなかったなあ\u3000チャムール……。\n\u3000もう\u3000お前を\u3000ひとりにはせん。\n\u3000やり直そう。ワシと\u3000一緒に……。": ""
  },
  "13682": {
    "「……グスッ。ダメだね……。\n\u3000あたい\u3000こういうのには\u3000弱いんだ。": ""
  },
  "13683": {
    "「……さてと\u3000これにて\u3000一件落着だね。\n\u3000つむじ風の旅団も\u3000いなくなったし\n\u3000ブデチョたちの\u3000わだかまりも消えたよ。": ""
  },
  "13684": {
    "「<cs_pchero>\u3000今回も\u3000また大活躍だったね。\n\u3000その礼をするからさ\n\u3000ガタラの酒場に\u3000来ておくれよっ。": ""
  },
  "13685": {
    "「では\u3000ワシから\u3000礼をさせてくれ。": ""
  },
  "13686": {
    "「<pc>よ。\n\u3000お前には\u3000オルゴールの件や\n\u3000今回の件で\u3000本当に\u3000世話になった。": ""
  },
  "13687": {
    "「その恩返しに\u3000盗賊の必殺技を\n\u3000お前に\u3000伝授しよう。\n\u3000さあ\u3000目を\u3000つむるがよい。": ""
  },
  "13688": {
    "<pc>は\u3000ブデチョの言葉に\n耳をかたむけた……。": ""
  },
  "13689": {
    "「その恩返しに\u3000これを受け取ってくれ。\n\u3000大事に\u3000使うんだぞ。": ""
  },
  "13690": {
    "「お前は\u3000盗賊を極められる器だ。\n\u3000そうだな。時が満ち\u3000レベル５０以上の\n\u3000盗賊になったら\u3000ワシの所へ来るがいい。": ""
  },
  "13691": {
    "「とっておきの\u3000試練を用意しといてやろう。\n\u3000では\u3000またな。": ""
  },
  "13692": {
    "「ブ…ブデチョのオッサン！\n\u3000あ！\u3000いや！\u3000ムーチョ先生っ！！": ""
  },
  "13693": {
    "「あたいを\u3000弟子にしてくれないかい！？\n\u3000あたい\u3000マスク・ド・ムーチョに\u3000あこがれて\n\u3000この世界に\u3000飛び込んだんだ！\u3000頼むよ！": ""
  },
  "13694": {
    "「すまんな。ワシは\u3000もう\n\u3000弟子は\u3000とらないことにしてるんだ。": ""
  },
  "13695": {
    "「もう……ってことは\n\u3000すでに\u3000お弟子さんが\u3000いるのかい！？": ""
  },
  "13696": {
    "「どこで\u3000ワシの正体を知ったのか\n\u3000ちょっと前に\u3000怪盗ポイなんとかって女の子が\n\u3000ワシの所に\u3000やってきたんだ。": ""
  },
  "13697": {
    "「もともと\u3000弟子をとるつもりは\u3000なかったが\n\u3000かわいい顔で\u3000熱心に頼みこんできたから\n\u3000ついつい\u3000断りきれなくてなあ。": ""
  },
  "13698": {
    "「ところが\u3000そのコ\u3000なかなか\u3000スジがよくて\n\u3000今は\u3000彼女の指導で\u3000手いっぱいなんだ。\n\u3000そういうわけで\u3000すまんなあ。はっはっはっは。": ""
  }
}