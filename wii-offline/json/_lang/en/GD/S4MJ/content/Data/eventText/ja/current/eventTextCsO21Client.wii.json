  "41126": {
    "「……ワン！": ""
  },
  "41127": {
    "「バンジーーーーッ！！": ""
  },
  "41128": {
    "「はいよっ\u3000お疲れさま！\n\u3000眠ってた勇気は\u3000目を覚ましたかい？": ""
  },
  "41129": {
    "「また\u3000気が向いたら\u3000いつでも\n\u3000海峡バンジーに\u3000挑戦しにきてくれよ！": ""
  },
  "44125": {
