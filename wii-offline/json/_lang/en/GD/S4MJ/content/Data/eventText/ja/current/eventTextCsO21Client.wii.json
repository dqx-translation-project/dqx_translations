{
  "1007": {
    "「……………………。": ""
  },
  "1010": {
    "「だまされてたまるか！\n\u3000邪悪なニオイを\u3000ぷんぷんさせた者めっ！": ""
  },
  "1012": {
    "「だまれ！\u3000誰に向かって\u3000クチをきいている！！": ""
  },
  "1015": {
    "「ほほう\u3000なるほど……。": ""
  },
  "1019": {
    "「…………ほう？": ""
  },
  "1021": {
    "「…………だが！！": ""
  },
  "1024": {
    "「こいつも\u3000さっきの\u3000ジジイと同じだ！\n\u3000牢に放り込んで\u3000一生出すな！！": ""
  },
  "1025": {
    "「くそっ\u3000頭が\u3000割れそうに痛む……！\n\u3000ガートラントめ……。": ""
  },
  "1027": {
    "「ハッ！": ""
  },
  "1028": {
    "「わたくし\u3000ザンボアであります！": ""
  },
  "1029": {
    "「じつは……\u3000先日も\u3000王の命令で\n\u3000あなたのような\u3000罪なき人を\n\u3000牢に入れたのですが\u3000すぐに釈放されました！": ""
  },
  "1030": {
    "「ですから\u3000あなたも\u3000すぐに\n\u3000出してもらえるのではないかと！\n\u3000こう思う次第であります！": ""
  },
  "1033": {
    "「わしは\u3000世界を旅して\u3000知った。": ""
  },
  "1034": {
    "「お前たち\u3000エテーネの民は\n\u3000冥王ネルゲルのやつに\u3000相当\n\u3000ひどい目に\u3000あわされたようじゃな。": ""
  },
  "1038": {
    "「やはり\u3000エイドスさまには\n\u3000おわかりなのですね！\n\u3000王が\u3000以前のバグド王ではないと！": ""
  },
  "1039": {
    "「じつは……\n\u3000王は\u3000先日まで\u3000病に倒れていたのです。": ""
  },
  "1040": {
    "「なんとか\u3000一命は取りとめましたが\n\u3000以来\u3000ひどい頭痛に悩まされ\u3000いつもイライラと\n\u3000すべてを憎んでいるかのような\u3000ご様子で……。": ""
  },
  "1041": {
    "「ガートラントに戦争を仕掛けるなど\n\u3000たとえ\u3000どんな理由があったとしても\n\u3000おっしゃらなかったはずなのに……。": ""
  },
  "1042": {
    "「いったい\u3000王は\u3000どうしてしまったのでしょう？\n\u3000あの頭痛さえ\u3000治れば\n\u3000元の\u3000優しい王に\u3000戻るのでしょうか？": ""
  },
  "1045": {
    "「王の頭痛を取りのぞく方法が\n\u3000ないわけでもないが……。": ""
  },
  "1047": {
    "「ジダン兵士長よ。\n\u3000教えるのなら\u3000そなたではなく\n\u3000この者のほうが\u3000よさそうじゃ。": ""
  },
  "1049": {
    "「お前の名は……\n\u3000そうか\u3000<pc>というのか。": ""
  },
  "1050": {
    "「<pc>よ。\n\u3000王を\u3000元に戻すには\u3000それなりの覚悟と\n\u3000勇気が必要になるじゃろう。": ""
  },
  "1051": {
    "「この国を救う覚悟ができたなら\n\u3000わしを訪ねて\u3000宿屋に来るがいい。\n\u3000……待っておるぞ。": ""
  },
  "1054": {
    "「あなただけが\u3000頼りなんです。\n\u3000さあ\u3000もう一度\u3000返事を聞かせてください。": ""
  },
  "1055": {
    "「ありがとうございます！\n\u3000さすが\u3000エイドスさまに見込まれた方！": ""
  },
  "1056": {
    "「さあ\u3000城の出口まで\u3000お送りしましょう。\n\u3000宿屋に滞在中の\u3000エイドスさまを\n\u3000お訪ねください。": ""
  },
  "1059": {
    "「来てくれたか\u3000<pc>。": ""
  },
  "1060": {
    "「時間がない。率直に言おう。\n\u3000バグド王の様子が\u3000おかしいのは\n\u3000悪しき瘴気\u3000魔瘴に侵されているからじゃ。": ""
  },
  "1061": {
    "「わしや\u3000お前に\u3000あれほど\n\u3000はげしい嫌悪を示したのは\u3000わしらの中の\n\u3000聖なるチカラに\u3000感づいたためじゃろう。": ""
  },
  "1062": {
    "「魔瘴のことは\u3000知っておるな？\n\u3000あの\u3000まがまがしき悪魔の霧のことじゃ。": ""
  },
  "1063": {
    "「魔物がまとえば\u3000そのチカラは何倍にも強まり\n\u3000人が触れれば\u3000命を落とすか\n\u3000心を\u3000悪に染められるという。": ""
  },
  "1064": {
    "「なかば\u3000忘れられた存在だった魔瘴が\n\u3000今\u3000ふたたび\u3000活発化したのは\u3000冥王ネルゲルが\n\u3000この地上に\u3000降り立ったためじゃ。": ""
  },
  "1065": {
    "「<pc>よ。\n\u3000この国を救う覚悟は\u3000できたな？": ""
  },
  "1066": {
    "「バグド王に取りついた魔瘴を\u3000はらうために\n\u3000必要なものは……。": ""
  },
  "1067": {
    "「……………………。": ""
  },
  "1068": {
    "「いや\u3000なんでもない。": ""
  },
  "1069": {
    "「必要なものは\u3000レムルの聖杯じゃ。\n\u3000グレン領西の北部\u3000ベコン渓谷の奥に\n\u3000今も\u3000眠っておる。": ""
  },
  "1070": {
    "「たやすく\u3000入手できるものではないから\n\u3000しっかりと準備をして\u3000おもむくがいい。\n\u3000聖杯が入手できた頃\u3000また\u3000ここで会おう。": ""
  },
  "1076": {
    "「オォォォォ……\u3000誰だ？\n\u3000われから\u3000聖杯を\u3000うばわんとする者は！？": ""
  },
  "1077": {
    "「……そうか\u3000貴様\n\u3000ガートラントの追っ手だな？": ""
  },
  "1078": {
    "「わが名は\u3000剣士オーレン……。\n\u3000レムルの聖杯は\u3000われに残された\n\u3000ただひとつの\u3000希望！": ""
  },
  "1079": {
    "「グオォォォォォ……………。": ""
  },
  "1080": {
    "「わ…が………": ""
  },
  "1081": {
    "「聖……杯……………。": ""
  },
  "1082": {
    "<cs_pchero>は\nレムルの聖杯（だいじなもの）を\u3000手に入れた！<me_60>": ""
  },
  "1083": {
    "「<pc>さんって\u3000あなたでしょ？\n\u3000エイドスさまから\u3000伝言を預かっているから\n\u3000読むわね？": ""
  },
  "1084": {
    "「急で\u3000すまぬが\u3000旅立つことになった。\n\u3000<pc>なら\u3000問題なく\n\u3000レムルの聖杯を\u3000手に入れてくれたと思う。": ""
  },
  "1085": {
    "「次は\u3000その聖杯を持って\u3000はるか南東へ行け。\n\u3000グレン領東の南から\u3000ゲルト海峡を南東に抜け\n\u3000ランドン山脈の南東から\u3000雲上湖へ行くのじゃ。": ""
  },
  "1086": {
    "「そこには\u3000グロリスの木という\n\u3000目には見えぬ\u3000不思議な樹木が\u3000そびえておる。\n\u3000その木が落とす\u3000しずくを\u3000持ち帰るのじゃ。": ""
  },
  "1087": {
    "「レムルの聖杯で\u3000受けとめた\n\u3000グロリスのしずくだけが\u3000魔瘴をはらえる。\n\u3000それを\u3000王に飲ませれば\u3000王は治るじゃろう。": ""
  },
  "1088": {
    "「ただ\u3000雲上湖には\u3000恐ろしい竜がおる。\n\u3000襲われぬように\u3000気をつけてな。\n\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000\u3000エイドス": ""
  },
  "1089": {
    "「王を治すだなんて\u3000さすが\u3000エイドスさま！\n\u3000やっぱり\u3000ステキ……。": ""
  },
  "1090": {
    "「きゃ～\u3000いや～～ん！": ""
  },
  "1096": {
    "<cs_pchero>は\nグロリスのしずく（だいじなもの）を\n手に入れた！<me_60>": ""
  },
  "1102": {
    "「お待ちしておりました\u3000<pc>さん！\n\u3000グロリスのしずくを\u3000手に入れたのですね？": ""
  },
  "1103": {
    "「エイドスさまから\u3000話は\u3000聞いています。\n\u3000それを\u3000王に飲ませれば\u3000王は治ると！": ""
  },
  "1104": {
    "「さあ\u3000そのグロリスのしずくを\u3000私に。": ""
  },
  "1107": {
    "「<pc>さん\u3000ありがとうございました！\n\u3000王に\u3000これを飲ませるのは\u3000私たちの役目です。\n\u3000どうか\u3000そこで見ていてください。": ""
  },
  "1109": {
    "「ぐっ……\u3000うう……。": ""
  },
  "1110": {
    "「貴様ら……\n\u3000いったい\u3000なんのマネだ……！？": ""
  },
  "1111": {
    "「その\u3000汚らわしい水を\n\u3000これ以上\u3000われに\u3000近づけたら……": ""
  },
  "1112": {
    "「命は\u3000ないぞ！！": ""
  },
  "1115": {
    "「ザンボア！\n\u3000早く\u3000グロリスのしずくを\u3000王に……！": ""
  },
  "1116": {
    "「やめろ！！\u3000やめるんだーーー！！\n\u3000ぐおおおおおおおお！！": ""
  },
  "1121": {
    "「おお……\u3000王よ……。\n\u3000元に\u3000戻られたのですね！": ""
  },
  "1124": {
    "「こんな\u3000すがすがしい気分になれる日が\n\u3000また\u3000来ようとは……。": ""
  },
  "1125": {
    "「ない！\u3000ネックレスが……\n\u3000誰か\u3000われのネックレスを\u3000知らぬか？": ""
  },
  "1126": {
    "「おそれながら\u3000ご報告させていただきます。\n\u3000王は\u3000あのネックレスの呪いで\n\u3000死のふちを\u3000さまよわれたのです。": ""
  },
  "1128": {
    "「バカな！\u3000あのネックレスは\n\u3000ガートラント城からの\u3000友好の証として\n\u3000贈られた品に\u3000入っていたのだぞ？": ""
  },
  "1129": {
    "「友好の証と見せかけて\u3000呪いの品を送るなど\n\u3000そのような姑息なまねを\n\u3000ガートラントが\u3000するはずがない！": ""
  },
  "1132": {
    "「神父や僧侶にも\u3000なすすべなく\n\u3000ただ\u3000弱っていく王を\u3000見守ることしか\n\u3000できなかった\u3000ある日……": ""
  },
  "1136": {
    "「これは\u3000魔瘴石のネックレスだ。\n\u3000あやうく\u3000王は死ぬところだったと\n\u3000マリーンは\u3000言いました。": ""
  },
  "1137": {
    "「そして\u3000王に\u3000いやしの術をかけ\n\u3000王の容態が\u3000安定したのを確認すると……": ""
  },
  "1138": {
    "「マリーンは\u3000このネックレスは危険だと言って\n\u3000この国から\u3000魔瘴石のネックレスを\n\u3000持ち去ってくれたのです。": ""
  },
  "1146": {
    "「……ほうびと言えば\u3000キーエンブレムだが。": ""
  },
  "1150": {
    "「なに！？\n\u3000われが\u3000ガートラント城に\u3000宣戦布告したと！？": ""
  },
  "1151": {
    "「それが本当なら……\n\u3000この者の\u3000はたらきがなければ\u3000我が国は……。": ""
  },
  "1152": {
    "「そういうことならば\u3000あいわかった！": ""
  },
  "1153": {
    "「<pc>よ！\u3000心から感謝する！\n\u3000そなたの活躍\u3000グレン城のキーエンブレムを\n\u3000与えるに値する\u3000はたらきであった！": ""
  },
  "1154": {
    "「さあ\u3000受け取るがいい！": ""
  },
  "1156": {
    "「その\u3000黒のキーエンブレムは\n\u3000グレンの英雄であることを示すもの。\n\u3000他国でも\u3000そなたのチカラの証となるだろう。": ""
  },
  "1157": {
    "「チグリ大臣よ。\n\u3000すぐに\u3000おふれを出せ！": ""
  },
  "1158": {
    "「ガートラントと\u3000いくさは\u3000やらん！\n\u3000皆\u3000日々の暮らしに戻れ！\u3000……とな。": ""
  },
  "1160": {
    "「いくさが起きていれば\n\u3000多くの血が\u3000このオーグリード大陸に\n\u3000流れるところであった……。": ""
  },
  "1161": {
    "「……本当に\u3000よかった。\n\u3000このグレンの民に\u3000つらい思いを\n\u3000させずにすんで……。": ""
  },
  "8017": {
    "「バグド王\u3000どうなさいました？\n\u3000エイドスさまが\u3000来てくださったのですぞ。": ""
  },
  "8018": {
    "「エイドスだと……！？": ""
  },
  "8019": {
    "「バ…バグド王……！\n\u3000まさか\u3000賢者エイドスさまのことが\n\u3000わからないのですか？": ""
  },
  "8020": {
    "「…………………。": ""
  },
  "8021": {
    "「そのジジイを\u3000牢に放り込め！\n\u3000二度と\u3000われに\u3000顔を見せるなっ！！": ""
  },
  "8022": {
    "「バグド王め。\n\u3000難儀なことに\u3000なっておるのう。": ""
  },
  "8023": {
    "「……この国では\n\u3000こんな問題が\u3000起こっておるのか。": ""
  },
  "8024": {
    "「バグド王に\u3000申し上げます！\n\u3000こちらの旅人が\u3000グレン城の兵士になりたいと\n\u3000志願しております。": ""
  },
  "8025": {
    "「やっと\u3000一人前の証を持つ者が\u3000現れたか。\n\u3000なるほど。それなりに\u3000ウデが立ちそうだな。": ""
  },
  "8026": {
    "「われの目を\u3000ごまかせると思うか？\n\u3000我が国に\u3000災いをもたらさんとする者め！！": ""
  },
  "8027": {
    "「さ\u3000さすがは\u3000バグド王！\n\u3000ひと目で\u3000この者の本質を\u3000見抜かれるとは！": ""
  },
  "8028": {
    "「ええい！\u3000そいつを早く牢に！\n\u3000われから遠ざけよ！": ""
  },
  "8029": {
    "「さあ\u3000来るんだ。": ""
  },
  "8030": {
    "「こんな所で会うとは\u3000奇遇じゃの。": ""
  },
  "8031": {
    "「ふむ……\u3000先ほど\u3000感じたとおり\n\u3000お前は\u3000生き返しを受けた者じゃな。": ""
  },
  "8032": {
    "「たいへん\u3000申し訳ございませんでした。\n\u3000どうか\u3000お許しください\u3000エイドスさま。": ""
  },
  "8033": {
    "「顔を上げられよ\u3000ジダン兵士長。\n\u3000今の王なら\u3000わしに\u3000あのような態度を取るのも\n\u3000仕方あるまい。": ""
  },
  "8034": {
    "「エイドスさま……！": ""
  },
  "8035": {
    "「バグド王のことは\n\u3000ヤツが\u3000赤ん坊の頃から知っておる。\n\u3000このまま\u3000見捨てようとは思わん。": ""
  },
  "8036": {
    "「じゃが\u3000知ってのとおり\u3000わしは忙しい。\n\u3000この国にも\u3000いつまで滞在できるか\n\u3000わからん身じゃ。": ""
  },
  "8037": {
    "「では\u3000エイドスさま！\n\u3000私に\u3000その方法を教えてください。\n\u3000王のためなら\u3000どんなことでもします！": ""
  },
  "8038": {
    "「お前の名は……\n\u3000たしか\u3000<pc>じゃったな。": ""
  },
  "8039": {
    "「王が今のままでは\u3000このオーグリード大陸にて\n\u3000ひどい戦争が起こります。\n\u3000そうなれば\u3000多くの民が\u3000苦しむことになる！": ""
  },
  "8040": {
    "「<pc>さん\u3000どうかお願いします。\n\u3000バグド王を\u3000元に戻すため\n\u3000チカラを貸してください！<yesno><close>": ""
  },
  "8041": {
    "「けっして\u3000誰にも渡さぬっ！！": ""
  },
  "8042": {
    "<pc>は\u3000ジダン兵士長に\nグロリスのしずくが入った\nレムルの聖杯を\u3000渡した！": ""
  },
  "8043": {
    "「これで\u3000バグド王を\u3000元に戻せる……。": ""
  },
  "8044": {
    "「う……\u3000うう……。": ""
  },
  "8045": {
    "「お許しください\u3000バグド王！": ""
  },
  "8046": {
    "「ぐおお！\u3000貴様ら\u3000許さんぞ！！": ""
  },
  "8047": {
    "「グァァァァァァァァァァ！！！": ""
  },
  "8048": {
    "「ア……\u3000アァァァァ……。": ""
  },
  "8049": {
    "「ハァハァ……\u3000ハァ……。": ""
  },
  "8050": {
    "「チグリ大臣か……\n\u3000われは\u3000いったい……？": ""
  },
  "8051": {
    "「信じられん……。": ""
  },
  "8052": {
    "「あの\u3000ひどい頭痛が\u3000消えておる。\n\u3000永遠に続くかと思われた\u3000あの頭痛が……。": ""
  },
  "8053": {
    "「なにっ！？": ""
  },
  "8054": {
    "「ええ。私も\u3000そう思います。\n\u3000おそらくは\u3000ガートラント以外の何者かが\n\u3000王の\u3000お命を狙ったのでしょう。": ""
  },
  "8055": {
    "「……あの\u3000忌まわしいネックレスは\n\u3000王の首から\u3000決して離れず\n\u3000あやしい光を\u3000たたえ続けていました。": ""
  },
  "8056": {
    "「突然\u3000とてつもなく大きな\n\u3000人間の女が\u3000現れました。\n\u3000それが\u3000あの賢者マリーンだったのです。": ""
  },
  "8057": {
    "「ウワサは聞いた。\n\u3000王を助けたいなら\u3000だまって見ていろと\n\u3000マリーンは言い……": ""
  },
  "8058": {
    "「彼女が呪文を唱えると\u3000私たちが\u3000何をしても\n\u3000はずせなかった\u3000ネックレスが\n\u3000あっさりと\u3000はずれたのです。": ""
  },
  "8059": {
    "「そうだったのか。\n\u3000あの名高い賢者マリーンが\u3000われを……": ""
  },
  "8060": {
    "「マリーンどのだけではありません。": ""
  },
  "8061": {
    "「王を\u3000頭痛から解き放つため\n\u3000グロリスのしずくを\u3000手に入れてくれたのが\n\u3000ここにいる\u3000<pc>さん……": ""
  },
  "8062": {
    "「そして\u3000この<pc>さんに\n\u3000王を治すための知恵を\u3000授けたのは\n\u3000あのエイドスさまなのです。": ""
  },
  "8063": {
    "「なんと！\n\u3000エイドスさまが\u3000いらしていたのか？": ""
  },
  "8064": {
    "「むう……\u3000まったく記憶にないぞ。\n\u3000いくら\u3000ひどい頭痛の中にあったとはいえ……": ""
  },
  "8065": {
    "「ともかく\u3000われは\u3000正気を失っている間に\n\u3000多くの人々に\u3000迷惑をかけたようだ。\n\u3000<pc>とやらにも\u3000礼をせねば。": ""
  },
  "8066": {
    "「う～む……。": ""
  },
  "8067": {
    "「しかし\u3000キーエンブレムとは\u3000英雄の証。\n\u3000頭痛を治した程度で\u3000与えてよいものか？": ""
  },
  "8068": {
    "「やはり\u3000この国を救うような\n\u3000大きなことを\u3000やりとげた者でなくては……。": ""
  },
  "8069": {
    "<pc>は\n黒のキーエンブレム（だいじなもの）を\n手に入れた！<me_72>": ""
  },
  "8070": {
    "「かしこまりました！": ""
  },
  "8071": {
    "「そして\u3000何より……\n\u3000オーガ同士に\u3000取り返しのつかない\n\u3000憎しみ合いを\u3000させずにすんで……。": ""
  },
  "31956": {
    "「オォォォォ……\u3000誰だ？\n\u3000われから\u3000聖杯を\u3000うばわんとする者は！？": ""
  },
  "31957": {
    "「……そうか\u3000貴様\n\u3000ガートラントの追っ手だな？": ""
  },
  "31958": {
    "「わが名は\u3000剣士オーレン……。\n\u3000レムルの聖杯は\u3000われに残された\n\u3000ただひとつの\u3000希望！": ""
  },
  "31959": {
    "「けっして\u3000誰にも渡さぬっ！！": ""
  },
  "41121": {
    "「ほら\u3000お客さん。\n\u3000正面に\u3000奇妙な形をした島が見えるだろう？\n\u3000あの島は\u3000ガミルゴの盾島って呼ばれている。": ""
  },
  "41122": {
    "「はるか昔\u3000ガートラントと\u3000グレンの王が\n\u3000同盟を誓いあった場所なんだそうだ。\n\u3000くわしいことは\u3000わかっていないがね。": ""
  },
  "41123": {
    "「さあ\u3000それより始めるよ。\n\u3000カウントーーダウンッ！！": ""
  },
  "41124": {
