{
  "15984": {
    "「ここは\u3000ガートラントの流行発信基地\n\u3000ぬいぐるみ屋でございます。": ""
  },
  "15985": {
    "「人気商品のチョコ神ぬいぐるみは\n\u3000ただいま\u3000在庫切れですので\u3000お求めの方は\n\u3000またの機会に\u3000お越しくださいませ。": ""
  },
  "15986": {
    "「ここは\u3000ガートラントの流行発信基地。\n\u3000ぬいぐるみ屋でございます。": ""
  },
  "15987": {
    "「……ふ～む。お客さん。\n\u3000さては\u3000当店の人気ナンバーワン商品\n\u3000チョコ神ぬいぐるみを\u3000お求めですね？<yesno><close>": ""
  },
  "15988": {
    "「おや\u3000ちがいましたか。\n\u3000でも\u3000今\u3000当店で扱ってるのは\n\u3000チョコ神ぬいぐるみだけなんですよ。": ""
  },
  "15989": {
    "「ですから\u3000申し訳ないのですが\n\u3000他の商品を\u3000お求めでしたら\n\u3000どうぞ\u3000お引き取りください。": ""
  },
  "15990": {
    "「ちょうど\u3000よかった！\n\u3000じつは\u3000今\u3000たった２個だけ\n\u3000在庫が\u3000残っているんですよ！": ""
  },
  "15991": {
    "「売り切れ続出の人気商品が\n\u3000予約なしに\u3000買えてしまうなんて\n\u3000お客さん\u3000ラッキーですねぇ。": ""
  },
  "15992": {
    "「待ちたまえっ！！": ""
  },
  "15993": {
    "「ガートラントの華\u3000スピンドル兵士長\n\u3000見！\u3000参！": ""
  },
  "15994": {
    "「……そいつが\u3000ちまたでウワサの\n\u3000チョコ神ぬいぐるみだな？": ""
  },
  "15995": {
    "「……フム。やはり\u3000間違いない！": ""
  },
  "15996": {
    "「あ\u3000あのう……\n\u3000いったい\u3000なんのご用でしょう？": ""
  },
  "15997": {
    "「ぬいぐるみ屋店主\u3000ザッケスよ！\n\u3000貴様を\u3000逮捕するっ！": ""
  },
  "15998": {
    "「は……\u3000はぁぁぁぁっ！？\n\u3000いったい\u3000ぜんたい\u3000どうしてっ？": ""
  },
  "15999": {
    "「先ごろ\u3000我が国を\u3000混乱におとしいれた\n\u3000マリーン事件。その主犯\u3000呪術師マリーンには\n\u3000共犯者が\u3000いたことが\u3000判明している。": ""
  },
  "16000": {
    "「……旅芸人ピュージュ。\n\u3000評判の大道芸人でありながら\u3000その正体は\n\u3000魔物であったらしいとの\u3000報告を受けている。": ""
  },
  "16001": {
    "「そして\u3000貴様が売っている\u3000この人形は\n\u3000ピュージュが\u3000芸に使っていた人形に\n\u3000うりふたつなのだ！": ""
  },
  "16002": {
    "「すなわち！\u3000貴様も\u3000また\n\u3000ピュージュの関係者に\u3000ちがいない！！": ""
  },
  "16003": {
    "「そ…そんな\u3000ムチャクチャなーっ！": ""
  },
  "16004": {
    "「そういえば\u3000その顔\u3000どこかで見た気がするな。\n\u3000……おおかた\u3000賞金首の手配書にでも\n\u3000載ってるんだろう？": ""
  },
  "16005": {
    "「お客さ～ん。\n\u3000お客さんからも\u3000言ってくださいよ。\n\u3000私も\u3000ぬいぐるみも\u3000潔白だって！": ""
  },
  "16006": {
    "「もし\u3000私が\u3000逮捕されちゃったら\n\u3000お客さん\u3000チョコ神ぬいぐるみを\n\u3000買えなくなっちゃいますよ！": ""
  },
  "16007": {
    "「……おや\u3000<pc>くん？\n\u3000こんなところで会うとは\u3000奇遇だな。": ""
  },
  "16008": {
    "「いくら\u3000キミが\u3000かばったところで\n\u3000この人形が\u3000ピュージュの人形と\n\u3000そっくりだという\u3000事実は動かせないぞ。": ""
  },
  "16009": {
    "「だ\u3000だったら\u3000この人形が\u3000普通に\n\u3000いくらでも\u3000買えるものだって\n\u3000証明できれば\u3000いいんですよね！？": ""
  },
  "16010": {
    "「お客さん\u3000どうか\u3000お願いします！\n\u3000プクランド大陸のオルフェア地方東にある\n\u3000ピィピのお宿へ\u3000行ってきてください！": ""
  },
  "16011": {
    "「じつは\u3000このチョコ神ぬいぐるみは\n\u3000その集落にいる\u3000ピルクノって人から\n\u3000大量に\u3000買い付けたものなんです。": ""
  },
  "16012": {
    "「彼こそ\u3000チョコ神ぬいぐるみを生みだした\n\u3000張本人です。それを\u3000証明できる物を\n\u3000彼から\u3000何か\u3000受け取ってきてください！": ""
  },
  "16013": {
    "「ふん。クチから\u3000でまかせを……。\n\u3000だが\u3000もし\u3000それが\u3000本当だったなら\n\u3000確かに\u3000この男の疑いは\u3000晴れるな。": ""
  },
  "16014": {
    "「……よし\u3000いいだろう！\n\u3000<pc>くんに免じて\n\u3000逮捕は\u3000しばらく待ってやろう。": ""
  },
  "16015": {
    "「その代わり\u3000無実が証明されるまでは\n\u3000この店は\u3000営業停止とする！": ""
  },
  "16016": {
    "「むろん\u3000証明されなければ\u3000逮捕の上\n\u3000きびしい取り調べは\u3000免れんからな。\n\u3000そのときは\u3000覚悟しておくがいい！": ""
  },
  "16017": {
    "「なんの縁もない\u3000あなたに頼むのは\n\u3000心苦しいのですが\u3000どうか\u3000どうか\n\u3000よろしくお願いしますね！": ""
  },
  "16018": {
    "「では\u3000<pc>くん。\n\u3000さっそく\u3000プクランド大陸に向かいたまえ。\n\u3000私は\u3000あまり\u3000気の長いほうではないぞ！": ""
  },
  "16019": {
    "「悪いが\u3000この店は\u3000営業停止中だ。\n\u3000……っと\u3000<pc>くんだったか。": ""
  },
  "16020": {
    "「お客さ～ん。早く\u3000オルフェア地方東にある\n\u3000ピィピのお宿に行って\u3000ピルクノって人から\n\u3000無実の証拠を\u3000手に入れてきてくださいよ～！": ""
  },
  "16021": {
    "「さあ\u3000<pc>くん。\n\u3000彼の疑いを晴らしたくば\u3000急ぐことだ。\n\u3000私は\u3000あまり\u3000気の長いほうではないぞ！": ""
  },
  "16022": {
    "「悪いが\u3000この店は\u3000営業停止中だ。\n\u3000……っと\u3000<pc>くんだったか。": ""
  },
  "16023": {
    "「おお！\u3000その手に持っているのは\n\u3000まぎれもなく\u3000チョコ神ぬいぐるみ\n\u3000……の作りかけ。": ""
  },
  "16024": {
    "「見てください\u3000スピンドル兵士長さま!\n\u3000あの作りかけの\u3000ぬいぐるみこそ\n\u3000私が\u3000無実であることの\u3000動かぬ証拠です！": ""
  },
  "16025": {
    "「……むむう。<pc>くん。\n\u3000その人形を\u3000こちらに\u3000渡してもらえるかな？": ""
  },
  "16026": {
    "<pc>は\u3000スピンドル兵士長に\n作りかけぬいぐるみを\u3000渡した！": ""
  },
  "16027": {
    "「……なるほど。これを\u3000ピィピのお宿の\n\u3000ピルクノという人物から\u3000手に入れたと？\n\u3000……くそっ。見込みちがいで\u3000あったか。": ""
  },
  "16028": {
    "「いいだろう！\u3000逮捕は\u3000なしだ。\n\u3000営業停止も\u3000解除しようじゃないか。": ""
  },
  "16029": {
    "「ありがとうございます\u3000<pc>さん。\n\u3000すべて\u3000あなたの\u3000おかげです！": ""
  },
  "16030": {
    "「何か\u3000お礼をしなければ……\n\u3000あっ！\u3000そういえば\u3000チョコ神ぬいぐるみを\n\u3000お求めだったんですよね！": ""
  },
  "16031": {
    "「それでは\u3000これ\u3000タダで差し上げます。\n\u3000本当は\u3000こんなんじゃ\u3000お礼としては\n\u3000全然\u3000足りないですけど……。": ""
  },
  "16032": {
    "<pc>は\nチョコ神ぬいぐるみ（だいじなもの）を\n受け取った！<me_60>": ""
  },
  "16033": {
    "「……フン。そんな人形の\u3000何がいいのか\n\u3000高貴なる私には\u3000わかりかねるな。": ""
  },
  "16034": {
    "「まあ\u3000そう\u3000おっしゃらずに。\n\u3000もう１個あるので\u3000兵士長さまにも\n\u3000差し上げますよ。": ""
  },
  "16035": {
    "「いや\u3000辞退させてもらおう！\n\u3000私にとっては\u3000無用の長物だからな。": ""
  },
  "16036": {
    "「じつは\u3000これ\u3000女性にプレゼントすると\n\u3000けっこう\u3000よろこばれるんですよ。\n\u3000意中の女性に\u3000贈っては\u3000いかがですか？": ""
  },
  "16037": {
    "「……コホン！\u3000まあ\u3000よく見れば\n\u3000なかなか\u3000愛嬌が\u3000あるかもな……。\n\u3000どうしてもと言うなら\u3000受け取らんでもないぞ。": ""
  },
  "16038": {
    "スピンドル兵士長は\nチョコ神ぬいぐるみを\u3000受け取った！": ""
  },
  "16039": {
    "「……私は\u3000これで\u3000失礼しよう。\n\u3000まあ\u3000今後は\u3000妙な疑惑をかけられぬよう\n\u3000気をつけて\u3000商売することだ！": ""
  },
  "16040": {
    "「……やれやれ。\n\u3000勝手に疑っておいて\u3000いい気なものだな。": ""
  },
  "16041": {
    "「……でも\u3000まあ\u3000兵士長さまから\n\u3000恨まれても\u3000ロクなことになりませんからね。\n\u3000これも\u3000商人の知恵ってもんです。": ""
  },
  "16042": {
    "「さあ\u3000売り物も\u3000なくなってしまったし\n\u3000今日は\u3000もう\u3000店じまいです。": ""
  },
  "16043": {
    "「本当に\u3000ありがとうございました。\n\u3000この\u3000ご恩は\u3000いつか必ず\n\u3000お返しさせていただきますからね！": ""
  },
  "16044": {
    "「おお。これは\u3000<pc>さん！\n\u3000その節は\u3000お世話になりました。": ""
  },
  "16045": {
    "「もしかして\u3000また\u3000チョコ神ぬいぐるみを\n\u3000お買い上げに\u3000いらしたので？": ""
  },
  "16046": {
    "「他ならぬ\u3000<pc>さんになら\n\u3000いくらでも\u3000おゆずりしたいところですが\n\u3000あいにく\u3000在庫切れでして……。": ""
  },
  "16047": {
    "「本当に\u3000申し訳ないのですが\n\u3000またの機会に\u3000してもらえませんか。\n\u3000いやはや\u3000面目ありません。": ""
  }
}