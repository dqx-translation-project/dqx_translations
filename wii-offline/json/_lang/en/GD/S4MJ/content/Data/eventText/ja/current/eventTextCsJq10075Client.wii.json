{
  "31335": {
    "「要求通り\u3000オレと\u3000<cs_pchero>の\n\u3000ふたりだけで\u3000来てやったぞぉ！\n\u3000おらっ！\u3000出てこいよ\u3000セインズ！！": ""
  },
  "31336": {
    "「……待ちかねましたよ。": ""
  },
  "31337": {
    "「……バトルマスターの証は\n\u3000ちゃんと\u3000持ってきたんでしょうね？": ""
  },
  "31338": {
    "「ああ。肌身\u3000はなさずにな。\n\u3000しかし\u3000オメーが\u3000そんなにまで\n\u3000こいつを\u3000欲しがってたとは知らなかったぜ。": ""
  },
  "31339": {
    "「そいつは\u3000アンタが\u3000オレのことを\n\u3000認めなかった証ですからね……。": ""
  },
  "31340": {
    "「今から\u3000アンタの自慢の弟子を倒し\n\u3000オレこそが\u3000証を受け継ぐにふさわしい\n\u3000バトルマスターだって\u3000証明してやるぜっ！": ""
  },
  "31341": {
    "「オメーは\u3000相変わらず\u3000わかっちゃいねーな。\n\u3000オレたちは\u3000狂戦士じゃないんだ……。\n\u3000強けりゃ\u3000それでいいってもんじゃねえ。": ""
  },
  "31342": {
    "「アンタは\u3000いつだって\u3000それだ！\n\u3000バトルマスターは\u3000戦いに生きる存在だぜ。\n\u3000強さ以外に\u3000なんの価値があるってんだ！？": ""
  },
  "31343": {
    "「……まあいいさ。\n\u3000そんなヤツに\u3000オレが手塩にかけて育てた\n\u3000<cs_pchero>が\u3000負けるはずねーからな。": ""
  },
  "31344": {
    "「そういうワケだ。\n\u3000あとのことは\u3000まかせたぜ。<cs_pchero>！": ""
  },
  "31345": {
    "「<cs_pchero>。お前のことは\u3000恨んじゃいねえ。\n\u3000だが\u3000オレの強さを\u3000証明するために\n\u3000たたきのめさせてもらうぜ！": ""
  },
  "31346": {
    "「恨むんなら\u3000ジェイコフの弟子になった\n\u3000自分のウカツさを\u3000恨むんだな！！": ""
  },
  "31347": {
    "「おせーよ\u3000<cs_pchero>。\n\u3000待ちくたびれたじゃねーか。": ""
  },
  "31348": {
    "「てっきり\u3000逃げだしたかと思ったが……\n\u3000まだ\u3000痛めつけられ足りないようだな。": ""
  },
  "31349": {
    "「さあ\u3000今度こそ\u3000どちらが\n\u3000バトルマスターの証を継ぐに\u3000ふさわしいか\n\u3000決着をつけようぜ！": ""
  },
  "31350": {
    "「ぐうっ……クソッ！\n\u3000なぜだ？\u3000なぜ\u3000勝てないっ！？": ""
  },
  "31351": {
    "「オレは\u3000ただ\u3000ひたすら\u3000強くなるためだけに\n\u3000すべてを\u3000なげうってきたってのに……。": ""
  },
  "31352": {
    "「……だからだよ。オメーの強さは\n\u3000オメー自身のためのものでしかねえ。\n\u3000本当のバトルマスターってのは……": ""
  },
  "31353": {
    "「セインズよ。せっかく\u3000手を回して\n\u3000復讐の機会を与えてやったのに\u3000そのザマか。": ""
  },
  "31354": {
    "「……まあ\u3000いい。\n\u3000そのふたりを\u3000呼び寄せたことで\n\u3000おまえは用済みだ。もろともに\u3000死ねっ！": ""
  },
  "31355": {
    "「……どうして\u3000オレなんかを？": ""
  },
  "31356": {
    "「……弟子のモノは\u3000師匠のモノ。\n\u3000オメーの命は\u3000オレのモノってことさ。\n\u3000勝手に\u3000死なせやしねーぞ！": ""
  },
  "31357": {
    "「くっ……悪いな\u3000<cs_pchero>。 \n\u3000このバケモノの相手は\u3000オメーにまかせる。": ""
  },
  "31358": {
    "「すぐに\u3000戦闘の準備を万全にして\n\u3000戻ってきてくれ。それまで\u3000この場は\n\u3000なんとか\u3000もたせておくからよ！": ""
  },
  "31359": {
    "「おせーよ\u3000<cs_pchero>。\n\u3000待ちくたびれたじゃねーか。": ""
  },
  "31360": {
    "「いいな。セインズのバカたれに\n\u3000真のバトルマスターの\u3000すごみを\n\u3000教えてやってくれ！！": ""
  },
  "46606": {
    "「今度こそ\u3000セインズのバカたれに\n\u3000真のバトルマスターの\u3000すごみを\n\u3000教えてやってくれ！！": ""
  },
  "46607": {
    "「セインズ\u3000目に焼きつけとけよ。 \n\u3000<cs_pchero>が\u3000真のバトルマスターの戦いを\n\u3000見せてくれるはずだからな。": ""
  },
  "60360": {
    "「バ\u3000バカな……わしの最強のペットが……。": ""
  },
  "60361": {
    "「ひ\u3000ひいっっ！！": ""
  },
  "60362": {
    "「おっと。今度こそ\u3000逃がしゃしねーぞ！": ""
  },
  "60363": {
    "「……ブランドンさん。\n\u3000あんたの野望も\u3000もう\u3000おしまいだ。\n\u3000そろそろ\u3000観念しようぜ。": ""
  },
  "60364": {
    "「ちくしょう……ちくしょう。": ""
  },
  "60365": {
    "「<cs_pchero>。\n\u3000お前の戦いを見ていて\u3000師匠の言うことが\n\u3000わかったような気がするよ。": ""
  },
  "60366": {
    "「自分のためじゃなく\n\u3000誰かのために戦う……そのための剣。\n\u3000それが\u3000バトルマスターだってことさ。": ""
  },
  "60367": {
    "「さあ\u3000これにて\u3000一件落着だ。\n\u3000ラッカラン島のコロシアムに\n\u3000戻るとするか……。": ""
  }
}