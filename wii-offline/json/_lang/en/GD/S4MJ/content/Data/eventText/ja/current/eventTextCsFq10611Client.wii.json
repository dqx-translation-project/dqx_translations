{
  "75863": {
    "「お待たせしました\u3000<pc>様。\n\u3000どうやら\u3000神父様に\n\u3000私の手紙を\u3000渡してくださったようですね。": ""
  },
  "75864": {
    "「はじめまして……神父様。\n\u3000お手紙で\u3000お伝えした通り\u3000私の婚約者……\n\u3000マレンとの結婚式を\u3000挙げさせてください。": ""
  },
  "75865": {
    "「たとえ\u3000死に別れたとしても\n\u3000彼女との約束を\u3000果たしたいのです。\n\u3000こうして\u3000結婚指輪も\u3000用意してきました。": ""
  },
  "75866": {
    "「……あなたのお気持ちは\u3000よくわかりました。\n\u3000それほどまでの\u3000マレンさんへの想い……。\n\u3000きっと\u3000神も\u3000祝福してくださいます。": ""
  },
  "75867": {
    "「そうと決まれば\u3000さっそく\n\u3000結婚式を\u3000とりおこないましょう！": ""
  },
  "75868": {
    "「……では\u3000新郎\u3000ランディ。\n\u3000そして\u3000新婦\u3000マレン。": ""
  },
  "75869": {
    "「あなたがたは\u3000互いを夫婦とし\n\u3000病める時も\u3000すこやかなる時も\u3000互いを助け\n\u3000互いを慈しみ\u3000死が\u3000ふたりを分かつまで……": ""
  },
  "75870": {
    "「……いや。たとえ\u3000死が\u3000ふたりの世界を\n\u3000分けようとも\u3000なお\u3000変わらず \n\u3000生涯\u3000互いを愛し合うことを誓いますか？": ""
  },
  "75871": {
    "「はい\u3000誓います。": ""
  },
  "75872": {
    "「……………。": ""
  },
  "75873": {
    "「……では\u3000次に\n\u3000指輪の交換を\u3000いたしましょう。": ""
  },
  "75874": {
    "「な\u3000なんと……！？": ""
  },
  "75875": {
    "「……………………！": ""
  },
  "75876": {
    "「まさか……。\n\u3000マレン！\u3000君なのかっ……！？": ""
  },
  "75877": {
    "「き\u3000消えた………。": ""
  },
  "75878": {
    "「これは……。\n\u3000神よ\u3000あなたのしわざですか？": ""
  },
  "75879": {
    "「これこそ\u3000奇跡です……\n\u3000ランディさんの\u3000マレンさんへの愛が\n\u3000きっと\u3000天に届いたのでしょう……。": ""
  },
  "75880": {
    "「マ\u3000マレン……！": ""
  },
  "75881": {
    "「僕は\u3000君を愛していた……！\n\u3000君がいてくれたおかげで\u3000僕は……。": ""
  },
  "75882": {
    "ランディと\u3000マレンの結婚式は\nこうして\u3000終わった。": ""
  },
  "75883": {
    "「……<pc>様。\n\u3000あなたのおかげで\u3000私とマレンは\n\u3000無事\u3000結婚式を挙げることができました。": ""
  },
  "75884": {
    "「マレンは\u3000今も\u3000きっと\u3000どこかで\n\u3000私を\u3000見守ってくれている……。\n\u3000さっきのことは\u3000そう思うようにします。": ""
  },
  "75885": {
    "「あなたへのお礼を\u3000しなければなりませんね。\n\u3000さあ\u3000こちらを\u3000お受け取りください。\n\u3000……私の給料\u3000三ヶ月分です。": ""
  },
  "75886": {
    "「……おやおや。\n\u3000ずいぶんな\u3000言われようであります。": ""
  },
  "75887": {
    "「……今になって\u3000気づきましたが\n\u3000<pc>様には\u3000すでに\u3000結婚指輪の用意を\n\u3000手伝っていただいてましたね。": ""
  },
  "75888": {
    "「では\u3000お礼として\u3000こちらを\n\u3000お受け取りください。\n\u3000このたびは\u3000本当に\u3000ありがとうございました。": ""
  },
  "75889": {
    "「……おや\u3000どうやら\u3000誓いの儀式には\n\u3000立ち会えなかったようであります。": ""
  },
  "75890": {
    "「ゴ……ゴーレック様！": ""
  },
  "75891": {
    "「大切な結婚式に\u3000このゴーレックを\n\u3000呼んでくれないとは\u3000なかなか\n\u3000貴君も\u3000水くさい男ですな。": ""
  },
  "75892": {
    "「結婚おめでとう\u3000ランディ。 \n\u3000そして……\u3000マレン君。": ""
  },
  "75893": {
    "「貴君の優しさと深い愛は\u3000きっと\n\u3000彼女にも\u3000届いたことでありましょうな。": ""
  },
  "75894": {
    "「……これは\u3000自分からの\n\u3000結婚祝いであります。\n\u3000どうか\u3000エンリョせず\u3000受け取ってくだされ。": ""
  },
  "75895": {
    "「こっ……これは！": ""
  },
  "75896": {
    "「家臣の結婚式を\u3000手伝ってくださった\n\u3000貴君にも\u3000お礼をせねばなりませんな。\n\u3000さあ\u3000受け取っていただきたい。": ""
  },
  "75897": {
    "<pc>は\u3000ちいさなメダルを\u3000受け取った！": ""
  },
  "75898": {
    "「では\u3000自分は\u3000これにて。\n\u3000ランディ……どうぞ\u3000お幸せに。": ""
  },
  "75899": {
    "「ゴーレック様が\u3000命よりも大事にしている\n\u3000ちいさなメダルを\u3000くださるなんて……。\n\u3000私は\u3000つくづく\u3000幸せ者ですね。": ""
  },
  "75900": {
    "「私は\u3000彼女を失ってから\u3000ずっと \n\u3000自分の悲しみにばかり\u3000囚われていましたが\n\u3000これで\u3000気持ちに\u3000区切りがつけられそうです。": ""
  },
  "75901": {
    "「いつまでも\u3000みっともない姿を見せていては\n\u3000妻に\u3000愛想を尽かされてしまいますからね。": ""
  },
  "76088": {
    "「そっ……そんな目で\u3000見ないでください！ \n\u3000言いづらいことですが……\u3000ゴーレック様から\n\u3000いただける\u3000お給料は\u3000とっても安いのです！": ""
  }
}