  },
  "3914": {
    "「むかーし\u3000むかしの\u3000お話さね……。": ""
  },
  "3915": {
    "<center>むかし\u3000むかし……といっても\n１５年ほど\u3000前のこと……。\nオルフェアに\u3000娘が\u3000おりました。": ""
  },
  "3916": {
    "<center>娘には\u3000生まれつき\u3000未来のことがわかる\n不思議なチカラが\u3000ありました。": ""
  },
  "3917": {
    "<center>ある日……娘は\u3000どうしても\n銀の丘へ\u3000行かなければならないと\nそんな予感が\u3000したのです……。": ""
  },
  "3918": {
    "「ほんとに\u3000ヘンな扉\u3000あるし～！？": ""
  },
  "3919": {
    "「予知っ娘☆アルウェちゃんも\n\u3000こんな\u3000ヘンなのが\u3000ほんとにあるなんて\n\u3000さすがに\u3000びっくりだわあ……。": ""
  },
  "3920": {
    "「えーとお\u3000こんにちはぁ？\n\u3000よばれて\u3000とびでた\u3000アルウェですうー。": ""
  },
  "3921": {
    "<center>銀の丘に現れた\u3000不思議な扉の中で\n娘は\u3000フォステイルという\u3000プクリポから\nなんでも願いがかなう\u3000ノートをもらいました。": ""
  },
  "3922": {
    "<center>ノートに書ける\u3000願いごとは\u3000３つ。\nただし……３つめの願いを\u3000書いたとき\n願いを書いた者は\u3000破滅する……。 ": ""
  },
  "3923": {
    "<center>フォステイルは\u3000そう語ったそうです。": ""
  },
  "3924": {
    "「これってえ\u3000これってえ\u3000ほんとなのかなあ？": ""
  },
  "3925": {
    "「えーとお……そっか！\n\u3000ためしてみちゃえば\u3000いいんだーっ。\n\u3000アルウェちゃん\u3000かしこーい！": ""
  },
  "3926": {
    "「ノートさん\u3000ノートさん。おねがーいっ！": ""
  },
  "3927": {
    "「あたし\u3000アルウェちゃんはあ\u3000\n\u3000本物のお姫様に\u3000なりたいでーすっ。": ""
  },
  "3928": {
    "<center>娘の願いは\u3000かないました。\n次の日\u3000メギストリスのお城から\u3000使いが来て\n娘を\u3000王の妃に迎えたいと\u3000告げたのです。": ""
  },
  "3929": {
    "<center>それから娘は\u3000メギストリス王妃として\nしあわせな日々を\u3000送っていました。": ""
  },
  "3930": {
    "<center>……しかし……。": ""
  },
  "3931": {
    "「お前は\u3000予知のチカラを持つ娘……\n\u3000アルウェに\u3000まちがいないな……？": ""
  },
  "3932": {
    "「ちがいまぁーすっ。": ""
  },
  "3933": {
    "「なっ\u3000なんだと！？": ""
  },
  "3934": {
    "「あたしはぁ\u3000もう\u3000お姫様なんだから！ \n\u3000アルウェ王妃ちゃん様って\u3000呼びなさーい。": ""
  },
  "3935": {
    "「ふざけるなっ！\n\u3000頭から\u3000バリバリ\u3000食ってやるぞ！！": ""
  },
  "3936": {
    "「やーん。こっわーいっ！\n\u3000怒ったー\u3000怒ったー！！": ""
  },
  "3937": {
    "「ぐぬぬ……この\u3000バカ娘め……。": ""
  },
  "3938": {
    "「まあ\u3000よい……。\n\u3000貴様は\u3000アルウェ……": ""
  },
  "3939": {
    "「ちっちっち！\n\u3000かわいい\u3000アルウェ王妃ちゃん様\u3000だもーん。": ""
  },
  "3940": {
    "「貴様は\u3000かわいい\n\u3000アルウェ王妃ちゃん……様？\u3000に\n\u3000まちがいないな？": ""
  },
  "3941": {
    "「そうだけどお。あなた\u3000だあれ？": ""
  },
  "3942": {
    "「……この大陸の\u3000どこかに……\n\u3000プクリポの救世主が\u3000生まれているはず……。": ""
  },
  "3943": {
    "「そいつの居所を\u3000予知してもらおう……。": ""
  },
  "3944": {
    "「えぇ～？\u3000やだぁ。": ""
  },
  "3945": {
    "「アルウェ\u3000そういうの\u3000予知したくなあい！": ""
  },
  "3946": {
    "「予知しないのなら\u3000それでもよい……。": ""
  },
  "3947": {
    "「お前を殺し！\u3000プクリポの子供たちを\n\u3000かたっぱしから\u3000喰らってやるまでよ！！": ""
  },
  "3948": {
    "「………うぅう……。\n\u3000そういう\u3000悪いことは\u3000ダメよう！": ""
  },
  "3949": {
    "「はっはっは！\u3000あっはっはっはっはあっ！": ""
  },
  "3950": {
    "「おそろしいかぁ！？\u3000おそろしいだろう！\n\u3000ならば\u3000言うことを聞け！！": ""
  },
  "3951": {
    "「プクリポの救世主の居所を\n\u3000私のために\u3000予知するのだっ！！": ""
  },
  "3952": {
    "<center>娘は\u3000世界に\u3000おそるべき災いが\n迫っていることを\u3000悟りました……。": ""
  },
  "3953": {
    "<center>そして\u3000娘は\u3000不思議なチカラで\nいまだ\u3000プクランド大陸には\u3000救世主が\n生まれていないことも\u3000知っていたのです……。": ""
  },
  "3954": {
    "「………救世主くんは………": ""
  },
  "3955": {
    "「救世主くんは\u3000まだ\u3000生まれてないの。": ""
  },
  "3956": {
    "「なんだとぉ！？\n\u3000いいかげんなことを言うと\u3000承知せんぞ！": ""
  },
  "3957": {
    "「ほんとよ\u3000ほんとなのよ！！": ""
  },
  "3958": {
    "「……救世主くんは\u3000まだ\u3000いない……。": ""
  },
  "3959": {
    "「でも\u3000もうすぐ……\n\u3000これから\u3000１５年の間に\n\u3000オルフェアのどこかで\u3000生まれるの……。": ""
  },
  "3960": {
    "「ほらあ！\u3000予知してあげたわよおっ！\n\u3000今度は\u3000あたしの言うこと\u3000聞きなさい！": ""
  },
  "3961": {
    "「なんだと……？": ""
  },
  "3962": {
    "「……約束して！": ""
  },
  "3963": {
    "「１５年よ。１５年間\u3000ぜったいに\n\u3000オルフェアの子には\u3000手を出しちゃダメ！！": ""
  },
  "3964": {
    "「１５年経ったら\u3000オルフェアの子を\n\u3000全員\u3000食べちゃえばいいわ！！\n\u3000でも\u3000それまでは\u3000ぜったい……": ""
  },
  "3965": {
    "「ぜったいの\u3000ぜったい\u3000ダメなのっ！！": ""
  },
  "3966": {
    "「……なにを\u3000言いだすかと思えば。": ""
  },
  "3967": {
    "「たった１５年ぽっち\u3000待てばよいのだな？\n\u3000悪魔にとっては\u3000ほんの\u3000ひと眠りよ。": ""
  },
  "3968": {
    "「よかろう。お前と\u3000契約を交わしてやろう。\n\u3000これから１５年の間は\u3000オルフェアの子供には\n\u3000決して\u3000手を出さん。": ""
  },
  "3969": {
    "「ただし……１５年後の\u3000今日になったら\n\u3000好きにさせてもらうぞ……。": ""
  },
  "3970": {
    "「１５年後の今日\u3000オルフェア中の子供を\n\u3000皆殺しにし……\n\u3000救世主を\u3000始末してくれるわ！": ""
  },
  "3971": {
    "「ご苦労だったな\u3000アルウェ！！": ""
  },
  "3972": {
    "「予知のほうびに\u3000お前は\u3000いずれ\n\u3000苦しまぬよう\u3000殺してやろう！！": ""
  },
  "3973": {
    "「はっはっは！\u3000あっはっはっはっはあっ！": ""
  },
  "3974": {
    "「あたし……わかるの……。": ""
  },
  "3975": {
    "「救世主くんは……生まれない……。": ""
  },
  "3976": {
    "「でも……１５年後には……いるの。\n\u3000１５年後に\u3000救世主くんがいるのは\n\u3000あたし\u3000わかるの……。": ""
  },
  "3977": {
    "「アルウェのヤツが\u3000オルフェアに里帰りして \n\u3000ひとり息子の\u3000ラグアス王子を\u3000生んだのは\n\u3000それから\u3000１年後のことだった。": ""
  },
  "3978": {
    "「悪魔なんざと\u3000契約したせいなのか…… \n\u3000ほんとのトコは\u3000わからねえが\u3000アルウェは\n\u3000その後\u3000ひどい死に方をしちまった。": ""
  },
  "3979": {
    "「住んでた家\u3000もろとも……\n\u3000ひと晩で\u3000ミイラみてえに\u3000ひからびて\n\u3000死んじまったと\u3000聞いてるぜ。": ""
  },
  "3980": {
    "「じ……じゃあ\u3000もしかして\n\u3000アルウェさんは\u3000ノートに\n\u3000３つめの願いを\u3000書いちゃったの！？": ""
  },
  "3981": {
    "「さあなあ……。俺には\u3000わからねえ。\n\u3000でも\u3000これだけは\u3000確かよ。": ""
  },
  "3982": {
    "「アルウェは\u3000オルフェアのガキどもを\n\u3000悪魔から守るため\u3000１５年後の今日\n\u3000町中の子供をさらえと\u3000俺に頼んだのさ。": ""
  },
  "3983": {
    "「子供さえ\u3000隠しておきゃあ\n\u3000演芸チャンピオンの\u3000強～い旅人さんが\n\u3000悪魔ザイガスを\u3000倒してくれるから…ってな。": ""
  },
  "3984": {
    "「子供さえ\u3000隠しておきゃあ\n\u3000<pc_race>の\u3000強～い旅人さんが\n\u3000悪魔ザイガスを\u3000倒してくれるから…ってな。": ""
  },
  "3985": {
    "「おおっと。ついつい\u3000長話になっちまったぜ。": ""
  },
  "3986": {
    "「本当に\u3000すまなかったなあ\u3000<pc>。\n\u3000おめえには\u3000礼をしたいから\n\u3000後で\u3000サーカステントへ\u3000来てくれ。絶対だぜ！": ""
  },
  "3987": {
    "「おお～い！\u3000ガキども～！！\n\u3000オルフェアの町へ\u3000帰るぞ～！！": ""
  },
  "3988": {
    "「ここかぁ～！！！\n\u3000悪漢ナブレットの\u3000アジトはっ！？": ""
  },
  "3989": {
    "「うぬう。かような場所に\u3000不似合いな\n\u3000いかにも\u3000アヤシイ扉を発見……！！": ""
  },
  "3990": {
    "「悪漢ナブレットめっ！！\n\u3000神妙に\u3000お縄に\u3000かかれいっ！": ""
  },
  "3991": {
    "「ななっ\u3000なんであるかっ！？\n\u3000このミョーな\u3000場所は……！？": ""
  },
  "3992": {
    "「あっ\u3000開けてくれぇ～い！！\n\u3000誰か～！\u3000助けてえ～っ！！！！": ""
  },
  "3993": {
    "「レディース\u3000エンド\u3000ジェントルメン！\n\u3000エーンド\u3000オルフェアの\u3000チルドレン！\n\u3000そして……": ""
  },
  "3994": {
    "「勇敢なる旅人\u3000<pc>！！": ""
  },
  "3995": {
