{
  "3675": {
    "「ぴゃ～っ！\u3000今日も\u3000おっもしろいね～！！\n\u3000次の出し物\u3000何かな～？": ""
  },
  "3676": {
    "「空中ブランコに\u3000つなわたりに\n\u3000ピエロも\u3000出ただろ……？\n\u3000ええと……まあ\u3000見てれば\u3000わかるって。": ""
  },
  "3677": {
    "「そっかあ！\u3000そうだよね！\n\u3000今日は\u3000サイコーの日だよっ。": ""
  },
  "3678": {
    "「なんだよ\u3000フッタ！\n\u3000弟のくせに\u3000ぼくが言いたかったこと\n\u3000先に言うなよ！！": ""
  },
  "3679": {
    "「ひどいよ\u3000にいちゃ～ん！！": ""
  },
  "3680": {
    "「……でもさあ\u3000にいちゃん。\n\u3000ホントに\u3000今日のサーカスって\u3000タダなの？\n\u3000こんな\u3000面白いのに？": ""
  },
  "3681": {
    "「ああ。サーカスが始まって\u3000１５周年だから\n\u3000記念に\u3000子供はみんな\u3000タダなんだって！\n\u3000ナブレット団長さんが\u3000言ってたよ。": ""
  },
  "3682": {
    "「……ほんとだ。\n\u3000オルフェア中の子供が\u3000見にきてる。": ""
  },
  "3683": {
    "「しかも\u3000サーカスの後は\n\u3000特製アクロバットケーキ\u3000食べ放題だぜ！\n\u3000団長さんって\u3000ふとっぱらで\u3000いい人だよな～。": ""
  },
  "3684": {
    "「しーっ！\u3000\n\u3000次の出し物が\u3000始まるわよ！": ""
  },
  "3685": {
    "「レディース\u3000エンド\u3000ジェントルメン！\n\u3000エーンド……": ""
  },
  "3686": {
    "「オルフェアの\u3000チルドレン！！": ""
  },
  "3687": {
    "「本日は\u3000当\u3000ナブナブ大サーカス団の\n\u3000１５周年を祝う\u3000特別なショーへ\n\u3000ご来場\u3000まことに\u3000ありがとうございます！": ""
  },
  "3688": {
    "「よっ！\u3000待ってました！！\n\u3000オルフェア町長っ！\n\u3000いや\u3000ナブナブ大サーカス\u3000団長っ！！": ""
  },
  "3689": {
    "「……お集まりの\u3000皆さま。": ""
  },
  "3690": {
    "「本日\u3000最後にお見せする\u3000この奇術は\n\u3000１５年目の\u3000この日に\u3000ふさわしい\n\u3000とっておき中の\u3000とっておき。": ""
  },
  "3691": {
    "「どうぞ\u3000目をこらして\n\u3000よーく\u3000ごらんくださいませ。": ""
  },
  "3692": {
    "「このサーカスを\u3000観ている\n\u3000オルフェア中の子供たちを……": ""
  },
  "3693": {
    "「いっしゅんにして！": ""
  },
  "3694": {
    "「……消してごらんにいれましょう！": ""
  },
  "3695": {
    "「３……": ""
  },
  "3696": {
    "「２……": ""
  },
  "3697": {
    "「１……": ""
  },
  "3698": {
    "「プップクペッポッ\u3000プー！": ""
  },
  "3699": {
    "「に\u3000にいちゃん！？\n\u3000まっくらだよ\u3000こわいよ……。": ""
  },
  "3700": {
    "「だいじょうぶだよ\u3000フッタ。\n\u3000すぐに\u3000明るく……": ""
  },
  "3701": {
    "「………………。": ""
  },
  "3702": {
    "「きゃーっ！！！": ""
  },
  "3703": {
    "「すばらしい！\u3000見事に\u3000子供を消し去るとは\n\u3000さすがは\u3000ナブナブ大サーカス団！！\n\u3000ワガハイも\u3000感激いたしましたぞ！": ""
  },
  "3704": {
    "「……さりとて\u3000ナブレット団長どのの姿まで\n\u3000見えぬとは\u3000面妖な。": ""
  },
  "3705": {
    "「うちの子\u3000どこに消えちゃったのかしら？": ""
  },
  "3706": {
    "「おいおい\u3000どうなってるんだよ？": ""
  },
  "3707": {
    "「くっくっくっくっく……": ""
  },
  "3708": {
    "「アーッハッハッハッハッハ！！！": ""
  },
  "3709": {
    "「レディース\u3000エンド\u3000ジェントルメン！！": ""
  },
  "3710": {
    "「当\u3000ナブナブ大サーカス団の\n\u3000１５周年を記念する\u3000最後の大奇術。\n\u3000お楽しみ\u3000いただけましたでしょうか？": ""
  },
  "3711": {
    "「残念ながら\u3000オルフェアの子供たちは\n\u3000もう\u3000戻っては\u3000きません。": ""
  },
  "3712": {
    "「ちょっと！？\u3000どういうこと！？": ""
  },
  "3713": {
    "「いやいや\u3000そんなに\u3000あわてなくても\n\u3000子供たちは\u3000すぐに出てきますよ。": ""
  },
  "3714": {
    "「……いいえ。子供たちは\u3000今日かぎり\n\u3000オルフェアの町から\u3000消え去るのです！": ""
  },
  "3715": {
    "「おいっ！！\u3000ふざけるな！！": ""
  },
  "3716": {
    "「子供たちを\u3000返して！！！": ""
  },
  "3717": {
    "「……これにて\u3000サーカスは\u3000おしまい。": ""
  },
  "3718": {
    "「愛する\u3000オルフェアの町の皆さん。": ""
  },
  "3719": {
    "「ごきげんよう！\u3000": ""
  },
  "3720": {
    "「こ……これは\u3000もしや……\n\u3000……ゆうかい事件では……？": ""
  },
  "3721": {
    "「ゴクッ。": ""
  },
  "3722": {
    "「苦節３０年！！\u3000ワガハイこと\u3000パクレ警部の\n\u3000優秀な頭脳を\u3000オルフェア中に知らしめる\n\u3000ビッグなチャンスが\u3000やっと\u3000おとずれたっ！！": ""
  },
  "3723": {
    "「皆さ～ん！\u3000ごせいしゅくに！！": ""
  },
  "3724": {
    "「たった今\u3000オルフェア中の子供たちが\n\u3000ナブレット団長に\u3000さらわれてしまいました！": ""
  },
  "3725": {
    "「しかし\u3000ご安心めされい！": ""
  },
  "3726": {
    "「このパクレ警部が\u3000かならずや！\n\u3000子供たちを\u3000取り戻してみせますぞ！！": ""
  },
  "3727": {
    "「おのれ！\u3000悪漢ナブレット！！\n\u3000待て待て待てぇ～い！！": ""
  },
  "3728": {
    "「……他の連中の目は\u3000ごまかせても\n\u3000ワガハイの目は\u3000ごまかせんぞ！": ""
  },
  "3729": {
    "「ナブナブ大サーカス団長にして\n\u3000オルフェア町長とは\u3000世をしのぶ仮の姿！\n\u3000その正体は……": ""
  },
  "3730": {
    "「世紀の悪漢\u3000ナブレット！！\n\u3000ヤツは\u3000オルフェアの子供たちを\u3000さらった\n\u3000にっくき凶悪犯！\u3000なのだっ！！": ""
  },
  "3731": {
    "「隠しだてすると\u3000貴様らも\u3000共犯とみなすぞ！\n\u3000さあ\u3000吐け！\u3000吐くのだ！！\n\u3000悪漢ナブレットは\u3000どこへ逃げたっ！？": ""
  },
  "3732": {
    "「……団長は\u3000消えたんだ。": ""
  },
  "3733": {
    "「であるから\u3000その\u3000消えた団長の行き先を\n\u3000教えろと言っているのだっ！！": ""
  },
  "3734": {
    "「そうよ\u3000団長は\u3000奇術で消えちゃったの。\n\u3000もう\u3000どこにもいないわ。\n\u3000オルフェアの子供たちもね。": ""
  },
  "3735": {
    "「フザケたことを\u3000ぬかすなであるっ！！\n\u3000貴様ら\u3000全員\u3000タイホだーっ！！": ""
  },
  "3736": {
    "「待ってください！！": ""
  },
  "3737": {
    "「むむっ\u3000貴様は……。": ""
  },
  "3738": {
    "「おお。子供ではないか！\n\u3000悪漢ナブレットから\u3000逃げてきたのだな！": ""
  },
  "3739": {
    "「ちがうよ！\u3000ぼくは\u3000さらわれてないよ！\n\u3000それに……ナブレット団長は\n\u3000子供をさらったりする人じゃないもの！！": ""
  },
  "3740": {
    "「団長さんは\u3000この町の\u3000しんせきに引き取られた\n\u3000ぼくを\u3000団員にしてくれた。いい人なんだよ！\n\u3000子供をさらうなんて\u3000なにかの\u3000まちがいだよ！": ""
  },
  "3741": {
    "「貴様\u3000なにゆえ\n\u3000そこまで\u3000悪漢ナブレットを\n\u3000かばおうとするのであるか……？": ""
  },
  "3742": {
    "「ははあ……。": ""
  },
  "3743": {
    "「さては\u3000貴様も共犯だな！？": ""
  },
  "3744": {
    "「子供だからと言って\u3000ようしゃはせんのだ！\n\u3000悪漢ナブレットの居場所を\u3000白状するまで\n\u3000せっかんしてやるであるっ！！": ""
  },
  "3745": {
    "「そうか……うっかりしてたぜ。": ""
  },
  "3746": {
    "「団長っ！\u3000いつのまに！？": ""
  },
  "3747": {
    "「プディン。よその町から来た\u3000おめえも\n\u3000今じゃあ\u3000すっかり\u3000オルフェアの子供だ。\n\u3000おめえを忘れちゃあ\u3000意味がねえな。": ""
  },
  "3748": {
    "「さあ\u3000来るんだ！\u3000プディン！！": ""
  },
  "3749": {
    "「今度こそ\u3000オルフェアの子供は\n\u3000全員\u3000さらったぞっ！": ""
  },
  "3750": {
    "「では……さらばだ\u3000諸君！！": ""
  },
  "3751": {
    "「なっ\u3000なんと！？": ""
  },
  "3752": {
    "「一度ならず\u3000二度までも\n\u3000ワガハイの目の前で\u3000子供をさらうとは……。\n\u3000悪漢ナブレットめ\u3000ゆるさーん！！": ""
  },
  "3753": {
    "「待て待て待てぇーい！！": ""
  },
  "3754": {
    "「……誰だい？\u3000あんた。": ""
  },
  "3755": {
    "「へえ……あんた\u3000プディンの知り合いの\n\u3000演芸チャンピオンかい！": ""
  },
  "3756": {
    "「そうか\u3000そうか……。\n\u3000あんたのギャグの数々\u3000プディンから\n\u3000よーく\u3000聞いてるよ。ぷくくっ。": ""
  },
  "3757": {
    "「しかし……そうか。\n\u3000知り合いなら\u3000プディンのこと心配だよな。\n\u3000………そうだよな。": ""
  },
  "3758": {
    "「ふうん……<pc>って\u3000言うのか。\n\u3000キーエンブレムを求めて\u3000来たのかい？": ""
  },
  "3759": {
    "「なら\u3000タイミングが悪かったな。\n\u3000今\u3000行っちまった\u3000ナブレット団長が\n\u3000このオルフェアの\u3000町長なのさ。": ""
  },
  "3760": {
    "「町長が\u3000いないんじゃ\n\u3000キーエンブレムは\u3000もらえないだろ？": ""
  },
  "3761": {
    "「……ナブレット団長が\u3000行きそうな場所に\n\u3000心当たりが\u3000ないわけじゃない。": ""
  },
  "3762": {
    "「オルフェア地方西から\u3000南へ行くと\n\u3000リンクル地方に出る。そこを\u3000さらに南に進んだ\n\u3000銀の丘って場所へ\u3000行ってみるといいだろう。": ""
  },
  "3763": {
    "「ちょっと\u3000ハカル！？\n\u3000こんな\u3000どこの馬の骨とも\u3000わからないヤツに\n\u3000教えちゃっていいの！？": ""
  },
  "3764": {
    "「ナブレット団長が言ってた\u3000例の旅人ってのは\n\u3000もしかしたら\u3000こいつかもしれない。\n\u3000……そんな気がするんだ。": ""
  },
  "3765": {
    "「…………。": ""
  },
  "3766": {
    "「団長は\u3000おそらく\u3000銀の丘だ。\n\u3000<pc>。気をつけてな。": ""
  },
  "3767": {
    "「やだよう！\u3000うちに\u3000帰してよう！": ""
  },
  "3768": {
    "「そうだ！\u3000ナブレット団長！！\n\u3000ぼくたちを\u3000どうするつもりだ！？": ""
  },
  "3769": {
    "「………悪いなあ\u3000ボウズども。": ""
  },
  "3770": {
    "「おめえらを\u3000家に帰すわけには\n\u3000いかねえんだよ。": ""
  },
  "3771": {
    "「ほれっ\u3000ここに\u3000入ってな！": ""
  },
  "3772": {
    "「なっ\u3000なんだよ！？\u3000ここ！\n\u3000どうなってるんだ！？": ""
  },
  "3773": {
    "「やだあ！\u3000帰してー！！": ""
  },
  "3774": {
    "「……さあ\u3000おめえも来るんだ。プディン！": ""
  },
  "3775": {
    "「おめえも\u3000もう\u3000オルフェアの子供だ！\n\u3000さっさと\u3000この扉の中へ\u3000入るんだよっ！！\n\u3000さあっ！！": ""
  },
  "3776": {
    "「ど……どうして？\u3000団長さん！": ""
  },
  "3777": {
    "「団長さん\u3000あんなに\u3000優しかったのに……。\n\u3000いつも\u3000おいしいケーキ焼いてくれたのに……。\n\u3000どうして\u3000こんな\u3000ひどいことするの！？": ""
  },
  "3778": {
    "「…………。": ""
  },
  "3779": {
    "「……悪いな\u3000プディン。": ""
  },
  "3780": {
    "「もう\u3000時間がねえんだよ。": ""
  },
  "3781": {
    "「団長さんっ！？": ""
  },
  "3782": {
    "「開けて！\u3000開けてよーっ！！": ""
  },
  "3783": {
    "「うぇーん！！\u3000帰して！\u3000おうち\u3000帰して！！": ""
  },
  "3784": {
    "「……アルウェ。これで\u3000いいんだな？": ""
  },
  "3785": {
    "「んっ？\u3000誰だ\u3000おめえは……。": ""
  },
  "3786": {
    "「まさかっ！！": ""
  },
  "3787": {
    "「いや\u3000いい……。なにも言うな。\n\u3000おめえの種族を\u3000俺が\u3000当ててやろう。": ""
  },
  "3788": {
    "「おめえは\u3000プクリポの……\n\u3000演芸チャンピオン……そうだな？": ""
  },
  "3789": {
    "「おめえは……\n\u3000<pc_race>だ。そうだろう？": ""
  },
  "3790": {
    "「……やっぱりな。": ""
  },
  "3791": {
    "「俺の種族当ては\u3000百発百中だが……\n\u3000今日ほど\u3000当たって\u3000うれしかったことはねえ。": ""
  },
  "3792": {
    "「ついでに\u3000もうひとつ\u3000当ててやろう。\n\u3000おめえは\u3000オルフェアの町から\n\u3000俺を\u3000追いかけてきた。そうだろう？": ""
  },
  "3793": {
    "「ガキどもは\u3000あの扉の中に\u3000閉じ込めた。\n\u3000今は\u3000絶対に\u3000開かないぜ。": ""
  },
  "3794": {
    "「なにしろ……開くべき運命の時にのみ開く\n\u3000不思議な扉だ……って\n\u3000死んだ妹が\u3000言ってたからな。": ""
  },
  "3795": {
    "「……じゃあな\u3000演芸チャンピオン。\n\u3000あんたが\u3000俺の思ったとおりのヤツなら\n\u3000次は\u3000オルフェアで\u3000会うことになるだろう。": ""
  },
  "3796": {
    "「……じゃあな\u3000<pc_race>の\u3000旅の人。\n\u3000あんたが\u3000俺の思ったとおりのヤツなら\n\u3000次は\u3000オルフェアで\u3000会うことになるだろう。": ""
  },
  "3797": {
    "「おや\u3000<pc>か。": ""
  },
  "3798": {
    "「どうだった？\u3000銀の丘で\n\u3000ナブレット団長には\u3000会えたかい？": ""
  },
  "3799": {
    "「……なんだって？\n\u3000団長が\u3000こっちに戻ってこなかったかだと？": ""
  },
  "3800": {
    "「いや……。今のところ\u3000サーカステントには\n\u3000ナブレット団長は\u3000戻ってきていないが……。\n\u3000なにか\u3000あったのか？": ""
  },
  "3801": {
    "「な\u3000なんだと！？": ""
  },
  "3802": {
    "「ナブレット団長が\n\u3000銀の丘の\u3000不思議な扉の中に\n\u3000プディンや\u3000子供たちを閉じ込めた！？": ""
  },
  "3803": {
    "「ね\u3000ねえ……団長は\n\u3000いったい\u3000何をしようとしているの？": ""
  },
  "3804": {
    "「わからん……。": ""
  },
  "3805": {
    "「団長が\u3000なんのために\u3000そんなことをしたのか\n\u3000オレたちには\u3000わからないが\n\u3000……これだけは\u3000はっきり言える。": ""
  },
  "3806": {
    "「オレたちは\u3000何があっても\u3000団長を信じる。": ""
  },
  "3807": {
    "「た\u3000たいへんだ！！": ""
  },
  "3808": {
    "「空が！\u3000不気味な色に！！": ""
  },
  "3809": {
    "「……なんだ\u3000こりゃあ……！？": ""
  },
  "3810": {
    "「やだ……。\n\u3000なんか\u3000こわい……。": ""
  },
  "3811": {
    "<center>……今日で\u3000１５年目だ……": ""
  },
  "3812": {
    "<center>約束の\u3000１５年目だぞ\u3000アルウェ！！\nこの悪魔ザイガスとの契約\n忘れたとは\u3000言わせんぞ！！": ""
  },
  "3813": {
    "「さあ！\u3000オルフェアの子供らの命！": ""
  },
  "3814": {
    "「すべて\u3000この私に\u3000差しだしてもらおうかっ！": ""
  },
  "3815": {
    "「なっ\u3000なんだ\u3000アイツは！？": ""
  },
  "3816": {
    "「魔物よ！\u3000魔物が\u3000町の中に！！": ""
  },
  "3817": {
    "「き\u3000貴様ーっ！！\n\u3000町内侵入罪で\u3000タイホするのであるっ！！": ""
  },
  "3818": {
    "「……と思ったが\u3000今日は\u3000機嫌がいいので\n\u3000特別に\u3000見逃してやるのである！！": ""
  },
  "3819": {
    "「んん……？": ""
  },
  "3820": {
    "「なんだとお！？": ""
  },
  "3821": {
    "「だましたな！\u3000アルウェぇえええ！！": ""
  },
  "3822": {
    "「この町には\u3000子供など\n\u3000ひとりも\u3000いないではないかっ！！": ""
  },
  "3823": {
    "「……おどろいたぜ。\n\u3000何もかも\u3000アルウェの言ったとおりじゃねえか。": ""
  },
  "3824": {
    "「誰だ！？\n\u3000隠れてないで\u3000出てこい！！": ""
  },
  "3825": {
    "「クックックック……。\n\u3000そう\u3000あわてなさんなよ。悪魔のダンナ。": ""
  },
  "3826": {
    "「オルフェアの\u3000ガキどもはなあ……": ""
  },
  "3827": {
    "「このオルフェアの町長にして\n\u3000ナブナブ大サーカス団長の\u3000ナブレット様が\n\u3000ぜーんいん\u3000さらっちまったのさ！！": ""
  },
  "3828": {
    "「さあ！\u3000オルフェアのガキどもの命\n\u3000とれるモンなら\u3000とってみやがれいっ！": ""
  },
  "3829": {
    "「……貴様ああああ！！！": ""
  },
  "3830": {
    "「ゆるさんぞ！！\u3000契約どおり\n\u3000子供を\u3000よこせええっ！！": ""
  },
  "3831": {
