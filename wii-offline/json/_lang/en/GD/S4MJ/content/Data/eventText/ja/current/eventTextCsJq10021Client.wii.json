{
  "13758": {
    "「止まれ！！": ""
  },
  "13759": {
    "「……わからないか？\u3000泉の\u3000かげりが。\n\u3000今\u3000ともしびの木に触れれば\n\u3000お前の心は\u3000けがされてしまうぞ。": ""
  },
  "13760": {
    "「ザホック！\n\u3000すぐに\u3000浄化の儀を始めよう。": ""
  },
  "13761": {
    "「かしこまりました\u3000ヘルガ僧正。": ""
  },
  "13762": {
    "「神の鏡が\u3000映すは光……。": ""
  },
  "13763": {
    "「影よ……\u3000闇夜のもとへ帰れ！": ""
  },
  "13764": {
    "「成功でしょうか？": ""
  },
  "13765": {
    "「ああ。浄化は\u3000無事に終わった。\n\u3000枝を１本\u3000拝借して\n\u3000あの香術師に\u3000持ちかえってやるとしよう。": ""
  },
  "13766": {
    "「……さて。": ""
  },
  "13767": {
    "「お前は\u3000誰だ？\u3000なぜ\u3000こんな所へ？": ""
  },
  "13768": {
    "「……なるほどな。\n\u3000<pc>\u3000お前は\u3000あの香術師に頼まれ\n\u3000私の身を案じて\u3000ここへ来たというのか。": ""
  },
  "13769": {
    "「それは\u3000また\u3000ご苦労なことだ。": ""
  },
  "13770": {
    "「<pc>さん。\n\u3000我らは\u3000みかがみの泉の\u3000かげりに気づいて\n\u3000浄化の儀の\u3000準備をしていたのですよ。": ""
  },
  "13771": {
    "「どうやって\u3000この場所を知り得たか\u3000わからぬが\n\u3000こんな時に\u3000お前のような者と出会えたのは\n\u3000神の\u3000ご意志かもしれない。": ""
  },
  "13772": {
    "「さて。用も\u3000済んだことだ。\n\u3000アズランの\u3000キリカ聖堂に戻るとしよう。\n\u3000<pc>。お前も\u3000来るといい。": ""
  },
  "13773": {
    "「ややっ\u3000<pc>さん！": ""
  },
  "13774": {
    "「ヘルガ僧正から\u3000話は聞きました。\n\u3000結局\u3000いらぬ心配だったようで……\n\u3000いやはや\u3000ご迷惑を\u3000おかけしました。": ""
  },
  "13775": {
    "「でも\u3000おかげさまで\n\u3000無事に\u3000ともしびの木が\u3000手に入りました！": ""
  },
  "13776": {
    "「ほらっ\u3000いい香りでしょう？\n\u3000この\u3000ともしびの木の香りが\n\u3000魔物は\u3000大の苦手なんだそうです。": ""
  },
  "13777": {
    "「これがあれば\u3000森に入っても安心！\n\u3000……ということで\u3000薬草摘みの方に\n\u3000たいへん\u3000よろこんでいただけるんですよ。": ""
  },
  "13778": {
    "「おっと\u3000いけません。\n\u3000<pc>さんに\u3000ヘルガ僧正から\n\u3000お話が\u3000あるそうですよ。": ""
  },
  "13779": {
    "「聞いたぞ\u3000<pc>。\n\u3000我らが\u3000キリカ修道会への入門を\n\u3000望んでいるそうだな。": ""
  },
  "13780": {
    "「お前のチカラは\u3000すでに見せてもらった。\n\u3000キリカ修道会の僧侶として\u3000認めよう。": ""
  },
  "13781": {
    "「大僧正様\u3000かまいませんね？": ""
  },
  "13782": {
    "「ええ\u3000ええ。もちろんですとも……。\n\u3000新たな兄弟\u3000<pc>を\n\u3000ここに\u3000迎え入れましょう。": ""
  },
  "13783": {
    "「<pc>。私たち\u3000キリカ修道会は \n\u3000大いなる\u3000エルドナ神の教えのもと\n\u3000多くの人々を\u3000災いから\u3000救ってきました。": ""
  },
  "13784": {
    "「あなたも\u3000エルドナ神の御手となり\n\u3000偉大な仕事を\u3000になうのです。\n\u3000いっそうの精進を\u3000忘れないように。": ""
  },
  "13785": {
    "「それから\u3000ヘルガ僧正。\n\u3000<pc>の師は\u3000あなたに\u3000まかせます。": ""
  },
  "13786": {
    "「はい\u3000大僧正様。": ""
  },
  "13787": {
    "「……そういうわけだ。\n\u3000これからは\u3000師である私の教えに従え。": ""
  },
  "13788": {
    "「お前の入門を祝って\u3000これを\u3000さずけよう。\n\u3000よろしくな\u3000<pc>。": ""
  },
  "13789": {
    "「テキスト削除": ""
  },
  "13790": {
    "「テキスト削除": ""
  },
  "13791": {
    "「さて。私は\u3000しばし\u3000出かける。\n\u3000行くぞ\u3000ザホック！": ""
  },
  "13792": {
    "「はい\u3000ヘルガ僧正。\n\u3000よろこんで\u3000おともいたします。": ""
  },
  "13793": {
    "「<pc>よ。修練を積むのだ。\n\u3000時が過ぎ\u3000お前が\u3000レベル３５になる頃に\n\u3000私は\u3000ここに戻ってくるだろう。": ""
  },
  "13794": {
    "「お前には\u3000期待しているぞ。": ""
  },
  "27397": {
    "「そうそう。私からのお礼も\u3000まだでしたね。 \n\u3000一緒に\u3000受け取ってください。\n\u3000本当に\u3000ありがとうございました！": ""
  }
}