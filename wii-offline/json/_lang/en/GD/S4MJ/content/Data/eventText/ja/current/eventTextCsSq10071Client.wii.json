{
  "70851": {
    "「……水温よし。\n\u3000しびれくらげの姿も……見えないな。": ""
  },
  "70852": {
    "「ムーロンさん。問題なさそうっス！": ""
  },
  "70853": {
    "「今年も\u3000このときが来ちまったか。\n\u3000スリルとロマンスの\u3000夏\u3000本番……。": ""
  },
  "70854": {
    "「ゴウレ！\u3000若者たちに告げな！": ""
  },
  "70855": {
    "「よぉーっし！\u3000お前たち！\n\u3000お待ちかね\u3000海開きの時間だぞぉっ！": ""
  },
  "71177": {
    "「コイツはな\u3000この船とともに沈んだ\n\u3000仲間たちの遺品なんだ。": ""
  },
  "71178": {
    "「あれはもう……\n\u3000今から\u3000５００年ほど前のことだ。": ""
  },
  "71179": {
    "「アストルティアに\u3000未曾有の災厄が訪れた。\n\u3000……いつわりの太陽が\u3000地表を焦がし\n\u3000そこに住む者たちを\u3000次々に焼いたのさ。": ""
  },
  "71180": {
    "「オレたちは\u3000人々の混乱に乗じて宝を盗みだし\n\u3000この船に\u3000たんまり載せて\u3000逃げ回っていた。\n\u3000いつわりの太陽が\u3000消え去る日を待ってな。": ""
  },
  "71181": {
    "「だが……食料を調達するために\n\u3000立ち寄った島で\u3000オレの運命は変わった。": ""
  },
  "71182": {
    "「オレは\u3000島に住む者たちを集めて\n\u3000ありったけの食いもんを出せと\u3000命じたんだ。\n\u3000切っ先がノドにかかるほど\u3000剣を突きつけてな。": ""
  },
  "71183": {
    "「だが\u3000あいつらは\u3000そんな脅しに動じなかった。\n\u3000それどころか\u3000極悪非道のデュレーク海賊団を\n\u3000つかまえて\u3000こう言ったんだ。": ""
  },
  "71184": {
    "「神さまが\u3000迎えに来てくれた……。\n\u3000この人たちが\u3000私たちを\u3000安らぎの地へ\n\u3000いざなってくれる……ってな。": ""
  },
  "71185": {
    "「……あの\u3000いつわりの太陽のせいで\n\u3000この世界は\u3000狂っちまったんだ。": ""
  },
  "71186": {
    "「略奪に来た海賊を\u3000まさかの神さま扱い……。\n\u3000そんな異様な光景を\u3000目の当たりにして\n\u3000オレ自身も\u3000狂っちまったんだろうな……。": ""
  },
  "71187": {
    "「胸に\u3000熱い想いが\u3000たぎってきてなぁ。\n\u3000気がついたら\u3000ヤツらを船に乗せていたんだ。\n\u3000全員乗れるように\u3000大切な宝を捨ててな。": ""
  },
  "71188": {
    "「その後も行く先々で\u3000宝を捨てては\u3000苦しんでる\n\u3000人たちを船に乗せたよ。捨てる宝がなくなったら\n\u3000乗員たちが荷物を捨て\u3000船を軽くしてくれた。": ""
  },
  "71189": {
    "「だが\u3000救いを求める人々は\u3000あとを絶たず\n\u3000ついに\u3000この船にも限界が来た。\n\u3000これ以上\u3000人を乗せたら\u3000船は沈んじまう……。": ""
  },
  "71190": {
    "「そのときだ……。肌身離さず持っていた\n\u3000大切なお守りを\u3000みんなが\u3000捨てはじめたのさ。\n\u3000少しでも\u3000船を軽くしようってな……。": ""
  },
  "71191": {
    "「みんなで\u3000安らぎの地に\u3000たどり着く……。\n\u3000その心の支えにしてた\u3000お守りまで捨てて……\n\u3000まったく\u3000バカな連中だぜ。": ""
  },
  "71192": {
    "「船長として\u3000今のオレが\u3000やるべきこと……。\n\u3000それは\u3000この地に縛られている\u3000仲間たちに\n\u3000希望を返し\u3000新たな航路を示してやること。": ""
  },
  "71193": {
    "「ほら\u3000お前たちの希望を返すよ。\n\u3000もう二度と\u3000手放すんじゃねえぞ。": ""
  },
  "71194": {
    "「みんな……今度こそ\n\u3000安らぎの地へ行くんだぜ……。": ""
  },
  "71195": {
    "「さてと……しめっぽいのは\u3000おしめえだ。\n\u3000長話に\u3000付き合わせちまって\u3000悪かったな。\n\u3000さあ\u3000今回の礼を受け取ってくれ。": ""
  },
  "71196": {
    "「……こんなボロボロの姿になっても\n\u3000オレは\u3000この船の船長だ。\n\u3000ここに残って\u3000一緒にいてやらねーとな。": ""
  },
  "71198": {
    "「この夏\u3000最大の青春が\n\u3000大グチ開けて\u3000待ってるってなぁ！": ""
  }
}