{
  "46476": {
    "「キハダさんっ。まだ\u3000間に合います。\n\u3000やめるなんて言わずに\u3000もう一度\n\u3000考え直してください！": ""
  },
  "46477": {
    "「げーっ\u3000また来たのかよ\u3000アンタ……。\n\u3000うるせえなぁ。おれっちは\n\u3000もう\u3000木工職人になんざ\u3000未練はねぇんだ！": ""
  },
  "46478": {
    "「郷里のお母さまが\u3000ご病気で\n\u3000お金が必要だったのは\u3000わかります……。": ""
  },
  "46479": {
    "「でも\u3000うちに入門するとき\u3000世界一の\n\u3000木工職人になって\u3000お城に\u3000家具を献上するのが\n\u3000夢だって\u3000おっしゃっていたじゃないですか！": ""
  },
  "46480": {
    "「よう\u3000邪魔するぜ\u3000キハダさん。\n\u3000金が返せねぇなら\u3000もういいかげん\n\u3000こっちに\u3000身体\u3000あずけてもらおうじゃねぇか。": ""
  },
  "46481": {
    "「うっ！\u3000デュバルさん……。\n\u3000わかりました……。今\u3000行きます。": ""
  },
  "46482": {
    "「待って！\u3000あなたたちは\u3000どなたです？\n\u3000うちの職人を\u3000どこへ連れていく気ですか？": ""
  },
  "46483": {
    "「もう\u3000いいんだ\u3000カンナさん……。\n\u3000夢じゃ\u3000食っていけねぇんだ。": ""
  },
  "46484": {
    "「ごちゃごちゃ言ってねーで\u3000早く来い！\n\u3000テメーらみたいな\u3000カビくせぇ木工職人じゃ\n\u3000利息分だって\u3000払えねぇだろうが！": ""
  },
  "46485": {
    "「………………あ？": ""
  },
  "46486": {
    "「カビくさい……だと？\n\u3000ちょっと\u3000聞き捨てならない言葉だね！！": ""
  },
  "46487": {
    "「……アタシは\u3000素材にも\u3000道具にも\n\u3000カビなんて生やさせたこたぁ\u3000ありゃしないよ！\n\u3000職人の誇りにかけてね！！": ""
  },
  "46488": {
    "「アンタらこそ\u3000今\u3000自分のやってることに\n\u3000誇りが\u3000あるってのかい！？\n\u3000胸張って\u3000仕事してんのかい？\u3000えぇ！？": ""
  },
  "46489": {
    "「キハダ！\u3000アンタもアンタだよ！\n\u3000借金が苦しいからって\u3000一度抱いた夢を\n\u3000捨てるなんて\u3000情けない男だね！": ""
  },
  "46490": {
    "「カ……カンナさん……！？": ""
  },
  "46491": {
    "「ちょ……ちょっと\u3000アニキ！\n\u3000ツバクロのアニキ～！！": ""
  },
  "46492": {
    "「なんじゃ\u3000騒がしいのぅ。\n\u3000オメーらで\u3000ちーたぁ片付けぇや……。": ""
  },
  "46493": {
    "「ん\u3000んん！？\n\u3000……もしや\u3000お嬢？\u3000お嬢じゃろか？": ""
  },
  "46494": {
    "「おや\u3000誰かと思ったら\u3000ツバクロじゃないか。\n\u3000ひさしぶりだね。": ""
  },
  "46495": {
    "「フン……。一文無しで\u3000じいさんに拾われて\n\u3000ギルドの\u3000使い走りしてたアンタが\u3000今じゃ\n\u3000アコギな商売で\u3000デカい顔してるみたいだねぇ。": ""
  },
  "46496": {
    "「まぁいいさ。アンタなら\u3000話が早いよ。\n\u3000これ\u3000受け取ってくんな！\u3000その代わり\n\u3000キハダの借金は\u3000チャラにしておくれ。": ""
  },
  "46497": {
