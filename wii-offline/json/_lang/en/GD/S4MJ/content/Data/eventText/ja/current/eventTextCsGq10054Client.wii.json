  },
  "46498": {
    "「今のアタシにとって\u3000門弟よか\n\u3000大事なモンなんて\u3000ないんでね。\n\u3000じいさんも\u3000わかってくれるさ……。": ""
  },
  "46499": {
    "「カンナさん……。": ""
  },
  "46500": {
    "「まったく\u3000お嬢には\u3000かなわんのぉ。\n\u3000……ほいじゃ\u3000こりゃあ\n\u3000わしが\u3000いっとき\u3000あずからせてもらいます。": ""
  },
  "46501": {
    "「ツバクロ\u3000恩に着るよ……。": ""
  },
  "46502": {
