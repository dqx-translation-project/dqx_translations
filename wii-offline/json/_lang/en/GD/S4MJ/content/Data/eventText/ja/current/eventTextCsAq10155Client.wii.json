{
  "22054": {
    "「<pc>さん！\n\u3000今の話\u3000ボクも聞かせてもらいましたよ！\n\u3000どうやら\u3000有力な情報みたいですね！": ""
  },
  "22055": {
    "「シエラ巡礼地は\u3000たしか\u3000ジュレットの町の南\n\u3000ミューズ海岸から\u3000ジュレー島下層大空洞に出て\n\u3000東に渡った\u3000レーナム緑野の北東にあったはず。": ""
  },
  "22056": {
    "「うん。行ってみる価値は\u3000ありますね！\n\u3000そこに\u3000ドゥラくんがいないか\n\u3000シエラ巡礼地を\u3000くまなく探してみましょう！": ""
  },
  "22057": {
    "「ドゥラくん\u3000海を見ながら\n\u3000妙な気を起こしてなければ\u3000いいけど……。\n\u3000それでは\u3000<pc>さん\u3000行きましょう！": ""
  },
  "22058": {
    "「ドゥラくん！！": ""
  },
  "22059": {
    "「ラ\u3000ラミザ王子……？\n\u3000それに\u3000<pc>さんも……。": ""
  },
  "22060": {
    "「探したんだよ\u3000ドゥラくん！\n\u3000行き先も告げず\u3000こんな所に来て……\n\u3000いったい\u3000何してるのさ！？": ""
  },
  "22061": {
    "「お…落ち着いてください\u3000ラミザ王子。\n\u3000私は\u3000花を摘みにきただけですよ。": ""
  },
  "22062": {
    "「は…\u3000花……？": ""
  },
  "22063": {
    "「はい。これです。\n\u3000シエラの花というのですが\n\u3000ここにしか咲かない\u3000貴重な花なのです。": ""
  },
  "22064": {
    "「そうだったんだ。よかった……。\n\u3000ドゥラくん\u3000思いつめた顔をしてたから\n\u3000ボクは\u3000てっきり……。": ""
  },
  "22065": {
    "「私が\u3000自ら\u3000命を絶つのではないか…と？": ""
  },
  "22066": {
    "「う\u3000うん……。": ""
  },
  "22067": {
    "「お気づかい\u3000ありがとうございます。\n\u3000ですが\u3000心配いりません。": ""
  },
  "22068": {
    "「私には\u3000まだ\u3000やるべきことが\n\u3000残っていますので……。": ""
  },
  "22069": {
    "「それでは\u3000失礼します。": ""
  },
  "22070": {
    "「え？\u3000ドゥ…ドゥラくん！\n\u3000今度は\u3000どこへ行くの？": ""
  },
  "22071": {
    "「モガレ修道院に\u3000この花を\n\u3000渡さなくてはならない人がいるのです。": ""
  },
  "22072": {
    "「では……。": ""
  },
  "22073": {
    "「モガレ修道院……。\n\u3000マザー・ヘレナがいた\u3000ドゥラくんの故郷……。": ""
  },
  "22074": {
    "「<pc>さん\u3000なにやら\u3000胸騒ぎがします！\n\u3000ボクたちも行きましょう\u3000モガレ修道院に！": ""
  },
  "22075": {
    "「ドゥラ……！？\n\u3000修道院を捨てた\u3000アンタが\n\u3000今さら\u3000何しにきたのさ？": ""
  },
  "22076": {
    "「それに……\u3000マザー・ヘレナは\n\u3000一緒じゃないのかい？": ""
  },
  "22077": {
    "「……ニニカ。とりあえず\n\u3000これを\u3000受け取ってくれないか。": ""
  },
  "22078": {
    "「これって……。シエラの花？\n\u3000あたいが\u3000遠足のときに摘んできた……。": ""
  },
  "22079": {
    "「そう。そして\u3000世話係になったオレが\n\u3000すぐに\u3000枯らしてしまった花だ。\n\u3000あのときは\u3000キミに\u3000散々\u3000恨まれたっけな。": ""
  },
  "22080": {
    "「当時は\u3000子供だけで\u3000あそこに行けなかったから\n\u3000大人になったら\u3000その罪滅ぼしをしようと\n\u3000ずっと\u3000思っていたんだ。": ""
  },
  "22081": {
    "「アンタが\u3000この花のこと\n\u3000覚えてるなんて\u3000思わなかったよ……。\n\u3000でも\u3000なんで\u3000今になって？": ""
  },
  "22082": {
    "「意味なんてない。\n\u3000ただ\u3000借りを返したくなっただけだ……。": ""
  },
  "22083": {
    "「ドゥラ……？": ""
  },
  "22084": {
    "「……私は\u3000キミたちに\n\u3000伝えなければならないことがある。": ""
  },
  "22085": {
    "「マザー・ヘレナは……\n\u3000もう\u3000ここには帰ってこない。": ""
  },
  "22086": {
    "「帰ってくることが\u3000できないんだ……。": ""
  },
  "22087": {
    "「………………………………。": ""
  },
  "22088": {
    "「……ウソだ。そんなのウソだ。\n\u3000マザー・ヘレナが\u3000魔物と\u3000一緒に\n\u3000封印されて\u3000帰れなくなったなんて……。": ""
  },
  "22089": {
    "「ドゥラ……！\u3000貴様ァァァァ……！！\n\u3000お前が\u3000ついていながら\u3000マザー・ヘレナを\n\u3000見殺しにしたって言うのか！？\u3000ああッ！？": ""
  },
  "22090": {
    "「うえぇぇぇん！\u3000返してよ……！！\n\u3000あたしたちの\u3000マザー・ヘレナを返してよ！\n\u3000返してよう！！": ""
  },
  "22091": {
    "「……すまない。\n\u3000今の私には\u3000どうすることもできないのだ。": ""
  },
  "22092": {
    "「……だが\u3000キミたちに\n\u3000だまっているわけには\u3000いかなかった。\n\u3000だから\u3000それだけ\u3000伝えにきたんだ。": ""
  },
  "22093": {
    "「私のことを\u3000恨んでくれて構わない。\n\u3000この修道院にも\u3000もう二度と\u3000足を運ばない。\n\u3000本当に\u3000すまなかった……。": ""
  },
  "22094": {
    "「ドゥラ…くん……。": ""
  },
  "22095": {
    "「待ちな！\u3000ドゥラ！": ""
  },
  "22096": {
    "「アンタ\u3000これから\u3000どうするつもりだい？\n\u3000言いたいこと言って\u3000死んじまおうだなんて\n\u3000考えてるんじゃないだろうね？": ""
  },
  "22097": {
    "「………………………………。": ""
  },
  "22098": {
    "「アンタね。\n\u3000死んで\u3000責任逃れができるなんて思ったら\n\u3000大間違いだよ！": ""
  },
  "22099": {
    "「オレが\u3000自分の命を\u3000どうしようが勝手だ！\n\u3000キミに指図されたくはない！": ""
  },
  "22100": {
    "「待ちな！": ""
  },
  "22101": {
    "「……あたいも\u3000アンタに渡す物がある。": ""
  },
  "22102": {
    "「……これ。\n\u3000マザー・ヘレナから\u3000アンタにって。": ""
  },
  "22103": {
    "「手紙？\u3000マザー・ヘレナが\u3000オレに……。": ""
  },
  "22104": {
    "「この間\u3000アンタが使いを\u3000よこした後\n\u3000代筆を頼まれて\u3000書いたんだ。\n\u3000心して\u3000読みな……。": ""
  },
  "22105": {
    "<center>ドゥラ。私の愛しい子。\n私の身に\u3000何かあったときのため\n手紙を\u3000残しておこうと思いました。": ""
  },
  "22106": {
    "<center>あなたは\u3000人一倍\u3000正義感が強く\n誰よりも\u3000思いやりのある\u3000優しい子でした。": ""
  },
  "22107": {
    "<center>おなかを空かせた子がいたら\u3000パンを分けあたえ\nお友達が\u3000ガキ大将に\u3000いじめられたと知ったら\nわき目もふらず\u3000飛びだしていった。": ""
  },
  "22108": {
    "<center>そして\u3000目の見えない\u3000私を思いやって\nいつも\u3000私の手を引いてくれましたね……。": ""
  },
  "22109": {
    "「……ね\u3000ねえ\u3000マザー・ヘレナ？": ""
  },
  "22110": {
    "「なあに？\u3000ドゥラ。": ""
  },
  "22111": {
    "「あ\u3000あのね\u3000ボクね。\n\u3000マザー・ヘレナに\u3000ひとつだけ\n\u3000お願いがあるんだ……。": ""
  },
  "22112": {
    "「マザー・ヘレナのこと……\n\u3000お母さん…\u3000って呼んでもいい？": ""
  },
  "22113": {
    "<center>……しかし\u3000手のアザに\u3000気づいたときから\nあなたは\u3000変わってしまった。": ""
  },
  "22114": {
    "<center>自分が\u3000ドルワームの王子であることを\nみんなに\u3000認めてもらうため\n自分を押し殺し\u3000必死に勉強をした……。": ""
  },
  "22115": {
    "<center>まるで\u3000王子でなければ\n自分には\u3000生きている価値がないとでも\n感じているかのように……。": ""
  },
  "22116": {
    "<center>そして\u3000私は\u3000風の便りで\u3000耳にしました。\n自分が\u3000王子でないと知った\u3000あなたは\nひどく落ち込んでしまったと……。": ""
  },
  "22117": {
    "<center>けれど\u3000ドゥラ。": ""
  },
  "22118": {
    "<center>あなたは\u3000その手で\u3000人のためになる研究をし\nその手で\u3000パンを分けあたえ\u3000その手で……\n目の見えない私の手を\u3000引いてくれたのです。": ""
  },
  "22119": {
    "<center>あなたの価値は\u3000手のアザにあるのではなく\nあなたの手\u3000そのものにあるのです。": ""
  },
  "22120": {
    "<center>これからも\u3000その手で\n多くの人を\u3000救いなさい。\nあなたには\u3000それができるのですよ。": ""
  },
  "22121": {
    "「うう……。母さん……。\n\u3000ヘレナ母さん……！": ""
  },
  "22122": {
    "「……ねえ\u3000ドゥラ。アンタ\u3000覚えてる？\n\u3000マザー・ヘレナが\u3000あたいたちに\n\u3000いつも言っていた言葉……。": ""
  },
  "22123": {
    "「……あなたたちは\u3000両親の愛情には\n\u3000恵まれなかったかもしれない。": ""
  },
  "22124": {
    "「でも\u3000見守っていてくれる人は\u3000必ずいる。\n\u3000その人たちのためにも\n\u3000いつでも\u3000精一杯\u3000生きなさい……。": ""
  },
  "22125": {
    "「だから\u3000お願い\u3000ドゥラ……。\n\u3000自分から\u3000命を絶とうなんて\n\u3000もう二度と\u3000思わないで……。": ""
  },
  "22126": {
    "「手紙に書いてある通り\n\u3000アンタには\u3000あたいたちにはない才能がある。\n\u3000それを信じて\u3000がんばりな。": ""
  },
  "22127": {
    "「……ありがとう\u3000ニニカ。": ""
  },
  "22128": {
    "「私は\u3000マザー・ヘレナと\n\u3000キミたちによって……": ""
  },
  "22129": {
    "「生きることを\u3000ゆるされた…………。": ""
  },
  "22130": {
    "「よかったですね\u3000ドゥラくん。\n\u3000本当に\u3000よかった……。": ""
  },
  "22131": {
    "「<pc>さん。\n\u3000これまで\u3000ありがとうございました。\n\u3000どうか\u3000ボクからのお礼\u3000受け取ってください。": ""
  },
  "22132": {
    "「ドゥラくんは\u3000もう大丈夫ですよね。\n\u3000人生の宝物ともいえる\u3000最高の贈り物を\n\u3000母親から\u3000もらったんですから。": ""
  },
  "22133": {
    "「それでは\u3000<pc>さん。\n\u3000ボクも\u3000ドルワームに戻りますね！\n\u3000また\u3000会いましょう！": ""
  }
}