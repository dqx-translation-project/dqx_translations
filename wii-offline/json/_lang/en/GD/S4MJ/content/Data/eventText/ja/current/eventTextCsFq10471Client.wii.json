{
  "66591": {
    "「あニャ？\u3000そこにいるのは\n\u3000<pc>じゃないかニャ。": ""
  },
  "66592": {
    "「なんで\u3000キサマが\u3000ここにいるニャ？\n\u3000もしかして\u3000オレの追っかけを\n\u3000始めたのかニャー。": ""
  },
  "66593": {
    "「……まあいいニャ。\n\u3000ヒマしてたとこだから\u3000話があるなら\n\u3000聞いてやってもいいニャ。": ""
  },
  "66594": {
    "<pc>は\u3000キャット・バルバドと\nリューデという\u3000ふたりの勇士の子孫を\n探していることを\u3000話した。": ""
  },
  "66595": {
    "「……ふむ。確かに\u3000キャット・バルバドさまは\n\u3000オレのご先祖さまニャ。そして\u3000我が家には\n\u3000代々\u3000こんな言葉が\u3000伝えられているニャ。": ""
  },
  "66596": {
    "「輝くマントを求める者\u3000現れし時\n\u3000勇士の血を引きし\u3000ふたりの者\n\u3000いさかいの手を休め\u3000チカラを合わせよ。": ""
  },
  "66597": {
    "「そして\u3000永遠の地下迷宮の広間にて\n\u3000ともに\u3000祈りを捧げよ。\n\u3000さすれば\u3000海淵の間への道は\u3000開かれん……。": ""
  },
  "66598": {
    "「もうひとりの勇士の子孫が\u3000誰なのか\n\u3000気にはニャっていたが\u3000アヤツを見たとき\n\u3000オレは\u3000気づいてしまったのニャよ。": ""
  },
  "66599": {
    "「もうひとりの勇士の子孫は\n\u3000あの\u3000ヒューザとかいう\n\u3000ムカつくヤツに\u3000ちがいないニャ！": ""
  },
  "66600": {
    "「だが\u3000残念だったニャ\u3000<pc>ーー！！": ""
  },
  "66601": {
    "「あの\u3000泥くさい小魚野郎のヒューザは\n\u3000オレが\u3000やっつけちまったのニャー！！": ""
  },
  "66602": {
    "「……その出会いは\u3000偶然だったニャ。\n\u3000旅の身空の者同士。ここで会ったが百年目。\n\u3000オレとアヤツは\u3000黙って\u3000剣を抜いたニャ。": ""
  },
  "66603": {
    "「時が止まったかのような\u3000にらみ合い。\n\u3000だが\u3000ひきょうなことに\u3000アヤツは\n\u3000猫の弱点\u3000マタタビを投げつけてきたのニャ！": ""
  },
  "66604": {
    "「オレは\u3000とろんとする\u3000身体をふるい立たせ！\n\u3000アヤツの剣を\u3000右に！\u3000左に！\u3000華麗にかわし！": ""
  },
  "66605": {
    "「アヤツの\u3000一瞬のスキを狙い！\n\u3000キャット剣法の秘奥義\u3000キャット空中大車輪を\n\u3000おみまいしてやったのニャー！！": ""
  },
  "66606": {
    "「それで\u3000アヤツは\u3000ジ・エンドだったニャ。\n\u3000ニャーッハッハッハッ。": ""
  },
  "66607": {
    "「……というわけで\u3000ヒューザは\n\u3000もう\u3000この世には\u3000いニャいが\n\u3000安心するのニャ\u3000<pc>。": ""
  },
  "66608": {
    "「アヤツなんか\u3000いなくても\u3000オレが祈れば\n\u3000海淵の間への道を開くことなど\u3000猫飯前ニャ。\n\u3000なんなら\u3000キサマも\u3000一緒に祈るニャ。": ""
  },
  "66609": {
    "「そうと決まれば\u3000さっそく\n\u3000永遠の地下迷宮の広間へ\u3000向かうニャ。\n\u3000<pc>も\u3000すぐに来るがいいニャ。": ""
  },
  "66610": {
    "「ニャッ？\u3000やっと\u3000来たかニャ。": ""
  },
  "66611": {
    "「<cs_pchero>が来るのが\u3000おそいんで\n\u3000ちょっと奥で\u3000狩りをしてたニャ。": ""
  },
  "66612": {
    "「……ふむ。\n\u3000たしか\u3000海淵の間への道が開く場所は\n\u3000あっちの方だニャ。ついてくるのニャ。": ""
  },
  "66613": {
    "「それニャあ\u3000さっそく\u3000剣をかかげて\n\u3000祈ってみるかニャ。せっかくだから\n\u3000<cs_pchero>も\u3000一緒に\u3000祈るといいのニャ。": ""
  },
  "66614": {
    "リベリオは\u3000剣をかかげ\u3000祈りはじめた。": ""
  },
  "66615": {
    "<cs_pchero>も\u3000リベリオに合わせて\n祈ってみた……。": ""
  },
  "66616": {
    "「…………何も起こらないニャ。": ""
  },
  "66617": {
    "「……ニャハハハッ。ダメみたいだニャー。\n\u3000これはもう\u3000キサマは\u3000王者になれない\n\u3000運命だったと\u3000あきらめるしかないニャ。": ""
  },
  "66618": {
    "「……ニャッ？\u3000オレのせいじゃないニャ！\n\u3000キサマが\u3000もっと早く\u3000王者のマントを取りに\n\u3000オレのとこに来てれば\u3000よかったのニャ！": ""
  },
  "66619": {
    "「そしたら\u3000あの小魚野郎のヒューザを\n\u3000殺すこともなく\u3000ご先祖さまの教えの通り\n\u3000キサマに\u3000協力してやれたのニャ！": ""
  },
  "66620": {
    "「……誰が\u3000誰を殺したって？": ""
  },
  "66621": {
    "「ニャニャッ！？\n\u3000なぜ\u3000キサマが\u3000ここに！": ""
  },
  "66622": {
    "「ちょっと\u3000猫島に寄ったら\u3000<cs_pchero>が\n\u3000オレを探してるって\u3000ネコどもに聞いてな。\n\u3000わざわざ探して\u3000来てやったんだよ。": ""
  },
  "66623": {
    "「で？\u3000なんで\u3000オレが\n\u3000ブタネコに\u3000殺されたことになってるんだ？": ""
  },
  "66624": {
    "「確かに\u3000ちょっと前にバッタリ会って\n\u3000お前と\u3000やり合ったが\u3000すぐに\u3000しっぽを巻いて\n\u3000逃げだしたのは\u3000誰だったっけかな？": ""
  },
  "66625": {
    "「ぬぬぬぬ……。うるさいニャ！\n\u3000ちょっと\u3000お茶目なウソをついただけニャッ。": ""
  },
  "66626": {
    "「今は\u3000ブタネコと\u3000コントやってる\n\u3000場合じゃねえんだよな\u3000<cs_pchero>。\n\u3000王者のマントが\u3000ほしいんだろ？": ""
  },
  "66627": {
    "「オレに\u3000そんなチカラがあるとは思えないし\n\u3000無駄かもしれねえが\u3000やるだけやってみるさ。\n\u3000他でもない\u3000<cs_pchero>のためだからな。": ""
  },
  "66628": {
    "「おい\u3000ブタネコ。\n\u3000オレたちで\u3000何をすればいいんだ？": ""
  },
  "66629": {
    "「ブタネコって言うの\u3000やめろニャ！\n\u3000ふたりで\u3000同時に剣をかかげて\n\u3000祈りを捧げれば\u3000いいんニャ！！": ""
  },
  "66630": {
    "「ふん……。それじゃ\u3000さっさとやるぞ。": ""
  },
  "66631": {
    "ヒューザと\u3000リベリオは\nともに\u3000剣をかかげ\u3000祈りはじめた。": ""
  },
  "66632": {
    "なんと\u3000広間の床が\u3000光りはじめ\n旅の扉が\u3000現れた！": ""
  },
  "66633": {
    "「へえ\u3000おどろいたな……。\n\u3000オレに\u3000こんなことが\u3000できるなんてな。": ""
  },
  "66634": {
    "「ご先祖さまの言葉には\u3000続きがあったのを\n\u3000思いだしたニャ。": ""
  },
  "66635": {
    "「海淵の間への道は\u3000奥深き迷宮。\n\u3000果てなき向こうに待つは\u3000強大なる守護者なり。\n\u3000……だったかニャあ。": ""
  },
  "66636": {
    "「なんだか知らねえが\u3000ここから先は\n\u3000お前がやらなきゃ\u3000意味のないことなんだろ？\n\u3000大丈夫。<cs_pchero>なら\u3000やれるさ。": ""
  },
  "66637": {
    "「オレは\u3000旅の途中の身だ。\n\u3000お前の帰りは\u3000待たないからな。\n\u3000それじゃ\u3000また\u3000どこかで会おうぜ！": ""
  },
  "66638": {
    "<cs_pchero>は\n王者のマント（だいじなもの）を\u3000手に入れた！<me 60>": ""
  },
  "69782": {
    "<cs_pchero>のもとに\u3000天から\n光に包まれた武具が\u3000降りてきた。": ""
  }
}