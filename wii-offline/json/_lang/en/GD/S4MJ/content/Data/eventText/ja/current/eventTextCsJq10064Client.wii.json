{
  "14098": {
    "「芸で得られる\u3000よろこびなんか\u3000まやかしだぜ。\n\u3000覚えとけ。芸は\u3000なんの役にも立たねえんだよ。": ""
  },
  "14099": {
    "「……へへ\u3000誰かと思ったら\u3000<cs_pchero>か。\n\u3000会いたかったぜ\u3000とーってもな。": ""
  },
  "14100": {
    "「ポルファンの元で\u3000修行してるってことは\n\u3000お前も\u3000ご立派な教えに共感してんだろ？": ""
  },
  "14101": {
    "「芸は\u3000人を救えるって\u3000アレだよ。": ""
  },
  "14102": {
    "「……ハンッ\u3000クソが！\u3000イライラさせやがる！\n\u3000どいつもこいつも甘ちゃんで\u3000ヘドがでるぜ！": ""
  },
  "14103": {
    "「オレは\u3000芸の無力さに絶望し\n\u3000闇芸人ルルルリーチ様に\u3000尽くすと決めたのだ！": ""
  },
  "14104": {
    "「いくぞ\u3000弟弟子\u3000<cs_pchero>よ！\n\u3000本当に芸で人を救えるのなら\n\u3000それを\u3000オレの前で\u3000証明してみせろ！": ""
  },
  "14105": {
    "「……ククク。なかなか\u3000やるな。\n\u3000だが\u3000それでは\u3000オレは止められんぞ。": ""
  },
  "14106": {
    "悪魔道化師ゲイザーの身体のキズが\n見る見るうちに\u3000ふさがっていく。": ""
  },
  "14107": {
    "「オレは\u3000旅芸人を抹殺するため\n\u3000何度\u3000ケガを負っても\u3000復活する身体を\n\u3000ルルルリーチ様から\u3000与えられたのだ。": ""
  },
  "14108": {
    "「弟弟子よ。お前の芸が\u3000いつわりでないのなら\n\u3000芸で人を救えるというのなら\u3000ポルファンに\n\u3000言われたとおり\u3000オレに\u3000ボケを決めてみせろ！": ""
  },
  "14109": {
    "「……芸で\u3000人なんか救えねえ。 \n\u3000それがわかるまで\u3000何百回でも\u3000何千回でも\n\u3000お前を\u3000たたきつぶしてやるっ！": ""
  },
  "14110": {
    "「芸は\u3000人を救う……。": ""
  },
  "14111": {
    "「ポルファンの言葉が\u3000いつわりでないのなら\n\u3000このオレを\u3000止めてみせろ！": ""
  },
  "14112": {
    "「……やるじゃねえか。弟弟子よ。\n\u3000お前の芸\u3000確かに見せてもらったぜ。": ""
  },
  "14113": {
    "「いいボケだった……。": ""
  },
  "14114": {
    "「ひさしぶりに\u3000人間のころの笑いを思いだした。\n\u3000ははっ\u3000なかなか\u3000面白かったよ……。": ""
  },
  "14115": {
    "「あ～あ\u3000せっかく\u3000キミの中にあった\n\u3000芸を憎む心を\u3000利用してあげたのに。\n\u3000ずいぶん\u3000カンタンに負けちゃったね。": ""
  },
  "14116": {
    "「ルルルリーチ様は\u3000人間のわりに\n\u3000邪悪なオーラを持っていた\u3000キミを気に入って\n\u3000魔物に\u3000してあげたのになぁ。": ""
  },
  "14117": {
    "「もう\u3000用済みだねぇ。\n\u3000だいぶ\u3000旅芸人を殺してくれたみたいだし\n\u3000そろそろ\u3000死んじゃっていいよ。": ""
  },
  "14118": {
    "「そ～れ！\u3000燃えちゃえ～♪\n\u3000３連続\u3000メラゾーマ～♪": ""
  },
  "14119": {
    "「必殺♪\u3000燃え燃えイリュージョン～♪": ""
  },
  "14120": {
    "「うおおおおおおおおおおーーーッ！！": ""
  },
  "14121": {
    "「うっひょ～\u3000これは死んだね～♪\n\u3000見てるだけで熱そう♪\u3000痛そう♪": ""
  },
  "14122": {
    "「ケケケ♪\u3000ケケケ♪": ""
  },
  "14123": {
    "「うう……<cs_pchero>。": ""
  },
  "14124": {
    "「み\u3000みせてくれ。\n\u3000さい…ごに\u3000お前…の芸を…。": ""
  },
  "14125": {
    "<cs_pchero>は\u3000ボケた！": ""
  },
  "14126": {
    "会心のボケ！": ""
  },
  "14127": {
    "「はは…は。やはり\u3000面白いな……。": ""
  },
  "14128": {
    "「はは……。そう…いえば\n\u3000母の…死に顔は\u3000おだやか…だった。": ""
  },
  "14129": {
    "「……きっと\u3000母…も\n\u3000師匠の芸を見て……こんな風に\n\u3000安心して…旅立ったん…だろうな。": ""
  },
  "14130": {
    "「……ははっ\u3000まい…ったな。\n\u3000これが\u3000芸は…人を救うということか。": ""
  },
  "14131": {
    "「師匠……。オレが\u3000まち…がってたよ。\n\u3000あな…たは\u3000確かに\u3000芸で…人を……\n\u3000救って……いた…………。": ""
  }
}