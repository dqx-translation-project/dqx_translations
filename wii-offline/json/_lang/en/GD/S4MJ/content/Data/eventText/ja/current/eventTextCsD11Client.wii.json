{
  "3383": {
    "「むっ！\n\u3000今のは\u3000まさか\u3000アクロニア鉱山か！？": ""
  },
  "3384": {
    "「チャルコ！\u3000何があった！？": ""
  },
  "3385": {
    "「ホ\u3000ホッツィ親方！\u3000大変ですっ！！": ""
  },
  "3386": {
    "「アクロニア鉱山で\u3000崩落が起こって\n\u3000<pc>が……\n\u3000<pc>が\u3000巻き込まれましたっ！！": ""
  },
  "3387": {
    "「な\u3000なんだってーっ！？": ""
  },
  "3388": {
    "「オラ\u3000見たんだ……。\n\u3000変な紫の霧が\u3000岩壁から\u3000ふきだしてよォ。": ""
  },
  "3389": {
    "「そしたら\u3000でかい岩が\u3000はがれるように\n\u3000落ちてきて\u3000<pc>の上に……。": ""
  },
  "3390": {
    "「<pc>\u3000返事してくれよォ！": ""
  },
  "3391": {
    "「今\u3000上の町へ\u3000シスターを呼びに\n\u3000行かせていますが……。": ""
  },
  "3392": {
    "「………………。": ""
  },
  "3393": {
    "「はあ\u3000はあ……。\n\u3000どこです\u3000<pc>さんは！？": ""
  },
  "3394": {
    "「わざわざ来てもらって\u3000すまんな\u3000マレレ。": ""
  },
  "3395": {
    "「いいんです。でも\u3000困ったわ……。\n\u3000こんなとき\u3000ホルタ神父が生きていたら……。": ""
  },
  "3396": {
    "「マレレ\u3000お前しか\u3000いねえんだ。\n\u3000頼むっ！！": ""
  },
  "3397": {
    "「……はい。": ""
  },
  "3398": {
    "「天にまします\u3000われらが神よ。\n\u3000われらを見守る\u3000山神イプチャルよ。": ""
  },
  "3399": {
    "「どうか\u3000<pc>の\u3000みたまを\n\u3000呼び戻したまえ……！": ""
  },
  "3400": {
    "「…………。": ""
  },
  "3401": {
    "「………………。": ""
  },
  "3402": {
    "「チカラが\u3000およばず……\u3000すみません。": ""
  },
  "3403": {
    "「いや\u3000マレレが\u3000謝ることはない。\n\u3000ホルタ神父でも\u3000今の\u3000<pc>を\n\u3000助けることは\u3000できなかっただろう……。": ""
  },
  "3404": {
    "「ウソだろ？\n\u3000アクロニア鉱山で\u3000死者が出るなんて……。": ""
  },
  "3405": {
    "「山神イプチャルは\u3000何してやがんだ！？": ""
  },
  "3406": {
    "「ムチェ\u3000ブチャ\u3000山神さまを\n\u3000悪く言うもんじゃねえ。\n\u3000神さまにだって……\u3000きっと都合があるんだ。": ""
  },
  "3407": {
    "「チッ！\u3000何が\u3000都合だ。\n\u3000そんなことで片付けられちゃ\n\u3000死んだ\u3000<pc>も\u3000浮かばれねえぜ！": ""
  },
  "3408": {
    "「それに\u3000ここ最近\u3000ろくな鉱石も採れねえし。\n\u3000神さまの都合で\u3000ビンボー暮らしさせられちゃ\n\u3000たまったもんじゃねえよ！": ""
  },
  "3409": {
    "「オレとブチャは\u3000出ていかせてもらうぜ。\n\u3000あばよッ！": ""
  },
  "3410": {
    "「待つんだ\u3000ムチェ！\u3000ブチャ！": ""
  },
  "3411": {
    "「ほっとけ！\n\u3000行きたいヤツは\u3000行かせりゃいい。": ""
  },
  "3412": {
    "「それよりも\u3000今は\u3000<pc>のために\n\u3000祈ってやろうじゃねえか。\n\u3000安らかな眠りに\u3000つけるようによ……。": ""
  },
  "3413": {
    "「んん！？": ""
  },
  "3414": {
    "「ぬおおおおっ！？\u3000<pc>？": ""
  },
  "3415": {
    "「ああ\u3000よかった！\n\u3000<pc>が\u3000息を吹き返したよ！\n\u3000マレレと\u3000あたしたちの祈りが\u3000届いたんだね！": ""
  },
  "3416": {
    "「<pc>……\u3000お前\u3000本当に\u3000大丈夫か？\n\u3000なんつうか\u3000お前の身体に\n\u3000別の魂が\u3000宿ったようにも見えたが……。": ""
  },
  "3417": {
    "「……いや\u3000その様子なら\u3000大丈夫そうだな。\n\u3000まったく\u3000ヒヤヒヤさせやがって。": ""
  },
  "3418": {
    "「助かったぜ\u3000マレレ。\n\u3000何か\u3000礼をしねえとな！": ""
  },
  "3419": {
    "「いえ\u3000お礼なんて\u3000いいんです。\n\u3000ただ……\u3000そのぅ………。": ""
  },
  "3420": {
    "「親方さん。私と\u3000一緒に\n\u3000教会へ\u3000来ていただけないでしょうか？\n\u3000ルナナさんが\u3000話がしたいって。": ""
  },
  "3421": {
    "「ルナナが！？": ""
  },
  "3422": {
    "「チッ……。あの人間の小娘め。\n\u3000テメエの\u3000くだらん話には乗らんと\n\u3000何度も言っておるのに\u3000しつこいヤツだ！": ""
  },
  "3423": {
    "「世話になった\u3000ホルタ神父の娘だと思って\n\u3000甘い顔をしていれば\u3000つけ上がりやがって……。": ""
  },
  "3424": {
    "「あの……\u3000親方さん………？": ""
  },
  "3425": {
    "「あ\u3000ああ……。": ""
  },
  "3426": {
    "「……そうか。ルナナの所へな。うん。\n\u3000マレレには\u3000<pc>を助けてもらったし\n\u3000行かないわけには\u3000いかねえな。": ""
  },
  "3427": {
    "「ああっ！": ""
  },
  "3428": {
    "「ダ\u3000ダメだ。\n\u3000なんだか\u3000腹が痛いし\u3000頭も痛いし\n\u3000めまいがする……ゲホ\u3000ゲホッ！": ""
  },
  "3429": {
    "「残念だが\u3000ルナナの所へは\n\u3000行けそうにないなあ……。\n\u3000誰か\u3000オレの代わりに\u3000行ってくれねえかな？": ""
  },
  "3430": {
    "「おおっ！\u3000そうか\u3000<pc>！\n\u3000お前が\u3000行ってくれるか！": ""
  },
  "3431": {
    "「そうだよな。お前は\u3000命を助けてもらった\n\u3000礼を言いに\u3000教会まで行かないとな。\n\u3000ついでに\u3000ルナナの所へ\u3000寄るといい。": ""
  },
  "3432": {
    "「<pc>！\n\u3000ルナナのヤツに\u3000ビシッと言ってこい。": ""
  },
  "3433": {
    "「親方は\u3000絶対に\u3000イヤだと言っている。\n\u3000もう二度と\u3000親方を呼んだりするなと！": ""
  },
  "3434": {
    "「では\u3000頼んだぞ\u3000<pc>。": ""
  },
  "3435": {
    "「ゲホゲホ\u3000ゴーホゴホッ……！": ""
  },
  "3436": {
    "「大丈夫かしら……\u3000親方さん。": ""
  },
  "3437": {
    "「では\u3000私は\u3000教会に戻りますけど……\n\u3000また何かあったら\u3000呼んでください。": ""
  },
  "3438": {
    "「<pc>さんは\u3000のちほど\n\u3000上の町の教会に住んでいる\n\u3000ルナナさんを\u3000訪ねてくださいね。": ""
  },
  "3439": {
    "「相変わらず\u3000ノックもなしに\n\u3000入っていらっしゃるのね\u3000ホッツィさん。": ""
  },
  "3440": {
    "「でも……\u3000怒ったりなんてしなくてよ？\n\u3000こんなに早く\u3000来てくださったんだもの。\n\u3000今日こそ\u3000いい返事を\u3000お聞かせ願えるのよね？": ""
  },
  "3441": {
    "「このルナナに\u3000まかせてくだされば\n\u3000決して\u3000悪いようには\u3000いたしませんわ。": ""
  },
  "3442": {
    "「ねっ\u3000ホッツィさん<heart>": ""
  },
  "3443": {
    "「……って\u3000誰よ\u3000あんた！？": ""
  },
  "3444": {
    "「……はあッ！？\n\u3000親方の代理で\u3000返事をしにきたですって？": ""
  },
  "3445": {
    "「いい度胸ね\u3000あのクソ親父！": ""
  },
  "3446": {
    "「この\u3000あたしの厚意を\u3000無視するなんて\n\u3000ありえないわッ！": ""
  },
  "3447": {
    "「な……何よ。あんた\u3000まだいたの？": ""
  },
  "3448": {
    "「あー\u3000親方の返事なら\u3000いらないわよ。": ""
  },
  "3449": {
    "「代理をよこすぐらい\n\u3000あたしと\u3000話したくないんだもの。\n\u3000断ってこいって\u3000言われたんでしょ？": ""
  },
  "3450": {
    "「……………………。": ""
  },
  "3451": {
    "「あなた\u3000よく見ると\u3000下の町のヤツらとは\n\u3000どことなーく\u3000ちがってるのね。\n\u3000みょうに\u3000人間っぽいっていうか？": ""
  },
  "3452": {
    "「……へえ\u3000<pc>っていうの？\n\u3000じゃあ\u3000命令するわ\u3000<pc>。": ""
  },
  "3453": {
    "「あなた\u3000あたしの下僕になりなさいッ！<yesno><close>": ""
  },
  "3454": {
    "「よく\u3000聞こえなかったわ。\n\u3000<pc>\u3000あなた\n\u3000あたしの下僕に\u3000なるわよねッ！？<yesno><close>": ""
  },
  "3455": {
    "「いい返事ね\u3000<pc>。\n\u3000あなたは\u3000幸せ者よ。": ""
  },
  "3456": {
    "「あたしは\u3000このアグラニの救世主となり\n\u3000父以上の英雄に\u3000なるんだから。\n\u3000あなたも\u3000下僕として\u3000歴史に名を残せるわよ！": ""
  },
  "3457": {
    "「<pc>。ここ数年\u3000アクロニア鉱山から\n\u3000宝石はおろか\u3000まともな鉱石すら\n\u3000出ていないことは\u3000知ってるわよね？": ""
  },
  "3458": {
    "「でも\u3000あたしは知っているの。\n\u3000アクロニア鉱山の\u3000どこを掘れば\n\u3000宝石が\u3000ザクザク出るのかを……！": ""
  },
  "3459": {
    "「アグラニの町の\u3000書物という書物を調べて\n\u3000探り当てた情報だから\u3000間違いないわ！": ""
  },
  "3462": {
    "「でもね\u3000あの親方ったら\u3000おかしな理由をつけて\n\u3000その場所だけは\u3000掘らないって言うのよ！\n\u3000まったく\u3000理解不能だわッ！": ""
  },
  "3463": {
    "「下の町のヤツらは\u3000どいつも\u3000こいつも\n\u3000親方の言いなりみたいだけど……": ""
  },
  "3464": {
    "「親方よりもエラい\u3000賢者サマが\n\u3000そこを\u3000掘ってもいいって言ったら\n\u3000みんな聞くと\u3000思わない？": ""
  },
  "3465": {
    "「そういうワケで\u3000<pc>。\n\u3000あたしの下僕として\u3000さっそく\n\u3000はたらいてもらいたいの。": ""
  },
  "3466": {
    "「アクロニア鉱山に住む\u3000賢者ブロッゲン。\n\u3000あいつを説得して\u3000その場所を掘ってもいいって\n\u3000おスミつきを\u3000もらってくるのよッ！": ""
  },
  "3467": {
    "「ちょっぴり\u3000むずかしい仕事だけど\n\u3000もし成功したら\u3000あたしのルーラストーンを\n\u3000あげてもいいわッ！": ""
  },
  "3468": {
    "「ルーラストーンがあれば\n\u3000石に記憶させた場所に\u3000一瞬で行けるのよ。\n\u3000誰もが欲しがる\u3000貴重なものなんだから！": ""
  },
  "3469": {
    "「<pc>\u3000頼んだわよ。\n\u3000アクロニア鉱山へ行って\u3000必ず\n\u3000ブロッゲンを\u3000説得してきてちょうだいね！": ""
  },
  "3474": {
    "「あたし\u3000バカとノロマは\u3000嫌いなのよね……。": ""
  },
  "3475": {
    "「あんな\u3000暗くてジメジメしてて\n\u3000魔物まで出る所\u3000あたしは大キライだけど\n\u3000あなたにとっては\u3000庭みたいな場所でしょ？": ""
  },
  "3476": {
    "「さっさと\u3000アクロニア鉱山にもぐって\n\u3000ブロッゲンを\u3000仲間に引き込みなさいッ！": ""
  },
  "3477": {
    "「下の町に住む\u3000あなたが\u3000ルーラストーンを\n\u3000手に入れられる\u3000チャンスなんて\n\u3000もう\u3000二度とないんだからね！": ""
  },
  "3478": {
    "「偉大なる\u3000大賢者ブロッゲンさまの\n\u3000お帰りでアールっ！！": ""
  },
  "3479": {
    "「おおっ!\n\u3000おかえりなさいませ\u3000ブロッゲンさま。": ""
  },
  "3480": {
    "「ぐう\u3000ぐう……。": ""
  },
  "3481": {
    "「ブロッゲンさまは\n\u3000留守中\u3000変わったことは\u3000なかったかと\n\u3000おたずねでアールっ！！": ""
  },
  "3482": {
    "「じつは\u3000このアクロニア鉱山の中で\n\u3000崩落事故が\u3000起こりまして\u3000そのとき……": ""
  },
  "3483": {
    "「ふせろっ！！": ""
  },
  "3484": {
    "「ふうう……。": ""
  },
  "3485": {
    "「あ\u3000あの\u3000紫の霧は……？": ""
  },
  "3486": {
    "「もしや\u3000あれが\u3000崩落があったときに\n\u3000現れたという\u3000怪しい霧では！？": ""
  },
  "3487": {
    "「ぐう\u3000ぐう……。": ""
  },
  "3488": {
    "「ブロッゲンさま？": ""
  },
  "3489": {
    "「あれは……": ""
  },
  "3490": {
    "「触れれば\u3000命を落とすと言われる\u3000魔瘴の霧。\n\u3000こんな所にまで現れるとは\u3000本格的に\n\u3000手を打たねば……とのことでアール！！": ""
  },
  "3491": {
    "「魔瘴……。": ""
  },
  "3492": {
    "「ねえ\u3000こいつ\u3000誰？": ""
  },
  "3493": {
    "「鉱山で見習いをしている\u3000<pc>です。\n\u3000ブロッゲンさまに\u3000話があるとかで\n\u3000ここまで\u3000来たようですが……。": ""
  },
  "3494": {
    "「ふ～～～ん。": ""
  },
  "3495": {
    "「どうしました\u3000ブロッゲンさまの杖さま？\n\u3000<pc>に\u3000おかしなところでも？": ""
  },
  "3496": {
    "「むふふ～\u3000ヒミツぅ～～♪": ""
  },
  "3497": {
    "「……は\u3000はあ。": ""
  },
  "3498": {
    "「ところでさ\u3000<pc>。\n\u3000話って\u3000なんなの？": ""
  },
  "3499": {
    "<pc>は\u3000事情を説明した。": ""
  },
  "3500": {
    "「……ルナナおじょうさんね。\n\u3000知ってる\u3000知ってる！\n\u3000あの\u3000ホルタ神父の娘だね！": ""
  },
  "3501": {
    "「……なるほど\u3000なるほど。確かに\n\u3000ブロッゲンさまの言うことを\u3000聞かないヤツは\n\u3000アグラニには\u3000いないからね～。": ""
  },
  "3502": {
    "「ぐう\u3000ぐう……。": ""
  },
  "3503": {
    "「ふむふむ……。\n\u3000ブロッゲンさまは\u3000こう\u3000おっしゃって\n\u3000おらレール！": ""
  },
  "3504": {
    "「ルナナの言う\u3000書物に記された地とは\n\u3000アクロニア鉱山で\u3000はたらく者たちが\n\u3000戒めの地と呼ぶ場所であり……": ""
  },
  "3505": {
    "「はるか昔\u3000あの地に眠る\u3000貴重な宝石をめぐり\n\u3000強欲なドワーフたちが\u3000命を奪い合うという\n\u3000忌まわしい事件が\u3000起きた場所なのでアール！": ""
  },
  "3506": {
    "「そして\u3000その場にいたドワーフたちは\u3000死後\n\u3000欲と未練にまみれた怨霊となり\u3000鉱山に入る者を\n\u3000退けるようになってしまったのさ。": ""
  },
  "3507": {
    "「その祈りが届き\u3000怨霊は\u3000ついに鎮められた。\n\u3000親方たちは\u3000その話を知っているから\n\u3000戒めの地だけは\u3000掘らないってわけさ……。": ""
  },
  "3508": {
    "「ぐう\u3000ぐう……。": ""
  },
  "3509": {
    "「……えっ！？": ""
  },
  "3510": {
    "「<pc>……。": ""
  },
  "3511": {
    "「ブロッゲンさまは\u3000自分が行って\n\u3000ルナナに\u3000戒めの地の説明をしてやろうと\n\u3000おっしゃっておらレール……。": ""
  },
  "3512": {
    "「<pc>は\u3000しっかりと見届けよ……\n\u3000とのことでアール。": ""
  },
  "3513": {
    "「ブロッゲンさま\u3000くれっぐれも\n\u3000お手柔らかに\u3000お願いしますよ～！": ""
  },
  "3514": {
    "「ボクは\u3000ただの通訳なんですからね？\n\u3000へし折られたりとか\u3000イヤですよっ！": ""
  },
  "3515": {
    "「うるさい\u3000ヒゲッ！\n\u3000お説教なんて\u3000もうウンザリ！！": ""
  },
  "3516": {
    "「この……ッ\u3000カビだんごッ！！": ""
  },
  "3517": {
    "「ブロッゲンを\u3000説得できなかったんだから\n\u3000ルーラストーンは\u3000あげないわよ！\n\u3000下僕も\u3000クビよ\u3000クビっ！！": ""
  },
  "3518": {
    "「ふんッ！": ""
  },
  "3519": {
    "「あわわわ……\u3000こわ～い。": ""
  },
  "3520": {
    "「でも\u3000いくら怒ったところで\n\u3000あんな\u3000おじょうさん\u3000ひとりじゃ\n\u3000なんにも\u3000できないよね！": ""
  },
  "3521": {
    "「ぐう\u3000ぐう……。": ""
  },
  "3522": {
    "「えっ……？": ""
  },
  "3523": {
    "「ぐう\u3000ぐう……！": ""
  },
  "3524": {
    "「………はあ\u3000わかりましたよぅ。": ""
  },
  "3525": {
    "「ブロッゲンさまは\u3000<pc>に\n\u3000手伝いをしてほしいと\u3000望んでおらレール！": ""
  },
  "3526": {
    "「<pc>が\u3000我々と\u3000一緒に\n\u3000戒めの地の見回りに\u3000行ってくれるなら……": ""
  },
  "3527": {
    "「ルナナに\u3000もらいそびれたルーラストーンを\n\u3000<pc>に\u3000やろうと！\n\u3000……くううっ\u3000なんと\u3000慈悲深いお言葉。": ""
  },
  "3528": {
    "「まあ\u3000それはさておき\u3000<pc>。\n\u3000ブロッゲンさまの手伝い\u3000してくれるよね！？<yesno><close>": ""
  },
  "3529": {
    "「いいえ\u3000とか\u3000言うなっ！！": ""
  },
  "3530": {
    "「ブロッゲンさまが\u3000気をつかって\n\u3000ルーラストーンをくれるって言ってるんだぞ？\n\u3000手伝うに\u3000決まってるよねっ！？<yesno><close>": ""
  },
  "3531": {
    "「ブロッゲンさまが\u3000先に\u3000ルーラストーンを\n\u3000くださるそうでアール！": ""
  },
  "3532": {
    "「ぐう\u3000ぐう……。": ""
  },
  "3533": {
