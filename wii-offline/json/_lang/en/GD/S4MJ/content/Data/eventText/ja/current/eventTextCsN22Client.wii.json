{
  "46813": {
    "「とーちゃんは\u3000ケガしてんだから\n\u3000無理すんなって！": ""
  },
  "46814": {
    "「もし\u3000また化け物が現れても\n\u3000ザンクローネ様が\u3000絶対\u3000助けにきてくれるよ！": ""
  },
  "46815": {
    "「ラスカ\u3000お前も見ただろう。\n\u3000ザンクローネ様が\u3000死んじまったとこを……。": ""
  },
  "46816": {
    "「ザンクローネ様は\u3000英雄なんだ！\n\u3000化け物なんかに\u3000やられたりしねえよ！": ""
  },
  "46817": {
    "「英雄だろうが\u3000なんだろうが\n\u3000ダメなときはダメだべぇ！": ""
  },
  "46818": {
    "「…………ん？": ""
  },
  "46819": {
    "「あんた\u3000まさか\u3000旅人さんか？\n\u3000いんやァ\u3000よく来なすった！\n\u3000俺が\u3000この村の村長\u3000ガッシュだべ！": ""
  },
  "46820": {
    "「いてて……。": ""
  },
  "46821": {
    "「だ\u3000大丈夫かよっ！？": ""
  },
  "46822": {
    "「うぇるかむ\u3000我がメルサンディ村へ！\n\u3000この村は\u3000ええ村だべえ！": ""
  },
  "46823": {
    "「……と言っても\u3000今は\u3000ちょいと\n\u3000歓迎できる状態じゃないんだけどな……。": ""
  },
  "46824": {
    "「お前さんも\u3000ここに来るまでに見ただろうよ。\n\u3000やせた畑に\u3000枯れた井戸\u3000壊れた家……\n\u3000そして\u3000おびえる村人たち……。": ""
  },
  "46825": {
    "「……この村は\u3000得体の知れねえ\n\u3000化け物に襲われとるんだ。": ""
  },
  "46826": {
    "「はじめは\u3000でかい足だった。\n\u3000でかい足の化け物が\u3000突如\u3000村に現れて\n\u3000村人たちを\u3000踏みつぶしていきよった。": ""
  },
  "46827": {
    "「そのときは\u3000村の英雄の\n\u3000ザンクローネ様っちゅう\u3000お方が\n\u3000化け物を\u3000退治してくれたのよ。": ""
  },
  "46828": {
    "「だけんど\u3000先日……\n\u3000今度は\u3000でかい頭の化け物が\u3000現れおった。\n\u3000そいつは\u3000村中を飛び回り……": ""
  },
  "46829": {
    "「村人たちを\u3000かたっぱしから\n\u3000むしゃむしゃ食っちまったんだ！": ""
  },
  "46830": {
    "「俺は\u3000足にケガを負って……\n\u3000何も……\u3000できなかった……。": ""
  },
  "46831": {
    "「……ザンクローネ様は\u3000そのときも\n\u3000村のために\u3000命を賭して戦ってくださった。\n\u3000そして\u3000化け物と\u3000相討ちになっただよ……。": ""
  },
  "46832": {
    "「だから\u3000この村にはもう\u3000救いはねえ。\n\u3000村人たちも\u3000不安がるっちゅうもんだ……。": ""
  },
  "46833": {
    "「今こそ\u3000俺が\u3000がんばらにゃ……。": ""
  },
  "46834": {
    "「ガッシュのおやっさん！\n\u3000これが\u3000村の門の外に……。": ""
  },
  "46835": {
    "「こりゃ……\u3000となりのデニーが\n\u3000いつもかぶってる帽子でねえか！\n\u3000な\u3000何があっただー！？": ""
  },
  "46836": {
    "「もしかして\u3000また\n\u3000化け物が現れたんじゃ……？": ""
  },
  "46837": {
    "「心配すんなって！\n\u3000絶対\u3000ザンクローネ様が助けに……": ""
  },
  "46838": {
    "「ラスカ。ザンクローネ様は\u3000もういねえんだ。 \n\u3000また\u3000化け物が現れたかもしれんというときに\n\u3000死んだ英雄に\u3000頼っとるわけにゃいかん。": ""
  },
  "46839": {
    "「だから！！\u3000ザンクローネ様は\n\u3000絶対に\u3000死なない……": ""
  },
  "46840": {
    "「ええかげんにせんか\u3000ラスカァ！！": ""
  },
  "46841": {
    "「うっ…………": ""
  },
  "46842": {
    "「とーちゃんの\u3000バッキャロー！！": ""
  },
  "46843": {
    "「待たんか\u3000ラスカ！": ""
  },
  "46844": {
    "「おじさま。私が見てまいります。": ""
  },
  "46845": {
    "「す\u3000すまんな\u3000ミシュア……。\n\u3000頼むベ……。": ""
  },
  "46846": {
    "「ミシュアには\u3000頭があがらんなあ。": ""
  },
  "46847": {
    "「……ウォッホン。\n\u3000サヴァル\u3000すぐに村中を回って\n\u3000デニーの捜索にあたってくれい。": ""
  },
  "46848": {
    "「騒がしくて申し訳ねえだ\u3000旅人さん。\n\u3000見ての通り\u3000村は\u3000大変な状況でよ……。": ""
  },
  "46849": {
    "「……ふむ。お前さん \n\u3000どうやら\u3000なかなか旅慣れていそうだべな。": ""
  },
  "46850": {
    "「ほう。<pc>と言うだか。\n\u3000すまんが\u3000<pc>\n\u3000ひとつ\u3000頼まれてくれんか。": ""
  },
  "46851": {
    "「俺のおふくろは\u3000村の北西にある小屋で\n\u3000水車の管理人をしとるんだが……。\n\u3000あんな所に\u3000ひとり置いとくのは心配でな。": ""
  },
  "46852": {
    "「村のことで手いっぱいの\u3000俺に代わって\n\u3000おふくろを\u3000迎えに行ってきてほしいのよ。": ""
  },
  "46853": {
    "「来て早々の\u3000旅人さんに\n\u3000面倒をかけて申し訳ないが……\n\u3000人助けと思って\u3000チカラを貸してくだされ。": ""
  },
  "46854": {
    "「じゃあ\u3000俺も\u3000村の見回りに行くんで\n\u3000おふくろのこと\u3000くれぐれも\u3000よろしく頼むべ。\n\u3000ちゃんと\u3000お礼も用意しとくでな。": ""
  },
  "46855": {
    "「ラスカ\u3000みいつけた。": ""
  },
  "46856": {
    "「ここに\u3000いるんじゃないかと思ったの。\n\u3000ねえ\u3000ラスカ……。": ""
  },
  "46857": {
    "「なんだよ\u3000ミシュアねえちゃんには\n\u3000カンケーねえだろ……ぐすっ。": ""
  },
  "46858": {
    "「たとえ\u3000すべての麦が倒れ\n\u3000水が干上がり\u3000涙が枯れても……": ""
  },
  "46859": {
    "「お前の声が\u3000かれない限り\n\u3000救いは\u3000必ず訪れる。": ""
  },
  "46860": {
    "「……俺は\u3000必ず駆けつける。": ""
  },
  "46861": {
    "「ねえちゃん\u3000いつの間に覚えたの？\n\u3000ザンクローネ様の決めゼリフ！": ""
  },
  "46862": {
    "「ラスカから\u3000たくさん\n\u3000お話を聞いたから\u3000覚えちゃったわ。": ""
  },
  "46863": {
    "「でも\u3000とーちゃんは信じてくれないんだ。\n\u3000あいつは\u3000死んだんだって\n\u3000もう\u3000助けにこないって言うんだ……。": ""
  },
  "46864": {
    "「英雄は\u3000死なないわ。": ""
  },
  "46865": {
    "「信じて\u3000待っていてくれる人が\n\u3000ひとりでもいる限り……。": ""
  },
  "46866": {
    "「村に来る前に\u3000誰かから\n\u3000……そう\u3000聞いた気がするの。": ""
  },
  "46867": {
    "「ほんと！？": ""
  },
  "46868": {
    "「ええ。でもね\u3000ガッシュのおじさまは\n\u3000村に住む\u3000みんなを\u3000守らなきゃいけない……。\n\u3000だから\u3000とても慎重になっているの。": ""
  },
  "46869": {
    "「お父さんの気持ちも\n\u3000ラスカは\u3000わかってあげられるよね？": ""
  },
  "46870": {
    "「うん……。": ""
  },
  "46871": {
    "「……いい子ね。\n\u3000あなたが\u3000希望を持ち続ける限り\n\u3000ザンクローネ様は\u3000きっと大丈夫。": ""
  },
  "46872": {
    "「さあ\u3000帰りましょう。": ""
  },
  "46873": {
    "「ハアー\u3000金\u3000銀\u3000ぷらちな\n\u3000ザックラホイ♪\n\u3000人生金色\u3000ヨヨイノヨイ♪": ""
  },
  "46874": {
    "「ちょいこら\u3000そこの若僧！\n\u3000ノックもなしに\u3000うちの敷居をまたぐたあ\n\u3000いい度胸してるね！": ""
  },
  "46875": {
    "「あたしは\u3000この水車の管理人\u3000コペだよ。\n\u3000粉が引きたきゃ\u3000使用料払いな。\n\u3000金がなけりゃ\u3000水車は回せんわな。": ""
  },
  "46876": {
    "「…………アァン？\n\u3000化けモンが出て\u3000危険だから\n\u3000……あたしを\u3000迎えにきた？": ""
  },
  "46877": {
    "「ハン！\u3000ぬかすんじゃないよ\u3000若ヒョットコ！\n\u3000あたしゃ\u3000ここが気に入ってんのさ。\n\u3000そう\u3000やすやすと\u3000村に帰れるかい。": ""
  },
  "46878": {
    "「化けモンだか\u3000シナモンだか知らないけど\n\u3000そんなのに\u3000やられるほど\n\u3000あたしゃ\u3000やわじゃないよ。": ""
  },
  "46879": {
    "「……まったく\u3000あのトンカチ息子は\n\u3000ろくに\u3000顔も見せずに\n\u3000こんな若いのを\u3000寄こすなんてね。": ""
  },
  "46880": {
    "「しかし\u3000せっかく活きのいいのが来たんだから\n\u3000お手伝いでも\u3000してもらおうかねぇ。": ""
  },
  "46881": {
    "「最近\u3000水車の回りが悪くてさ。\n\u3000たぶん\u3000歯車に\u3000何か\u3000はさまってんだわな。": ""
  },
  "46882": {
    "「水車小屋のカギは\u3000開けてあるから \n\u3000ちょっくら\u3000直してきておくれよ。": ""
  },
  "46883": {
    "「さあ\u3000とっとと行きな。\n\u3000たいむ\u3000いず\u3000ごーるど！\u3000だよ！": ""
  },
  "46884": {
    "「いやーん\u3000バーティ\n\u3000そっち押し込んでぇ！": ""
  },
  "46885": {
    "「まかせて\u3000ジャーミィ\n\u3000あと\u3000ひといきよ～！": ""
  },
  "46886": {
    "「キュ～\u3000キュ～！": ""
  },
  "46887": {
    "「ふう\u3000しびれくらげを\n\u3000水車の歯車に\u3000はさむ仕事は\n\u3000骨が折れるわねぇ。": ""
  },
  "46888": {
    "「でも\u3000楽しいわ～。\n\u3000生きがいを感じるわ～。": ""
  },
  "46889": {
    "「あの方に\u3000たっぷり\n\u3000ほめてもらわなきゃねぇ。": ""
  },
  "46890": {
    "「あららん？\u3000誰かに\n\u3000見られちゃった～。": ""
  },
  "46891": {
    "「おややん？\u3000まずいわぁ。\n\u3000まだ\u3000見つかっちゃダメって\u3000言われてたのに。": ""
  },
  "46892": {
    "「今日のところは\n\u3000逃げるが\u3000カチカチ山よ～。": ""
  },
  "46893": {
    "「キュ～\u3000キュ～。": ""
  },
  "46894": {
    "「…………ふう。\n\u3000ラスカは\u3000元気かねえ。": ""
  },
  "46895": {
    "「……って\u3000なんで\u3000あんたは\n\u3000ノックもせずに\u3000入ってくるんだい！\n\u3000まったく\u3000最近の若いもんは……。": ""
  },
  "46896": {
    "「フン。どうやら\u3000水車は直せたようだね。\n\u3000ちっとは\u3000役に立つじゃないか。\n\u3000つっ立ってないで\u3000こっちへおいで。": ""
  },
  "46897": {
    "「さてさて\u3000次は何をやってもらおうかねえ。\n\u3000家中のクモの巣とりか\u3000煙突掃除……\n\u3000いやいや\u3000花壇の草むしりも\u3000あるわいな。": ""
  },
  "46898": {
    "「ほうきで床をはいて\u3000ぞうきんがけ\n\u3000窓ふき\u3000タンスの片付け\n\u3000芝を刈って\u3000小川のゴミ拾い……": ""
  },
  "46899": {
    "「こんにちは\u3000コペおばあさま！": ""
  },
  "46900": {
    "「おや\u3000また遊びに来たのかい\u3000家出娘。": ""
  },
  "46901": {
    "「はい。おばあさまに\n\u3000会いたくなっちゃって。": ""
  },
  "46902": {
    "「<pc>さん\u3000お疲れさま。\n\u3000ここに\u3000いらっしゃると聞いたので\n\u3000私も\u3000おチカラになりに来ました。": ""
  },
  "46903": {
    "「……ねえ\u3000コペおばあさま。\n\u3000近頃\u3000出没する化け物は\u3000本当に恐ろしくて\n\u3000ガッシュのおじさまも\u3000心を痛めておられるの。": ""
  },
  "46904": {
    "「私も\u3000おばあさまが心配よ……。\n\u3000どうか\u3000一緒に\u3000村へ帰りましょう。": ""
  },
  "46905": {
    "「なんだい\u3000つまらないね。あんたも\n\u3000トンカチ息子の\u3000回しモンってことかい。": ""
  },
  "46906": {
    "「フン！\u3000だいたい心配なら\u3000ガッシュが\n\u3000自分で迎えにくりゃ\u3000いいじゃないのさ。": ""
  },
  "46907": {
    "「いつもいつも\u3000村のことばかりで\n\u3000ちっとも\u3000かまってくれないしさ。\n\u3000あんな親不孝者に\u3000育てた覚えはないね。": ""
  },
  "46908": {
    "「あらあら。でもね\u3000おばあさま。\n\u3000ラスカは\u3000とっても\n\u3000会いたがっていましたよ？": ""
  },
  "46909": {
    "「…………本当かい？": ""
  },
  "46910": {
    "「ええ！\u3000おばあさまに\n\u3000ザンクローネ様が\u3000大活躍した昔話を\n\u3000いっぱい\u3000教えてもらうんだって。": ""
  },
  "46911": {
    "「そうかい……。\n\u3000ラスカが\u3000そんなことを……。": ""
  },
  "46912": {
    "「おお！\u3000……そういえば\u3000村に置いてきた\n\u3000ヘソクリを\u3000取りにいこうと思ってたんだ！\n\u3000しーかたないねえ\u3000ちょこっと帰るかねえ。": ""
  },
  "46913": {
    "「……そうだ！\u3000あたしが荷物をまとめてる間に\n\u3000あんたたち\u3000もうひと仕事\u3000頼まれておくれ。": ""
  },
  "46914": {
    "「水車に\u3000また何か\u3000はさまると困るから\n\u3000小川の掃除をしてほしかったのさ。\n\u3000水車小屋の裏の\u3000桟橋から川に入れるからね！": ""
  },
  "46915": {
    "「しばらく\u3000家を空けるんだから\n\u3000しっかり頼んだよ。": ""
  },
  "46916": {
    "「はい\u3000おばあさま！": ""
  },
  "46917": {
    "「<pc>さん\u3000一緒に\n\u3000がんばりましょうね！<yesno><close>": ""
  },
  "46918": {
    "「この\u3000お手伝いが終われば\n\u3000おばあさまも\u3000気持ちよく\n\u3000村へ\u3000帰ってくださるの思うの。": ""
  },
  "46919": {
    "「もう少しだけ\u3000おチカラを\n\u3000貸していただけませんか？<yesno><close>": ""
  },
  "46920": {
    "「ありがとう\u3000<pc>さん！\n\u3000じゃあ\u3000先に桟橋に行っていますね。": ""
  },
  "46946": {
    "「そうか\u3000デニーは\u3000まだ見つからんか……。": ""
  },
  "46947": {
    "「ああ。みんなに聞いてまわったけど\n\u3000誰も\u3000姿を見てねえそうだべ。": ""
  },
  "46948": {
    "「俺は\u3000もう少し\u3000村ん中を探そう……。\n\u3000サヴァル\u3000お前は\u3000門の見張りを頼む。": ""
  },
  "46949": {
    "「お！\u3000コペばーさんじゃねえか。\n\u3000ずいぶん\u3000ひさしぶりだベな。\n\u3000ガッシュのおやっさんと\u3000ケンカすんなよ！": ""
  },
  "46950": {
    "「やーかましい！": ""
  },
  "46951": {
    "「おふくろォ！\n\u3000いんやあ\u3000元気にしとったべか！": ""
  },
  "46952": {
    "「化け物にやられて\u3000干からびとったら\n\u3000俺ァ\u3000どうしたもんかと……": ""
  },
  "46953": {
    "「いってぇ！": ""
  },
  "46954": {
    "「フン！\u3000このトンカチ息子！\n\u3000心配なら\u3000自分で迎えにこんかい。": ""
  },
  "46955": {
    "「わ\u3000悪かったべよ。\n\u3000俺も\u3000手いっぱいでよゥ……。": ""
  },
  "46956": {
    "「言い訳なんか\u3000聞きたかないよ！\n\u3000それより\u3000あの子は……？": ""
  },
  "46957": {
    "「おかえり\u3000ばーちゃん！": ""
  },
  "46958": {
    "「ラ\u3000ラスカ……！\n\u3000しばらく見ないうちに\u3000大きくなって！": ""
  },
  "46959": {
    "「えー！\u3000オレ\u3000そんなに背ぇ伸びてねえぞ。\n\u3000そんなことより\u3000ザンクローネ様の話\n\u3000また聞かせてくれなっ！": ""
  },
  "46960": {
    "「しようのない子だねえ……。": ""
  },
  "46961": {
    "「<pc>。お迎え\u3000ご苦労だったベなあ。\n\u3000ささやかだけど\u3000礼を用意させてもらっただ！": ""
  },
  "46962": {
    "「お前さんには\u3000この村の宿屋の\n\u3000びっぷるーむを\u3000お取りしたべよ！\n\u3000休む時は\u3000その部屋を使ってくれい。": ""
  },
  "46963": {
    "「宿屋の\u3000おかみには\u3000伝えてあっから\n\u3000話しかけりゃ\u3000部屋まで案内してくれんべ。": ""
  },
  "46964": {
    "「ほんだら\u3000俺は\u3000まだ捜索が残っとるから\n\u3000おふくろたちは家に帰って\u3000ゆっくり休めよ。": ""
  },
  "46965": {
    "「あんた\u3000<pc>って言うんだって？": ""
  },
  "46966": {
    "「フフン。若いけど\u3000なかなか骨があるね。\n\u3000いい水車小屋の管理人になれるよ。": ""
  },
  "46967": {
    "「……ほらよ\u3000お駄賃だ。これ\u3000持ってお行き。": ""
  },
  "46968": {
    "<pc>は\u3000紅蓮の大宝石を\nふたたび\u3000受け取った！": ""
  },
  "46978": {
    "「ミシュアねえちゃん！！": ""
  },
  "46979": {
    "「ねえちゃん！\u3000ねえちゃん！！\n\u3000うっ……\u3000うううっ…………。": ""
  },
  "46980": {
    "「ラスカ！！\u3000なんで\u3000ここにおるだあ！？": ""
  },
  "46981": {
    "「さっき\u3000引きずり込まれたのは\n\u3000もしかして\u3000ミシュアなのか！？": ""
  },
  "46982": {
    "「ぐすっ……\u3000オレのせいだ……。": ""
  },
  "46983": {
    "「オレが\u3000ザンクローネ様を探すって\n\u3000家を飛び出したら\u3000化け物がいて……": ""
  },
  "46984": {
    "「ミシュアねえちゃんが\n\u3000オレをかばって\u3000あいつに…………。": ""
  },
  "46985": {
    "「な\u3000なんてこったァ……。": ""
  },
  "46986": {
    "「後を追ったんだけど……\n\u3000オ\u3000オレ……\u3000\n\u3000何も\u3000できな……かっ…………。": ""
  },
  "46987": {
    "「……もうええ。ここは危険だ。\n\u3000お前は\u3000サヴァルと一緒に帰っとれ。": ""
  },
  "46988": {
    "「……これで\u3000わかっただろう\u3000ラスカ。": ""
  },
  "46989": {
    "「英雄は\u3000もう\u3000いねえんだ。": ""
  },
  "46990": {
    "「英雄…………。": ""
  },
  "46991": {
    "「そうだ……\u3000オレ\n\u3000ザンクローネ様と約束したんだ。": ""
  },
  "46992": {
    "<center>……よく覚えとけ\u3000ラスカ。": ""
  },
  "46993": {
    "<center>ちょっとの勇気がありゃ\n誰だって\u3000英雄になれんだよ。": ""
  },
  "46994": {
    "<center>ケガしちまった\u3000親父に代わって\nお前が\u3000家族を守れ。\nお前自身が\u3000英雄になるんだ！！": ""
  },
  "46995": {
    "「そう\u3000約束したんだ。\n\u3000……オレが\u3000家族を守るって。": ""
  },
  "46996": {
    "「うおおおおおおおおお！！": ""
  },
  "46997": {
    "「ラスカァァ！": ""
  },
  "46998": {
    "「落ちつけ……\u3000おやっさん！\n\u3000そんな足で\u3000何ができるべ！？": ""
  },
  "46999": {
    "「チクショー……。": ""
  },
  "47000": {
    "「<pc>……。\n\u3000頼む……\u3000手を貸してくれ……。": ""
  },
  "47001": {
    "「今の俺にゃ\u3000息子を……\n\u3000そして\u3000娘を助けられねえ……。": ""
  },
  "47002": {
    "「うちの子らを……\n\u3000頼むゥ…\u3000助けてくれェ…………。": ""
  },
  "47003": {
    "「おい\u3000おやっさん！！": ""
  },
  "47004": {
    "「……やべぇ。すげー熱だ。\n\u3000大ケガしてんのに\u3000無茶するからだよ……。": ""
  },
  "47005": {
    "「ガッシュのおやっさんは\n\u3000俺が責任をもって\u3000村に連れ帰る。\n\u3000あいつらのこと……\u3000頼むべ。": ""
  },
  "47006": {
    "「ミ……\u3000ミシュアねえちゃんを離せ！\n\u3000この……\u3000化け物ヤロー！！": ""
  },
  "47007": {
    "「うぐ……\u3000あっ…………！": ""
  },
  "47008": {
    "「やめろおおおおおおお！！": ""
  },
  "47009": {
    "「<cs_pchero>……！\u3000おまえ\u3000つえーんだな！\n\u3000すっげー\u3000助かったぞ！": ""
  },
  "47010": {
    "「そうだ\u3000ミシュアねえちゃん！": ""
  },
  "47011": {
    "「大丈夫よ\u3000ラスカ。": ""
  },
  "47012": {
    "「助けにきてくれて\u3000ありがとう。\n\u3000あなたは\u3000立派な英雄ね！": ""
  },
  "47013": {
    "「へへっ！\u3000よかった！": ""
  },
  "47014": {
    "「え……？": ""
  },
  "47015": {
    "「助けて\u3000ザンクローネ様ッ！！": ""
  },
  "47016": {
    "<center>たとえ\u3000すべての麦が倒れ": ""
  },
  "47017": {
    "<center>水が干上がり\u3000涙が枯れても": ""
  },
  "47018": {
    "<center>お前の声が\u3000かれない限り": ""
  },
  "47019": {
    "<center>救いは\u3000必ず訪れる": ""
  },
  "47020": {
    "<center>俺は\u3000必ず駆けつける！": ""
  },
  "47021": {
    "「待たせたな\u3000ボウズ！": ""
  },
  "47022": {
    "「ザンクローネ様！！": ""
  },
  "47023": {
    "「まったく\u3000俺がいないと\n\u3000てんでダメだな\u3000お前らは！": ""
  },
  "47024": {
    "「まあ\u3000いいぜ……。\n\u3000黙って\u3000俺の背中を見てな。": ""
  },
  "47025": {
    "「さあ\u3000遊ぼうか\u3000おててちゃん。": ""
  },
  "47026": {
    "「焼きあがれ！\u3000魂が焦げるほどにッ！": ""
  },
  "47027": {
    "「カ……\u3000カッケーーーーー！！\n\u3000ザンクローネ様\u3000やっぱり生きてたんだな！": ""
  },
  "47028": {
    "「そう簡単にゃ\u3000くたばんねえよ。\n\u3000だけど\u3000まあ……\n\u3000今回ばかりは\u3000そこそこ\u3000まいったぜ。": ""
  },
  "47029": {
    "「前の戦いの時\u3000負ったダメージで\n\u3000ろくに\u3000身体が動かなくなっちまってな。 \n\u3000魂を結晶化させて\u3000回復に専念してたのさ。": ""
  },
  "47030": {
    "「おい\u3000お前！\u3000なんてったっけ……\n\u3000そうだ\u3000<cs_pchero>！": ""
  },
  "47031": {
    "「お前の懐にいた時\u3000熱い魂の鼓動を感じた。\n\u3000おかげで\u3000キズが早く癒えたのさ。\n\u3000……恩に着るぜ！": ""
  },
  "47032": {
    "「それから……\u3000ラスカ。\n\u3000俺を呼ぶ声\u3000確かに届いたぞ。": ""
  },
  "47033": {
    "「どんな時も\u3000希望は捨てんな。\n\u3000メルサンディ村は\u3000俺とともにある！": ""
  },
  "47034": {
    "「ま\u3000待ってよー！\u3000ザンクローネ様ー！": ""
  },
  "47035": {
    "「……ありがとう\u3000<cs_pchero>さん。\n\u3000あなたが\u3000来てくれたから\n\u3000こんな奇跡が\u3000起こったんだと思うの。": ""
  },
  "47036": {
    "「やっぱり\u3000英雄は\u3000死なないのね……": ""
  },
  "47037": {
    "「勇……は……\u3000死な…な…い……。": ""
  },
  "47038": {
    "「…………行かなきゃ。": ""
  },
  "47039": {
    "「ザンクローネ様\u3000見失っちまった……。": ""
  },
  "47040": {
    "「あれ？\u3000<cs_pchero>。\n\u3000ミシュアねえちゃんは\u3000どこ行ったんだ？\n\u3000先に\u3000帰っちゃったのか……？": ""
  },
  "47041": {
    "「これって\u3000ねえちゃんの髪飾りだよな？\n\u3000落とすなんて\u3000そそっかしいぜ……。\n\u3000あとで\u3000渡してやるか。": ""
  },
  "47042": {
    "「うわあー\u3000食べないでー！！": ""
  },
  "47043": {
    "「…………あれ？\n\u3000ここ……\u3000どこなんでしょう？": ""
  },
  "47044": {
    "「うお！\u3000行方不明のデニーじゃん。\n\u3000とっくに\u3000化け物に\u3000食われちまったと\n\u3000思ってたぜ。": ""
  },
  "47045": {
    "「おお\u3000そうでした！\n\u3000私\u3000化け物に\u3000つかまったんでした～。\n\u3000はやく\u3000帰って\u3000無事を知らせないと。": ""
  },
  "47046": {
    "「さあ\u3000メルサンディ村に帰ろうぜ！": ""
