{
  "70903": {
    "「この絶え間ない水音……。\n\u3000しんと\u3000冷えきった空気……。": ""
  },
  "70904": {
    "「そうです……。たしかに\u3000私は\n\u3000ここに\u3000幽閉されていました。": ""
  },
  "70905": {
    "「あぁっ……ア\u3000アタマが……。": ""
  },
  "70906": {
    "「<cs_pchero>さま……\u3000あの巨人が \n\u3000私の記憶のカギを\u3000にぎっているようです……。\n\u3000どうか\u3000チカラをお貸しください……。": ""
  },
  "70907": {
    "「すべて\u3000思いだしました……。\n\u3000あの巨人は\u3000私の罪悪感が\n\u3000魔物となって\u3000具現化したもの……。": ""
  },
  "70908": {
    "「そう……。私は\u3000この場所で\n\u3000あの子の声を聞いたんです。": ""
  },
  "70909": {
    "「……そんなに泣いて\u3000どうしたのです\u3000テティ？": ""
  },
  "70910": {
    "「あのね\u3000あのね\u3000シスター･サテラ。\n\u3000テティのパパの船\u3000あらしのなかにいるの。": ""
  },
  "70911": {
    "「パパ\u3000だいじょーぶかな……。\n\u3000ちゃんと\u3000ただいまーって\u3000かえれるかな……。": ""
  },
  "70912": {
    "「テティ…………。": ""
  },
  "70913": {
    "「テティ。昨夜\u3000お祈りをしている時\n\u3000テティのパパの船を\u3000空の上から見守っている\n\u3000星々の声が\u3000聴こえたわ。": ""
  },
  "70914": {
    "「ほ\u3000ほんとっ？": ""
  },
  "70915": {
    "「星々は\u3000こう言っていたの。\n\u3000テティのパパは\u3000もうすぐ\u3000無事に帰ります。": ""
  },
  "70916": {
    "「ほんとに\u3000ほんとねっ？": ""
  },
  "70917": {
    "<center>はじめは\u3000子供たちを励ますための\n小さなウソでした……。": ""
  },
  "70918": {
    "<center>テティの\u3000お父さまの船は無事に戻り……\nそれからも\u3000私は何度か\n子供たちのために\u3000偽りの予言をしました。": ""
  },
  "70919": {
    "<center>そのうち……\u3000大人たちまでもが\n私の予言のチカラを\n本物だと\u3000ささやくようになり……": ""
  },
  "70920": {
    "<center>そして\u3000あの日……\n取り返しのつかないことが\u3000起こったのです。": ""
  },
  "70921": {
    "「このひとよ！\u3000このひとが\u3000シスター・サテラ！\n\u3000おほしさまの声が\u3000きけるの。": ""
  },
  "70922": {
    "「……失礼します。 \n\u3000あなたが\u3000シスター・サテラ殿ですかな？": ""
  },
  "70923": {
    "「は\u3000はい……私が\u3000サテラです。": ""
  },
  "70924": {
    "「先の世を見通すチカラをお持ちと\n\u3000ウワサに聞き及んでおります。そのチカラに\n\u3000おすがりしようと\u3000はるばる参りました。": ""
  },
  "70925": {
    "「我が国は\u3000今\u3000戦乱の中にあり \n\u3000国王は\u3000兵をさらに進めるべきか\n\u3000退くべきかの決断に\u3000悩んでおられる。": ""
  },
  "70926": {
    "「そこで\u3000我が国王のため\u3000どうかひとつ\n\u3000予言を授けては\u3000いただけまいか。": ""
  },
  "70927": {
    "「いえ……わ\u3000私は……。": ""
  },
  "70928": {
    "「聖職にあるとはいえ\u3000あなたも\u3000ひとりの\n\u3000国民として\u3000国を思う気持ちは変わりますまい。\n\u3000サテラ殿……どうか……。": ""
  },
  "70929": {
    "「シスター・サテラ……。\n\u3000このおじさん\u3000とても\u3000こまってるみたいよ。": ""
  },
  "70930": {
    "「………………。": ""
  },
  "70931": {
    "「ほ…星々が\u3000未来を告げています。\n\u3000今の状況では\u3000兵を……": ""
  },
  "70932": {
    "「兵を……\u3000進めるべきです。": ""
  },
  "70933": {
    "「強き意志を\u3000持つ者にこそ……\n\u3000勝利の女神は\u3000ほほえむでしょう……。": ""
  },
  "70934": {
    "「兵を進めるべき……。なるほど。\n\u3000それが\u3000そなたの\u3000予言なのですな？": ""
  },
  "70935": {
    "「ありがとうございます。\n\u3000では\u3000我が王に\u3000そのように伝えましょう。": ""
  },
  "70936": {
    "<center>私の\u3000その予言は……\n悲劇の元凶になりました。": ""
  },
  "70937": {
    "<center>私の\u3000偽りの予言通りに\nその国の王が\u3000兵を進めた結果……": ""
  },
  "70938": {
    "<center>その進軍は\u3000敵に読まれていました。\n兵士たちの進んだ先には\u3000罠が仕掛けられており\n何もできずに\u3000軍は壊滅したそうです……。": ""
  },
  "70939": {
    "<center>私は\u3000偽りの予言をした罪で\nこのナギリ洞に\u3000閉じ込められました。": ""
  },
  "70940": {
    "「……こんな大きな罪\u3000私には\u3000つぐなえない。": ""
  },
  "70941": {
    "「もしも\u3000予言のチカラが本物だったら \n\u3000私は\u3000誰も……。": ""
  },
  "70942": {
    "「うう……っ。 \n\u3000ひっく\u3000ひっく……。": ""
  },
  "70943": {
    "「ど\u3000どなたですか……？": ""
  },
  "70944": {
    "「あなたは……。\n\u3000なんで\u3000こんな所に……。 ": ""
  },
  "70945": {
    "「ボ……ボク……。": ""
  },
  "70946": {
    "「ボク……帰らなくちゃいけなくて……。\n\u3000だけど\u3000追いだされてしまったから\n\u3000ひとりじゃ\u3000帰れなくて……。": ""
  },
  "70947": {
    "「……………………。": ""
  },
  "70948": {
    "「おねえちゃん\u3000ボクといっしょに\n\u3000帰ってくれないかな。おねえちゃんと\n\u3000いっしょなら\u3000ボク\u3000きっと帰れるから。": ""
  },
  "70949": {
    "「そしたら\u3000ボク……\u3000おねえちゃんの頼み\n\u3000どんなことでも\u3000きいてあげるから！": ""
  },
  "70950": {
    "「……あなたは\u3000不思議な方ですね。\n\u3000もしや\u3000神さまの\u3000お使いなのでしょうか。": ""
  },
  "70951": {
    "「どうか\u3000私の懺悔を\u3000お聞きください……。\n\u3000私は\u3000ある国の人々に\u3000偽りの予言を伝え\n\u3000多くの死者を生むこととなりました。": ""
  },
  "70952": {
    "「もし私に\u3000本当の予言のチカラがあれば \n\u3000あの人々を\u3000死なさずに済んだのに……。": ""
  },
  "70953": {
    "「それが\u3000おねえちゃんの願いなんだね？\n\u3000わかった。それじゃあ\u3000目を閉じて……。": ""
  },
  "70954": {
    "「さあ\u3000ゆっくりと目を開けて……。": ""
  },
  "70955": {
    "「歌が……聴こえます……。\n\u3000これは\u3000星が歌っているの……？": ""
  },
  "70956": {
    "「これで\u3000ボクといっしょに帰ってくれるよね？": ""
  },
  "70957": {
    "「あなたは……\u3000いったい……？": ""
  },
  "70958": {
    "「ボクはね………………": ""
  },
  "70959": {
    "「……すべて\u3000思いだしました。 \n\u3000何が\u3000私を\u3000世告げの姫として\n\u3000動かしていたのか……。": ""
  },
  "70960": {
    "「しかし\u3000後悔はありません……。\n\u3000世告げの姫として\u3000人々を救うことが\n\u3000少しでも\u3000罪の償いになるのなら……。": ""
  },
  "70961": {
    "「それに\u3000世告げの姫としての使命が終わったら \n\u3000私は\u3000あの教会へ戻り\u3000本当の予言のチカラで\n\u3000迷える人々に\u3000手を差しのべられる……。": ""
  },
  "70962": {
    "「<cs_pchero>さま\u3000ありがとうございます。\n\u3000この記憶があれば\u3000災厄の王の幻術を\n\u3000破ることができましょう。": ""
  },
  "70963": {
    "「こちらは\u3000心ばかりの\u3000お礼になります。\n\u3000災厄の王との決戦に\u3000お役立てくださいませ。": ""
  },
  "70964": {
    "「<cs_pchero>さま\u3000覚えておいでですか？\n\u3000幾千の星が舞い散った\u3000あの日を……。": ""
  },
  "70965": {
    "「あの時より\u3000何度も救っていただいて\n\u3000<cs_pchero>さまは\u3000見違えるほど\n\u3000お強くなられましたね。": ""
  },
  "70966": {
    "「舵取りのマレンが\u3000<cs_pchero>さまのことを \n\u3000待っているはずです。\n\u3000次は\u3000彼女を\u3000救ってさしあげてください。": ""
  },
  "70967": {
    "「……星々は\u3000やがて歌うでしょう。\n\u3000<cs_pchero>さまの\u3000勝利の歌を……。": ""
  }
}