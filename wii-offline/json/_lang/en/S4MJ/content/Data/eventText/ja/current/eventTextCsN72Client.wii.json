{
  "50869": {
    "「ご苦労さまです。\n\u3000どうやら\u3000ミシュアさんの記憶は\n\u3000取り戻せたようですね。": ""
  },
  "50870": {
    "「<pc>さん。見覚えがありませんか？": ""
  },
  "50871": {
    "「この光は\u3000かつて\u3000あなたが見た光……。": ""
  },
  "50872": {
    "「そう……。あなたが\u3000生き返しを受け\n\u3000新たな運命を得た地で見た\u3000あの光なのです。": ""
  },
  "50873": {
    "「この奇妙な時間のズレ……。\n\u3000ミシュアさんと\u3000アンルシア姫という\n\u3000生き写しのような\u3000ふたりの存在……。": ""
  },
  "50874": {
    "「この世界には\u3000何か\u3000大きな秘密が\n\u3000隠されているようですね。": ""
  },
  "50875": {
    "「……私の本当の名は\u3000アンルシア。\n\u3000グランゼドーラ王国の姫として\u3000生まれ\n\u3000今\u3000伝説の勇者として\u3000目覚めました。": ""
  },
  "50876": {
    "「兄さまの死を\u3000悲しむあまりに\n\u3000私は\u3000自分が勇者であるという記憶すらも\n\u3000自らのチカラで\u3000封じてしまっていた……。": ""
  },
  "50877": {
    "「でも\u3000もう\u3000迷いはありません！": ""
  },
  "50878": {
    "「ありがとう\u3000<pc>。\n\u3000私が\u3000こうして\u3000勇者として\n\u3000目覚められたのは\u3000あなたのおかげ。": ""
  },
  "50879": {
    "「あなたが勇者を探して\u3000五大陸から\n\u3000このレンダーシアへ\u3000来てくれなければ\n\u3000私は\u3000ずっと\u3000ミシュアのままでした……。": ""
  },
  "50880": {
    "「……おい！\u3000今の光は\u3000いったい\u3000なんだ！？": ""
  },
  "50881": {
    "「わ……わかりません！！\n\u3000突然\u3000この塔から光が\u3000あふれだしました！": ""
  },
  "50882": {
    "「……今の私には\u3000はっきりと\u3000わかります。\n\u3000ここは\u3000私の知っているグランゼドーラとは\n\u3000まったく\u3000ちがう場所だって。": ""
  },
  "50883": {
    "「いったい\u3000ここは\u3000どこなのか……\n\u3000もうひとりの私が\u3000何をしようとしているのか\n\u3000確かめなきゃいけないわ。": ""
  },
  "50884": {
    "「だけど\u3000まずは\u3000この城を抜けださないと。\n\u3000行きましょう\u3000<pc>。": ""
  },
  "50885": {
    "「ふふっ。待っていたぞ\u3000ミシュア。\n\u3000いや。アンルシア……と呼ぶべきか？": ""
  },
  "50886": {
    "「この裏切り者から\u3000お前のもとへ\n\u3000<pc>を向かわせたと\u3000聞いてな。\n\u3000こうして\u3000待っていたのさ。": ""
  },
  "50887": {
    "「勇者覚醒の光。私も\u3000見せてもらったよ。\n\u3000ついに\u3000記憶を取り戻したんだろう？\n\u3000おめでとう\u3000アンルシア。": ""
  },
  "50888": {
    "「……あなたは\u3000何者なんですか？\n\u3000私の名と姿をかたって\u3000いったい\n\u3000何をしようと\u3000しているの！？": ""
  },
  "50889": {
    "「かたってなど\u3000いない！\n\u3000私は\u3000グランゼドーラ王国の姫\u3000アンルシア。\n\u3000勇者となるべく\u3000生まれてきた者だっ！": ""
  },
  "50890": {
    "「お前のチカラは\u3000私がもらう。\n\u3000これからは\u3000私が\u3000本物の勇者となるのさ。": ""
  },
  "50891": {
    "「私のチカラを……？\n\u3000そんなことは\u3000させない！": ""
  },
  "50892": {
    "「ヒョーヒョヒョッ。\n\u3000私の研究成果をもってすれば\u3000簡単なこと。": ""
  },
  "50893": {
    "「これまでにも\u3000多くの者のチカラを抽出し\n\u3000姫さまに\u3000お与えしてきましたからねえ。": ""
  },
  "50894": {
    "「ま……まさか\u3000その中に\u3000私の孫も……？": ""
  },
  "50895": {
    "「お前の孫\u3000テグラムも\u3000私に命を捧げてくれた。\n\u3000そのチカラは今\u3000私と共にある。\n\u3000光栄に思うがいいぞ\u3000ダイム老。": ""
  },
  "50896": {
    "「……ううっ。やはり\u3000テグラムは……。\n\u3000うあああっ……。": ""
  },
  "50897": {
    "「なんて\u3000ひどいことを……。": ""
  },
  "50898": {
    "「ふん……。\n\u3000キルギル。すぐに始めろ。": ""
  },
  "50899": {
    "「ヒョヒョッ。かしこまりまして\u3000ございます。": ""
  },
  "50900": {
    "「ヒョヒョッ？\u3000さすが\u3000勇者のチカラ。\n\u3000簡単には\u3000いかないようですねえ。\n\u3000ならば\u3000最大出力ぅっ！！": ""
  },
  "50901": {
    "「ぐわあっ！！": ""
  },
  "50902": {
    "「ダイムさんっ！": ""
  },
  "50903": {
    "「……チカラを吸えぬか。": ""
  },
  "50904": {
    "「ヒギギギ……。私の計算を超えるとは。\n\u3000これ以上のパワーを出すには\n\u3000創生の魔力を\u3000もってするしか……。": ""
  },
  "50905": {
    "「ならば\u3000創生の渦へ\u3000向かうぞ。\n\u3000私が\u3000勇者となるためならば\n\u3000禁を破ることになろうと\u3000かまわない。": ""
  },
  "50906": {
    "「ヒョヒョッ。このキルギル\n\u3000そのお言葉を\u3000ずっと\u3000お待ちしておりました。\n\u3000いよいよ\u3000創生の魔力を試せるのですね！": ""
  },
  "50907": {
    "「では\u3000さっそく\u3000まいりましょう。\n\u3000ヒョーーッヒョッヒョヒョ。": ""
  },
  "50908": {
    "「ま……待ちなさい！！": ""
  },
  "50909": {
    "「私を止めたくば\u3000ダーマ神殿へ来い。\n\u3000創生の渦への道は\u3000開けておいてやろう。": ""
  },
  "50910": {
    "「ふふふ……。ははははっ！！": ""
  },
  "50911": {
    "「くっ……。": ""
  },
  "50912": {
    "「うぐっ……。": ""
  },
  "50913": {
    "「ダイムさん！？": ""
  },
  "50914": {
    "「ううっ。あなたが\u3000本物の勇者姫さま……。\n\u3000では\u3000私が\u3000これまで仕えていた\n\u3000あの姫さまは\u3000いったい……。": ""
  },
  "50915": {
    "「やはり\u3000この世界は\u3000おかしかった……。\n\u3000私が\u3000それに気付けたのは……真の勇者である\n\u3000あなたと\u3000一緒に過ごせた\u3000おかげ……。": ""
  },
  "50916": {
    "「ありがとう……ございました。\n\u3000アンルシア……姫さま……ぐふっ。": ""
  },
  "50917": {
    "「……私は\u3000あの人たちを許さない。": ""
  },
  "50918": {
    "「すぐに\u3000後を追いかけましょう。\n\u3000チカラを貸して\u3000<pc>。": ""
  },
  "50919": {
    "「ダーマ神殿に\u3000向かい\n\u3000創生の渦への道を\u3000探さないと！": ""
  },
  "50920": {
    "「あの人たちの言っていた\u3000創生の渦への道って\n\u3000この\u3000旅の扉のことみたいね。": ""
  },
  "50921": {
    "「創生の渦……。\n\u3000そこに\u3000何があるのか\u3000確かめないと。\n\u3000行きましょう\u3000<pc>。": ""
  },
  "50922": {
    "「ここは……？\n\u3000村のようだけど\u3000ほとんどが壊されていて\n\u3000跡形も\u3000なくなっているわ……。": ""
  },
  "50923": {
    "「あの人たち\u3000ここには\u3000いないみたいね。\n\u3000村の外に出て\u3000創生の渦を探してみましょう。": ""
  },
  "50927": {
    "「ここは……？": ""
  },
  "50928": {
    "「ヒョッ？\u3000まさか\u3000本当に追ってくるとは。\n\u3000なんと\u3000あわれで\u3000おろかなる実験素材。\n\u3000ヒョーヒョッヒョッ！": ""
  },
  "50929": {
    "「実験素材……？\n\u3000いったい\u3000何を企んでいるの！？": ""
  },
  "50930": {
    "「やれやれ。無知で無学で無教養な\u3000あなた方に\n\u3000特別に\u3000教えてさしあげましょう。": ""
  },
  "50931": {
    "「あれこそは\u3000創生の渦！！": ""
  },
  "50932": {
    "「すべてを創りだし\u3000生みだす\n\u3000創生の魔力の……その根源に通じるという\n\u3000チカラの象徴なのです！": ""
  },
  "50933": {
    "「あの渦に秘められた魔力……。\n\u3000はたして\u3000どれほどのものなのか\n\u3000あなた方に\u3000想像できますか？": ""
  },
  "50934": {
    "「……できませんよねえ？\n\u3000でも\u3000悲観することは\u3000ありませんよ。\n\u3000すぐに\u3000体験できるのですから。": ""
  },
  "50935": {
    "「我が姫さまは\u3000まさに今！\n\u3000創生の渦に秘められた\u3000絶大な魔力を\n\u3000その身に\u3000宿そうとしているところなのですよ。": ""
  },
  "50936": {
    "「この私にも\u3000計りしれないほどの\n\u3000創生の魔力を得た\u3000姫さまのチカラは\n\u3000確実に\u3000勇者のチカラを超えるでしょう！": ""
  },
  "50937": {
    "「あなたたちの思いどおりには\u3000させない！": ""
  },
  "50938": {
    "「残念ですが\u3000もう遅いのですよ……。": ""
  },
  "50939": {
    "「感じる……感じますよ！\n\u3000ついに\u3000姫さまが\u3000創生の魔力をっ。\n\u3000ヒョーヒョッヒョッ！！": ""
  },
  "50940": {
    "「ふふふ……。\n\u3000創生の魔力は\u3000我が身に宿った……。": ""
  },
  "50941": {
    "「くっ……。身体が\u3000動かな……い……。": ""
  },
  "50942": {
    "「おお……我が姫さま。なんと\u3000美しい。\n\u3000まさに\u3000魔の勇者……": ""
  },
  "50943": {
    "「ふふふ……。はーっはっはっ！\n\u3000見よ\u3000この姿を！": ""
  },
  "50944": {
    "「創生の魔力によって\n\u3000私は\u3000勇者を超えるチカラを得た！": ""
  },
  "50945": {
    "「だが\u3000私が望むことは\u3000ただひとつ。\n\u3000お前から\u3000勇者のチカラを奪い\n\u3000真の勇者となることだ！！": ""
  },
  "50946": {
    "「その前に……。\n\u3000目障りな邪魔者を\u3000排除する必要があるな。": ""
  },
  "50947": {
    "「ふふふ。<cs_pchero>……。\n\u3000創生の魔力が\u3000もたらすチカラを\n\u3000まずは\u3000お前で試させてもらうとしよう。": ""
  },
  "50948": {
    "「はははっ\u3000アンルシアよ。\n\u3000何もできぬまま\u3000<cs_pchero>が\n\u3000消し飛ぶところを\u3000そこで見ているがいい！": ""
  },
  "50949": {
    "「見逃してやったというのに\u3000戻ってくるとはな。\n\u3000どこまでも\u3000目障りな奴だ……。": ""
  },
  "50950": {
    "「<cs_pchero>よ。創生の魔力を得た私に\n\u3000打ち勝とうなどと\u3000考えるな。\n\u3000素直に\u3000死を受け入れるがいい！！": ""
  },
  "50951": {
    "「<cs_pchero>……。\n\u3000お前のチカラを\u3000見くびっていたようだ……。": ""
  },
  "50952": {
    "「人の身で\u3000創生の魔力を得た私と\n\u3000ここまで戦えるとは\u3000おどろいたぞ……。": ""
  },
  "50953": {
    "「だがな……。": ""
  },
  "50954": {
    "「……どんなに強かろうと\u3000お前では\n\u3000私を滅ぼすことは\u3000できない。": ""
  },
  "50955": {
    "「お前に\u3000残されているのは\n\u3000私に\u3000消し飛ばされるという運命だけなのさ！": ""
  },
  "50956": {
    "「…………！！": ""
  },
  "50957": {
    "「さあ\u3000お別れだ……。\n\u3000これまで\u3000アンルシアを守ってくれて\n\u3000感謝しているぞ\u3000<cs_pchero>。": ""
  },
  "50958": {
    "「ふふふ……。はーっはっはははははっ！！": ""
  },
  "50959": {
    "「……<cs_pchero>！！": ""
  },
  "50960": {
    "「……なにっ？\n\u3000創生の魔力で作られた戒めから\u3000逃れただと！？": ""
  },
  "50961": {
    "「これ以上\u3000<cs_pchero>だけを\n\u3000危険な目に\u3000あわせるわけには\u3000いかないわ！\n\u3000私も\u3000一緒に戦います！！": ""
  },
  "50962": {
    "「勇者のチカラを\u3000ぶつければ\n\u3000この化け物も\u3000滅ぼすことができるはず。\n\u3000それには\u3000あなたの協力が必要だわ！": ""
  },
  "50963": {
    "「私が\u3000勇者のチカラを高めるまで\n\u3000化け物の相手を\u3000お願い。\n\u3000ふたりのチカラを\u3000ひとつにするの！": ""
  },
  "50964": {
    "「ふふふ……。何をしようと\u3000無駄なことだ。": ""
  },
  "50965": {
    "「さあ\u3000アンルシア。\n\u3000お前の勇者のチカラを\u3000私に寄こすがいい！": ""
  },
  "50966": {
    "「来てくれたのね\u3000<cs_pchero>。\n\u3000私の\u3000勇者のチカラをぶつければ\n\u3000この化け物も\u3000滅ぼすことができるはず。": ""
  },
  "50967": {
    "「私が\u3000勇者のチカラを高めるまで\n\u3000化け物の相手を\u3000お願い。\n\u3000ふたりのチカラを\u3000ひとつにするの！": ""
  },
  "50968": {
    "「ふふふ……。何をしようと\u3000無駄なことだ。": ""
  },
  "50969": {
    "「さあ\u3000アンルシア。\n\u3000お前の勇者のチカラを\u3000私に寄こすがいい！": ""
  },
  "50970": {
    "「……うぐあああっ！！": ""
  },
  "50971": {
    "「なんということだ……。\n\u3000創生の魔力をもってしても\n\u3000勇者のチカラには\u3000及ばぬというのか！！": ""
  },
  "50972": {
    "「うっうう……。": ""
  },
  "50973": {
    "「ふ……ふふ。やはり\u3000私では\n\u3000ダメだったということらしい……。": ""
  },
  "50974": {
    "「私は\u3000しょせん\u3000創られた存在。\n\u3000本物の勇者になど\u3000なれるわけが\n\u3000なかったのさ……。": ""
  },
  "50975": {
    "「創られた……存在？": ""
  },
  "50976": {
    "「……そうだ。\n\u3000私は\u3000勇者となって\u3000お前と入れ替わるため\n\u3000この創生の渦から\u3000生みだされた。": ""
  },
  "50977": {
    "「……大魔王\u3000マデサゴーラの手によってな。": ""
  },
  "50978": {
    "「大魔王マデサゴーラ……。": ""
  },
  "50979": {
    "「だが\u3000私は\u3000勇者として覚醒できなかった。\n\u3000できそこないの失敗作と\u3000さげすまれ\n\u3000大魔王に\u3000見切りをつけられたのさ……。": ""
  },
  "50980": {
    "「それでも\u3000あきらめきれなかった……。\n\u3000私には\u3000勇者となる以外に\n\u3000生きている価値などないのだから……。": ""
  },
  "50981": {
    "「……覚醒するために\u3000なんでもやった。\n\u3000できることは\u3000すべてだ。": ""
  },
  "50982": {
    "「しかし\u3000何をしようと\u3000覚醒の時は訪れない。\n\u3000そのときだ。お前が現れたのは……。": ""
  },
  "50983": {
    "「私の身体は\u3000歓喜に打ちふるえたよ。\n\u3000本物の勇者から\u3000そのチカラを奪えば\n\u3000ついに\u3000勇者になれると……。": ""
  },
  "50984": {
    "「その結果が\u3000このザマさ……。": ""
  },
  "50985": {
    "「いいことを教えてやろう……。\n\u3000大魔王に創られたのは\u3000この私だけじゃない。": ""
  },
  "50986": {
    "「この地に生きる者のすべてが……。\n\u3000存在する物のすべてが\u3000大魔王によって\n\u3000創生の渦の魔力で\u3000創りだされたものだ。": ""
  },
  "50987": {
    "「ここは\u3000偽りのレンダーシア！\n\u3000この地そのものが\u3000創られた存在であり\n\u3000救われることのない\u3000呪われし世界なのさ！！": ""
  },
  "50988": {
    "「ふふふ……はははははっ。\n\u3000……あははははははははっ！！": ""
  },
  "50989": {
    "「…………。": ""
  },
  "50990": {
    "「ここが\u3000創られた世界だなんて……。\n\u3000偽物の私まで創りだして\u3000大魔王は\n\u3000いったい\u3000何をしようとしているの？": ""
  },
  "50991": {
    "「それに……。\n\u3000ここが\u3000偽りのレンダーシアだとしたら\n\u3000本当のレンダーシアは……": ""
  },
  "50992": {
    "「この世界の秘密を\u3000知ったようですね。": ""
  },
  "50993": {
    "「私は\u3000この時を待っていました。\n\u3000真の勇者が目覚め\u3000偽りの勇者を打ち滅ぼす\n\u3000まさに\u3000この時を。": ""
  },
  "50994": {
    "「あなたのいた\u3000レンダーシアが\n\u3000今\u3000どうなっているか……。\n\u3000知る手段は\u3000ここにあります。": ""
  },
  "50995": {
    "「これは\u3000ブレイブストーン。\n\u3000勇者が使ったならば\u3000次元の壁さえも超えて\n\u3000好きな場所に\u3000移動できるという秘石です。": ""
  },
  "50996": {
    "「それを使えば\u3000私たちは\n\u3000真のレンダーシアに\u3000帰れるんですか！？": ""
  },
  "50997": {
    "「その通り。偽りの勇者は\u3000覚醒を迎えた後に\n\u3000この石を使って\u3000真のレンダーシアへと\n\u3000渡るつもりだったのでしょう。": ""
  },
  "50998": {
    "「ですが\u3000今の戦いで\u3000石は割れてしまった。\n\u3000しばしの時が\u3000いただけるなら\n\u3000この私が\u3000直してみせますが\u3000いかがです？": ""
  },
  "50999": {
    "「時間が\u3000かかっても\u3000かまいません。\n\u3000その石を\u3000使えるようにしてください！": ""
  },
  "51000": {
    "「では\u3000グランゼドーラ城の\u3000西の塔\n\u3000３階の姫の部屋で\u3000お待ちください。\n\u3000石が直り次第\u3000お届けにあがりましょう。\u3000": ""
  },
  "51001": {
    "「<cs_pchero>。私は\u3000グランゼドーラ城で\n\u3000ブレイブストーンの完成を待つことにするわ。\n\u3000あなたも\u3000その時が来たら\u3000城に来て。": ""
  },
  "51002": {
    "「共に\u3000真のレンダーシアへ\u3000帰りましょう！": ""
  }
}