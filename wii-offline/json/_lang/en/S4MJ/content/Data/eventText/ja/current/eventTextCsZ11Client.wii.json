{
  "9421": {
    "「おぬし\u3000どうやら\u3000一度死んで\n\u3000生き返しを受けた者……\n\u3000すなわち\u3000生き返リストのようじゃな。": ""
  },
  "9422": {
    "「わしの名は\u3000放浪の賢者ホーロー。": ""
  },
  "9423": {
    "「このアストルティアに\n\u3000知らぬことなしと\u3000うたわれる\n\u3000賢者の中の賢者じゃよ<heart>": ""
  },
  "9424": {
    "「わしの眼力にかかれば\u3000おぬしが\n\u3000生き返リストか\u3000どうかなど\n\u3000一目りょーぜんというわけじゃ!": ""
  },
  "9425": {
    "「……さて\u3000こちらが\u3000名乗ったのだから\n\u3000おぬしも名乗るのが\u3000礼儀じゃろ？\n\u3000まずは\u3000名前を聞かせてもらおーかの。": ""
  },
  "9426": {
    "「……ふーむ\u3000<pc>というのか。\n\u3000いかにも\u3000エテーネの民らしい\n\u3000プリミティブかつ\u3000エレガントな名前じゃな。": ""
  },
  "9427": {
    "「……そう\u3000おぬしの故郷\u3000エテーネの村は\n\u3000冥王ネルゲルの手で\u3000封印されし大地\n\u3000レンダーシアの真ん中に\u3000位置しておる。": ""
  },
  "9428": {
    "「そして\u3000勇者覚醒の光が\u3000放たれたのも\n\u3000レンダーシア……\u3000そう。\n\u3000おぬしは\u3000かの地を目指さねばならぬのじゃ！": ""
  },
  "9429": {
    "「そのためには\u3000何をすべきか\n\u3000教えてやってもいいのじゃが……。\u3000": ""
  },
  "9430": {
    "「……ときに\u3000おぬし\n\u3000いくつ集めたんじゃ？": ""
  },
  "9431": {
    "「…………。": ""
  },
  "9432": {
    "「……………………。": ""
  },
  "9433": {
    "「……むっ\u3000言葉足らずだったようじゃな。\n\u3000すまん\u3000すまん。": ""
  },
  "9434": {
    "「わしが聞きたいのは\u3000キーエンブレムの数じゃ。\n\u3000それを聞けば\u3000おぬしの実力と活躍のほどが\n\u3000どれくらいのものか\u3000わかるからのう。": ""
  },
  "9435": {
    "<pc>は\u3000賢者ホーローに\n自分の持つ\u3000キーエンブレムの数を教えた。": ""
  },
  "9436": {
    "「なんと！\u3000それだけか！？\n\u3000うむむむ……これは\u3000先が思いやられるのう。": ""
  },
  "9437": {
    "「まあ\u3000それしかないのなら仕方ない。 \n\u3000これから\u3000がんばれば\u3000よいのじゃからな。\n\u3000今は\u3000ただ\u3000キーエンブレムを集めるのじゃ。": ""
  },
  "9438": {
    "「おぬしの実力が\u3000頼むに足りると\n\u3000判断したとき\u3000レンダーシアの封印を\n\u3000解くための方法を\u3000教えちゃおう。\u3000": ""
  },
  "9439": {
    "「次は～\u3000アズラン～\u3000アズラン～。\n\u3000車両と\u3000ホームの間が\u3000広くなっております。\u3000\n\u3000足もとに気をつけて\u3000お降りください。": ""
  },
  "9441": {
    "「い\u3000いかん！\u3000アズラン駅では\u3000\n\u3000名物のカムシカせんべえを\u3000買うんじゃった！\n\u3000こりゃ\u3000ノンビリしておれん。": ""
  },
  "9442": {
    "「い\u3000いかん！\u3000娯楽島ラッカラン駅では\u3000\n\u3000名物のコロシアムバーガーを\u3000買うんじゃった！\n\u3000こりゃ\u3000ノンビリしておれん。": ""
  },
  "9443": {
    "「そのときまで\u3000せいぜい\n\u3000キーエンブレムを\u3000集めておくのじゃぞ！\n\u3000ホッホッホッ……。": ""
  },
  "9444": {
    "「おお\u3000そのビビッドかつ\u3000ユニークな\n\u3000顔立ちは\u3000<pc>ではないか！\n\u3000また\u3000会ったのう。": ""
  },
  "9445": {
    "「よもや\u3000わしのことを\u3000忘れちゃいまいな？\n\u3000アストルティアに\u3000知らぬことなし!\n\u3000放浪の賢者\u3000ホーローじゃ。": ""
  },
  "9446": {
    "「……して\u3000いくつ集めたんじゃ？": ""
  },
  "9447": {
    "「…………。": ""
  },
  "9448": {
    "「……………………。": ""
  },
  "9449": {
    "「……むう\u3000ツーカーとはいかんもんじゃな。\n\u3000わしが\u3000聞きたいのは\u3000とーぜん\n\u3000おぬしの持つ\u3000キーエンブレムの数じゃ。": ""
  },
  "9450": {
    "<pc>は\u3000賢者ホーローに\n自分の持つ\u3000キーエンブレムの数を教えた。": ""
  },
  "9451": {
    "「ほう\u3000そうか\u3000そうか。\n\u3000なかなか\u3000がんばってるようじゃな。": ""
  },
  "9452": {
    "「そうじゃなぁ……５個？\n\u3000いや\u3000６個……６個じゃな！": ""
  },
  "9453": {
    "「……<pc>よ。\n\u3000おぬしには\u3000キーエンブレムを６個以上\n\u3000集めてきてほしいのじゃ。": ""
  },
  "9454": {
    "「それほどのウデ前の\u3000持ち主ならば\n\u3000わしも\u3000安心して\u3000おぬしに\n\u3000大事な使命を\u3000託すことができるからのう。": ""
  },
  "9455": {
    "「……その使命とは\u3000ズバリ！\n\u3000冥王ネルゲルを倒し\u3000やつに封印された\n\u3000レンダーシアの大地を救うことじゃ！": ""
  },
  "9456": {
    "「故郷の村を\u3000ネルゲルに滅ぼされた\n\u3000おぬしじゃ。できることなら\u3000今すぐ\n\u3000仇討ちを果たしたいことじゃろう。": ""
  },
  "9457": {
    "「だがな\u3000お若いの。焦りは禁物じゃよ。\n\u3000今のおぬしでは\u3000とうてい\n\u3000あの冥王には\u3000勝てまい。": ""
  },
  "9458": {
    "「それに\u3000ヤツの支配する\u3000冥界への入り口は\n\u3000ランドン山脈の奥深く\u3000断崖の先にあり\u3000\n\u3000誰も\u3000そこへ至ることは\u3000かなわぬという。": ""
  },
  "9459": {
    "「……そう。このワシを\u3000のぞいてはな。": ""
  },
  "9460": {
    "「今は\u3000実力の証\u3000キーエンブレムを集めながら\n\u3000チカラを\u3000たくわえる時期なのじゃ。\n\u3000くれぐれも\u3000無策\u3000無謀に走るでないぞ。": ""
  },
  "9461": {
    "「次は～\u3000アズラン～\u3000アズラン～。\n\u3000本日の運転は\u3000スキッピオ運転手が～\u3000\n\u3000車掌は私\u3000マリウスが\u3000ご案内いたしました。": ""
  },
  "9463": {
    "「いかん！\u3000アズラン駅では\u3000名物の\n\u3000カムシカせんべえを\u3000買うんじゃった。\n\u3000こりゃ\u3000急がねば！": ""
  },
  "9464": {
    "「いかん！\u3000娯楽島ラッカラン駅では\u3000名物の\n\u3000コロシアムバーガーを\u3000買うんじゃった。\n\u3000こりゃ\u3000急がねば！": ""
  },
  "9465": {
    "「おぬしが\u3000キーエンブレムを\n\u3000６個以上\u3000集める日を\n\u3000わしは\u3000心待ちにしておるからな～。": ""
  },
  "9466": {
    "「……見つけたぞ\u3000エテーネの民の生き残りよ。": ""
  },
  "9467": {
    "「貴様たちは\u3000危険な存在……\n\u3000ひとりたりとも\u3000生かしてはおけぬ……。": ""
  },
  "9468": {
    "「……ずいぶん\u3000うなされていたのう。": ""
  },
  "9469": {
    "「なにか悪い夢でも\u3000見ていたようじゃが\n\u3000よかったら\u3000このジジイに\u3000聞かせてくれんか？": ""
  },
  "9470": {
    "<pc>は\u3000賢者ホーローに\n夢の内容を\u3000語った。": ""
  },
  "9471": {
    "「……なるほどのう。\n\u3000夢の中で\u3000ネルゲルが\u3000そんなことを……。": ""
  },
  "9472": {
    "「どうやら\u3000事態は\u3000思っていた以上に\n\u3000シリアスかつ\u3000デンジャーなようじゃな。\n\u3000こりゃ\u3000ノンビリしておれん！": ""
  },
  "9473": {
    "「次は～\u3000アズラン～\u3000アズラン～。\n\u3000お降りのお客さまは\u3000お忘れ物のなきよう\n\u3000今一度\u3000ご確認の上\u3000ご降車ください。": ""
  },
  "9475": {
    "「……おっと\u3000しかし\u3000メギストリスの都駅では\u3000\n\u3000名物のメギス鶏のからあげを\u3000買うんじゃった。\n\u3000今は\u3000そちらが\u3000先決じゃ！": ""
  },
  "9476": {
    "「おぬしは\u3000一刻も早く\n\u3000キーエンブレムを\u3000６個以上集めるのじゃぞ。\n\u3000わしは\u3000わしで\u3000準備を進めておくからな。": ""
  },
  "9477": {
    "「……ほっほう。\n\u3000これは\u3000これは……。": ""
  },
  "9478": {
    "「またまた\u3000会ったのう\u3000<pc>。\n\u3000アストルティアに\u3000知らぬことなし！\n\u3000ご存知\u3000放浪の賢者\u3000ホーローじゃ。": ""
  },
  "9479": {
