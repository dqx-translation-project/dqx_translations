{
  "70990": {
    "「……<cs_pchero>さま。デモンシーサーを\n\u3000倒してくださったようですね。": ""
  },
  "70991": {
    "「それは……なんですか？": ""
  },
  "70992": {
    "「この盾の紋章は\u3000ラッカラン島の島主\n\u3000ゴーレック氏に仕える\u3000兵士である証……。\n\u3000私が持っていた盾と\u3000同じ作り……。": ""
  },
  "70993": {
    "「<cs_pchero>さま……。\n\u3000私は………………": ""
  },
  "70994": {
    "<center>……かつて\u3000私は\u3000ラッカランの\nゴーレック氏に仕える\u3000女兵士でした。": ""
  },
  "70995": {
    "<center>その頃\u3000私は\u3000同僚である\nランディという青年と\u3000婚約を交わしたばかりで\n共に暮らせる日を\u3000心待ちにしていました。": ""
  },
  "70996": {
    "<center>ですが\u3000任務で\u3000モリナラ大森林を訪れた際\n私たちは\u3000あのデモンシーサーに襲われたのです。": ""
  },
  "70997": {
    "「ランディ……ランディ……。\n\u3000お願い\u3000目を開けてちょうだい！\n\u3000ずっと一緒だって\u3000約束したじゃない……！": ""
  },
  "70998": {
    "「…………。": ""
  },
  "70999": {
    "「あなた\u3000ひとりを\u3000死なせたりしないわ。\n\u3000この世で\u3000結ばれないのなら\n\u3000せめて\u3000あの世で\u3000あなたと一緒に……": ""
  },
  "71000": {
    "「うぅ……っ。\n\u3000ひっく\u3000ひっく……。": ""
  },
  "71001": {
    "「……誰っ！？": ""
  },
  "71002": {
    "「あ\u3000あなたは……？\n\u3000どうして\u3000子供が\u3000こんな所に……？": ""
  },
  "71003": {
    "「ボ……ボク……。": ""
  },
  "71004": {
    "「ボク……帰らなくちゃいけなくて……。\n\u3000だけど\u3000追いだされちゃったから\n\u3000ひとりじゃ\u3000帰れなくて……。": ""
  },
  "71005": {
    "「……………………。": ""
  },
  "71006": {
    "「おねえちゃん\u3000ボクといっしょに\n\u3000帰ってくれないかな。おねえちゃんと\n\u3000いっしょなら\u3000ボク\u3000きっと帰れるから。": ""
  },
  "71007": {
    "「そしたら\u3000ボク……\u3000おねえちゃんの頼み\n\u3000どんなことでも\u3000きいてあげるから！": ""
  },
  "71008": {
    "「どんな……ことでも……？": ""
  },
  "71009": {
    "「……残念だけど\u3000少し\u3000遅かったみたいね。": ""
  },
  "71010": {
    "「もう呼びかけても\u3000返事をしないの。\n\u3000息も\u3000止まってしまった……。\n\u3000ランディは\u3000助からないのよ……。": ""
  },
  "71011": {
    "「おねえちゃんの\u3000願いは\n\u3000その人を\u3000助けることなんだね？\n\u3000じゃあ……すこし待ってて。": ""
  },
  "71012": {
    "「う……うぅ……。": ""
  },
  "71013": {
    "「ラ…ランディ！？": ""
  },
  "71014": {
    "「これで\u3000ボクといっしょに帰ってくれるよね？": ""
  },
  "71015": {
    "「あなたは………………。": ""
  },
  "71016": {
    "「ボクはね………………": ""
  },
  "71017": {
    "「……すべてを思いだしました。\n\u3000何が\u3000私を\u3000世告げの姫として\n\u3000動かしていたのか……。": ""
  },
  "71018": {
    "「……この盾は\u3000私の婚約者\u3000ランディの物。\n\u3000おそらく\u3000魔物に襲われた時に\n\u3000落としてしまったのでしょう。": ""
  },
  "71019": {
    "「ランディが\u3000その後\u3000どうしているのか……。\n\u3000気がかりですが\u3000私には\u3000まだ\n\u3000世告げの姫として\u3000成すべき任務があります。": ""
  },
  "71211": {
    "「この戦いさえ\u3000終わらせることができれば\n\u3000私は\u3000元の女兵士に戻れるでしょう。\n\u3000そうすれば\u3000また\u3000ランディと共に……。": ""
  },
  "71212": {
    "「これは\u3000決戦をひかえた\u3000<cs_pchero>さまへの\n\u3000はなむけであり\u3000私からの\u3000お礼でもあります。\n\u3000どうぞ\u3000お受け取りくださいませ。": ""
  },
  "71213": {
    "「……そろそろ\u3000メルエが\n\u3000<cs_pchero>さまの\u3000訪れを\n\u3000待っていることでしょう。": ""
  },
  "71214": {
    "「彼女もまた\u3000過去の記憶を失ったせいで\n\u3000心に\u3000迷いを抱えているのかもしれません。\n\u3000どうか\u3000よろしくお願いいたします。": ""
  }
}