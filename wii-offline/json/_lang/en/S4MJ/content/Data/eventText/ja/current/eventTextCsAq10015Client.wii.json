{
  "17218": {
    "「おお\u3000<pc>か！\u3000よく来てくれた。\n\u3000ヒメア様が\u3000そなたと\n\u3000アカシを\u3000呼んでいるのだ。": ""
  },
  "17219": {
    "「ちょうど\u3000アカシも来たようだな。\n\u3000さあ\u3000ふたりとも\u3000入るがよい。": ""
  },
  "17220": {
    "「<pc>\u3000そして\u3000アカシ……。\n\u3000よくぞ\u3000来てくれました。": ""
  },
  "17221": {
    "「……そなたたちと\u3000別れたあとで\n\u3000私も\u3000すこし\u3000考えてみたのです。": ""
  },
  "17222": {
    "「コハクが\u3000あのようなことにならなければ\n\u3000私たちは\u3000３００年前に\n\u3000ふたりだけの\u3000婚礼の儀を行うはずでした。": ""
  },
  "17223": {
    "「もしも\u3000そなたたちの言うとおり\n\u3000コハクが\u3000その約束を\u3000覚えているのなら……": ""
  },
  "17224": {
    "「コハクは\u3000私たちが\u3000誓いの盃を\n\u3000交わすはずだった\u3000約束の地……\n\u3000世界樹の丘へ\u3000向かったのかもしれません。": ""
  },
  "17225": {
    "「そなたたちの\u3000言葉を信じて\n\u3000私は\u3000世界樹の丘へ\u3000行きましょう。": ""
  },
  "17226": {
    "「<pc>。アカシ。そなたたちも\n\u3000ともに\u3000世界樹の丘に\u3000行ってくれますか？\n\u3000私たちの行く末を\u3000見届けてほしいのです。": ""
  },
  "17227": {
    "「<pc>さんが\u3000行くなら\n\u3000あたしも行きます！": ""
  },
  "17228": {
    "「ありがとう……\u3000礼を言います。": ""
  },
  "17229": {
    "「世界樹の丘は\u3000この村の\u3000東にある\n\u3000久遠の森を抜けた先です。\n\u3000すぐに\u3000出発しましょう。": ""
  },
  "17230": {
    "「私は\u3000先に\u3000世界樹の丘へ向かいます。\n\u3000そなたたちも\u3000準備ができたら\n\u3000すぐに\u3000来てください。": ""
  },
  "17231": {
    "「礼を言います\u3000<pc>。\n\u3000……しかし\u3000そなたのことを\n\u3000多くの者が\u3000必要としているようですね。": ""
  },
  "17232": {
    "「ならば\u3000そなたは\u3000その者たちの所へ\n\u3000行くべきでしょう。わざわざ\u3000呼び立てて\n\u3000すまないことをしましたね。 ": ""
  },
  "17233": {
    "「……そうですか。\n\u3000残念ですが\u3000そなたが\u3000そう言うのなら\n\u3000あきらめるほか\u3000ありませんね。": ""
  },
  "17234": {
    "「まあ……\u3000ふたりとも\n\u3000戻ってきてくれたのですね。": ""
  },
  "17235": {
    "「私は\u3000コハクが\u3000いることを信じ\n\u3000これより\u3000世界樹の丘へ\u3000行くつもりです。\n\u3000あの地は\u3000コハクとの\u3000約束の地なのです……。": ""
  },
  "17236": {
    "「<pc>……アカシ。そなたたちも\n\u3000ともに\u3000世界樹の丘に\u3000行ってくれますか？\n\u3000私たちの行く末を\u3000見届けてほしいのです。": ""
  },
  "17237": {
    "「キシャアアアアア！！": ""
  },
  "17238": {
    "「……思えば\u3000そなたと最初に出会ったのも \n\u3000この丘であったな。": ""
  },
  "17239": {
    "「あれから\u3000３００年…… \n\u3000時が流れ\u3000世が移ろいゆく中で\n\u3000私と\u3000そなたの時間だけが\u3000止まったままだ。": ""
  },
  "17240": {
    "「そのことが\u3000不幸なのかどうかさえ\n\u3000今の私には\u3000もはや\u3000わからぬ。\n\u3000ただ…………": ""
  },
  "17241": {
    "「永遠に思えた我が命も\u3000まもなく尽きるようだ。\n\u3000この世界樹が\u3000花をつけようとしている。": ""
  },
  "17242": {
    "「数百年に一度咲く\u3000世界樹の花……。\n\u3000花が咲くのを見届ければ\u3000我が役割は終わる。": ""
  },
  "17243": {
    "「未練はない。我が身が\u3000朽ちるのならば\n\u3000これもまた\u3000さだめ……。\n\u3000私は\u3000その前に\u3000なすべきことを果たすまでだ。": ""
  },
  "17244": {
    "「コハク。ともに逝こう。": ""
  },
  "17245": {
    "「その獣を殺されては\u3000困りますよ\u3000ヒメア様。\n\u3000私の貴重な\u3000研究材料でしてね。": ""
  },
  "17246": {
    "「きさま……まだ\u3000不老の術を欲するか……。": ""
  },
  "17247": {
    "「永遠の命は\u3000生きとし生ける者の\n\u3000共通の夢でしょう？\u3000いかなるリスクがあろうと\n\u3000手を出す価値は……\u3000む？ ": ""
  },
  "17248": {
    "「ウ……\u3000アア…………。": ""
  },
  "17249": {
    "「あぐっ！！": ""
  },
  "17250": {
    "「フウ……。フウ……。フウ……。": ""
  },
  "17251": {
    "「コハク……\u3000そなた……。": ""
  },
  "17252": {
    "「グオオオオオォーーーーン！！！": ""
  },
  "17253": {
    "「なぜ\u3000戻ってきた\u3000<cs_pchero>！\n\u3000今のコハクは\u3000怒りで\u3000我を忘れている！\n\u3000早く\u3000立ち去るのです！": ""
  },
  "17254": {
    "「グオオオオオーーーーン！！！ ": ""
  },
  "17255": {
    "「ウウウウウゥ……\u3000ググ……。": ""
  },
  "17256": {
    "「ヒ……………\u3000メ…ア……。": ""
  },
  "17257": {
    "「そなた……\u3000私の名を……。": ""
  },
  "17258": {
    "「私が\u3000わかるのか？\u3000コハク……。": ""
  },
  "17259": {
    "「グルアアアア！！": ""
  },
  "17260": {
    "「くっ…………。": ""
  },
  "17261": {
    "「そなたは\u3000私に……人としての幸福と\n\u3000生きることの意味を\u3000教えてくれた。": ""
  },
  "17262": {
    "「代わりに\u3000私は\u3000そなたに\n\u3000なにを与えられただろう？\n\u3000すべてを奪い\u3000３００年\u3000鎖につなぎ……。": ""
  },
  "17263": {
    "「長い間\u3000苦しめて\u3000すまなかった。\n\u3000せめて今\u3000我が手で\u3000黄泉へと送ろう。": ""
  },
  "17264": {
    "「誓いの盃……。": ""
  },
  "17265": {
    "「そなたは\u3000この丘で\u3000婚礼の儀を行う約束を\n\u3000忘れずにいてくれたのだな……。": ""
  },
  "17266": {
    "「今\u3000そなたとの約束を\u3000果たそう。": ""
  },
  "17267": {
    "「風よ。この盃に\u3000清めの酒を。": ""
  },
  "17268": {
    "「そして\u3000願わくば\u3000我らに祝福を……。": ""
  },
  "17269": {
    "「さあ\u3000コハク。これで我らも夫婦になれた。": ""
  },
  "17270": {
    "「ともに生きることが\u3000かなわぬのなら\n\u3000せめて\u3000ともに\u3000この世を去ろう。": ""
  },
  "17271": {
    "「私が死のうとも\u3000世界樹は\u3000じきに花をつける。\n\u3000この程度の自由は\u3000許されるだろう……。\n\u3000私にできる\u3000せめてもの\u3000つぐないだ。": ""
  },
  "17272": {
    "「ヒメア様！！\n\u3000そんな……\u3000やめてください！！": ""
  },
  "17273": {
    "「お\u3000男の決意を\u3000バカにすんじゃねえ！！": ""
  },
  "17274": {
    "「あの\u3000ラブレターにはなあ！\n\u3000男の一生分の\u3000すんげー覚悟が\u3000つまってんだ。\n\u3000アンタ\u3000そいつを踏みにじろうってのか！": ""
  },
  "17275": {
    "「オイラたちの夢を\u3000こわすってのか！": ""
  },
  "17276": {
    "「そうですよ……！\u3000コハクさんは\n\u3000こんな……\u3000ヒック……つぐないなんて\n\u3000望んでるわけないじゃないですか……！": ""
  },
  "17277": {
    "「死んじゃうなんて\u3000やめてください。\n\u3000ヒメア様\u3000お願いです……。\n\u3000ぜったい\u3000ぜったい\u3000やめてください……。": ""
  },
  "17278": {
    "「そなたたち……。": ""
  },
  "17279": {
    "「ヒ\u3000ヒメア様が\u3000いなくなったら……\n\u3000うっ\u3000うっ……。ひっく。": ""
  },
  "17280": {
    "「師は\u3000教えることよりも\n\u3000教えられることのほうが多いと言うが……\n\u3000本当に\u3000そうかもしれぬ。": ""
  },
  "17281": {
    "「学びの庭を作り\u3000子供たちに\n\u3000学問の道を開こうと言ったのは\n\u3000コハクだった……。": ""
  },
  "17282": {
    "「コハクよ\u3000見えるか……。": ""
  },
  "17283": {
    "「ともに生きることは\u3000かなわなかったが……\n\u3000ここに\u3000我らの子供たちがいるのだ。": ""
  },
  "17284": {
    "「ヒメア様……。": ""
  },
  "17285": {
    "「ツスクルの村へ\u3000帰りましょう。\n\u3000私は\u3000世界樹の守り手であり\n\u3000そなたたち学徒を導く\u3000母なのですから。": ""
  },
  "17286": {
    "「皆\u3000後で\u3000私の屋敷へ来てください。": ""
  },
  "17287": {
    "「やれやれ……。私は\u3000おいとましますよ。\n\u3000あんな\u3000不完全な禁術など\n\u3000私の美意識に\u3000そぐわないものでしてね。": ""
  },
  "17288": {
    "「よく\u3000来てくれましたね。": ""
  },
  "17289": {
    "「そなたたちへの\u3000感謝の気持ちとしては\n\u3000これでは\u3000足りないかもしれませんが……\n\u3000せめてもの礼として\u3000受け取ってください。": ""
  },
  "17290": {
    "「……この館からは\u3000学びの庭の様子が\n\u3000とても\u3000よく見えるのです。": ""
  },
  "17291": {
    "「走り回る子……\u3000転んで泣く子。\n\u3000木陰で\u3000本を読む子。\n\u3000食べてばかりいる子……。": ""
  },
  "17292": {
    "「皆\u3000私と\u3000コハクの子なのだと思った途端\n\u3000この世を去ることが\u3000悲しくなりました。": ""
  },
  "17293": {
    "「この残された命は\u3000学徒たちのために\n\u3000使うことにしましょう。\n\u3000最期まで\u3000皆の\u3000そばにおります。": ""
  },
  "17294": {
    "「コハクには\u3000もうしばらく\n\u3000黄泉の入り口で\u3000待っていてもらいましょう。\n\u3000きっと……\u3000彼も\u3000許してくれるでしょう。": ""
  }
}