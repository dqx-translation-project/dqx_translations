{
  "16295": {
    "「いつの間に入れ替わったのかは\u3000わからぬが\n\u3000先刻\u3000ガズバランの牙から\u3000わし宛てに\n\u3000１通の書状が\u3000届いたのじゃ。": ""
  },
  "16296": {
    "「書状の内容は\u3000以下のようなものでした。\n\u3000……ガートラント王族\u3000ゼラリム姫の身柄は\n\u3000我ら\u3000ガズバランの牙が\u3000あずかった。": ""
  },
  "16297": {
    "「姫の命が惜しくば\u3000捕らえられている\n\u3000牙のメンバーを\u3000全員\u3000解放したのち\n\u3000現王グロスナーは\u3000退位せよ！": ""
  },
  "16298": {
    "「……聞いてのとおりだ。\n\u3000一国の王として\u3000このような脅迫に\n\u3000屈するわけにはいかん。": ""
  },
  "16299": {
    "「だが\u3000ゼラリムは\u3000わしにとって\n\u3000ただひとりの肉親。あの子が\u3000今どうしているか\n\u3000思うだけで\u3000わしの胸は\u3000張り裂けそうじゃ。": ""
  },
  "16300": {
    "「今すぐ\u3000兵を率い\u3000姫を救いだしたいところだが\n\u3000そんなことをすれば\u3000ヤツらに感づかれて\n\u3000いたずらに\u3000姫の命を危険に\u3000さらすだけ……。": ""
  },
  "16301": {
    "「そこでじゃ！\u3000今回は\u3000お前さんに\n\u3000ゼラリム姫の救出を\u3000頼みたい。\n\u3000……もちろん\u3000秘密裏にじゃぞ。": ""
  },
  "16302": {
    "「失敗の許されない\u3000重大な使命じゃ。\n\u3000引き受けてくれるか\u3000<pc>？": ""
  },
  "16303": {
    "「よく言ってくれた\u3000<pc>！\n\u3000お前さんならば\u3000きっと\u3000無事に\n\u3000姫を救いだしてくれると\u3000信じておるぞ。": ""
  },
  "16304": {
    "「問題は\u3000兵を使って\u3000捜索させるわけにも\n\u3000いかないため\u3000姫が\u3000どこに囚われているか\n\u3000わからぬことじゃが……": ""
  },
  "16305": {
    "「そうじゃな。ガズバランの剣に\n\u3000くわしい者ならば\u3000何か知っているかもしれん。\n\u3000まずは\u3000そういう者を探してくれ。": ""
  },
  "16306": {
    "「おお\u3000引き受けてくれるか！\n\u3000……だが\u3000お前さん\u3000どうやら\u3000多くの\n\u3000頼まれごとを\u3000引き受けているようじゃな。": ""
  },
  "16307": {
    "「ゼラリム姫の命が\u3000かかっておる以上\n\u3000そんな\u3000いいかげんなことでは困る。\n\u3000さっさと\u3000片付けてくるのじゃ！": ""
  },
  "16308": {
    "「ここで\u3000断るとか\u3000ありえんじゃろう！\n\u3000しっかりしろ\u3000<pc>よ！": ""
  },
  "16309": {
    "「まさか\u3000この場所が\u3000見つかるとは\n\u3000思いませんでしたよ。\n\u3000なかなか\u3000優秀ですな\u3000<cs_pchero>さん。": ""
  },
  "16310": {
    "「あなたの目的は\u3000わかってますよ。\n\u3000この人形……\u3000本物のゼラリム姫を\n\u3000助けだしに\u3000来たのでしょう？": ""
  },
  "16311": {
    "「……ですが\u3000真正面から\u3000乗り込んでくるのは\n\u3000いただけませんね。\n\u3000こうなるとは\u3000思わなかったのですか？": ""
  },
  "16312": {
    "「ほ～ら\u3000ほ～ら。もう\u3000動けない♪": ""
  },
  "16313": {
    "「帰って\u3000グロスナー王に伝えなさい。\n\u3000姑息なマネなどしないで\u3000いさぎよく\n\u3000玉座から\u3000退くようにとね！": ""
  },
  "16314": {
    "「<cs_pchero>くんっ\u3000目を閉じたまえっ！！": ""
  },
  "16315": {
    "「……フウ\u3000フウ。\n\u3000ガートラント兵士団\u3000支給品の閃光玉は\n\u3000なかなかの威力だろう？": ""
  },
  "16316": {
    "「謹慎中の身だが\u3000どうにも\n\u3000じっとしていられなくてね。\n\u3000気がついたら\u3000ここまで来てしまったよ。": ""
  },
  "16317": {
    "「さあ\u3000姫は\u3000救いだした！\n\u3000あとは\u3000王家にたてつく\u3000不届き者どもを\n\u3000退治するのみだぞ\u3000<cs_pchero>くん！": ""
  },
  "16318": {
    "「き\u3000貴様は\u3000スピンドル！\n\u3000……そうか。このアジトの場所は\n\u3000お前が\u3000教えたというわけか？": ""
  },
  "16319": {
    "「ガズバランの剣では\u3000新米だった貴様が……\u3000\n\u3000よくよく\u3000私の邪魔をしてくれるな。": ""
  },
  "16320": {
    "「やはり\u3000それを知っているのか。\n\u3000どこか見覚えのある\u3000その容姿……\n\u3000キミは\u3000ゼクセン兵士長の血縁なのだな？": ""
  },
  "16321": {
    "「血縁だと？\u3000私は\u3000天涯孤独の身。\n\u3000子を持った覚えはないし\u3000兄弟もおらぬ。\n\u3000クックック……。": ""
  },
  "16322": {
    "「ここまで言っても\u3000わからぬか\u3000スピンドル？\n\u3000私に言わせれば\u3000見る影もなく\u3000ブクブク太った\n\u3000お前のほうが\u3000よほど\u3000別人に見えるがな。": ""
  },
  "16323": {
    "「バ\u3000バカな！？\n\u3000お前が\u3000ゼクセン兵士長のはずない！\n\u3000あの人は\u3000私より\u3000１０才は年上なのだぞ。": ""
  },
  "16324": {
    "「クックック……。王国を追放された後も\n\u3000私は\u3000ひたすらに\u3000自身を\u3000きたえつづけた。\n\u3000強さこそが\u3000オーガの価値だと信じてな。": ""
  },
  "16325": {
    "「だが\u3000いくら\u3000きたえあげようとも\n\u3000肉体は\u3000時とともに\u3000老いおとろえていく。": ""
  },
  "16326": {
    "「自らの\u3000おとろえに気づいた私は\u3000絶望した。\n\u3000このまま\u3000年老いて\u3000世間を見返すこともできず\n\u3000ひっそりと\u3000死んでいくのかと……。": ""
  },
  "16327": {
    "「そこに現れたのが\u3000このピュージュだ！\n\u3000彼のおかげで\u3000私は\u3000若き肉体と\n\u3000さらなる強さを\u3000手に入れることができた。": ""
  },
  "16328": {
    "「……そう。人を超える存在としての強さをな。": ""
  },
  "16329": {
    "「はいは～い。\n\u3000それじゃあ\u3000いってみよ～か♪": ""
  },
  "16330": {
    "「見よ\u3000この無敵の肉体をっ！\n\u3000このチカラがあれば\u3000人質などなくとも\n\u3000我が復讐は\u3000果たされるだろう。": ""
  },
  "16331": {
    "「ガズバランの剣を\u3000解散に追い込み\n\u3000私を追放した\u3000グロスナーに……\n\u3000ガートラントに\u3000思い知らせてくれるっ！！": ""
  },
  "16332": {
    "「<cs_pchero>！\n\u3000私は\u3000姫様の御身を\u3000守らねばならぬ。\n\u3000この戦いは\u3000キミにまかせるぞ！": ""
  },
  "16333": {
    "「フウ\u3000フウ……\u3000<cs_pchero>。\n\u3000わ\u3000私は\u3000姫様を守らねば……ならん。\n\u3000後のこと……\u3000ま\u3000まかせるぞ……。": ""
  },
  "16334": {
    "「何度\u3000来ようとも\u3000結果は同じ。\n\u3000人を超える存在となった私に\n\u3000人たる身で\u3000かなうものか。": ""
  },
  "16335": {
    "「このチカラがあれば\u3000グロスナーに……\n\u3000ガートラントに\u3000思い知らせてやれる。\n\u3000今こそ\u3000復讐のときは来たのだっ！！": ""
  },
  "16336": {
    "「グォォ……お\u3000おのれぇ……。\n\u3000人を超えた存在である私が\n\u3000や\u3000敗れるはずが……。": ""
  },
  "16337": {
    "「ピュージュっ！！\n\u3000もっと……チカラをくれ！\u3000もっとだ！": ""
  },
  "16338": {
    "「私は……誰よりも\u3000強くあって\n\u3000ガズバランの剣の思想が\u3000正しいことを\n\u3000証明……せねば\u3000ならんのだぁっ！！": ""
  },
  "16339": {
    "「もう\u3000やめてください\u3000ゼクセン兵士長！": ""
  },
  "16340": {
    "「ガズバランの剣が\u3000目指していたものは\n\u3000そんな\u3000魔物のチカラに頼った\n\u3000まがい物の強さでは\u3000なかったはずです！": ""
  },
  "16341": {
    "「私は……今の地位に\u3000あぐらをかいて\n\u3000修練をおこたり\u3000かつてのチカラを失いました。": ""
  },
  "16342": {
    "「どうして\u3000こうなってしまったんだろうと\n\u3000毎日\u3000そんなことを\u3000考えるばかりで……。\n\u3000まったく\u3000情けないかぎりです。": ""
  },
  "16343": {
    "「ですが\u3000そんな\u3000私でも\n\u3000デルタニス王子が\u3000生前\u3000言っておられた\n\u3000この教えだけは\u3000忘れていません！": ""
  },
  "16344": {
    "「ガズバランの剣が目指す\u3000強さとは\n\u3000ただ\u3000敵に勝てればいいというものではない。\n\u3000おのれの心に勝つ\u3000本当の強さだ……と。": ""
  },
  "16345": {
    "「あなたの強さは\u3000ガズバランの剣が\n\u3000求めたものではない！\u3000復讐者が振るう\n\u3000毒のぬられた\u3000凶刃のようなものです！": ""
  },
  "16346": {
    "「……デルタニスの言葉だ……と？\n\u3000ガ\u3000ガズバランの剣は……\u3000私は……。": ""
  },
  "16347": {
    "「がっ！！\u3000……をぉぉぉぉ。": ""
  },
  "16348": {
    "「身体が……\u3000身体が\u3000燃えるように熱い。": ""
  },
  "16349": {
    "「あ～あ。もう\u3000限界が来ちゃったか♪\n\u3000意外と\u3000早かったね。": ""
  },
  "16350": {
    "「ゼクセンくんの身体が\u3000ボクのあげた魔力に\n\u3000耐えられなくなっちゃったんだよ。\n\u3000とーぜん\u3000もっと強くするとか\u3000ムリだから♪": ""
  },
  "16351": {
    "「ぐっ……。ピュージュ\u3000貴様っ……。": ""
  },
  "16352": {
    "「な～に\u3000そのウラミがましい目は？\n\u3000これまで\u3000さんざん\u3000協力してあげたのに\n\u3000そんな態度取られると\u3000キズつくな～。": ""
  },
  "16353": {
    "「でも\u3000まあ\u3000いいヒマつぶしには\u3000なったよ。\n\u3000おかげで\u3000ガートラントを混乱させろって\n\u3000あの方の命令も\u3000じゅーぶん果たせたしね♪": ""
  },
  "16354": {
    "「それじゃ\u3000ボクは\u3000そろそろ失礼するよ♪": ""
  },
  "16355": {
    "「……ああ\u3000<cs_pchero>くん。\n\u3000キミのことは\u3000よ～く覚えておくよ。\n\u3000いつか\u3000また\u3000遊ぼうね～♪": ""
  },
  "16356": {
    "「クッ……ククククク。\n\u3000アーッハッハッハッ……。": ""
  },
  "16357": {
    "「ゼ\u3000ゼクセン兵士長！？": ""
  },
  "16358": {
    "「……これが\u3000笑わずにいられようか。\n\u3000魔物のチカラまで……借りて\n\u3000復讐に……走った挙句が\u3000このザマだ。": ""
  },
  "16359": {
    "「スピンドル\u3000<cs_pchero>。\n\u3000どうか\u3000グロスナー王に……伝えてくれ。": ""
  },
  "16360": {
    "「私の復讐は\u3000実体のない……ハリボテだったが\n\u3000今のままのガートラントでは\u3000いずれまた\n\u3000剣の遺志を継ぐ者が……現れよう。": ""
  },
  "16361": {
    "「そのこと\u3000ゆめゆめ\u3000お忘れなきように\n\u3000……と。": ""
  },
  "16362": {
    "「ゼクセン兵士長\u3000あなたは……。": ""
  },
  "16363": {
    "「あのう……\u3000ここは\u3000どこなのでしょう？": ""
  },
  "16364": {
    "「<cs_pchero>さまには\n\u3000いろいろ\u3000ご迷惑をおかけしてしまったようで\n\u3000本当に\u3000申し訳ありませんでした。": ""
  },
  "16365": {
    "「まさか\u3000あのチョコ神ぬいぐるみが\n\u3000そのような\u3000恐ろしい企みに\n\u3000利用されていたなんて……。": ""
  },
  "16366": {
    "「それでは\u3000私は\u3000ひと足先に\n\u3000姫を城まで\u3000お送りさせていただく。": ""
  },
  "16367": {
    "「<cs_pchero>くんも\u3000できるだけ早く\n\u3000戻ってくれたまえ。": ""
  },
  "16368": {
    "「お前さんの活躍は\u3000すでに\n\u3000スピンドルから\u3000聞いておるぞ。\n\u3000よくやってくれたな\u3000<pc>！": ""
  },
  "16369": {
    "「思えば\u3000一連のガズバランの牙事件では\n\u3000最初から\u3000<pc>の世話に\n\u3000なりっぱなしであったな。": ""
  },
  "16370": {
    "「感謝の気持ちには\u3000とても足りぬが\n\u3000せめてもの\u3000礼の品じゃ。受け取ってくれ。": ""
  },
  "16371": {
    "「ピュージュを逃がしたのは\u3000残念だが\n\u3000姫は無事に戻り\u3000ガズバランの牙は壊滅。\n\u3000……よろこばしいこと\u3000この上ないな。": ""
  },
  "16372": {
    "「グロスナー王！\n\u3000どうか\u3000前兵士長ゼクセンの最期の言葉を\n\u3000お忘れなきように。": ""
  },
  "16373": {
    "「今のままのガートラントでは\u3000いずれまた\n\u3000ガズバランの剣の遺志を継ぐ者が\u3000現れる……\n\u3000私には\u3000ただの妄言とは\u3000思えませぬ。": ""
  },
  "16374": {
    "「……そうであったな。ピュージュが言い残した\n\u3000あの方とやらの\u3000存在も気になるし\n\u3000よろこんでばかりも\u3000おられぬか。": ""
  },
  "16375": {
    "「思えば\u3000この国は\u3000平和に慣れきってしまい\n\u3000それを\u3000ゆるぎないものとするための努力を\n\u3000おこたっていたのかもしれぬ。": ""
  },
  "16376": {
    "「この国を\u3000治める者として\n\u3000ゼクセンの言葉\u3000しかと\u3000胸に刻んでおこう！": ""
  },
  "45129": {
    "「ぐっ……ぐおぉぉぉぉぉ……。": ""
  }
}