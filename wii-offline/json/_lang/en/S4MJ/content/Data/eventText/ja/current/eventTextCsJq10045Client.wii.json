{
  "14159": {
    "「待たせたな。来たぜ～\u3000ガウラド。": ""
  },
  "14160": {
    "「<cs_pchero>殿も\u3000来たのですか。\n\u3000いいでしょう。歓迎いたしますよ。": ""
  },
  "14161": {
    "「で\u3000なんの用なんだ？\n\u3000お小言なら\u3000もう聞きたくないぜ。\n\u3000マジメに\u3000やってるだろ\u3000オレ。": ""
  },
  "14162": {
    "「お別れです\u3000ヤーン様。": ""
  },
  "14163": {
    "「は？\u3000何を言ってるんだ\u3000ガウラド。": ""
  },
  "14164": {
    "「超天道士の名を持つ者と\n\u3000やっと\u3000闘える日が来ました。": ""
  },
  "14165": {
    "「私が\u3000あなたを殺します。": ""
  },
  "14166": {
    "「おいおい。お前の\u3000じょうだんは\n\u3000相変わらず\u3000つまんねえなあ。\n\u3000もっと\u3000笑えるのにしろよ。": ""
  },
  "14167": {
    "「超天道士を名乗る者を殺し\n\u3000その名に宿りし\u3000チカラを得る……。\n\u3000それが\u3000この私の使命……。": ""
  },
  "14168": {
    "「お前……。": ""
  },
  "14169": {
    "<pipipi_mid>「超天道士を倒すため\u3000魔界より訪れた使者。\n\u3000武闘魔ガウラド……それが\u3000私の本当の姿だ。": ""
  },
  "14170": {
    "「だが\u3000なんということか……。\n\u3000私が目的を果たさんとしたとき\u3000超天道士は\n\u3000病に冒され\u3000死を目前としていたのだ。": ""
  },
  "14171": {
    "「そんな\u3000おとろえた超天道士を倒しても\n\u3000チカラを得ることなど\u3000できぬ！\n\u3000私が倒すのは\u3000完全なる超天道士でなくてはっ！": ""
  },
  "14172": {
    "「だから\u3000待ったのだ。\n\u3000超天道士の名を継ぐ者が現れる\u3000その日を！\n\u3000貴様を倒せば\u3000私の使命は果たされるのだ！！": ""
  },
  "14173": {
    "「くだらねえ……。\n\u3000そんなことのために\u3000お前は\u3000これまで\n\u3000オレの世話をしてきたっていうのか？": ""
  },
  "14174": {
    "「ヤーン！\u3000超天道士の名を継ぐ者よ！\n\u3000さあ\u3000私と闘え！\n\u3000そして\u3000そのチカラをよこせ！": ""
  },
  "14175": {
    "「イヤだね。オレは\u3000お前の相手なんか\n\u3000これっぽっちも\u3000する気ね～よ。": ""
  },
  "14176": {
    "「超天道士の名を継ぐ者が\u3000逃げるのか！？": ""
  },
  "14177": {
    "「ちげ～っつーの。お前なんかじゃ\n\u3000オレの相手にならね～って\u3000言ってるんだよ。": ""
  },
  "14178": {
    "「……そうだな。コイツに勝てたら\n\u3000お前の相手をしてやっても\u3000いいぜ。": ""
  },
  "14179": {
    "「<cs_pchero>\u3000悪いが頼むぜ。\n\u3000アンタの闘いを\u3000見せてやってくれよ。": ""
  },
  "14180": {
    "「ガウラド。お前じゃ\u3000<cs_pchero>を\n\u3000倒すなんて\u3000できね～と思うぜ。": ""
  },
  "14181": {
    "「<cs_pchero>を倒せば\u3000貴様が\n\u3000この私と闘うと\u3000いうのだな……。\n\u3000その言葉に\u3000いつわりはないな？": ""
  },
  "14182": {
    "「<cs_pchero>よ。まずは貴様からだ。\n\u3000さあ\u3000私の使命のため\u3000消えるがいい！！": ""
  },
  "14183": {
    "「まさか……。超天道士の名を持たぬ者に\n\u3000この私が\u3000敗れる……だと！？\u3000": ""
  },
  "14184": {
    "「名前に\u3000チカラが宿るわけじゃない。\n\u3000お前がしてることには\u3000なんの意味もね～よ。": ""
  },
  "14185": {
    "「超天道士の名なんか\u3000継いでなくても\n\u3000<cs_pchero>は\u3000こんだけ\u3000強いんだぜ。": ""
  },
  "14186": {
    "「だが\u3000私は\u3000超天道士を倒さねば……。\n\u3000使命を果たさねば\u3000魔界へ帰ることはできぬ！": ""
  },
  "14187": {
    "「私と……。私と闘え\u3000ヤーン！！": ""
  },
  "14188": {
    "「わかった。オレが相手をしてやる。": ""
  },
  "14189": {
    "「フフ……。なんという強さ……。\n\u3000さすが\u3000超天……道士……の……。": ""
  },
  "14190": {
    "「なあ\u3000ガウラド……。オレと\u3000お前はさ。\n\u3000ずいぶん長く\u3000一緒に暮らしてたよな。\n\u3000わがままも\u3000たくさん\u3000言ったっけなあ……。": ""
  },
  "14191": {
    "「じ～さんが死んだ後も\u3000お前がオレの世話を\n\u3000焼いてくれたのは\u3000そんな\u3000くだらない\n\u3000使命のためだけじゃ\u3000なかったんだろ？": ""
  },
  "14192": {
    "「なのに\u3000なぜ\u3000いつまでも\n\u3000そんな使命に\u3000こだわってさ……。\n\u3000こんなことをしたんだよ……。\u3000": ""
  },
  "14193": {
    "「貴様には\u3000わかるまい……。\n\u3000魔界に生きる者に\u3000課せられた使命の重さを。": ""
  },
  "14194": {
    "「だが……。だが\u3000なぜ私は\n\u3000その使命を果たさねば\u3000ならなかったのか……。\n\u3000今となっては\u3000もう覚えておらぬ……。": ""
  },
  "14195": {
    "「いつからか\u3000私は\u3000理由もなく\n\u3000ただ\u3000与えられた使命を果たすためだけに\n\u3000生きてきたように思える……。": ""
  },
  "14196": {
    "「……使命のことは\u3000もう忘れちまえ。\n\u3000そして\u3000ゆっくり眠れば\u3000いいさ。": ""
  },
  "14197": {
    "「せめて\u3000最期は……。あなたの知る姿で……。": ""
  },
  "14198": {
    "「私は\u3000使命を果たすことに囚われ……。\n\u3000安息の日など\u3000一日たりとも\n\u3000訪れることはなかった……。": ""
  },
  "14199": {
    "「ただ……なぜか……\n\u3000あなたと共に暮らした日々は……。": ""
  },
  "14200": {
    "「とても\u3000楽しかっ……た……。": ""
  },
  "14201": {
    "「ヤーン……様……。": ""
  },
  "14202": {
    "「…………。": ""
  },
  "14203": {
    "「中に\u3000コレが入ってたよ。\n\u3000武闘家の証……って\u3000言われてるヤツだ。": ""
  },
  "14204": {
    "「超天道士が死ぬ間際に\u3000オレに渡せと言って\n\u3000ガウラドのヤツに\u3000あずけたらしいぜ。\n\u3000この手紙に\u3000そう書いてあったよ……。": ""
  },
  "14205": {
    "「大事に\u3000持ってやがったんだなあ。\n\u3000アイツの使命とは\u3000関係ないモノだろうに。": ""
  },
  "14206": {
    "「……なあ\u3000<cs_pchero>。\n\u3000突然だけどさ。オレと勝負してくれよ。\n\u3000確かめたいことが\u3000あるんだ。": ""
  },
  "14207": {
    "「アンタと拳を交えれば\u3000きっと\n\u3000その答えが\u3000わかるはずなんだよ。": ""
  },
  "14208": {
    "「本格的に\u3000コロシアムで\u3000やろうぜ。\n\u3000そこの関係者の\u3000グララってオーガの女に\n\u3000もう\u3000話をつけてあるんだ。": ""
  },
  "14209": {
    "「オレは\u3000ジュレットの町に\u3000ヤボ用がある。\n\u3000アンタは\u3000先に\u3000ラッカラン島の\n\u3000コロシアムに\u3000行っててくれないか。": ""
  },
  "14210": {
    "「<cs_pchero>\u3000今度は\u3000イケるよな。\n\u3000これまでの修行を\u3000思いだせばいいんだ。\n\u3000アンタなら\u3000勝てるはずだぜ。": ""
  },
  "14211": {
    "「ヤーン。まだ貴様は\u3000闘おうとしないのか？\n\u3000私の使命は\u3000超天道士の名を持つ貴様を\n\u3000倒さぬ限り\u3000果たされぬのだ！": ""
  },
  "14212": {
    "「<cs_pchero>は\u3000まだ\u3000負けてね～よ。\n\u3000お前の前で\u3000倒れてるか？\n\u3000立ちあがって\u3000闘おうとしてるだろ？": ""
  },
  "14213": {
    "「……相変わらず\u3000クチの減らない男だ。\n\u3000よかろう。ならば\u3000今度は完全に\n\u3000たたきつぶしてくれるわっ！": ""
  },
  "14214": {
    "「よく来てくれた～\u3000<cs_pchero>。\n\u3000ここなら\u3000ジャマも入らないだろ？": ""
  },
  "14215": {
    "「アンタと\u3000拳を交えれば\n\u3000オレが確かめたいことの\u3000答えが出るんだ。\n\u3000だから\u3000手加減とかは\u3000ナシにしてくれよ。": ""
  },
  "14216": {
    "「……もう\u3000言葉は\u3000いらないよな。\n\u3000あとは\u3000拳で語り合おうぜ。": ""
  },
  "14217": {
    "「いくぞ～\u3000<cs_pchero>！": ""
  },
  "14218": {
    "「<cs_pchero>……。アンタなら\n\u3000また来てくれると\u3000思ってたぜ～。": ""
  },
  "14219": {
    "「勝負は\u3000まだ\u3000ついてないよな？\n\u3000<pc>の本気を\u3000オレは\n\u3000まだ\u3000見せてもらってないぜ～。": ""
  },
  "14220": {
    "「今度は\u3000見せてくれよ～。\n\u3000<cs_pchero>の\u3000本気の拳をな！！": ""
  },
  "14221": {
    "「ははっ\u3000強いなあ～\u3000<cs_pchero>。\n\u3000超天道士の名を継いだオレが\u3000負けちまったよ。": ""
  },
  "14222": {
    "「だが\u3000ずっと\u3000確かめたかったことが\n\u3000アンタと闘って\u3000やっと\u3000わかった。\n\u3000それが\u3000なんなのか\u3000聞いてくれるか。": ""
  },
  "14223": {
    "「……オレが\u3000じ～さんに弟子入りしたのは\n\u3000超天道士って名が\u3000欲しかったからじゃない。\n\u3000その強さに\u3000あこがれたからだ。": ""
  },
  "14224": {
    "「その名を継がなくても\u3000超天道士を超える強さを\n\u3000身につけられると\u3000オレは信じていた。": ""
  },
  "14225": {
    "「だから\u3000ずっと\u3000名を継ぐことを避けてたのさ。\n\u3000本気のじ～さんと闘って\u3000勝つ日が来るまで\n\u3000……と思ってな。": ""
  },
  "14226": {
    "「なのに\u3000じ～さんは\u3000死んじまった……。": ""
  },
  "14227": {
    "「……本当はさ。超天道士の名を継いだ\n\u3000アンタと闘って\u3000勝つつもりだったんだ。\n\u3000それが\u3000逆になっちまったってわけさ。": ""
  },
  "14228": {
    "「だが\u3000超天道士の名を継いだ\u3000このオレを\n\u3000アンタが\u3000超えてみせてくれた。": ""
  },
  "14229": {
    "「名前が強さを\u3000もたらすわけじゃない。\n\u3000強さってのは\u3000人に宿るってことが\n\u3000やっと\u3000確かめられたよ……。": ""
  },
  "14230": {
    "「よし……っと。\n\u3000<cs_pchero>のおかげで\n\u3000いろいろと\u3000ふっきれたぜ。": ""
  },
  "14231": {
    "「超天道士の名は\u3000今やオレの身体の一部だ。\n\u3000この名と共に\u3000オレは生きていくよ。": ""
  },
  "14232": {
    "「<cs_pchero>～！\n\u3000アンタとの勝負は\u3000本当に楽しかったぜ。": ""
  },
  "14233": {
    "「アンタは\u3000いい武闘家になるよ。\n\u3000超天道士のように\u3000伝説に名を残す\n\u3000そんな\u3000すげえ武闘家だ。": ""
  },
  "14234": {
    "「このオレが\u3000言うんだ。\n\u3000絶対に\u3000まちがいね～って！": ""
  },
  "14235": {
    "「オレに勝ったんだからな。\n\u3000コレは\u3000アンタに受け取ってほしい。\n\u3000ガウラドの置いていった\u3000武闘家の証だ。": ""
  },
  "14236": {
    "「その武闘家の証は\u3000いつか\u3000オレが\n\u3000証に\u3000ふさわしい男になる日まで\n\u3000アンタに\u3000あずけておくよ。": ""
  },
  "14237": {
    "「勝者への\u3000ごほうびだ。\n\u3000コレを\u3000アンタに贈らせてもらおう。": ""
  },
  "14238": {
    "「オレも\u3000超天道士の名に恥じない\n\u3000武闘家にならなきゃ\u3000いけね～からな。\n\u3000もっと\u3000修行に\u3000はげむことにする。": ""
  },
  "14239": {
    "「今度\u3000闘うことがあったら\u3000絶対に負けないぜ。\n\u3000超天道士の名に\u3000かけてな！": ""
  },
  "14240": {
    "「じゃあ\u3000またな\u3000<cs_pchero>！": ""
  },
  "41978": {
    "「…………。": ""
  }
}