{
  "16377": {
    "「あっ\u3000<pc>！\n\u3000もうレベル３０以上の\u3000パラディンに\n\u3000なっているのだ！\u3000すごいのだ～！": ""
  },
  "16378": {
    "「おおっ\u3000ズーボー。\n\u3000いいところに来てくれた！": ""
  },
  "16379": {
    "「お前も\u3000一緒に行ってくれんか？\n\u3000<pc>に\u3000マグナスさまの愛犬を\n\u3000散歩させる任務を\u3000依頼したんだが……。": ""
  },
  "16380": {
    "「犬の散歩？\n\u3000それなら\u3000オイラにも\u3000まかせてほしいのだ！": ""
  },
  "16381": {
    "「この国の重鎮\u3000マグナスさまの愛犬を\n\u3000おあずかりするのだから\n\u3000細心の注意を払って\u3000散歩にあたるように！": ""
  },
  "16382": {
    "「まずは\u3000２階の\u3000マグナスさまの部屋へ\n\u3000愛犬マリーを\u3000迎えにいってくれ。頼んだぞ！": ""
  },
  "16383": {
    "「<pc>。マグナスさまの部屋へ行くには\n\u3000この部屋のとなりの\u3000兵士詰所のそばにある\n\u3000階段を使うと\u3000近いのだ。": ""
  },
  "16384": {
    "「オイラ\u3000先に\u3000マグナスさまの部屋に\n\u3000行っているのだ！\n\u3000<pc>も\u3000来るのだ！": ""
  },
  "16385": {
    "「あああっ\u3000待つのだ！！": ""
  },
  "16386": {
    "「もうっ！\u3000ズーボーさんが\n\u3000ちゃんと見てないから\u3000マリーちゃんが\n\u3000逃げちゃったじゃないですかっ！": ""
  },
  "16387": {
    "「マリーちゃんに\u3000何かあったら\n\u3000しかられるのは\u3000私なんですからねっ！\n\u3000絶対に\u3000ケガなんて\u3000させないでくださいよっ！": ""
  },
  "16388": {
    "「だ…大丈夫なのだ\u3000ピチョン！\n\u3000オイラたちに\u3000まかせるのだ！": ""
  },
  "16389": {
    "「じゃあ\u3000頼みましたからねっ！": ""
  },
  "16390": {
    "「あっという間に\u3000消えるなんて\u3000マリーちゃんは\n\u3000よっぽど\u3000外に出たかったのだ！": ""
  },
  "16391": {
    "「マリーちゃんを\u3000城の外へ出さないように\n\u3000１階の出入り口にいる衛兵に\u3000頼んでくるのだ。\n\u3000<pc>は\u3000マリーちゃんを探すのだ！": ""
  },
  "16392": {
    "「どうしたの？\u3000マリーちゃんなら\n\u3000まだ\u3000帰ってきていませんよ。": ""
  },
  "16393": {
    "「あの子ったら\u3000やんちゃで手がつけられないの。\n\u3000この前も\u3000散歩中に逃げだして\n\u3000城下町の外まで\u3000行っちゃったらしいし。": ""
  },
  "16394": {
    "「とにかく\u3000早く\u3000マリーちゃんを見つけて\n\u3000ちゃんと散歩させてきてくださいね！": ""
  },
  "16395": {
    "「はあはあ……。\n\u3000やっと\u3000マリーちゃんを\u3000捕まえたのだ！": ""
  },
  "16396": {
    "「わんっ\u3000わんっ！": ""
  },
  "16397": {
    "「うん？\n\u3000どうしたのだ\u3000マリーちゃん？": ""
  },
  "16398": {
    "「わんっ\u3000わんっ\u3000わんっ！": ""
  },
  "16399": {
    "「そうか！\n\u3000マリーちゃんは\u3000いっぱい\u3000走りたいのだな！\n\u3000ようし！\u3000じゃあ\u3000追いかけっこするのだ！！": ""
  },
  "16400": {
    "「<pc>！\n\u3000ギルザッド地方まで\u3000競争するのだ！！\n\u3000この坂を下りて\u3000道沿いに\u3000南東へ走るのだ！！": ""
  },
  "16401": {
    "「く～ん\u3000く～ん。": ""
  },
  "16402": {
    "「はあはあ……\u3000くたびれたのだ。\n\u3000先に\u3000着いてるとは\n\u3000さすが\u3000<pc>なのだ。": ""
  },
  "16403": {
    "「マリーちゃん\u3000とっても\u3000楽しそうなのだ！\n\u3000きっと\u3000ここに友達がいるから\n\u3000城の外に\u3000出たかったのだ。": ""
  },
  "16404": {
    "「わんっ\u3000わんっ！": ""
  },
  "16405": {
    "「帰りたいって\u3000言ってるみたいなのだ。\n\u3000きっと\u3000満足したのだ！": ""
  },
  "16406": {
    "「マリーちゃん。\n\u3000ここに来たければ\u3000オイラが\u3000いつでも\n\u3000連れてきてあげるのだ。": ""
  },
  "16407": {
    "「だから\u3000ひとりで来ちゃいけないのだ。\n\u3000魔物に襲われて\u3000ケガでもしたら\n\u3000マグナスさまが\u3000悲しむのだ。": ""
  },
  "16408": {
    "「く～ん……。": ""
  },
  "16409": {
    "「よしよし……\u3000わかってくれれば\u3000いいのだ。\n\u3000さあ\u3000ガートラント城に\u3000帰ろうなのだ！": ""
  },
  "16410": {
    "「わんっ\u3000わんっ！": ""
  },
  "16411": {
    "「あああっ\u3000マリーちゃん……\u3000まだ元気なのだ！": ""
  },
  "16412": {
    "「ようし！\n\u3000マグナスさまの部屋まで\u3000競争するのだ！\n\u3000<pc>も\u3000遅れちゃダメなのだ！": ""
  },
  "16413": {
    "「はあはあ……。こんなに\n\u3000たっぷり走ったのは\u3000ひさしぶりなのだ。": ""
  },
  "16414": {
    "「<pc>！\n\u3000一緒に\u3000マリーちゃんを\u3000返そうなのだ。": ""
  },
  "16415": {
    "「あらっ\u3000おかえりなさい。": ""
  },
  "16416": {
    "「マリーちゃんが\u3000あんなに\u3000素直に寝るなんて。\n\u3000あなたたち\u3000よほど\u3000たくさん\n\u3000マリーちゃんを\u3000散歩させてくれたのねっ。": ""
  },
  "16417": {
    "「いつもなら\u3000部屋で\u3000もう\u3000ひとあばれ\n\u3000されるところだったから\u3000助かっちゃった。\n\u3000本当に\u3000ありがとうっ！": ""
