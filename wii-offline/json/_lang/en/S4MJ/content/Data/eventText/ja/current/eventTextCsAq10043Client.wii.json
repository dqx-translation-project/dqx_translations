{
  "19748": {
    "「なにぶん\u3000昔のことだからねえ。\n\u3000こんなものしか\u3000なかったよ。": ""
  },
  "19749": {
    "<pipipi_low>「首尾はどうかな\u3000<pc>くん？\n\u3000おっ\u3000手がかりが\u3000出てきたようだね！": ""
  },
  "19750": {
    "「これは\u3000結婚式の出席者の\u3000一覧だね。\n\u3000あれれ？\u3000私の\u3000おばあちゃんの名前がある。\n\u3000関係は……新婦側の親族？": ""
  },
  "19751": {
    "「ああ～\u3000そういえば\u3000私の\u3000おばあちゃんと\n\u3000ダーリアさんは\u3000姉妹だって話を\n\u3000前に聞いたような……。": ""
  },
  "19752": {
    "「あっ\u3000名前の消されてる所がある！": ""
  },
  "19753": {
    "「これ\u3000やっぱり\u3000あの女の子かな？\n\u3000確認してみたほうが\u3000よさそうだね。": ""
  },
  "19754": {
    "「ラージャ神父。この出席者の一覧から\n\u3000名前が消されている\u3000村人がいます。\n\u3000これは\u3000１０歳くらいの女の子……ですか？": ""
  },
  "19755": {
    "「……知らないほうがいい。": ""
  },
  "19756": {
    "「どうして\u3000隠すんですか？\n\u3000それは\u3000もしかして……。": ""
  },
  "19757": {
    "「その女の子が\u3000死の言葉を使う\n\u3000女の子だからですか？": ""
  },
  "19758": {
    "「ル\u3000ルベカ！\n\u3000なぜ\u3000それを！？": ""
  },
  "19759": {
    "「やっぱり\u3000そうなんだ……。\n\u3000じつは\u3000私のアタマの中に\u3000その女の子の声……\n\u3000死の言葉が\u3000聞こえてくるんです。": ""
  },
  "19760": {
    "「……ああ\u3000なんということだ。\n\u3000今になって\u3000そんなことが\u3000起ころうとは……。": ""
  },
  "19761": {
    "「我々は\u3000あの少女のことを\u3000忘れようとした。 \n\u3000しかし\u3000それは\u3000許されぬことなのか。\n\u3000神よ。語れと申されるのですな……。": ""
  },
  "19762": {
    "「教えてくれますね？": ""
  },
  "19763": {
    "「……わかった。\n\u3000私が\u3000先代より\u3000聞かされた話を伝えよう。": ""
  },
  "19764": {
    "「……昔。この村に\u3000赤子が拾われてきた。\n\u3000時が過ぎ\u3000赤子は１０歳の少女へと成長した。": ""
  },
  "19765": {
    "「ある日\u3000少女が村人の名を呼び\u3000死ぬと言った。\n\u3000数日して\u3000その村人が事故で死んだ。": ""
  },
  "19766": {
    "「名前を呼ばれ\u3000死んでいく村人は\n\u3000ひとり……また\u3000ひとりと増えていった。": ""
  },
  "19767": {
    "「村人たちは\u3000恐れた。\n\u3000次に\u3000少女に名を呼ばれるのは\n\u3000自分かもしれない……と。": ""
  },
  "19768": {
    "「……そして\u3000レグとダーリアの結婚式を\n\u3000間近に控えた\u3000ある日のことだ。\n\u3000その少女は……": ""
  },
  "19769": {
    "「ダーリアが死ぬ……と告げたのだ。": ""
  },
  "19770": {
    "「人々の恐れは\u3000一気に\u3000怒りへ変わった！\n\u3000少女を捕らえた村人は\u3000むりやり薬を飲ませ\n\u3000二度と\u3000言葉を発せられぬようにしたのだ！": ""
  },
  "19771": {
    "「声をうばわれた少女は\u3000その後\n\u3000村人たちによって\u3000どこか遠い地に\n\u3000閉じ込められたという。 ": ""
  },
  "19772": {
    "「だが……。結婚式の前の日。": ""
  },
  "19773": {
    "「少女は\u3000慰霊の浜に\u3000姿を現した！\n\u3000そして\u3000身を清めようと海に入った \n\u3000ダーリアのもとへ\u3000駆け寄り…… ": ""
  },
  "19774": {
    "「ダーリアを\u3000海に沈めたのだ。": ""
  },
  "19775": {
    "「そんな……ダーリアさんは\n\u3000その女の子に\u3000殺されたってこと？": ""
  },
  "19776": {
    "「あの……。その子の名前は……？": ""
  },
  "19777": {
    "「……それは\u3000言えぬ。": ""
  },
  "19778": {
    "「その名を告げれば \n\u3000私のアタマの中にも\u3000死の言葉が\n\u3000ひびくことになるかもしれぬ……。": ""
  },
  "19779": {
    "「……なら\u3000せめて\u3000その子が\n\u3000閉じ込められたっていう場所だけでも\n\u3000教えてもらえませんか？": ""
  },
  "19780": {
    "「コルット地方にある\u3000浜辺の洞くつの奥だ……。\n\u3000今はもう\u3000誰かが\u3000いるはずもない。": ""
  },
  "19781": {
    "「ダーリアさんは\u3000やっぱり\n\u3000海で\u3000おぼれたんじゃ\u3000なかったんだね……。": ""
  },
  "19782": {
    "「だけど\u3000どうして？\n\u3000１０歳の女の子が\u3000どんな理由があって\n\u3000ダーリアさんを\u3000殺したりするの……？": ""
  },
  "19783": {
    "「私\u3000もっと\u3000その女の子のことを知りたい。": ""
  },
  "19784": {
    "「でも\u3000今ある\u3000手がかりは\u3000その子が\n\u3000閉じ込められてたっていう洞くつだけよね。\n\u3000とにかく\u3000そこへ\u3000行ってみようと思うの。": ""
  },
  "19785": {
    "「コルット地方にある\u3000浜辺の洞くつだからね。\n\u3000私は\u3000ちょっと\u3000家の掃除を頼まれてるから\n\u3000それが\u3000終わったら\u3000行くね！": ""
  },
  "19786": {
    "「遅くなって\u3000ごめんね。\n\u3000テーブルの汚れが\u3000なかなか\u3000取れなくて。": ""
  },
  "19787": {
    "「ちょっ……。なんで\u3000魔物がいるの？\n\u3000このままじゃ\u3000調べられないよ。": ""
  },
  "19788": {
    "「あっ\u3000そうだ。少女探偵ルベカちゃんには\n\u3000<cs_pchero>っていう\u3000優秀な助手がいたんだ。\n\u3000あの魔物を\u3000片付けちゃって！": ""
  },
  "19789": {
    "「じゃあ\u3000<cs_pchero>\u3000よろしくね！": ""
  },
  "19790": {
    "「あの魔物\u3000まだ\u3000いるね……。": ""
  },
  "19791": {
    "「私は\u3000ここを\u3000どうしても調べたいの。\n\u3000魔物を\u3000片付けちゃってくれるかな？": ""
  },
  "19792": {
    "「じゃあ\u3000<cs_pchero>\u3000よろしくね！": ""
  },
  "19793": {
    "「さすがだね\u3000<cs_pchero>。\n\u3000頼りになる助手がいて\u3000助かったわ。": ""
  },
  "19794": {
    "「ラージャ神父の話が本当なら\u3000あの女の子は\n\u3000ここに\u3000閉じ込められていたのね……。": ""
  },
  "19795": {
    "「人がいた跡とか\u3000ないみたい。\n\u3000手がかりは\u3000何も残ってないのかな……。": ""
  },
  "19796": {
    "「あれ？\u3000何かが……。": ""
  },
  "19797": {
    "「<cs_pchero>\u3000こっちへ来て！": ""
  },
  "19798": {
    "「うん……。この辺り。": ""
  },
  "19799": {
    "「なんだろう？\u3000よく\u3000わからないけど\n\u3000何かを\u3000感じるの……。": ""
  },
  "19800": {
    "「……ひゃあっ！！": ""
  },
  "19801": {
    "「あわわわ……。": ""
  },
  "19802": {
    "「聞こえたの！\u3000あの女の子の声が……。\n\u3000まちがいないよ。聞いたことのある声だもん。\n\u3000それに…………": ""
  },
  "19803": {
    "「まさか……\n\u3000あれが\u3000あの子の名前だったなんて……。": ""
  },
  "19804": {
    "「……ううん。なんでもないわ。": ""
  },
  "19805": {
    "「ラージャ神父の\u3000言ったとおりよ。\n\u3000あの女の子は\u3000ここに\n\u3000閉じ込められていたんだわ……。": ""
  },
  "19806": {
    "「……なんだか\u3000とても\u3000疲れちゃった。\n\u3000今日は\u3000この辺で\u3000終わりにしよう？": ""
  },
  "19807": {
    "「<cs_pchero>だって\u3000魔物と戦って\u3000\n\u3000きっと\u3000疲れてるはずだよね。": ""
  },
  "19808": {
    "「一緒に\u3000来てくれて\u3000ありがとう。\n\u3000ちゃんと\u3000お礼は\u3000持ってきてあるんだ。\n\u3000受け取ってね。": ""
  },
  "19809": {
    "「それじゃ\u3000私は\u3000レーンの村に帰るよ。\n\u3000続きは\u3000疲れが取れてからにしたいの。": ""
  },
  "19810": {
    "「<cs_pchero>も\u3000ゆっくり\u3000休んで。\n\u3000これからも\u3000手伝ってもらうんだから。": ""
  },
  "28440": {
    "「ブロォォォォム！！": ""
  },
  "31549": {
    "「ブロォォォォム！！": ""
  }
