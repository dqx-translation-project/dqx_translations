{
  "18512": {
    "「ああっ！\u3000大変だよ！\n\u3000大変なことに\u3000なっちゃった！": ""
  },
  "18513": {
    "「王さまが\u3000大軍を率いて\u3000行っちゃったの！\n\u3000博士さんも\u3000行っちゃった！": ""
  },
  "18514": {
    "「うう……。暗黒大樹に\u3000行ったんだよ。\n\u3000ボク\u3000兵士さんの話を聞いたんだ。": ""
  },
  "18515": {
    "「暗黒大樹を\u3000破壊しにいくって！": ""
  },
  "18516": {
    "「ボ…ボク\u3000イヤだよ。\n\u3000博士さんも\u3000パパも\u3000みんな\u3000いい人なのに……": ""
  },
  "18517": {
    "「エルフと\u3000大樹の番人が\n\u3000戦うなんて\u3000おかしいよ。": ""
  },
  "18518": {
    "「ね…ねえ\u3000ボクを\n\u3000暗黒大樹に\u3000連れてって。": ""
  },
  "18519": {
    "「ボク\u3000戦いを止めたいんだ。\n\u3000お…お願いします。": ""
  },
  "18520": {
    "「あ…ありがと！\n\u3000ボクの頼みを\u3000聞いてくれて！": ""
  },
  "18521": {
    "「ボク\u3000後から\u3000ついていくね！": ""
  },
  "18522": {
    "「あ…ありがと！\n\u3000でも\u3000ほかの人たちの頼まれごとで\n\u3000なんだか\u3000いっぱいみたい……。": ""
  },
  "18523": {
    "「は…早くしないと\u3000戦いが始まっちゃう！\n\u3000用事が済んだら\u3000すぐに戻ってきてね！": ""
  },
  "18524": {
    "「そ…そんな。\n\u3000早くしないと\u3000戦いが始まっちゃう……。": ""
  },
  "18525": {
    "「でも\u3000ほかに頼める人がいないし\n\u3000ど…どうすればいいんだろ。": ""
  },
  "18526": {
    "「ニコロイ王は\u3000ご不在だ。\n\u3000すまないが\u3000また後で来てくれ。": ""
  },
  "18527": {
    "「ボク\u3000エルフたちと\n\u3000大樹の番人が戦うのを\u3000止めたい。\n\u3000ボ…ボクを\u3000暗黒大樹に連れてって。": ""
  },
  "18528": {
    "「あ…暗黒大樹の場所は\u3000覚えてる？\n\u3000城を出たら\u3000北へ進んで\n\u3000カミハルムイ領北に\u3000出るの。": ""
  },
  "18529": {
    "「北西に進んで\u3000落陽の草原に着いたら\n\u3000西に\u3000まっすぐ進むんだよ。": ""
  },
  "18530": {
    "「ボク\u3000後をついてくから\n\u3000よ…よろしくね。": ""
  },
  "18531": {
    "「そなたが\u3000ここの長だな？": ""
  },
  "18532": {
    "「そうだ\u3000エルフの王。": ""
  },
  "18533": {
    "「暗黒大樹の長よ……。聞いてくれ。\n\u3000今\u3000暗黒大樹が活性化し\n\u3000各地で\u3000魔瘴が\u3000次々と発生しているのだ。": ""
  },
  "18534": {
    "「このままでは\u3000遠からず\n\u3000エルトナ大陸は\u3000魔瘴により\u3000滅びるだろう。\n\u3000滅びから逃れる方法は\u3000ひとつしかない。": ""
  },
  "18535": {
    "「……暗黒大樹の破壊だ。": ""
  },
  "18536": {
    "「……………。": ""
  },
  "18537": {
    "「私の後方には\u3000大勢の兵士が控えている。\n\u3000号令をかければ\u3000大挙して押し寄せるだろう。": ""
  },
  "18538": {
    "「……そうなれば\u3000双方とも\n\u3000大きな被害が出ることは\u3000まぬがれん。\n\u3000できれば\u3000戦いは避けたいのだ。": ""
  },
  "18539": {
    "「どうだ？\n\u3000ムダな血を流す前に\u3000退いてもらえぬか？": ""
  },
  "18540": {
    "「お前\u3000なにも\u3000わかってない。": ""
  },
  "18541": {
    "「お前\u3000なにも\u3000見えてない。": ""
  },
  "18542": {
    "「大樹の破壊\n\u3000お前たちの寿命を\u3000縮めるだけ。": ""
  },
  "18543": {
    "「我々の寿命を\u3000縮めるだと……？\n\u3000いったい\u3000どういうことだ？": ""
  },
  "18544": {
    "「ムリだ。言っても\u3000わからない。\n\u3000お前たち\u3000見たものしか信じない。": ""
  },
  "18545": {
    "「……そうか。\n\u3000残念だが\u3000交渉の余地は\u3000なさそうだな。": ""
  },
  "18546": {
    "「許せ！！\u3000暗黒大樹の番人たちよ！！": ""
  },
  "18547": {
    "「全軍……！": ""
  },
  "18548": {
    "「震動……！？\u3000地面から！？\n\u3000ま…まずい！！": ""
  },
  "18549": {
    "「王さま\u3000危険です！\n\u3000早く\u3000この場から離れてください！": ""
  },
  "18550": {
    "「な…なんだ！？": ""
  },
  "18551": {
    "「うん？\u3000地面が……。": ""
  },
  "18552": {
    "「う…うわあああああーーーーー！！！": ""
  },
  "18553": {
    "「魔瘴だと！？": ""
  },
  "18554": {
    "「ギョギョ！\u3000ギョギョギョ！": ""
  },
  "18555": {
    "「しくじったわ……。逃げおくれた……。": ""
  },
  "18556": {
    "「は…博士さん！！": ""
  },
  "18557": {
    "「ハッパ！？": ""
  },
  "18558": {
    "「ねえ！\u3000博士さんを助けにいこう！": ""
  },
  "18559": {
    "「博士さんたちが\u3000あぶない！": ""
  },
  "18560": {
    "「ねえ！\u3000みんなを助けにいこう！": ""
  },
  "18561": {
    "「ましょううおを\u3000倒したか。\n\u3000お前\u3000勇気ある者だ。": ""
  },
  "18562": {
    "「ハッパ。強い仲間\u3000持ったな。": ""
  },
  "18563": {
    "「パパ……。": ""
  },
  "18564": {
    "「パパ……？\n\u3000暗黒大樹の長が\u3000育ての親だったのね……。": ""
  },
  "18565": {
    "「な…なんだ\u3000今のは！？": ""
  },
  "18566": {
    "「暗黒大樹が光り\n\u3000魔瘴を\u3000取り込んでいった！？": ""
  },
  "18567": {
    "「暗黒…大樹が……？": ""
  },
  "18568": {
    "「そういうことだったのか……。": ""
  },
  "18569": {
    "「ふふっ。まいった……。\n\u3000これは\u3000想像以上の発見だわ。": ""
  },
  "18570": {
    "「この樹は\u3000魔瘴を取り込み\u3000浄化することで\n\u3000魔瘴から\u3000エルトナ大陸を守ってきたのね。": ""
  },
  "18571": {
    "「な…なんだと！？": ""
  },
  "18572": {
    "「そうだ。お前\u3000賢い者だ。": ""
  },
  "18573": {
    "「エルトナ大陸に発生した\u3000魔瘴。\n\u3000聖なる大樹\u3000魔瘴を取り込んでいき\n\u3000どんどん\u3000黒く染まっていった。": ""
  },
  "18574": {
    "「なにも知らない\u3000エルフたち。\n\u3000いつからか\u3000聖なる大樹を\n\u3000暗黒大樹と呼ぶようになった。": ""
  },
  "18575": {
    "「だけど長年\u3000魔瘴を取り込んだせいで\n\u3000この樹の\u3000はたらきは\u3000徐々に弱まっていった。\n\u3000次第に\u3000魔瘴を取り込むチカラは落ちていき……": ""
  },
  "18576": {
    "「取り込みきれず\u3000あふれた魔瘴が\n\u3000今\u3000各地で\u3000ふきだしている。\n\u3000暗黒大樹の正体は……": ""
  },
  "18577": {
    "「すなわち\u3000世界樹。そういうことね？": ""
  },
  "18578": {
    "「そうだ。": ""
  },
  "18579": {
    "「な…なんだと！？\n\u3000この暗黒大樹が\u3000大いなる緑の象徴！？": ""
  },
  "18580": {
    "「はるか昔から\u3000私たちエルフを\n\u3000見守り続けてきた\u3000世界樹だというのか……？": ""
  },
  "18581": {
    "「大樹の番人\u3000大樹を見守るのが役目。\n\u3000誰にも\u3000ジャマさせない。": ""
  },
  "18582": {
    "「エルフたちよ。去れ。": ""
  },
  "18583": {
    "「パパ……？": ""
  },
  "18584": {
    "「ハッパ\u3000立派になった。": ""
  },
  "18585": {
    "「うん……。\n\u3000ボク\u3000博士さんの所で\n\u3000いっぱい\u3000お手伝いしたから……。": ""
  },
  "18586": {
    "「博士さん？": ""
  },
  "18587": {
    "「あたしのことよ。": ""
  },
  "18588": {
    "「賢い者か。\n\u3000お前に\u3000感謝する。": ""
  },
  "18589": {
    "「……ハッパ。なぜ\u3000お前を\n\u3000ここから\u3000追いだしたのか話す。": ""
  },
  "18590": {
    "「大樹\u3000芯まで\u3000濃い魔瘴に覆われた。\n\u3000芯\u3000大樹の命。": ""
  },
  "18591": {
    "「大樹\u3000もうすぐ\u3000限界。\n\u3000魔瘴を\u3000取り込めなくなる。": ""
  },
  "18592": {
    "「ここ\u3000濃い魔瘴だらけになったら\n\u3000エルフの\u3000お前\u3000生きていけなくなる。\n\u3000だから\u3000お前を遠ざけた。": ""
  },
  "18593": {
    "「そ…そんな！\n\u3000大樹を\u3000助けられないの！？": ""
  },
  "18594": {
    "「これも\u3000自然の意志。": ""
  },
  "18595": {
    "「さらばだ。": ""
  },
  "18596": {
    "「……対策を\u3000練り直すべきね。": ""
  },
  "18597": {
    "「王さま。ひとまず\u3000城に戻りましょう。": ""
  },
  "18598": {
    "「うむ……。": ""
  },
  "18599": {
    "「ハッパ！\u3000<cs_pchero>！\n\u3000戻るわよ！": ""
  },
  "18600": {
    "「誰も\u3000大樹を助けられない……。": ""
  },
  "18601": {
    "「暗黒大樹と呼ばれてた樹が\u3000世界樹だった……。\n\u3000はるか昔から\u3000魔瘴を取り込み\u3000浄化していて\n\u3000今\u3000限界が\u3000きているか……。": ""
  },
  "18602": {
    "「は…博士さん？": ""
  },
  "18603": {
    "「……あたしの研究は\u3000ムダだったってわけね。\n\u3000魔瘴の増加は\u3000おさえられないし\n\u3000もう\u3000あたしたちは終わりなのかしら……。": ""
  },
  "18604": {
    "「ね…ねえ\u3000博士さん！？": ""
  },
  "18605": {
    "「あっ\u3000ごめんね。ハッパ。\n\u3000どしたの？": ""
  },
  "18606": {
    "「あ…あのね。\n\u3000暗黒大樹の芯を覆う\u3000魔瘴って\n\u3000どうにか\u3000できないかな？": ""
  },
  "18607": {
    "「えっ……？": ""
  },
  "18608": {
    "「大樹の芯から\u3000魔瘴がなくなれば\n\u3000魔瘴を取り込むチカラが\u3000回復するんでしょ？": ""
  },
  "18609": {
    "「そしたら\u3000各地に現れた魔瘴も\n\u3000また\u3000暗黒大樹が取り込んで\u3000浄化するように\n\u3000なるかもしれないし……。方法は\u3000ないかな？": ""
  },
  "18610": {
    "「多くの研究者が\u3000今も\n\u3000魔瘴を\u3000消滅させる方法を調べてるけど\n\u3000まだ\u3000誰にも突き止められてないのよ……。": ""
  },
  "18611": {
    "「もう\u3000時間も残されてないし\n\u3000今から調べても\u3000間に合わないわ……。": ""
  },
  "18612": {
    "「そうなの？\n\u3000でも\u3000博士さんなら\u3000きっと\u3000できるよ。": ""
  },
  "18613": {
    "「そ…そう？": ""
  },
  "18614": {
    "「そうだよ！\n\u3000だって\u3000博士さんは天才だもん！": ""
  },
  "18615": {
    "「天…才……？\n\u3000あたしは\u3000天才……。": ""
  },
  "18616": {
    "「へへ！\u3000そうよね！\n\u3000まだ\u3000終わったわけじゃないわ！": ""
  },
  "18617": {
    "「魔瘴を消滅させる方法さえ\u3000突き止めれば\n\u3000いいんだし\u3000こんなの楽勝だわ！": ""
  },
  "18618": {
    "「よーし！\u3000いちから出直しよ！\n\u3000魔瘴を消滅させる方法は\u3000あたしが\n\u3000なんとしてでも\u3000つかんでみせる！": ""
  },
  "18619": {
    "「ハッパ！\u3000お使いよ！": ""
  },
  "18620": {
    "「ハラが減っては\u3000いくさは\u3000できぬってね！\n\u3000なんか\u3000栄養のあるもの買ってきて！": ""
  },
  "18621": {
    "「うん！\u3000わかった！": ""
  },
  "18622": {
    "「えへへ！\u3000暗黒大樹に\n\u3000連れてってくれて\u3000ありがとね！\n\u3000これ！\u3000ボクからの\u3000お礼だよ！": ""
  },
  "18623": {
    "「えへへ！\n\u3000ボク\u3000買い物\u3000行ってくるね！": ""
  }
}