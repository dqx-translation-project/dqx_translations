{
  "21458": {
    "「……ちょっと\u3000アンタッ！\n\u3000急に\u3000ウチに転がり込んできて\n\u3000家事のひとつも\u3000手伝わねえんですかッ！": ""
  },
  "21459": {
    "「アンタみてえなヤツは\u3000この家から……": ""
  },
  "21460": {
    "「絶対に\u3000出ていかねえでくださいッ！\n\u3000このウチは\u3000使えねえ野郎は\u3000大歓迎ですッ！\n\u3000どんどん\u3000なまけてくだせえッ！": ""
  },
  "21461": {
    "「アッ！\u3000ダストンさま\u3000ダメですよ！\n\u3000モテない\u3000サエない\u3000使えないは\n\u3000ボクの専売特許なんですからねっ！": ""
  },
  "21462": {
    "「おお\u3000<pc>よ！\n\u3000まともに話せる\u3000そちを待っておったぞ！\n\u3000ここにいる者の話は\u3000ワケがわからぬでな。": ""
  },
  "21463": {
    "「……ときに\u3000ウルベアの遺跡で話した\n\u3000グルヤンラシュの話\u3000そちは覚えておるか？<yesno><close>": ""
  },
  "21464": {
    "「グルヤンラシュとは\u3000かつて\n\u3000ウルベア地下帝国に現れた神官でな。\n\u3000当時\u3000乱世を招いた張本人じゃ。": ""
  },
  "21465": {
    "「ウルベアとガテリアの\u3000技術力を競わせ\n\u3000相討ちを目論んだ\u3000きゃつの奸計で\n\u3000両国は滅んだと言うても\u3000過言ではない。": ""
  },
  "21466": {
    "「じつは\u3000その話\u3000続きがあってな……。\n\u3000ウルベア皇帝に取り入って\u3000計略をめぐらせた\n\u3000グルヤンラシュじゃが……": ""
  },
  "21467": {
    "「その正体は\u3000知略に長けた魔物なのじゃ！": ""
  },
  "21468": {
    "「グルヤンラシュは\u3000神官の姿に化け\n\u3000あやしげな術で\u3000ウルベア皇帝の心をつかむと\n\u3000そのまま\u3000宰相として登用されてな……。": ""
  },
  "21469": {
    "「ウルベアを意のままに操ると\n\u3000軍事にかたよった\u3000技術革新を推し進め\n\u3000ガテリア皇国との戦争を\u3000始めたのじゃ……！": ""
  },
  "21470": {
    "「そのせいで\u3000余の祖国は……。\n\u3000許すまじ……！\u3000奸臣グルヤンラシュ……！": ""
  },
  "21471": {
    "「いくら時が過ぎたとはいえ\u3000あれほどまで\n\u3000知略の優れた魔物が\u3000死んでいるとは思えぬ！\n\u3000今も\u3000謀り事を\u3000めぐらせているはずじゃ！": ""
  },
  "21472": {
    "「<pc>よ\u3000頼む。\n\u3000余と共に\u3000グルヤンラシュの根城に向かい\n\u3000きゃつの討伐を\u3000果たしてはくれぬか？": ""
  },
  "21473": {
    "「きゃつの根城は\u3000おそらく当時のまま\n\u3000南の\u3000グルグ地下道に\u3000あるはずじゃ。\n\u3000我が祖国のカタキ\u3000この手で討たせてたもれ！": ""
  },
  "21474": {
    "「うむ！\u3000苦しゅうないぞよ！\n\u3000そちがおれば\u3000百人力じゃ！": ""
  },
  "21475": {
    "「そして\u3000おそらく……\n\u3000あのリウ老師も\u3000余と同じ考えに至り\n\u3000グルヤンラシュの討伐に\u3000向かったはずじゃ。": ""
  },
  "21476": {
    "「余の家庭教師\u3000リウ老師は\u3000グルヤンラシュが\n\u3000魔物であることを\u3000早々に見抜いておってな。\n\u3000いずれ\u3000なんとかせねばと\u3000申していたのだ。": ""
  },
  "21477": {
    "「リウ老師が\u3000地下遺跡に\u3000いなかったのは\n\u3000祖国のカタキを討ちに\u3000グルヤンラシュのもとへ\n\u3000向かっているからに\u3000相違あるまい！": ""
  },
  "21478": {
    "「うまくいけば\u3000リウ老師に会えるはずじゃ。\n\u3000それでは\u3000グルヤンラシュの根城へ急ごうぞ！\n\u3000余は\u3000そちの後を\u3000ついていくでな！": ""
  },
  "21479": {
    "「……ムムッ！\n\u3000そちは\u3000下々の者の依頼を\u3000たくさん抱えており\n\u3000余の頼みは\u3000受けられぬようじゃな。": ""
  },
  "21480": {
    "「……まあ\u3000よい。余は\u3000寛大じゃからな。\n\u3000とはいえ\u3000事態は\u3000一刻を争うのじゃ。\n\u3000早急に依頼を片付け\u3000余を手伝ってたもれ。": ""
  },
  "21481": {
    "「なんと！\u3000余の頼みを\u3000断ると申すか！\n\u3000……時の流れとは\u3000かくも無情なるものか。\n\u3000大国の威光など\u3000うたかたの夢の如し……。": ""
  },
  "21482": {
    "「とはいえ\u3000事態は\u3000一刻を争うのじゃ。\n\u3000そう言わずに\u3000手を貸してくれぬか。\n\u3000余は\u3000ここにおるでな。また来てたもれ。": ""
  },
  "21483": {
    "「おお\u3000待っておったぞ\u3000<pc>！\n\u3000祖国のカタキ\u3000グルヤンラシュを討伐する件\n\u3000引き受けてくれる気になったのかえ？": ""
  },
  "21484": {
    "「いくら時が過ぎたとはいえ\u3000あれほどまで\n\u3000知略の優れた魔物が\u3000死んでいるとは思えぬ！\n\u3000今も\u3000謀り事を\u3000めぐらせているはずじゃ！": ""
  },
  "21485": {
    "「<pc>よ\u3000頼む。\n\u3000余と共に\u3000グルヤンラシュの根城に向かい\n\u3000きゃつの討伐を\u3000果たしてはくれぬか？": ""
  },
  "21486": {
    "「きゃつの根城は\u3000おそらく当時のまま\n\u3000南の\u3000グルグ地下道に\u3000あるはずじゃ。\n\u3000我が祖国のカタキ\u3000この手で討たせてたもれ！": ""
  },
  "21487": {
    "「これから討伐に向かう\u3000グルヤンラシュは\n\u3000ウルベアとガテリアに\u3000戦争をもたらした\n\u3000乱世の使者……\u3000天下の奸臣じゃ。": ""
  },
  "21488": {
    "「きゃつは\u3000魔物でありながら\u3000人間に姿を変え\n\u3000あやしげな術で\u3000ウルベア皇帝の心をつかむと\n\u3000そのまま\u3000地下帝国を\u3000意のままに操った……。": ""
  },
  "21489": {
    "「そちには\u3000余と共に\u3000きゃつの根城がある\n\u3000南の\u3000グルグ地下道に\u3000向かってもらう。\n\u3000そこで\u3000我が祖国のカタキを討つのじゃ！": ""
  },
  "21490": {
    "「余の家庭教師である\u3000リウ老師も\n\u3000おそらく\u3000余と同じ考えであるはず……。\n\u3000うまくいけば\u3000老師にも会えるじゃろう。": ""
  },
  "21491": {
    "「それでは\u3000グルヤンラシュの根城へ急ごうぞ！\n\u3000余は\u3000そちの後を\u3000ついていくでな！\n\u3000頼んだぞよ\u3000<pc>！": ""
  },
  "21492": {
    "「ゼハー\u3000ゼハー……。\n\u3000こ…これ\u3000<pc>……。\n\u3000少しは\u3000余を気づかい\u3000歩を\u3000ゆるめぬか……。": ""
  },
  "21493": {
    "「ハア…\u3000ハア……。\n\u3000この辺りで\u3000ひと休みするぞえ……。\n\u3000こんなに歩いたのは\u3000はじめてじゃ……。": ""
  },
  "21494": {
    "「まったく……\u3000そちは\u3000スパルタじゃのう。\n\u3000リウ老師であれば\u3000余を\u3000いたわり……\n\u3000休みを……\u3000こまめに入れてくれたはずじゃ。": ""
  },
  "21495": {
    "「……まっこと\u3000リウ老師は\n\u3000完璧な\u3000家庭教師だったぞよ……。": ""
  },
  "21496": {
    "「……いや。\n\u3000そういえば\u3000老師にも\u3000ひとつだけ\n\u3000気に入らぬところが\u3000あったわ。": ""
  },
  "21497": {
    "「……リウ老師は\u3000ウルベア出身の技術者でな。\n\u3000その技能は\u3000天下一品と\u3000うたわれておった。\n\u3000そう。あの魔神兵も\u3000リウ老師が作ったのじゃ。": ""
  },
  "21498": {
    "「だが\u3000グルヤンラシュが現れたころから\n\u3000リウ老師は\u3000ウルベアを離れ……\n\u3000余の家庭教師として\u3000我が国に招かれたのじゃ。": ""
  },
  "21499": {
    "「天下一の技術者を\u3000近くに置き\n\u3000余は\u3000心を躍らせたものぞよ。\n\u3000誰よりも\u3000優れた技術を身につけられる\u3000とな。": ""
  },
  "21500": {
    "「……だが\u3000リウ老師は\n\u3000生きていくのに必要な\u3000最低限の技術しか\n\u3000余に\u3000教えてくれなかったのじゃ。": ""
  },
  "21501": {
    "「これ以上\u3000技術に身をゆだねると\n\u3000自分たちの首を絞めることになる……などと\n\u3000おかしなことを言うてな。": ""
  },
  "21502": {
    "「余は\u3000それが\u3000もどかしくて\u3000たまらなかった。\n\u3000国王となる\u3000余が\u3000先んじて\u3000技術を修めれば\n\u3000かのウルベアにも\u3000勝るというに……。": ""
  },
  "21503": {
    "「……さてと\u3000そろそろ\u3000行かねばな。\n\u3000話をしている間に\u3000足腰の疲れも取れたぞよ。\n\u3000待たせて\u3000すまなかったのう\u3000<pc>。": ""
  },
  "21504": {
    "「それでは\u3000歩を進めるとするぞえ。\n\u3000グルヤンラシュの根城まで\u3000あと少し……。\n\u3000きっと\u3000リウ老師にも会えるはずじゃ。": ""
  },
  "21505": {
    "「……着いたようじゃな。\n\u3000ここが\u3000当時\u3000グルヤンラシュの根城と\n\u3000言われていた場所じゃ。": ""
  },
  "21506": {
    "「気をつけよ\u3000<pc>。\n\u3000グルヤンラシュは\u3000どこかに身をひそめ\n\u3000不意に\u3000襲ってくるかもしれぬぞえ。": ""
  },
  "21507": {
    "「奸臣グルヤンラシュよ！\u3000姿を現せい！\n\u3000余は\u3000ガテリア皇国が\u3000第一の皇子\n\u3000ビャン・ダオなるぞ！": ""
  },
  "21508": {
    "「愛する祖国を\u3000滅亡へと追いやった\u3000悪鬼め！\n\u3000その罪は\u3000万死に値する！\u3000さあ\u3000出てこいッ！\n\u3000余が\u3000一刀のもとに斬り伏せてくれるわッ！": ""
  },
  "21509": {
    "「……………………。": ""
  },
  "21510": {
    "「老師ッ！！\u3000リウ老師ーッ！！\n\u3000余の声が\u3000聞こえるか！？\u3000ビャンが来たぞよ！\n\u3000いたら\u3000返事をするのじゃーッ！": ""
  },
  "21511": {
    "「……………………。": ""
  },
  "21512": {
    "「……コホン。<pc>よ\u3000苦しゅうない。\n\u3000もう\u3000楽にしてもよいぞよ。\n\u3000ここには\u3000誰も\u3000おらぬようじゃ。": ""
  },
  "21513": {
    "「グルヤンラシュめ\u3000ちょこざいな……。\n\u3000余が眠っている間に\u3000根城を変えようとは\n\u3000さすがの余でも\u3000思い至らなかったわ……。": ""
  },
  "21514": {
    "「<pc>\u3000すまぬ。\n\u3000これまでの苦労が\u3000水の泡となってしもうた。\n\u3000すべて\u3000余の過失じゃ。許してたもれ。": ""
  },
  "21515": {
    "「これは\u3000そのわびも兼ねた\u3000礼じゃ。\n\u3000なんとか\u3000これで\u3000機嫌を直してたもれ。": ""
  },
  "21516": {
    "「リウ老師が\u3000この場に\u3000いないのも\n\u3000グルヤンラシュの\u3000新たな根城を追って\n\u3000ここを\u3000後にしたためであろう。": ""
  },
  "21517": {
    "「のう\u3000<pc>よ。\n\u3000リウ老師のこと\u3000少し話させてくれぬか。\n\u3000そちには\u3000知っておいてもらいたいのじゃ。": ""
  },
  "21518": {
    "「……あれは\u3000余が\u3000この時代に来る直前。\n\u3000リウ老師が\u3000いつものように\n\u3000余の所へ通ってきた\u3000ある日のこと……。": ""
  },
  "21519": {
    "「グルヤンラシュの悪魔のささやきに耳を貸した\n\u3000ウルベア皇帝が\u3000ついに\u3000軍を動かし\n\u3000我がガテリアに\u3000侵攻してきおったのじゃ！": ""
  },
  "21520": {
    "「長きに渡る抗戦の末\u3000余と\u3000リウ老師は\n\u3000ウルベアに捕えられ\u3000牢獄に入れられた。\n\u3000そして\u3000余は\u3000交渉の材料となったのじゃ……。": ""
  },
  "21521": {
    "「ガテリアが降伏しなければ\u3000余は処刑……。\n\u3000降伏か……\u3000抗戦か……。\n\u3000その\u3000運命の審判が下された夜……。": ""
  },
  "21522": {
    "「ビャンさま……！": ""
  },
  "21523": {
    "「リウ老師！\u3000どこへ行っておった！\n\u3000余を\u3000ひとりにするでない！\n\u3000心細かったではないか！": ""
  },
  "21524": {
    "「それよりも\u3000なぜ\u3000牢の外に出ておる！\n\u3000余が眠っている間に\u3000何があったのじゃ！？\n\u3000我らは\u3000解放されたのか！？": ""
  },
  "21525": {
    "「聡明なる皇子\u3000ビャン・ダオさま……。\n\u3000どうか\u3000心を静め\u3000私の話をお聞きください。": ""
  },
  "21526": {
    "「遺憾ながら\u3000あなたさまの\u3000お父上は……": ""
  },
  "21527": {
    "「ウルベア帝国の侵攻に対し\n\u3000徹底抗戦の意を\u3000表明されました……！": ""
  },
  "21528": {
    "「それと同時に\u3000ガテリア兵が\u3000なだれ込み……\n\u3000私は\u3000その混乱に乗じて\u3000牢を開け\n\u3000あなたさまを\u3000ここまで\u3000お運びしたのです。": ""
  },
  "21529": {
    "「そんな……\u3000父上は……\n\u3000余を\u3000見捨て……。": ""
  },
  "21530": {
    "「ビャンさま！\u3000お気を確かに！\n\u3000我々に残された時間は\u3000あとわずか……！\n\u3000いずれ\u3000ここも\u3000敵兵に見つかりましょう！": ""
  },
  "21531": {
    "「さあ\u3000ビャンさま。御身を守るため\n\u3000どうか\u3000これに\u3000お乗りください。": ""
  },
  "21532": {
    "「これは\u3000私が\u3000ウルベアにいたとき\n\u3000極秘で研究していた\u3000魔神兵にございます。\n\u3000皇子を\u3000安全な場所まで\u3000お連れいたします。": ""
  },
  "21533": {
    "「イ…イヤじゃ！\u3000余\u3000ひとりでは\u3000イヤじゃ！\n\u3000リウ老師ッ！\u3000そなたも乗るのじゃ！": ""
  },
  "21534": {
    "「この魔神兵は\u3000もうひとつございます。\n\u3000私も\u3000後から魔神兵に乗りますゆえ\n\u3000どうか\u3000ご安心を……。": ""
  },
  "21535": {
    "「さあ\u3000早く！\n\u3000敵兵に\u3000見つかる前に……！": ""
  },
  "21536": {
    "「……こうして\u3000余は\u3000リウ老師の手によって\n\u3000あの\u3000特別な魔神兵に\u3000乗せられ\n\u3000この時代に\u3000やってきたのじゃ。": ""
  },
  "21537": {
    "「魔神兵は\u3000本来\u3000棺の役目を果たすもの……。\n\u3000死後\u3000復活をとげる前に\u3000肉体が朽ち果てぬよう\n\u3000保存し\u3000守るためのものなのじゃ。": ""
  },
  "21538": {
    "「リウ老師は\u3000それを改良し\u3000人を生かしたまま\n\u3000保存できる技術を\u3000研究していたのじゃろう。\n\u3000そのおかげで\u3000余は\u3000救われたのじゃ。": ""
  },
  "21539": {
    "「……父上は\u3000余の命よりも\u3000国を選んだ。\n\u3000リウ老師が逃がしてくれなかったら\n\u3000余は\u3000処刑されていた……。": ""
  },
  "21540": {
    "「結局\u3000余のことを心配してくれたのは\n\u3000リウ老師だけであった……。\n\u3000老師は\u3000余にとって\u3000特別な存在なのじゃ。": ""
  },
  "21541": {
    "「……のう\u3000<pc>よ。\n\u3000余は\u3000リウ老師に会いたいぞよ。\n\u3000そのために\u3000またチカラを貸してほしいのじゃ。": ""
  },
  "21542": {
    "「リウ老師は\u3000きっと\u3000どこかにいるはずじゃ。\n\u3000後から魔神兵に乗ると\n\u3000別れ際に\u3000余と\u3000約束を交わしたでな。": ""
  },
  "21543": {
    "「ひとまず\u3000余は\u3000ガラクタ屋敷に戻り\n\u3000今後のことを\u3000考えることにするぞえ。\n\u3000また\u3000様子を見にきてたもれ。": ""
  }
}