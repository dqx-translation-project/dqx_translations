  "23079": {
    "「では\u3000さっそく\u3000アバさまに\n\u3000この豆を\u3000お見せしてこよう。\n\u3000……そなたは\u3000ここで\u3000待つがよい。": ""
  },
  "23080": {
    "「ア……\u3000アバさまっ！\u3000大丈夫ですか？\n\u3000しっかりなさってください！": ""
  },
  "23081": {
    "「カメさまの\u3000お告げの\u3000救世主が\n\u3000あの\u3000ふしぎな豆の本をもとに\n\u3000このような豆を\u3000作ってまいりましたぞ！": ""
  },
  "23082": {
    "「あ……\u3000ぅ…………。": ""
  },
  "23083": {
    "「ま…………\u3000め…………？": ""
  },
  "23084": {
    "「ポ……\u3000ポリッ……\u3000もぐ\u3000もぐ……………。": ""
  },
  "23085": {
    "「なっ\u3000なんじゃ\u3000この豆！？\n\u3000めちゃくちゃ\u3000うまいでは\u3000ないかっ！！": ""
  },
  "23086": {
    "「もぐもが\u3000もぐもぐ……。\n\u3000じゅるっ……\u3000もがっ\u3000まめっ\u3000うまっ！！": ""
  },
  "23087": {
    "「……………………。": ""
  },
  "23088": {
    "「ぶっはぁっ！\u3000うまかったあ！\n\u3000チカラが\u3000みなぎってきたわい！": ""
  },
  "23089": {
    "「見ておれ……！\n\u3000今の\u3000わしにかかれば\u3000これしきの儀式\n\u3000またたく間に\u3000終わらせてくれるわっ！！": ""
  },
  "23090": {
    "「なんだったのだ\u3000あれは……？\n\u3000あれが……\u3000あの豆の\u3000チカラなのか！？": ""
  },
  "23091": {
    "「い\u3000今のは……！": ""
  },
  "23092": {
    "「儀式は\u3000終わった……。": ""
  },
  "23093": {
    "「<kyodai>だな？\n\u3000そなたのおかげだ。礼を言うぞ。": ""
  },
  "23094": {
    "「チャツカ！\n\u3000村の者たちを\u3000集めるのじゃ！": ""
  },
  "23095": {
    "「はいっ\u3000エルバさま！": ""
  },
  "23096": {
    "「聞け！\u3000エテーネの民たちよ！": ""
  },
  "23097": {
    "「カメさまの\u3000お告げにありし\u3000救世主のチカラで\n\u3000長きに渡った\u3000継承の儀式は終わった！": ""
  },
  "23098": {
    "「さあ！\u3000新たなる巫女を\u3000皆で迎えるのじゃ！！": ""
  },
  "23099": {
    "「おおっ……\u3000新たなる巫女さま\u3000バンザイっ！\n\u3000アバさま\u3000バンザイっ！！": ""
  },
  "23100": {
    "「わが名は\u3000アバ！\n\u3000新たなる巫女として\u3000エテーネの民を\n\u3000導く者なり！！": ""
  },
  "23101": {
    "「わしは\u3000巫女として\n\u3000エテーネの民たちに\u3000新しき道を\u3000示そう！": ""
  },
  "23102": {
    "「この豆\u3000めちゃくちゃ\u3000うまい！\n\u3000皆で\u3000このふしぎな豆を\u3000育てるのじゃ！！": ""
  },
  "23103": {
    "「なんと！\u3000見たこともない豆じゃ。": ""
  },
  "23104": {
    "「このふしぎな豆は\u3000わしに\u3000チカラを与え\n\u3000儀式の最後のカベを\u3000越えさせてくれた。\n\u3000わしは\u3000この豆を………": ""
  },
  "23105": {
    "「ハツラツ豆と\u3000名付ける！": ""
  },
  "23106": {
    "「ハツラツ豆……？\n\u3000あの豆が\u3000アバさまを\u3000救ってくれたのか！？": ""
  },
  "23107": {
    "「ありがたい豆なんだねえ。\n\u3000この地でも\u3000たくさん収穫できるよう\n\u3000皆で\u3000大事に育てていこう！": ""
  },
  "23108": {
    "「ふっふっふっ。これで\u3000ハツラツ豆が\n\u3000いつでも\u3000食べられるようになるわい。": ""
  },
  "23109": {
    "「アバ！\n\u3000大事な話を\u3000忘れておるじゃろう。\n\u3000<kyodai>のことを\u3000皆に\u3000説明せんか！": ""
  },
  "23110": {
    "「ああ……。\n\u3000そうじゃった\u3000そうじゃった。": ""
  },
  "23111": {
    "「皆に\u3000紹介しよう！\n\u3000この\u3000ハツラツ豆を作ってくれたのが\n\u3000ここにいる\u3000<kyodai>じゃ。": ""
  },
  "23112": {
    "「カメさまの\u3000お告げの通り\n\u3000わしが\u3000新たなる巫女となるために\n\u3000チカラを尽くしてくれた！": ""
  },
  "23113": {
    "「わしは\u3000村の救世主\u3000<kyodai>に敬意を表し\n\u3000エテーネの民のひとりとして\u3000迎えると決めた。\n\u3000皆の者も\u3000仲良くしてやってくれい！": ""
  },
  "23114": {
    "「以上！\u3000解散っ！！": ""
  },
  "23115": {
    "「ふう……。\n\u3000これで\u3000わしも\u3000肩の荷が下りたわい……。": ""
  },
  "23116": {
    "「<kyodai>。わしには\u3000わかっておるぞ。\n\u3000お前は\u3000時渡りの術により\n\u3000この時代に\u3000来たのじゃろう？": ""
  },
  "23117": {
    "「……何も言わんでよい。\n\u3000このことは\u3000お前と\u3000わしの\n\u3000ふたりだけの\u3000秘密にしておこう。": ""
  },
  "23118": {
    "「時渡りは\u3000とうの昔に\u3000忘れ去られた術。\n\u3000ふたたび\u3000人々が\u3000クチにするようになれば\n\u3000悪しき者に\u3000目をつけられやすくなるからのう。": ""
  },
  "23119": {
    "「……そう。今\u3000この時代に\n\u3000時渡りの術を使える者は\u3000おらん。\n\u3000お前が\u3000元の時代に帰る方法はないのじゃ。": ""
  },
  "23120": {
    "「だが\u3000<kyodai>よ\u3000気を落とすでない。": ""
  },
  "32265": {
    "「会うことは\u3000かなわぬとも\n\u3000我が祈りにより\u3000せめて\u3000お前の思いを\n\u3000<pc>の元へと\u3000届けてやろう。": ""
  },
  "32266": {
    "「さあ\u3000祈るのじゃ。\n\u3000遠く離れた場所にいる\u3000<pc_rel2>を思って……。": ""
  },
  "32267": {
    "「強く祈れば\u3000その思いは\u3000形となり\n\u3000必ず\u3000<pc>の元へ\u3000届くはずじゃ。": ""
  },
  "32268": {
    "「救世主\u3000<kyodai>の<pc_rel2>\u3000<pc>よ。\n\u3000<kyodai_rel3>は\u3000この時代で\u3000がんばったぞ。\n\u3000その思いを\u3000しっかり\u3000受け取っておくれ。": ""
  },
  "37759": {
    "「ゴルルルゥ。におう……におうぞォ！\n\u3000こいつは\u3000錬金術師の\u3000においだなァ！？": ""
  },
  "37760": {
    "「オレ様を\u3000こんなほこらに\n\u3000閉じ込めやがった\u3000錬金術師ィ！\n\u3000ゆるさん……ゆるさんぞォォォォォ！！": ""
  },
  "37761": {
    "「我は\u3000この世を絶望で満たすために\n\u3000はるか死の世界より\u3000訪れし者……。": ""
  },
  "37762": {
    "「せっかく\u3000ひとりの\u3000有能な錬金術師から\n\u3000その能力を消し去ったというのに\u3000すぐに\n\u3000新たな錬金術師が\u3000現れるとは……。": ""
  },
  "37763": {
    "「貴様も\u3000あの錬金術師のように\n\u3000我に\u3000錬金術師としてのチカラを捧げよ！\n\u3000そして\u3000ふたたび\u3000死の絶望を味わうのだ！": ""
  },
  "37764": {
    "「どうだい\u3000ボクのキンキラの身体。\n\u3000すっごい錬金術師が\u3000作ってくれたんだよ。": ""
  },
  "37765": {
    "「知ってるよ。キミも錬金術師なんだろ？\n\u3000ここまで来た人は\u3000本当に\u3000ひさしぶりで\n\u3000ボク\u3000とっても\u3000うれしいよ。": ""
  },
  "37766": {
    "「さあ\u3000キミのチカラを見せてほしいな。\n\u3000それが\u3000ボクのお仕事なんだ。\n\u3000ほら\u3000いくよっ\u3000いくよ～っ！！": ""
  },
  "37767": {
    "「おお……。ついに\u3000我が前に現れたか。\n\u3000セルゲイナスの呪いすら\u3000退ける\n\u3000類まれなる\u3000錬金術師の才能を持つ者よ。": ""
  },
  "37768": {
    "「私の名は\u3000バルザック。\n\u3000究極と呼ばれる錬金術……\u3000とある秘法により\n\u3000自身の姿すら作り変えた\u3000偉大なる錬金術師だ。": ""
  },
  "37769": {
    "「私は\u3000これまで\u3000多くの錬金術師を食らい\n\u3000その知識と技術を\u3000この身に宿してきた。": ""
  },
  "37770": {
    "「だが\u3000食らうだけの価値がある\n\u3000チカラを持った錬金術師は\u3000なかなか現れぬ。\n\u3000ゆえに\u3000自ら\u3000育てることにしたのだ。": ""
  },
  "37771": {
    "「ククク……。この地にある\u3000ほこらはな\n\u3000未熟な錬金術師に\u3000チカラをつけさせるため\n\u3000私が創りだした\u3000巨大な錬金釜だったのさ。": ""
  },
  "37772": {
    "「そうとも知らず\u3000貴様は\n\u3000錬金術師としての\u3000ウデをみがき続け\n\u3000こうして\u3000私の前に現れた！": ""
  },
  "37773": {
    "「残念だが\u3000このほこらの先に\n\u3000行かせるわけにはいかん！\u3000貴様は\u3000ここで\n\u3000我が錬金術のチカラの\u3000一部となるのだ！": ""
  },
  "37774": {
    "「ふたたび\u3000来るとは思わなかったぞ。\n\u3000だが\u3000残念ながら\u3000このほこらの先に\n\u3000行かせるわけにはいかん！": ""
  },
  "37775": {
    "「貴様が\u3000私を倒し\u3000このほこらの先に\n\u3000行くことは\u3000不可能だ！\u3000この身体こそ\n\u3000私の錬金術における\u3000最高傑作なのだからな！": ""
  },
  "37776": {
    "「今度こそ\u3000貴様を食わせてもらうぞ！\n\u3000私が\u3000究極の錬金術師となるためにな！": ""
  },
  "41007": {
    "「本は\u3000レシピを覚えると\u3000消えちまうが\n\u3000内容は\u3000せんれきの『釜錬金レシピブック』から\n\u3000確認できる。必要な材料も\u3000わかるはずだぞ！": ""
  },
  "41008": {
    "「レシピを覚えちまえば\u3000材料は\u3000せんれきの\n\u3000『釜錬金レシピブック』からも\u3000確認できる！\n\u3000どうか\u3000リリオルの命を救ってやってくれ！！": ""
  },
  "41009": {
    "イッショウは\u3000リリオルに\nメラゾ熱のクスリを\u3000飲ませた！": ""
  }
}