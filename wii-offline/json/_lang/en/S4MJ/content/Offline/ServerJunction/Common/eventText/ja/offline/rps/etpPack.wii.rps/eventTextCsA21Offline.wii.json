{
  "22963": {
    "「もらったあっ！！": ""
  },
  "22964": {
    "「いってえ……！": ""
  },
  "22965": {
    "「やい\u3000お前っ！\n\u3000なぁんで\u3000こんな所で\u3000寝てやがるっ！！": ""
  },
  "22966": {
    "「あとちょっとで\u3000狙ってた素材を\n\u3000奪えるとこだったのに！\n\u3000お前のせいで\u3000逃げられちまったじゃねえか！！": ""
  },
  "22967": {
    "「あぁん……？\u3000なんだ\u3000お前？": ""
  },
  "22968": {
    "「……ひっでえ\u3000ツラしてやがんな。\n\u3000まるで\u3000この世の終わりでも\n\u3000見てきたかのようなツラだぜ……。": ""
  },
  "22969": {
    "「はあ？\n\u3000エテーネの村が\u3000大変だって！？": ""
  },
  "22970": {
    "「…………はっはーん。": ""
  },
  "22971": {
    "「お前\u3000海から流れ着いた\u3000流れモンだな？\n\u3000にしちゃあ\u3000こんな海から離れた所で\n\u3000倒れてるってのも\u3000妙な話だが……。": ""
  },
  "22972": {
    "「ここは\u3000絶海の\u3000小さな孤島だ。\n\u3000あるのは\u3000ナルビアって町が\u3000ひとつっきりで\n\u3000エテーネの村なんて\u3000聞いたこともねえ。": ""
  },
  "22973": {
    "「起きられるんなら\u3000すぐそこの\n\u3000ナルビアの町に行きな。流れモンだからって\n\u3000冷たく\u3000あしらうような町じゃねえからよ。": ""
  },
  "22974": {
    "「今度\u3000ジャマしたら\u3000タダじゃおかねえぞ！": ""
  },
  "22978": {
    "「ふぅ……。\n\u3000リリオル\u3000帰ったぞ。": ""
  },
  "22979": {
    "「んんっ？\u3000誰だ\u3000お前！？": ""
  },
  "22980": {
    "「お前は……\u3000外で転がってた\u3000流れモンだな？\n\u3000勝手に\u3000オレの家に\u3000上がり込んで\n\u3000何してやがる！？": ""
  },
  "22981": {
    "「……なるほど。その釜に\u3000興味を持ったのか。\n\u3000どこのウマのホネとも\u3000知れねえヤツだが\n\u3000そいつに\u3000目をつけたところは\u3000ほめてやるぜ！": ""
  },
  "22982": {
    "「その釜は\u3000我が家に伝わる\u3000錬金釜だ。\n\u3000錬金術を使うためには\u3000欠かせない\n\u3000オレの\u3000命よりも大事な\u3000魔法の釜よ！": ""
  },
  "22983": {
    "「そして\u3000その錬金釜こそが\u3000錬金術師の証！\n\u3000つまり\u3000このオレこそが\u3000選ばれし存在……\n\u3000今では数少なくなった\u3000錬金術師様ってワケだ！": ""
  },
  "22984": {
    "「……あぁん？\u3000なんだって？\n\u3000錬金なら自分もできるって\u3000言ったか？": ""
  },
  "22985": {
    "「テキトーなこと\u3000抜かすんじゃねえ！\n\u3000なら\u3000証拠に\u3000上やくそうを錬金してみやがれ！\n\u3000上やくそうのレシピくらい\u3000知ってんだろ？": ""
  },
  "22986": {
    "「……………………。": ""
  },
  "22987": {
    "「まさか\u3000上やくそうのレシピも\u3000知らねえのか？\n\u3000そんなんで\u3000よくも\u3000錬金できるだなんて\n\u3000言えたもんだ！": ""
  },
  "22988": {
    "「ほらよっ\u3000この本をくれてやる。": ""
  },
  "22989": {
    "「ちっ……。かばんが\u3000いっぱいじゃねえか。\n\u3000ガラクタを\u3000処分したら\u3000また来やがれ！": ""
  },
  "22990": {
    "<kyodai>は\n初級錬金学入門を\u3000手に入れた！<me 60>": ""
  },
  "22991": {
    "「どうぐの中から\u3000そいつを選んで使うと\n\u3000上やくそうを始め\u3000簡単なレシピが覚えられる。": ""
  },
  "22992": {
    "「さあ\u3000レシピを覚えて\u3000オレの錬金釜で\n\u3000上やくそうを\u3000錬金してみろ！\n\u3000本当に\u3000やれるもんなら\u3000やってみやがれ！": ""
  },
  "22993": {
    "「できた……！？\n\u3000そんな\u3000まさか……。": ""
  },
  "22994": {
    "「す…すげえじゃねえか！\n\u3000なんで\u3000お前に\u3000錬金ができるんだ！？": ""
  },
  "22995": {
    "「はぁ？\u3000今まで\u3000箱で錬金してたって？\n\u3000箱に魔力が宿るなんて\u3000聞いたこともねえ。\n\u3000そんなもんで錬金してたって\u3000お前……。": ""
  },
  "22996": {
    "「……………………。": ""
  },
  "22997": {
    "「オレも\u3000すこし前までは\u3000この釜を使って\n\u3000なんでも\u3000錬金できたんだ。それが……\n\u3000あの日以来\u3000突然\u3000できなくなっちまってな。": ""
  },
  "22998": {
    "「釜が\u3000ぶっこわれたせいだと思い込んでいたが\n\u3000おかしくなったのは……\u3000釜じゃなくて\n\u3000やっぱり\u3000オレの方だったってことか。": ""
  },
  "22999": {
    "「おい\u3000ウマのホネ！\n\u3000お前に\u3000頼みがある！": ""
  },
  "23000": {
    "「メラゾ熱にかかって\u3000死にかけてる\u3000オレの娘\n\u3000……リリオルを\u3000治すクスリを\n\u3000お前に\u3000錬金してもらいてえんだ！": ""
  },
  "23001": {
    "「さあっ\u3000こいつを\u3000受け取ってくれ！": ""
  },
  "23002": {
    "「ちっ……。かばんが\u3000いっぱいじゃねえか。\n\u3000コトは\u3000一刻を争うってのに……！\n\u3000すぐに\u3000かばんを\u3000空けてきてくれ！": ""
  },
  "23003": {
    "<kyodai>は\nメラゾ熱のクスリの本を\u3000手に入れた！<me 60>": ""
  },
  "23004": {
    "「メラゾ熱ってのは\u3000大昔の\u3000恐ろしい病気だ。\n\u3000オレが\u3000素材集めなんか手伝わせたばっかりに\n\u3000リリオルを\u3000こんな目に\u3000あわせちまった……。": ""
  },
  "23005": {
    "「頼む！\u3000オレに代わってクスリを錬金してくれ！\n\u3000材料の\u3000めざめの花と\u3000レッドベリーは\n\u3000どっちも\u3000その辺で\u3000簡単に手に入る素材だ！": ""
  },
  "23016": {
    "「や……\u3000やってくれたか！\n\u3000すげえぞ\u3000ウマのホネ！": ""
  },
  "23017": {
    "「さあ\u3000そのクスリを\u3000オレにくれ！\n\u3000すぐに\u3000リリオルに飲ませよう！": ""
  },
  "23018": {
    "イッショウに\nメラゾ熱のクスリを\u3000渡しますか？<yesno><close>": ""
  },
  "23019": {
    "「お……おい\u3000ジョーダンだよな？\n\u3000こいつは\u3000オレの\u3000たったひとりの娘なんだ！\n\u3000……だから頼む！\u3000後生だ！<yesno><close>": ""
  },
  "23020": {
    "<kyodai>は\u3000イッショウに\nメラゾ熱のクスリを\u3000渡した！": ""
  },
  "23021": {
    "「ありがてえ……。恩に着るぜ！": ""
  },
  "23022": {
    "「はあ……\u3000はあ……。": ""
  },
  "23023": {
    "「リリオル\u3000クスリだぞ。\n\u3000さあ\u3000飲め。": ""
  },
  "23024": {
    "「…………………。": ""
  },
  "23025": {
    "「……呼吸が\u3000すこし\u3000おだやかになってきた。\n\u3000さっそく\u3000クスリが効いたんだな。": ""
  },
